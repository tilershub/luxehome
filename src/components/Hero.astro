---
---

<section class="hero" id="home">

  <div class="hero-split">
    <!-- Left: text -->
    <div class="hero-left">
      <div class="eyebrow">Sri Lanka's Premium Tiling Service</div>
      <h1>Your Home,<br /><em>Beautifully</em><br />Finished.</h1>
      <p class="hero-desc">
        Flooring, bathrooms, and kitchens — built with premium materials,
        transparent pricing, and online booking.
      </p>
      <div class="hero-actions">
        <a href="#shop" class="btn-primary">
          Shop Services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#quote-builder" class="btn-link">Build your quote →</a>
      </div>
    </div>

    <!-- Right: editorial photo -->
    <div class="hero-right">
      <img
        class="hero-img"
        src="https://images.pexels.com/photos/1571458/pexels-photo-1571458.jpeg?auto=compress&cs=tinysrgb&w=1400&h=1800&fit=crop"
        alt="Beautifully finished home interior"
        width="1400"
        height="1800"
        fetchpriority="high"
      />
      <div class="hero-scrim" aria-hidden="true"></div>
      <div class="hero-price-tag" aria-hidden="true">
        <span class="tag-label">Flooring from</span>
        <span class="tag-value">Rs. 350</span>
        <span class="tag-unit">per sq.ft</span>
      </div>
      <a href="https://wa.me/94774503744?text=Hello%20TILERSHUB%2C%20I%20would%20like%20a%20free%20quote." class="hero-wa" aria-label="WhatsApp TILERSHUB">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
        </svg>
        WhatsApp us
      </a>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero-bar">
    <div class="bar-item">
      <strong>500+</strong>
      <span>Projects completed</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>5★</strong>
      <span>Client rating</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>3</strong>
      <span>Core services</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>Island-wide</strong>
      <span>Coverage</span>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding-top: 4.5rem;
    background: var(--off-white);
  }

  /* ── Split ── */
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    flex: 1;
    min-height: 0;
  }

  /* ── Left panel ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 5rem 3.5rem 4rem 4rem;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #894428;
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp .7s .15s forwards;
  }

  .eyebrow::before {
    content: '';
    display: block;
    width: 1.8rem;
    height: 1px;
    background: #894428;
    flex-shrink: 0;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 4.8vw, 5.2rem);
    font-weight: 900;
    line-height: 1.03;
    letter-spacing: -.03em;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp .8s .3s forwards;
  }

  h1 em {
    font-style: italic;
    color: var(--clay);
  }

  .hero-desc {
    font-size: .97rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--warm-gray);
    max-width: 42ch;
    margin-bottom: 2.8rem;
    opacity: 0;
    animation: fadeUp .8s .48s forwards;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp .8s .65s forwards;
  }

  .btn-link {
    font-size: .9rem;
    font-weight: 500;
    color: var(--warm-gray);
    text-decoration: none;
    border-bottom: 1px solid var(--stone);
    padding-bottom: .15rem;
    transition: color .2s, border-color .2s;
  }

  .btn-link:hover {
    color: var(--charcoal);
    border-color: var(--charcoal);
  }

  /* ── Right panel: photo ── */
  .hero-right {
    position: relative;
    overflow: hidden;
    background: var(--charcoal);
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(.68) saturate(.75);
    transition: filter .4s;
    animation: fadeIn 1.2s .1s both;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(30, 26, 23, .35) 0%,
      transparent 50%,
      rgba(30, 26, 23, .15) 100%
    );
  }

  /* Price tag */
  .hero-price-tag {
    position: absolute;
    bottom: 2.5rem;
    left: 2.5rem;
    background: rgba(250, 247, 242, .96);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(212, 196, 176, .6);
    padding: 1.1rem 1.6rem;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: .15rem;
    opacity: 0;
    animation: fadeUp .8s 1s forwards;
  }

  .tag-label {
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--warm-gray);
  }

  .tag-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
  }

  .tag-unit {
    font-size: .72rem;
    color: var(--warm-gray);
  }

  /* WhatsApp */
  .hero-wa {
    position: absolute;
    top: 2rem;
    right: 2rem;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: rgba(37, 211, 102, .14);
    border: 1px solid rgba(37, 211, 102, .35);
    color: #1ea84d;
    text-decoration: none;
    font-size: .74rem;
    font-weight: 600;
    letter-spacing: .04em;
    padding: .5rem .95rem;
    border-radius: 99px;
    backdrop-filter: blur(10px);
    transition: background .2s, border-color .2s;
    opacity: 0;
    animation: fadeUp .7s 1.2s forwards;
  }

  .hero-wa:hover {
    background: rgba(37, 211, 102, .24);
    border-color: rgba(37, 211, 102, .55);
  }

  /* ── Stats bar ── */
  .hero-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 1.6rem 4rem;
    background: var(--cream);
    border-top: 1px solid var(--stone);
    opacity: 0;
    animation: fadeIn .8s 1.4s forwards;
  }

  .bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .2rem;
    padding: 0 3rem;
    text-align: center;
  }

  .bar-item strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1;
  }

  .bar-item span {
    font-size: .7rem;
    font-weight: 400;
    color: var(--warm-gray);
    text-transform: uppercase;
    letter-spacing: .09em;
  }

  .bar-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--stone);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .hero-left { padding: 4rem 2.5rem 3rem; }
    .bar-item { padding: 0 2rem; }
  }

  @media (max-width: 768px) {
    .hero { min-height: auto; }
    .hero-split { grid-template-columns: 1fr; }

    .hero-left {
      padding: 3rem 1.5rem 2.5rem;
      order: 2;
    }

    .hero-right {
      height: 55vw;
      min-height: 260px;
      order: 1;
    }

    h1 { font-size: clamp(2rem, 8vw, 2.6rem); }
    .hero-desc { max-width: none; }

    .hero-bar {
      padding: 1.4rem 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .bar-item { padding: 0 1.2rem; }
    .bar-sep { display: none; }
  }

  @media (max-width: 480px) {
    .hero-left {
      padding: 2.5rem 1.2rem 2rem;
    }

    .hero-right {
      height: 62vw;
      min-height: 220px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .btn-primary {
      justify-content: center;
    }

    .hero-actions .btn-link {
      text-align: center;
    }

    .hero-bar {
      padding: 1.2rem 1rem;
      gap: .6rem;
    }

    .bar-item {
      padding: 0 .8rem;
      flex: 1 0 40%;
    }

    .hero-price-tag {
      bottom: 1.5rem;
      left: 1.5rem;
      padding: .8rem 1.1rem;
    }

    .hero-wa {
      top: 1.2rem;
      right: 1.2rem;
    }
  }
</style>
