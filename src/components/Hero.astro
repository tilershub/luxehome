---
---

<section class="hero" id="home" aria-label="Hero">
  <!-- Background image -->
  <div class="hero-bg" aria-hidden="true">
    <img
      src="/hero-bathroom.png"
      alt=""
      width="1400"
      height="1800"
      fetchpriority="high"
      class="hero-img"
    />
    <div class="hero-scrim"></div>
  </div>

  <!-- Content -->
  <div class="hero-content">
    <p class="hero-eyebrow">Sri Lanka's Premium Renovation Brand</p>
    <h1>
      Luxury Renovations<br />
      <em>Designed to Inspire.</em>
    </h1>
    <p class="hero-desc">
      We create exceptional bathrooms, floors, staircases, and kitchens with premium design,
      expert craftsmanship, and complete project management.
    </p>
    <div class="hero-actions">
      <a href="/contact" class="btn-primary">Book a Consultation</a>
      <a href="/projects" class="btn-ghost-light">View Projects →</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>

  <!-- Stats bar -->
  <div class="hero-bar" aria-label="Key statistics">
    <div class="bar-item">
      <strong>50+</strong>
      <span>Projects Completed</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>3+</strong>
      <span>Years Experience</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>4</strong>
      <span>Service Specialisms</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>Western Province</strong>
      <span>Areas Served</span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: #0d0b09;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: brightness(.72) saturate(.92);
    transform-origin: center;
    animation: kenBurns 14s ease-in-out infinite alternate;
  }

  @keyframes kenBurns {
    from { transform: scale(1); }
    to   { transform: scale(1.06); }
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,.2) 0%,
      rgba(0,0,0,.1) 40%,
      rgba(0,0,0,.55) 75%,
      rgba(0,0,0,.82) 100%
    );
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 7rem 4.5rem;
    max-width: 820px;
  }

  .hero-eyebrow {
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeUp .7s .2s forwards;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -.02em;
    color: #fff;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp .9s .38s forwards;
  }

  h1 em {
    font-style: italic;
    color: rgba(240,236,224,.88);
    font-weight: 400;
  }

  .hero-desc {
    font-size: clamp(.95rem, 1.4vw, 1.1rem);
    font-weight: 300;
    line-height: 1.82;
    color: rgba(240,236,224,.78);
    max-width: 54ch;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp .8s .56s forwards;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp .8s .72s forwards;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--clay, #b8892a);
    color: #fff;
    padding: .9rem 2rem;
    border-radius: 3px;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
    min-height: 50px;
  }

  .btn-primary:hover { background: #9a7222; transform: translateY(-2px); }

  .btn-ghost-light {
    display: inline-flex;
    align-items: center;
    color: rgba(240,236,224,.88);
    border-bottom: 1px solid rgba(240,236,224,.4);
    padding-bottom: .12rem;
    font-size: .88rem;
    font-weight: 400;
    text-decoration: none;
    transition: color .2s, border-color .2s;
  }

  .btn-ghost-light:hover {
    color: #fff;
    border-color: #fff;
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    position: absolute;
    right: 4rem;
    bottom: 6rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .7rem;
    opacity: 0;
    animation: fadeIn 1s 1.4s forwards;
  }

  .scroll-line {
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(to bottom, transparent, rgba(240,236,224,.6));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: .5; }
    50%       { opacity: 1; }
  }

  .scroll-indicator span {
    font-size: .6rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(240,236,224,.55);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* ── Stats bar ── */
  .hero-bar {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,.08);
    padding: 1.4rem 4rem;
    opacity: 0;
    animation: fadeIn .8s 1.2s forwards;
  }

  .bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .18rem;
    padding: 0 3rem;
    text-align: center;
  }

  .bar-item strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--clay, #b8892a);
    line-height: 1;
  }

  .bar-item span {
    font-size: .66rem;
    font-weight: 400;
    color: rgba(240,236,224,.6);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .bar-sep {
    width: 1px;
    height: 2rem;
    background: rgba(255,255,255,.12);
    flex-shrink: 0;
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-img { animation: none; }
    .hero-eyebrow, h1, .hero-desc, .hero-actions, .scroll-indicator, .hero-bar {
      animation: none;
      opacity: 1;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .hero-content { padding: 0 4rem 4rem; }
    .scroll-indicator { right: 2.5rem; }
    .bar-item { padding: 0 2rem; }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 0 1.5rem 3.5rem;
      text-align: center;
      max-width: none;
    }
    h1 { font-size: clamp(2.2rem, 9vw, 3rem); }
    .hero-desc { max-width: none; margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .scroll-indicator { display: none; }
    .hero-bar {
      flex-wrap: wrap;
      padding: 1.2rem 1.5rem;
      gap: 1rem 0;
    }
    .bar-item { padding: .4rem 1.5rem; }
    .bar-sep { display: none; }
  }

  @media (max-width: 480px) {
    .hero-content { padding: 0 1.2rem 3rem; }
    .hero-actions { flex-direction: column; align-items: stretch; }
    .btn-primary { justify-content: center; }
    .btn-ghost-light { text-align: center; justify-content: center; }
  }
</style>
