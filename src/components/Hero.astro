---
---

<section class="hero" id="home">

  <div class="hero-split">
    <!-- Left: text -->
    <div class="hero-left">
      <div class="eyebrow">Interior Design • Construction • Renovation</div>
      <h1>Modern Interiors,<br /><em>Built</em><br />Beautifully.</h1>
      <p class="hero-desc">
        LUXEHOME designs, builds and renovates refined spaces across Sri Lanka — specialising in bathrooms, floors and staircases.
      </p>
      <div class="hero-actions">
        <a href="#shop" class="btn-primary">
          Explore Services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/contact" class="btn-link">Get a quote →</a>
      </div>
    </div>

    <!-- Right: editorial photo -->
    <div class="hero-right">
      <img
        class="hero-img"
        src="/hero-bathroom.png"
        alt="Luxury bathroom renovation — marble tiles, glass shower, backlit vanity"
        width="1400"
        height="1800"
        fetchpriority="high"
      />
      <div class="hero-scrim" aria-hidden="true"></div>
      <div class="hero-price-tag" aria-hidden="true">
        <span class="tag-label">Main services</span>
        <span class="tag-value">Bath · Floor</span>
        <span class="tag-unit">Staircase renovation</span>
      </div>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="hero-bar">
    <div class="bar-item">
      <strong>500+</strong>
      <span>Projects completed</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>5★</strong>
      <span>Client rating</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>3</strong>
      <span>Core services</span>
    </div>
    <div class="bar-sep" aria-hidden="true"></div>
    <div class="bar-item">
      <strong>Island-wide</strong>
      <span>Coverage</span>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 5.25rem 1rem 1rem;
    background: var(--off-white);
  }

  /* ── Split ── */
  .hero-split {
    display: grid;
    grid-template-columns: minmax(0, .92fr) minmax(0, 1.08fr);
    flex: 1;
    min-height: 0;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    border: 1px solid var(--stone);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface);
  }

  /* ── Left panel ── */
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(3rem, 6vw, 7rem);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--forest);
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp .7s .15s forwards;
  }

  .eyebrow::before {
    content: '';
    display: block;
    width: 1.8rem;
    height: 1px;
    background: var(--forest);
    flex-shrink: 0;
  }

  h1 {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(3.1rem, 6.7vw, 7.8rem);
    font-weight: 500;
    line-height: .94;
    letter-spacing: -.03em;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp .8s .3s forwards;
  }

  h1 em {
    font-style: normal;
    color: var(--warm-gray);
  }

  .hero-desc {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    font-weight: 300;
    line-height: 1.85;
    color: var(--warm-gray);
    max-width: 42ch;
    margin-bottom: 2.8rem;
    opacity: 0;
    animation: fadeUp .8s .48s forwards;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp .8s .65s forwards;
  }

  .btn-link {
    font-size: .9rem;
    font-weight: 500;
    color: var(--warm-gray);
    text-decoration: none;
    border-bottom: 1px solid var(--stone);
    padding-bottom: .15rem;
    transition: color .2s, border-color .2s;
  }

  .btn-link:hover {
    color: var(--charcoal);
    border-color: var(--charcoal);
  }

  /* ── Right panel: photo ── */
  .hero-right {
    position: relative;
    overflow: hidden;
    background: #ececea;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(.96) brightness(.9) saturate(.82);
    transition: filter .4s;
    animation: fadeIn 1.2s .1s both;
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, .18) 0%,
      transparent 46%,
      rgba(17, 17, 17, .18) 100%
    );
  }

  /* Price tag */
  .hero-price-tag {
    position: absolute;
    bottom: 2.5rem;
    left: 2.5rem;
    background: rgba(255, 255, 255, .9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(17, 17, 17, .08);
    padding: 1.1rem 1.6rem;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: .15rem;
    opacity: 0;
    animation: fadeUp .8s 1s forwards;
  }

  .tag-label {
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--warm-gray);
  }

  .tag-value {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.65rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
  }

  .tag-unit {
    font-size: .72rem;
    color: var(--warm-gray);
  }


  /* ── Stats bar ── */
  .hero-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 1.6rem 4rem;
    background: transparent;
    border-top: 0;
    max-width: 1440px;
    width: calc(100% - 2rem);
    margin: .9rem auto 0;
    border: 1px solid var(--stone);
    border-radius: var(--radius-lg);
    opacity: 0;
    animation: fadeIn .8s 1.4s forwards;
  }

  .bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .2rem;
    padding: 0 3rem;
    text-align: center;
  }

  .bar-item strong {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1;
  }

  .bar-item span {
    font-size: .7rem;
    font-weight: 400;
    color: var(--warm-gray);
    text-transform: uppercase;
    letter-spacing: .09em;
  }

  .bar-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--stone);
    flex-shrink: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .hero-left { padding: 4rem 2.5rem 3rem; }
    .bar-item { padding: 0 2rem; }
  }

  @media (max-width: 768px) {
    .hero { min-height: auto; }
    .hero-split { grid-template-columns: 1fr; }

    .hero-left {
      padding: 3rem 1.5rem 2.5rem;
      order: 2;
    }

    .hero-right {
      height: 55vw;
      min-height: 260px;
      order: 1;
    }

    h1 { font-size: clamp(2rem, 8vw, 2.6rem); }
    .hero-desc { max-width: none; }

    .hero-bar {
      padding: 1.4rem 1.5rem;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .bar-item { padding: 0 1.2rem; }
    .bar-sep { display: none; }
  }

  @media (max-width: 480px) {
    .hero-left {
      padding: 2.5rem 1.2rem 2rem;
    }

    .hero-right {
      height: 62vw;
      min-height: 220px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .btn-primary {
      justify-content: center;
    }

    .hero-actions .btn-link {
      text-align: center;
    }

    .hero-bar {
      padding: 1.2rem 1rem;
      gap: .6rem;
    }

    .bar-item {
      padding: 0 .8rem;
      flex: 1 0 40%;
    }

    .hero-price-tag {
      bottom: 1.5rem;
      left: 1.5rem;
      padding: .8rem 1.1rem;
    }

}
</style>
