---
---

<section id="shop">
  <div class="inner">

    <div class="section-head reveal">
      <div class="stag">What We Do</div>
      <h2>Two Services.<br />One Standard of Excellence.</h2>
    </div>

    <div class="svc-grid">

      <a class="svc-card reveal" href="/services/bathroom">
        <div class="svc-img">
          <img src="/hero-bathroom.png" alt="Luxury bathroom renovation" fetchpriority="auto" width="900" height="600" />
          <div class="svc-scrim"></div>
        </div>
        <div class="svc-body">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 19v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M2 19a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2"/><path d="M5 9V4a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v5"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
          </div>
          <div class="svc-label">Service 01</div>
          <h3>Bathroom Construction<br />&amp; Renovation</h3>
          <p>Complete end-to-end bathroom renovation — design, civil work, waterproofing, tiling, plumbing, electrical, fixtures, and handover. All materials included.</p>
          <div class="svc-pills">
            <span>3D Design Included</span>
            <span>Laticrete Waterproofing</span>
            <span>All Materials</span>
            <span>From LKR 985,000</span>
          </div>
          <div class="svc-cta">
            View Packages
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

      <a class="svc-card reveal" href="/services/flooring">
        <div class="svc-img">
          <img src="/floor-tiling-hero.svg" alt="Floor tiling" loading="lazy" width="900" height="600" />
          <div class="svc-scrim"></div>
        </div>
        <div class="svc-body">
          <div class="svc-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </div>
          <div class="svc-label">Service 02</div>
          <h3>Floor Tiling</h3>
          <p>Precision tile installation for any floor — up to 4×2 size tiles. All materials included: tiles, leveling system, Tokyo HP cement, and Swisstek grout.</p>
          <div class="svc-pills">
            <span>Mega Tiles</span>
            <span>Rocell Tiles</span>
            <span>All Materials</span>
            <span>From Rs. 1,000 /sq.ft</span>
          </div>
          <div class="svc-cta">
            View Pricing
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px);
    pointer-events: none;
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */

  .section-head {
    margin-bottom: 3rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
  }

  /* ── Grid: 2 equal columns ── */

  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  /* ── Card ── */

  .svc-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(255,255,255,.03);
    transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
    position: relative;
  }

  .svc-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .4s ease;
    z-index: 2;
  }

  .svc-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 28px 64px rgba(0,0,0,.45);
    border-color: rgba(184,148,90,.3);
  }

  .svc-card:hover::after {
    transform: scaleX(1);
  }

  /* ── Image ── */

  .svc-img {
    position: relative;
    height: 340px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .svc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.82) saturate(.9);
    transition: transform .55s ease, filter .45s ease;
  }

  .svc-card:hover .svc-img img {
    transform: scale(1.06);
    filter: brightness(.92) saturate(1);
  }

  .svc-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(22,28,26,.7) 100%);
  }

  /* ── Body ── */

  .svc-body {
    padding: 2.2rem 2rem 2.4rem;
    display: flex;
    flex-direction: column;
    gap: .85rem;
    flex: 1;
  }

  .svc-icon {
    width: 3rem;
    height: 3rem;
    background: rgba(184,148,90,.12);
    border: 1px solid rgba(184,148,90,.22);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay);
    flex-shrink: 0;
    transition: background .3s, border-color .3s;
  }

  .svc-card:hover .svc-icon {
    background: rgba(184,148,90,.22);
    border-color: rgba(184,148,90,.45);
  }

  .svc-label {
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: rgba(184,148,90,.65);
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.3rem, 2vw, 1.65rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
  }

  p {
    font-size: .9rem;
    font-weight: 300;
    color: rgba(240,236,224,.75);
    line-height: 1.8;
    max-width: 48ch;
  }

  /* ── Pills ── */

  .svc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
    margin-top: .2rem;
  }

  .svc-pills span {
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .05em;
    color: rgba(240,236,224,.72);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.09);
    padding: .22rem .7rem;
    border-radius: 20px;
  }

  /* ── CTA ── */

  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--clay);
    border-top: 1px solid rgba(255,255,255,.07);
    padding-top: .9rem;
    margin-top: auto;
    transition: gap .25s;
  }

  .svc-card:hover .svc-cta {
    gap: .85rem;
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-img { height: 280px; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .svc-img { height: 260px; }
    .svc-body { padding: 1.8rem 1.5rem 2rem; }
  }

  @media (max-width: 480px) {
    section { padding: 3.5rem 1.2rem; }
    .svc-img { height: 220px; }
  }
</style>
