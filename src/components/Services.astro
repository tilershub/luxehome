---

<section id="services">
  <div class="stag reveal">What We Do</div>
  <h2 class="reveal">Services for Every<br />Space & Budget</h2>
  <p class="sdesc reveal">
    Clear pricing, premium materials, and craftsmanship you can see — on every
    job, every time.
  </p>

  <div class="svc-grid reveal">

    <!-- Flooring — 3 tiers -->
    <div class="sc wide flooring" role="region" aria-label="Flooring services">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=1200&h=340&fit=crop" alt="Floor tiling" loading="lazy" width="1200" height="340" />
        <span class="sc-badge">Most Popular</span>
      </div>

      <div class="flooring-head">
        <div class="svc-name">Flooring</div>
        <div class="svc-tag">Tile leveling system · Tokyo cement · Swisstek grout</div>
      </div>

      <div class="flooring-tiers">

        <div class="tier">
          <div class="tier-name">Up to 4×2 Tiles</div>
          <div class="tier-row">
            <span class="tier-label">Floor</span>
            <span class="tier-price">Rs. 350 <em>/sq.ft</em></span>
          </div>
          <div class="tier-row">
            <span class="tier-label">Skirting</span>
            <span class="tier-price">Rs. 250 <em>/lin.ft</em></span>
          </div>
        </div>

        <div class="tier tier-mid">
          <div class="tier-name">Medium Tiles</div>
          <div class="tier-row">
            <span class="tier-label">Floor</span>
            <span class="tier-price">Rs. 500 <em>/sq.ft</em></span>
          </div>
          <div class="tier-row">
            <span class="tier-label">Skirting</span>
            <span class="tier-price">Rs. 350 <em>/lin.ft</em></span>
          </div>
        </div>

        <div class="tier">
          <div class="tier-name">Large Tiles &amp; Slabs</div>
          <div class="tier-row">
            <span class="tier-label">Floor</span>
            <span class="tier-price">Rs. 700 <em>/sq.ft</em></span>
          </div>
          <div class="tier-row">
            <span class="tier-label">Skirting</span>
            <span class="tier-price">Rs. 450 <em>/lin.ft</em></span>
          </div>
        </div>

      </div>

      <a href="#quote-builder" class="svc-link flooring-link">Get a Price &amp; Book →</a>
    </div>

    <!-- Staircase Tiling -->
    <a href="#book=others" class="sc" aria-label="Staircase Tiling — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=600&h=340&fit=crop" alt="Staircase tiling" loading="lazy" width="600" height="340" />
      </div>
      <div class="svc-name">Staircase Tiling</div>
      <div class="svc-tag">Double nosing · Router edge · Skirting included</div>
      <div class="svc-price">From <strong>Rs. 2,400</strong> / lin.ft</div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- Bathroom -->
    <a href="#book=bathroom" class="sc" aria-label="Bathroom Services — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=600&h=340&fit=crop" alt="Bathroom tiling and renovation" loading="lazy" width="600" height="340" />
      </div>
      <div class="svc-name">Bathroom</div>
      <div class="svc-tag">Tiling from Rs. 500/sq.ft · Full renovation from Rs. 450,000</div>
      <div class="svc-price"><strong>Tiling &amp; Renovation</strong></div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- Kitchen Pantry -->
    <a href="#book=others" class="sc" aria-label="Kitchen Pantry — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/1080721/pexels-photo-1080721.jpeg?auto=compress&cs=tinysrgb&w=600&h=340&fit=crop" alt="Kitchen pantry tiling" loading="lazy" width="600" height="340" />
      </div>
      <div class="svc-name">Kitchen Pantry</div>
      <div class="svc-tag">Countertop & backsplash · Waterproof joints</div>
      <div class="svc-price">From <strong>Rs. 5,000</strong> / lin.ft</div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- iPanel Ceiling -->
    <a href="#book=others" class="sc" aria-label="iPanel Ceiling — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/1643383/pexels-photo-1643383.jpeg?auto=compress&cs=tinysrgb&w=600&h=340&fit=crop" alt="iPanel ceiling installation" loading="lazy" width="600" height="340" />
      </div>
      <div class="svc-name">iPanel Ceiling</div>
      <div class="svc-tag">Plain or decorative PVC panels · Any room</div>
      <div class="svc-price">From <strong>Rs. 400</strong> / sq.ft</div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- Hand Railing -->
    <a href="#book=others" class="sc" aria-label="Hand Railing — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/6127375/pexels-photo-6127375.jpeg?auto=compress&cs=tinysrgb&w=600&h=340&fit=crop" alt="Hand railing installation" loading="lazy" width="600" height="340" />
      </div>
      <div class="svc-name">Hand Railing</div>
      <div class="svc-tag">Staircase & balcony · Glass & stainless steel</div>
      <div class="svc-price">From <strong>Rs. 12,500</strong> / lin.ft</div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- Kitchen Pantry Cupboard -->
    <a href="#book=others" class="sc wide" aria-label="Kitchen Pantry Cupboard — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/6283970/pexels-photo-6283970.jpeg?auto=compress&cs=tinysrgb&w=1200&h=280&fit=crop" alt="Kitchen pantry cupboard" loading="lazy" width="1200" height="280" />
      </div>
      <div class="svc-name">Kitchen Pantry Cupboard</div>
      <div class="svc-tag">Eco board · Melamine finish · Mcoco accessories · Quartz top · Backsplash</div>
      <div class="svc-price">From <strong>Rs. 40,000</strong> / lin.ft</div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

    <!-- Waterproofing -->
    <a href="#book=others" class="sc wide" aria-label="Waterproofing — get a price and book online">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/4953232/pexels-photo-4953232.jpeg?auto=compress&cs=tinysrgb&w=1200&h=280&fit=crop" alt="Waterproofing membrane application" loading="lazy" width="1200" height="280" />
      </div>
      <div class="svc-name">Waterproofing</div>
      <div class="svc-tag">Balcony · Terrace · Bathroom — Tokyo Super 2K membrane</div>
      <div class="svc-price"><strong>Get a Quote</strong></div>
      <span class="svc-link">Get a Price &amp; Book →</span>
    </a>

  </div>
</section>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 60px,
        rgba(255, 255, 255, .01) 60px,
        rgba(255, 255, 255, .01) 61px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(255, 255, 255, .01) 60px,
        rgba(255, 255, 255, .01) 61px
      );
  }

  h2 { color: var(--cream); }

  /* Bright clay on charcoal bg = 5.4:1 — override dark-section stag */
  .stag { color: var(--clay); }

  .sdesc { color: rgba(245, 240, 232, .65); }

  /* ── Service grid ── */

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(255, 255, 255, .07);
    border: 1.5px solid rgba(255, 255, 255, .07);
    position: relative;
    z-index: 1;
  }

  .sc {
    background: #211c18;
    padding: 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    position: relative;
    overflow: hidden;
    transition: background .25s;
  }

  .sc:hover { background: #28211a; }

  .sc::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .35s;
  }

  .sc:hover::after { transform: scaleX(1); }

  /* ── Card thumbnail ── */

  .sc-thumb {
    margin: -2rem -2rem 1.2rem;
    height: 185px;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .sc-badge {
    position: absolute;
    top: .85rem;
    left: .85rem;
    background: var(--clay);
    color: var(--cream);
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .28rem .75rem;
    border-radius: 2px;
    z-index: 2;
  }

  .sc-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.65) saturate(.75);
    transition: transform .45s ease, filter .4s ease;
  }

  .sc:hover .sc-thumb img {
    transform: scale(1.06);
    filter: brightness(.78) saturate(.9);
  }

  .svc-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
  }

  .svc-tag {
    font-size: .75rem;
    font-weight: 300;
    color: rgba(245, 240, 232, .6);
    line-height: 1.55;
  }

  .svc-price {
    font-size: .8rem;
    color: rgba(245, 240, 232, .6);
    margin-top: auto;
    padding-top: 1rem;
  }

  .svc-price strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--clay);
  }

  .svc-link {
    display: inline-block;
    font-size: .75rem;
    font-weight: 500;
    letter-spacing: .05em;
    color: var(--clay);
    border-bottom: 1px solid rgba(196, 120, 74, .3);
    padding-bottom: .1rem;
    width: fit-content;
    transition: border-color .2s, color .2s;
    margin-top: .3rem;
  }

  .sc:hover .svc-link {
    border-color: var(--clay);
    color: #e08c5a;
  }

  .sc.wide { grid-column: span 3; }

  /* ── Flooring card internals ── */

  .flooring {
    cursor: default;
  }

  .flooring-head {
    margin-bottom: 1.5rem;
  }

  .flooring-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, .08);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1.4rem;
  }

  .tier {
    background: rgba(255, 255, 255, .03);
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
  }

  .tier-mid {
    background: rgba(196, 120, 74, .07);
    border-left: 1px solid rgba(196, 120, 74, .18);
    border-right: 1px solid rgba(196, 120, 74, .18);
  }

  .tier-name {
    font-family: 'Playfair Display', serif;
    font-size: .95rem;
    font-weight: 700;
    color: var(--cream);
    padding-bottom: .6rem;
    border-bottom: 1px solid rgba(255, 255, 255, .08);
  }

  .tier-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: .5rem;
  }

  .tier-label {
    font-size: .75rem;
    color: rgba(245, 240, 232, .5);
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 400;
    flex-shrink: 0;
  }

  .tier-price {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clay);
    text-align: right;
  }

  .tier-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .7rem;
    font-weight: 300;
    color: rgba(245, 240, 232, .45);
    margin-left: .15rem;
  }

  .flooring-link {
    margin-top: 0;
  }

  @media (max-width: 768px) {
    .flooring-tiers {
      grid-template-columns: 1fr;
    }
    .tier-mid {
      border-left: none;
      border-right: none;
      border-top: 1px solid rgba(196, 120, 74, .18);
      border-bottom: 1px solid rgba(196, 120, 74, .18);
    }
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
    .sc.wide { grid-column: span 2; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .sc.wide { grid-column: span 1; }
  }
</style>
