<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px);
    pointer-events: none;
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-head {
    max-width: 56ch;
    margin-bottom: 3.5rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.78);
    line-height: 1.75;
  }

  /* ── Grid ── */

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Card ── */

  .svc-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
    position: relative;
  }

  .svc-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .35s ease;
    z-index: 2;
  }

  .svc-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0,0,0,.35);
    border-color: rgba(184,148,90,.25);
  }

  .svc-card:hover::before {
    transform: scaleX(1);
  }

  /* ── Image ── */

  .svc-img {
    position: relative;
    overflow: hidden;
    height: 200px;
    flex-shrink: 0;
  }

  .svc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.65) saturate(.7);
    transition: transform .5s ease, filter .4s ease;
  }

  .svc-card:hover .svc-img img {
    transform: scale(1.07);
    filter: brightness(.8) saturate(.88);
  }

  /* ── Body ── */

  .svc-body {
    padding: 1.6rem 1.5rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }

  .svc-icon {
    width: 2.6rem;
    height: 2.6rem;
    background: rgba(184,148,90,.12);
    border: 1px solid rgba(184,148,90,.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay);
    flex-shrink: 0;
    transition: background .3s, border-color .3s;
  }

  .svc-card:hover .svc-icon {
    background: rgba(184,148,90,.22);
    border-color: rgba(184,148,90,.4);
  }

  .svc-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.25;
  }

  .svc-desc {
    font-size: .82rem;
    font-weight: 300;
    color: rgba(240,236,224,.72);
    line-height: 1.75;
    flex: 1;
  }

  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--clay);
    padding-top: .4rem;
    border-top: 1px solid rgba(255,255,255,.06);
    transition: gap .2s;
  }

  .svc-card:hover .svc-cta {
    gap: .7rem;
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-grid { grid-template-columns: repeat(2, 1fr); gap: 1.2rem; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .svc-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .svc-img { height: 160px; }
    .svc-body { padding: 1.2rem 1.1rem 1.4rem; }
  }

  @media (max-width: 480px) {
    section { padding: 3.5rem 1.2rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .svc-img { height: 200px; }
  }
</style>
