---
const services = [
  {
    num: '01',
    name: 'Luxury Bathroom Renovation',
    desc: 'Complete end-to-end renovation — design, civil work, waterproofing, tiling, plumbing, electrical, fixtures, and handover.',
    inclusions: ['3D Design + Civil Plan', 'Laticrete Waterproofing', 'All Materials Included'],
    href: '/services/bathroom',
    img: '/hero-bathroom.png',
    imgAlt: 'Luxury bathroom renovation with premium tiles and fixtures',
  },
  {
    num: '02',
    name: 'Designer Floors',
    desc: 'Precision tile installation for any floor area. Up to 4×2 size tiles with leveling system, adhesive, and grout all included.',
    inclusions: ['Mega & Rocell Tiles', 'Swisstek Grout', 'All Materials Included'],
    href: '/services/flooring',
    img: 'https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=900&h=600&fit=crop',
    imgAlt: 'Designer floor tiling with large format tiles',
  },
  {
    num: '03',
    name: 'Designer Staircases',
    desc: 'Every step finished with double nosing, router edge detail, side elevation tiling, and skirting — a staircase that commands attention.',
    inclusions: ['Double Nosing Finish', 'Router Edge Detail', 'Side Elevation + Skirting'],
    href: '/services/staircase-tiling',
    img: 'https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=900&h=600&fit=crop',
    imgAlt: 'Premium staircase tiling with elegant finishes',
  },
  {
    num: '04',
    name: 'Luxury Kitchens',
    desc: 'Custom kitchen wall tiling and cupboard work — precision layout, premium materials, and finishes that elevate the heart of your home.',
    inclusions: ['Custom Wall Tiling', 'Cupboard & Pantry Work', 'Premium Design Consultation'],
    href: '/services/kitchen',
    img: 'https://images.pexels.com/photos/2724749/pexels-photo-2724749.jpeg?auto=compress&cs=tinysrgb&w=900&h=600&fit=crop',
    imgAlt: 'Luxury kitchen with custom tiling and cabinetry',
  },
];
---

<section id="shop" class="services-section">
  <div class="services-inner">

    <div class="section-head reveal">
      <div class="stag">What We Do</div>
      <h2>Four Specialisms.<br /><em>One Standard of Excellence.</em></h2>
    </div>

    <div class="svc-grid">
      {services.map((s) => (
        <a class="svc-card reveal" href={s.href}>
          <div class="svc-img">
            <img src={s.img} alt={s.imgAlt} loading="lazy" width="900" height="600" />
            <div class="svc-scrim" aria-hidden="true"></div>
            <div class="svc-num" aria-hidden="true">{s.num}</div>
          </div>
          <div class="svc-body">
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
            <ul class="svc-inclusions" aria-label="Inclusions">
              {s.inclusions.map((inc) => (
                <li>
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <circle cx="6" cy="6" r="6" fill="rgba(184,137,42,.15)"/>
                    <path d="M3.5 6L5.2 7.7L8.5 4.5" stroke="#b8892a" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {inc}
                </li>
              ))}
            </ul>
            <div class="svc-cta">
              Explore Service
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .services-section {
    background: var(--charcoal, #1e1a17);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .services-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.011) 60px, rgba(255,255,255,.011) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.011) 60px, rgba(255,255,255,.011) 61px);
    pointer-events: none;
  }

  .services-inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-head { margin-bottom: 3rem; }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.8rem);
    font-weight: 700;
    color: var(--cream, #f0ece0);
    line-height: 1.15;
  }

  h2 em {
    font-style: italic;
    font-weight: 400;
    color: rgba(240,236,224,.72);
  }

  /* ── Grid: 2×2 ── */
  .svc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  /* ── Card ── */
  .svc-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(255,255,255,.03);
    transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
    position: relative;
  }

  .svc-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--clay, #b8892a);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .4s ease;
    z-index: 2;
  }

  .svc-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 32px 72px rgba(0,0,0,.5);
    border-color: rgba(184,137,42,.28);
  }

  .svc-card:hover::after { transform: scaleX(1); }

  /* ── Image ── */
  .svc-img {
    position: relative;
    height: 260px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .svc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.75) saturate(.85);
    transition: transform .6s ease, filter .45s ease;
  }

  .svc-card:hover .svc-img img {
    transform: scale(1.07);
    filter: brightness(.88) saturate(.95);
  }

  .svc-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 35%, rgba(17,14,11,.75) 100%);
  }

  .svc-num {
    position: absolute;
    top: 1.2rem;
    left: 1.4rem;
    font-family: 'Playfair Display', serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .16em;
    color: rgba(184,137,42,.9);
    text-transform: uppercase;
    z-index: 1;
  }

  /* ── Body ── */
  .svc-body {
    padding: 1.8rem 1.8rem 2rem;
    display: flex;
    flex-direction: column;
    gap: .8rem;
    flex: 1;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.15rem, 1.8vw, 1.5rem);
    font-weight: 700;
    color: var(--cream, #f0ece0);
    line-height: 1.2;
  }

  p {
    font-size: .85rem;
    font-weight: 300;
    color: rgba(240,236,224,.7);
    line-height: 1.78;
    max-width: 50ch;
  }

  /* ── Inclusions ── */
  .svc-inclusions {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .45rem;
    margin-top: .2rem;
  }

  .svc-inclusions li {
    display: flex;
    align-items: center;
    gap: .55rem;
    font-size: .78rem;
    color: rgba(240,236,224,.72);
  }

  .svc-inclusions svg { flex-shrink: 0; }

  /* ── CTA ── */
  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    border-top: 1px solid rgba(255,255,255,.07);
    padding-top: 1rem;
    margin-top: auto;
    transition: gap .25s;
  }

  .svc-card:hover .svc-cta { gap: .9rem; }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .services-section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-img { height: 220px; }
  }

  @media (max-width: 768px) {
    .services-section { padding: 4rem 1.5rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .svc-img { height: 240px; }
    .svc-body { padding: 1.5rem 1.5rem 1.8rem; }
  }

  @media (max-width: 480px) {
    .services-section { padding: 3.5rem 1.2rem; }
    .svc-img { height: 200px; }
  }
</style>
