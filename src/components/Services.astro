    <!-- Waterproofing -->
    <a href="/services/waterproofing" class="sc wide" aria-label="Waterproofing — view service details">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/4953232/pexels-photo-4953232.jpeg?auto=compress&cs=tinysrgb&w=1200&h=280&fit=crop" alt="Waterproofing membrane application" loading="lazy" width="1200" height="280" />
      </div>
