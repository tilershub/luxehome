---
---

<section id="shop">
  <div class="stag reveal">What We Do</div>
  <h2 class="reveal">Services for Every<br />Space & Budget</h2>
  <p class="sdesc reveal">
    Clear pricing, premium materials, and craftsmanship you can see — on every
    job, every time.
  </p>

  <div class="svc-grid reveal">

    <!-- Bathroom — 3 named packages -->
    <div class="sc wide" role="region" aria-label="Bathroom renovation services">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1200&h=340&fit=crop" alt="Bathroom renovation" loading="lazy" width="1200" height="340" />
      </div>

      <div class="flooring-head">
        <div class="svc-name">Bathroom</div>
        <div class="svc-tag">Full renovation · You supply tiles, bathware &amp; tapware</div>
      </div>

      <div class="flooring-tiers">
        <div class="tier">
          <div class="tier-name">Essential Bath</div>
          <div class="tier-row"><span class="tier-label">Up to 40 sq.ft</span><span class="tier-price">Rs. 450,000</span></div>
          <div class="tier-row"><span class="tier-label">Over 40 sq.ft</span><span class="tier-price">+Rs. 5,000 <em>/sq.ft</em></span></div>
          <ul class="tier-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Lighting</li>
            <li>Shower Cubicle</li>
          </ul>
        </div>
        <div class="tier tier-mid">
          <div class="tier-name">Comfort Bath</div>
          <div class="tier-row"><span class="tier-label">Up to 40 sq.ft</span><span class="tier-price">Rs. 550,000</span></div>
          <div class="tier-row"><span class="tier-label">Over 40 sq.ft</span><span class="tier-price">+Rs. 6,000 <em>/sq.ft</em></span></div>
          <ul class="tier-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Lighting</li>
            <li>Plain Ceiling</li>
            <li>Shower Cubicle</li>
          </ul>
        </div>
        <div class="tier">
          <div class="tier-name">Signature Bath</div>
          <div class="tier-row"><span class="tier-label">Up to 40 sq.ft</span><span class="tier-price">Rs. 650,000</span></div>
          <div class="tier-row"><span class="tier-label">Over 40 sq.ft</span><span class="tier-price">+Rs. 6,000 <em>/sq.ft</em></span></div>
          <ul class="tier-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Ambience Lighting</li>
            <li>Design Ceiling</li>
            <li>Shower Cubicle</li>
            <li>Vanity Cupboard</li>
          </ul>
        </div>
      </div>

      <a href="/services/bathroom" class="svc-link flooring-link">View Packages &amp; Book →</a>
    </div>

    <!-- Floor — 4 tile-size packages -->
    <div class="sc wide flooring" role="region" aria-label="Flooring services">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=1200&h=340&fit=crop" alt="Floor tiling" loading="lazy" width="1200" height="340" />
        <span class="sc-badge">Most Popular</span>
      </div>

      <div class="flooring-head">
        <div class="svc-name">Floor</div>
        <div class="svc-tag">Tile leveling system · Tokyo cement · Swisstek grout · You supply tiles</div>
      </div>

      <div class="flooring-tiers floor-tiers-4">
        <div class="tier">
          <div class="tier-name">Small Tiles</div>
          <div class="tier-size">≤ 1 sq.m</div>
          <div class="tier-row"><span class="tier-label">Floor</span><span class="tier-price">Rs. 350 <em>/sq.ft</em></span></div>
          <div class="tier-row"><span class="tier-label">Skirting</span><span class="tier-price">Rs. 250 <em>/lin.ft</em></span></div>
        </div>
        <div class="tier tier-mid">
          <div class="tier-name">Medium Tiles</div>
          <div class="tier-size">1 – 2 sq.m</div>
          <div class="tier-row"><span class="tier-label">Floor</span><span class="tier-price">Rs. 500 <em>/sq.ft</em></span></div>
          <div class="tier-row"><span class="tier-label">Skirting</span><span class="tier-price">Rs. 300 <em>/lin.ft</em></span></div>
        </div>
        <div class="tier">
          <div class="tier-name">Large Tiles</div>
          <div class="tier-size">&gt; 2 sq.m</div>
          <div class="tier-row"><span class="tier-label">Floor</span><span class="tier-price">Rs. 700 <em>/sq.ft</em></span></div>
          <div class="tier-row"><span class="tier-label">Skirting</span><span class="tier-price">Rs. 350 <em>/lin.ft</em></span></div>
        </div>
        <div class="tier">
          <div class="tier-name">Plank Tiles</div>
          <div class="tier-size">Any length</div>
          <div class="tier-row"><span class="tier-label">Floor</span><span class="tier-price">Rs. 500 <em>/sq.ft</em></span></div>
          <div class="tier-row"><span class="tier-label">Skirting</span><span class="tier-price">Rs. 250 <em>/lin.ft</em></span></div>
        </div>
      </div>

      <a href="/services/flooring" class="svc-link flooring-link">Get a Price &amp; Book →</a>
    </div>

    <!-- Staircase -->
    <div class="sc wide" role="region" aria-label="Staircase services">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=1200&h=340&fit=crop" alt="Staircase tiling" loading="lazy" width="1200" height="340" />
      </div>

      <div class="flooring-head">
        <div class="svc-name">Staircase</div>
        <div class="svc-tag">Double nosing &amp; router edges · Landing counts as 2 steps · You supply tiles</div>
      </div>

      <div class="flooring-tiers stair-tiers">
        <div class="tier">
          <div class="tier-name">Staircase Tiling</div>
          <div class="tier-row"><span class="tier-label">Per Step</span><span class="tier-price">Rs. 2,400 <em>/lin.ft</em></span></div>
          <div class="tier-row"><span class="tier-label">Landing</span><span class="tier-price">2 steps rate</span></div>
          <div class="tier-note">Double nosing &amp; router edges included</div>
        </div>
        <div class="tier tier-mid">
          <div class="tier-name">Hand Railing</div>
          <div class="tier-row"><span class="tier-label">Rate</span><span class="tier-price">Rs. 12,500 <em>/ft</em></span></div>
        </div>
      </div>

      <a href="/contact" class="svc-link flooring-link">Get a Quote →</a>
    </div>

    <!-- Pantry -->
    <div class="sc wide" role="region" aria-label="Pantry services">
      <div class="sc-thumb">
        <img src="https://images.pexels.com/photos/6283970/pexels-photo-6283970.jpeg?auto=compress&cs=tinysrgb&w=1200&h=340&fit=crop" alt="Pantry tiling" loading="lazy" width="1200" height="340" />
      </div>

      <div class="flooring-head">
        <div class="svc-name">Pantry</div>
        <div class="svc-tag">Top &amp; backsplash tiling · You supply tiles</div>
      </div>

      <div class="flooring-tiers flooring-tiers--single">
        <div class="tier tier-mid">
          <div class="tier-name">Top &amp; Backsplash</div>
          <div class="tier-row"><span class="tier-label">Tiling</span><span class="tier-price">Rs. 5,000 <em>/lin.ft</em></span></div>
        </div>
      </div>

      <a href="/contact" class="svc-link flooring-link">Get a Quote →</a>
    </div>

  </div>
</section>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 60px,
        rgba(255, 255, 255, .01) 60px,
        rgba(255, 255, 255, .01) 61px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(255, 255, 255, .01) 60px,
        rgba(255, 255, 255, .01) 61px
      );
  }

  h2 { color: var(--cream); }

  .stag { color: var(--clay); }

  .sdesc { color: rgba(245, 240, 232, .65); }

  /* ── Service grid ── */

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(255, 255, 255, .07);
    border: 1.5px solid rgba(255, 255, 255, .07);
    position: relative;
    z-index: 1;
  }

  .sc {
    background: #211c18;
    padding: 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    position: relative;
    overflow: hidden;
    transition: background .25s;
  }

  .sc:hover { background: #28211a; }

  .sc::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .35s;
  }

  .sc:hover::after { transform: scaleX(1); }

  /* ── Card thumbnail ── */

  .sc-thumb {
    margin: -2rem -2rem 1.2rem;
    height: 185px;
    overflow: hidden;
    flex-shrink: 0;
    position: relative;
  }

  .sc-badge {
    position: absolute;
    top: .85rem;
    left: .85rem;
    background: var(--clay);
    color: var(--cream);
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .28rem .75rem;
    border-radius: 2px;
    z-index: 2;
  }

  .sc-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.65) saturate(.75);
    transition: transform .45s ease, filter .4s ease;
  }

  .sc:hover .sc-thumb img {
    transform: scale(1.06);
    filter: brightness(.78) saturate(.9);
  }

  .svc-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
  }

  .svc-tag {
    font-size: .75rem;
    font-weight: 300;
    color: rgba(245, 240, 232, .6);
    line-height: 1.55;
  }

  .svc-link {
    display: inline-block;
    font-size: .75rem;
    font-weight: 500;
    letter-spacing: .05em;
    color: var(--clay);
    border-bottom: 1px solid rgba(196, 120, 74, .3);
    padding-bottom: .1rem;
    width: fit-content;
    transition: border-color .2s, color .2s;
    margin-top: .3rem;
  }

  .sc:hover .svc-link {
    border-color: var(--clay);
    color: #e08c5a;
  }

  .sc.wide { grid-column: span 3; }

  .flooring { cursor: default; }

  .flooring-head { margin-bottom: 1.5rem; }

  /* ── Tier grid ── */

  .flooring-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, .08);
    border: 1px solid rgba(255, 255, 255, .08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1.4rem;
  }

  .flooring-tiers--single {
    grid-template-columns: minmax(0, 420px) !important;
    justify-content: center;
  }

  .floor-tiers-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .stair-tiers {
    grid-template-columns: repeat(2, 1fr);
  }

  .tier {
    background: rgba(255, 255, 255, .03);
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
  }

  .tier-mid {
    background: rgba(196, 120, 74, .07);
    border-left: 1px solid rgba(196, 120, 74, .18);
    border-right: 1px solid rgba(196, 120, 74, .18);
  }

  .tier-name {
    font-family: 'Playfair Display', serif;
    font-size: .95rem;
    font-weight: 700;
    color: var(--cream);
    padding-bottom: .6rem;
    border-bottom: 1px solid rgba(255, 255, 255, .08);
  }

  .tier-size {
    font-size: .68rem;
    color: rgba(245, 240, 232, .38);
    font-weight: 300;
    margin-top: -.45rem;
  }

  .tier-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: .5rem;
  }

  .tier-label {
    font-size: .75rem;
    color: rgba(245, 240, 232, .5);
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 400;
    flex-shrink: 0;
  }

  .tier-price {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clay);
    text-align: right;
  }

  .tier-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .7rem;
    font-weight: 300;
    color: rgba(245, 240, 232, .45);
    margin-left: .15rem;
  }

  .tier-note {
    font-size: .68rem;
    color: rgba(245, 240, 232, .38);
    font-style: italic;
    line-height: 1.45;
    margin-top: -.2rem;
  }

  /* ── Bathroom package includes list ── */

  .tier-includes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    margin-top: .2rem;
  }

  .tier-includes li {
    font-size: .72rem;
    color: rgba(245, 240, 232, .55);
    display: flex;
    align-items: center;
    gap: .5rem;
    line-height: 1.3;
  }

  .tier-includes li::before {
    content: '◆';
    font-size: .3rem;
    color: var(--clay);
    flex-shrink: 0;
  }

  .flooring-link { margin-top: 0; }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
    .sc.wide { grid-column: span 2; }
    .floor-tiers-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .svc-grid { grid-template-columns: 1fr; }
    .sc.wide { grid-column: span 1; }
    .flooring-tiers,
    .floor-tiers-4,
    .stair-tiers {
      grid-template-columns: 1fr;
    }
    .tier-mid {
      border-left: none;
      border-right: none;
      border-top: 1px solid rgba(196, 120, 74, .18);
      border-bottom: 1px solid rgba(196, 120, 74, .18);
    }
  }

  @media (max-width: 480px) {
    section { padding: 3.5rem 1.2rem; }

    .tier { padding: 1.1rem 1.2rem; }

    .tier-row {
      flex-direction: column;
      gap: .2rem;
    }

    .tier-price { font-size: .9rem; }

    .svc-link {
      font-size: .82rem;
      padding: .7rem 0;
      display: block;
    }
  }
</style>
