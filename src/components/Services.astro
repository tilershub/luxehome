---
---

<section id="shop">
  <div class="stag reveal">What We Do</div>
  <h2 class="reveal">Services for Every<br />Space & Budget</h2>
  <p class="sdesc reveal">
    Clear pricing, premium materials, and craftsmanship you can see — on every
    job, every time.
  </p>

  <div class="svc-list reveal">

    <a class="svc-card" href="/services/bathroom">
      <div class="svc-img">
        <img src="https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=900&h=500&fit=crop" alt="Bathroom renovation" loading="lazy" width="900" height="500" />
      </div>
      <div class="svc-body">
        <div class="svc-meta">
          <div class="svc-name">Bathroom</div>
          <div class="svc-tag">Full renovation · You supply tiles, bathware &amp; tapware</div>
        </div>
        <div class="svc-chips">
          <span>Essential Bath</span>
          <span>Comfort Bath</span>
          <span>Signature Bath</span>
        </div>
        <div class="svc-from">From Rs. 4,50,000</div>
        <div class="svc-link">View Packages →</div>
      </div>
    </a>

    <a class="svc-card" href="/services/flooring">
      <div class="svc-img">
        <img src="https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=900&h=500&fit=crop" alt="Floor tiling" loading="lazy" width="900" height="500" />
        <span class="svc-badge">Most Popular</span>
      </div>
      <div class="svc-body">
        <div class="svc-meta">
          <div class="svc-name">Floor</div>
          <div class="svc-tag">Tile leveling system · Tokyo cement · Swisstek grout · You supply tiles</div>
        </div>
        <div class="svc-chips">
          <span>Small ≤1 sq.m</span>
          <span>Medium 1–2 sq.m</span>
          <span>Large &gt;2 sq.m</span>
          <span>Plank</span>
        </div>
        <div class="svc-from">From Rs. 350 /sq.ft</div>
        <div class="svc-link">View Pricing →</div>
      </div>
    </a>

    <a class="svc-card" href="/services/staircase-tiling">
      <div class="svc-img">
        <img src="https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=900&h=500&fit=crop" alt="Staircase tiling" loading="lazy" width="900" height="500" />
      </div>
      <div class="svc-body">
        <div class="svc-meta">
          <div class="svc-name">Staircase</div>
          <div class="svc-tag">Double nosing &amp; router edges · Landing counts as 2 steps · You supply tiles</div>
        </div>
        <div class="svc-chips">
          <span>Staircase Tiling</span>
          <span>Hand Railing</span>
        </div>
        <div class="svc-from">From Rs. 2,400 /lin.ft</div>
        <div class="svc-link">View Service →</div>
      </div>
    </a>

    <a class="svc-card" href="/services/kitchen">
      <div class="svc-img">
        <img src="https://images.pexels.com/photos/6283970/pexels-photo-6283970.jpeg?auto=compress&cs=tinysrgb&w=900&h=500&fit=crop" alt="Kitchen renovation" loading="lazy" width="900" height="500" />
      </div>
      <div class="svc-body">
        <div class="svc-meta">
          <div class="svc-name">Kitchen</div>
          <div class="svc-tag">Pantry tiling · Cupboard installation · You supply tiles</div>
        </div>
        <div class="svc-chips">
          <span>Pantry Tiling</span>
          <span>Cupboard</span>
        </div>
        <div class="svc-from">From Rs. 5,000 /lin.ft</div>
        <div class="svc-link">View Service →</div>
      </div>
    </a>

  </div>
</section>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px);
  }

  h2 { color: var(--cream); }
  .stag { color: var(--clay); }
  .sdesc { color: rgba(240,236,224,.88); }

  /* ── Service list ── */

  .svc-list {
    display: flex;
    flex-direction: column;
    gap: 1.5px;
    background: rgba(255,255,255,.07);
    border: 1.5px solid rgba(255,255,255,.07);
    position: relative;
    z-index: 1;
  }

  .svc-card {
    display: grid;
    grid-template-columns: 380px 1fr;
    background: #1a2220;
    text-decoration: none;
    transition: background .25s;
    position: relative;
    overflow: hidden;
    min-height: 200px;
  }

  .svc-card:hover { background: #202a28; }

  .svc-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 3px;
    background: var(--clay);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .35s;
  }

  .svc-card:hover::after { transform: scaleY(1); }

  /* ── Image column ── */

  .svc-img {
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .svc-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.6) saturate(.75);
    transition: transform .45s ease, filter .4s ease;
  }

  .svc-card:hover .svc-img img {
    transform: scale(1.06);
    filter: brightness(.75) saturate(.9);
  }

  .svc-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--clay);
    color: var(--cream);
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .25rem .7rem;
    border-radius: 2px;
    z-index: 2;
  }

  /* ── Body column ── */

  .svc-body {
    padding: 2rem 2.4rem;
    display: flex;
    flex-direction: column;
    gap: .9rem;
    justify-content: center;
  }

  .svc-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: .1rem;
  }

  .svc-tag {
    font-size: .75rem;
    font-weight: 300;
    color: rgba(240,236,224,.75);
    line-height: 1.6;
  }

  .svc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
  }

  .svc-chips span {
    font-size: .7rem;
    font-weight: 500;
    letter-spacing: .06em;
    color: rgba(240,236,224,.78);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    padding: .22rem .65rem;
    border-radius: 20px;
  }

  .svc-from {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--clay);
  }

  .svc-link {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--clay);
    border-bottom: 1px solid rgba(61,79,66,.3);
    padding-bottom: .1rem;
    width: fit-content;
    transition: border-color .2s;
  }

  .svc-card:hover .svc-link {
    border-color: var(--clay);
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .svc-card { grid-template-columns: 280px 1fr; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }

    .svc-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .svc-img {
      height: 200px;
    }

    .svc-card::after {
      top: auto;
      left: 0;
      right: 0;
      bottom: 0;
      width: auto;
      height: 3px;
      transform: scaleX(0);
      transform-origin: left;
    }

    .svc-card:hover::after { transform: scaleX(1); }

    .svc-body { padding: 1.6rem; }
  }

  @media (max-width: 480px) {
    section { padding: 3.5rem 1.2rem; }
    .svc-name { font-size: 1.25rem; }
  }
</style>
