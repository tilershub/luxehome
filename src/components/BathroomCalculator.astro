---
---

<section class="bcalc-section" id="renovation-calculator">
  <div class="bcalc-inner">
    <div class="stag reveal">Instant Estimate</div>
    <h2 class="reveal">Bathroom Renovation Calculator</h2>
    <p class="sdesc reveal">
      Enter your bathroom details and select a package — get a cost estimate in seconds.
    </p>

    <div class="bcalc-layout">

      <!-- ── LEFT: Input Column ── -->
      <div class="bcalc-inputs">

        <!-- Client Details -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Your Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-name">Client Name</label>
              <input class="bc-input" type="text" id="bc-name" placeholder="Your full name" autocomplete="name" />
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-phone">Phone Number</label>
              <input class="bc-input" type="tel" id="bc-phone" placeholder="+94 7xx xxx xxx" autocomplete="tel" />
            </div>
          </div>
          <div class="bc-field">
            <label class="bc-label" for="bc-location">Project Location</label>
            <input class="bc-input" type="text" id="bc-location" placeholder="City / Town / District" autocomplete="address-level2" />
          </div>
        </div>

        <!-- Bathroom Details -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathroom Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-area">Floor Area</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-area" placeholder="e.g. 48" min="1" max="5000" step="0.1" />
                <span class="bc-area-unit">sq.ft</span>
              </div>
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-wall-area">Wall Area</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-wall-area" placeholder="e.g. 220" min="0" max="10000" step="0.1" />
                <span class="bc-area-unit">sq.ft</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Package Selection -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Select Package</div>
          <div class="pkg-grid" id="pkg-grid">

            <!-- Basic -->
            <label class="pkg-card" data-pkg="basic">
              <input type="radio" name="bcpkg" value="basic" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Basic</span>
                <div class="pkg-base-price">Rs. 450,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Masonry Works</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 5,000 / sq.ft over 40</div>
            </label>

            <!-- Standard -->
            <label class="pkg-card" data-pkg="standard">
              <input type="radio" name="bcpkg" value="standard" class="pkg-radio" />
              <div class="pkg-popular">Popular</div>
              <div class="pkg-header">
                <span class="pkg-name">Standard</span>
                <div class="pkg-base-price">Rs. 550,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Masonry Works</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 6,000 / sq.ft over 40</div>
            </label>

            <!-- Luxury -->
            <label class="pkg-card" data-pkg="luxury">
              <input type="radio" name="bcpkg" value="luxury" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Luxury</span>
                <div class="pkg-base-price">Rs. 650,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Masonry Works</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
                <li>Vanity Cupboard</li>
                <li>Shower Cubicle</li>
              </ul>
              <div class="pkg-extra">+Rs. 7,000 / sq.ft over 40</div>
            </label>

          </div>
        </div>

        <!-- Add-ons -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Optional Add-ons</div>
          <label class="addon-row">
            <input type="checkbox" id="addon-demo" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">Demolition Work</span>
              <span class="addon-price">Rs. 1,000 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="checkbox" id="addon-design" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">3D Bathroom Design</span>
              <span class="addon-price">Rs. 25,000 fixed</span>
            </div>
          </label>
        </div>

        <!-- Tile Supply Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Tile Supply (Add-on)</div>
          <p class="bc-addon-helper">Rocell Tiles &mdash; Rate applies to both floor &amp; wall area with 5% wastage allowance</p>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Tiles not included</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="600" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">60cm × 60cm</span>
              </div>
              <span class="addon-price">Rs. 600 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="700" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">45cm × 90cm</span>
              </div>
              <span class="addon-price">Rs. 700 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="800" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">120cm × 120cm</span>
              </div>
              <span class="addon-price">Rs. 800 / sq.ft</span>
            </div>
          </label>
        </div>

        <!-- Bathware + Taps + Geyser Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathware + Taps + Geyser (Add-on)</div>
          <p class="bc-addon-helper">Swiss Bathware &middot; Swiss Taps &middot; Ferroli Geyser</p>
          <label class="addon-row">
            <input type="radio" name="bc-bw" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Not included</span>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="300000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package A</span>
                <span class="addon-price">Rs. 300,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Back to Wall WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="350000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package B</span>
                <span class="addon-price">Rs. 350,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="400000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package C</span>
                <span class="addon-price">Rs. 400,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (BrushGold / Gun Gray) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
        </div>

        <button class="bc-generate-btn" id="bc-generate-btn" type="button">
          Generate Quote →
        </button>
        <div class="bc-error" id="bc-error"></div>

      </div><!-- /bcalc-inputs -->

      <!-- ── RIGHT: Result Column ── -->
      <div class="bcalc-result-col">

        <!-- Placeholder state -->
        <div class="bcalc-placeholder" id="bcalc-placeholder">
          <div class="bcp-icon">📐</div>
          <div class="bcp-text">Fill in the form and click<br /><strong>Generate Quote</strong> to see your estimate</div>
        </div>

        <!-- Result card (hidden until generated) -->
        <div class="bcalc-result" id="bcalc-result">

          <div class="result-printable" id="result-printable">

            <div class="rp-header">
              <div class="rph-brand">
                <div class="rph-logo">TILERSHUB</div>
                <div class="rph-tagline">Premium Tiling &amp; Renovation · Sri Lanka</div>
              </div>
              <div class="rph-title">Renovation Estimate</div>
            </div>

            <div class="rp-client" id="rp-client"></div>

            <div class="rp-metrics">
              <div class="rp-metric">
                <span class="rpm-label">Bathroom Area</span>
                <span class="rpm-value" id="r-area"></span>
                <span class="rpm-unit">sq.ft</span>
              </div>
              <div class="rp-metric rp-metric--mid">
                <span class="rpm-label">Package</span>
                <span class="rpm-value rpm-pkg" id="r-pkg"></span>
              </div>
              <div class="rp-metric">
                <span class="rpm-label">Final Total</span>
                <span class="rpm-value rpm-total" id="r-total-sm"></span>
              </div>
            </div>

            <!-- Price breakdown -->
            <div class="rp-breakdown" id="rp-breakdown"></div>

            <div class="rp-total-block">
              <div class="rptb-label">Final Estimated Price</div>
              <div class="rptb-price" id="r-total"></div>
            </div>

            <div class="rp-includes">
              <div class="rpi-title">Services Included</div>
              <div class="rpi-grid" id="r-includes"></div>
              <div id="r-brands"></div>
            </div>

            <div class="rp-payment">
              <div class="rpi-title">Payment Schedule</div>
              <div class="rp-pay-grid" id="r-payment"></div>
            </div>

            <div class="rp-disclaimer">
              ⚠ This is an estimated renovation cost. Final quotation will be confirmed after site inspection.
            </div>

            <div class="rp-footer">
              <div>TILERSHUB · tilershub.lk · +94 774 503 744</div>
              <div id="rp-date"></div>
            </div>

          </div><!-- /result-printable -->

          <div class="result-actions">
            <button class="ra-btn ra-pdf" id="ra-pdf" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PDF
            </button>
            <button class="ra-btn ra-wa" id="ra-wa" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/></svg>
              Share on WhatsApp
            </button>
          </div>

        </div><!-- /bcalc-result -->

      </div><!-- /bcalc-result-col -->

    </div><!-- /bcalc-layout -->
  </div>
</section>

<script>
  const PACKAGES = {
    basic: {
      name: 'Basic',
      basePrice: 450000,
      baseArea: 40,
      extraRate: 5000,
      includes: ['Masonry Works', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling'],
    },
    standard: {
      name: 'Standard',
      basePrice: 550000,
      baseArea: 40,
      extraRate: 6000,
      includes: ['Masonry Works', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling'],
    },
    luxury: {
      name: 'Luxury',
      basePrice: 650000,
      baseArea: 40,
      extraRate: 7000,
      includes: ['Masonry Works', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling', 'Vanity Cupboard', 'Shower Cubicle'],
    },
  };

  const TILE_SIZES: Record<string, string> = {
    '600': '60cm × 60cm',
    '700': '45cm × 90cm',
    '800': '120cm × 120cm',
  };

  type BwPkg = { name: string; items: string[] };
  const BW_PACKAGES: Record<string, BwPkg> = {
    '300000': {
      name: 'Package A',
      items: [
        'Swiss Back to Wall WC',
        'Swiss Vanity Basin',
        'Swiss Brass Shower & Taps (Stainless Steel) — 5yr corrosion-free warranty',
        'Ferroli 10L Geyser',
        'Mirrors & Decorative Accessories',
      ],
    },
    '350000': {
      name: 'Package B',
      items: [
        'Swiss Wall Mount WC',
        'Swiss Vanity Basin',
        'Swiss Brass Concealed Shower & Taps (Stainless Steel) — 5yr corrosion-free warranty',
        'Ferroli 10L Geyser',
        'Mirrors & Decorative Accessories',
      ],
    },
    '400000': {
      name: 'Package C',
      items: [
        'Swiss Wall Mount WC',
        'Swiss Vanity Basin',
        'Swiss Brass Concealed Shower & Taps (BrushGold / Gun Gray) — 5yr corrosion-free warranty',
        'Ferroli 10L Geyser',
        'Mirrors & Decorative Accessories',
      ],
    },
  };

  function fmt(n: number): string {
    return 'Rs. ' + n.toLocaleString('en-IN');
  }

  // Package card highlight
  document.querySelectorAll('.pkg-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('pkg-card--active'));
      card.classList.add('pkg-card--active');
    });
  });

  // Generate Quote
  document.getElementById('bc-generate-btn')!.addEventListener('click', () => {
    const name     = (document.getElementById('bc-name') as HTMLInputElement).value.trim();
    const phone    = (document.getElementById('bc-phone') as HTMLInputElement).value.trim();
    const location = (document.getElementById('bc-location') as HTMLInputElement).value.trim();
    const area     = parseFloat((document.getElementById('bc-area') as HTMLInputElement).value);
    const wallAreaRaw = parseFloat((document.getElementById('bc-wall-area') as HTMLInputElement).value);
    const wallArea = isNaN(wallAreaRaw) ? 0 : Math.max(0, wallAreaRaw);
    const pkgKey   = (document.querySelector('input[name="bcpkg"]:checked') as HTMLInputElement)?.value;
    const demoChecked   = (document.getElementById('addon-demo') as HTMLInputElement).checked;
    const designChecked = (document.getElementById('addon-design') as HTMLInputElement).checked;
    const tileRate  = parseFloat((document.querySelector('input[name="bc-tile"]:checked') as HTMLInputElement)?.value || '0');
    const bwAmt     = parseFloat((document.querySelector('input[name="bc-bw"]:checked') as HTMLInputElement)?.value || '0');
    const errorEl  = document.getElementById('bc-error')!;

    const errors: string[] = [];
    if (!name)         errors.push('Please enter your name.');
    if (!phone)        errors.push('Please enter your phone number.');
    if (!location)     errors.push('Please enter your project location.');
    if (!(area > 0))   errors.push('Please enter a valid floor area.');
    if (!pkgKey)       errors.push('Please select a package.');

    if (errors.length) {
      errorEl.innerHTML = errors.map(e => `<span>${e}</span>`).join('');
      errorEl.style.display = 'flex';
      return;
    }
    errorEl.style.display = 'none';

    const pkg = PACKAGES[pkgKey];
    const extraArea    = Math.max(0, area - pkg.baseArea);
    const extraCharge  = Math.round(extraArea * pkg.extraRate);
    const pkgPrice     = pkg.basePrice + extraCharge;
    const demolitionCost = demoChecked   ? Math.round(area * 1000) : 0;
    const designCost     = designChecked ? 25000 : 0;

    // Tile calculation with 5% wastage
    const baseTileArea        = tileRate > 0 ? (area + wallArea) : 0;
    const tileAreaWithWastage = parseFloat((baseTileArea * 1.05).toFixed(2));
    const tileCost            = Math.round(tileAreaWithWastage * tileRate);

    // Bathware cost
    const bathwareCost = Math.round(bwAmt);

    const total = pkgPrice + demolitionCost + designCost + tileCost + bathwareCost;

    // Client block
    document.getElementById('rp-client')!.innerHTML = `
      <div class="rpc-row"><span class="rpc-label">Name</span><span class="rpc-val">${name}</span></div>
      <div class="rpc-row"><span class="rpc-label">Phone</span><span class="rpc-val">${phone}</span></div>
      <div class="rpc-row"><span class="rpc-label">Location</span><span class="rpc-val">${location}</span></div>
      <div class="rpc-row"><span class="rpc-label">Floor Area</span><span class="rpc-val">${area.toFixed(1)} sq.ft</span></div>
      ${wallArea > 0 ? `<div class="rpc-row"><span class="rpc-label">Wall Area</span><span class="rpc-val">${wallArea.toFixed(1)} sq.ft</span></div>` : ''}
    `;

    (document.getElementById('r-area') as HTMLElement).textContent    = area.toFixed(1);
    (document.getElementById('r-pkg') as HTMLElement).textContent     = pkg.name;
    (document.getElementById('r-total-sm') as HTMLElement).textContent = fmt(total);
    (document.getElementById('r-total') as HTMLElement).textContent   = fmt(total);

    // Price breakdown rows
    type BkdRow = { label: string; sub: string; val: string };
    const bkdRows: BkdRow[] = [
      { label: 'Base Package Price', sub: `${pkg.name} — up to ${pkg.baseArea} sq.ft`, val: fmt(pkg.basePrice) },
    ];
    if (extraArea > 0) {
      bkdRows.push({ label: 'Additional Area', sub: `${extraArea.toFixed(1)} sq.ft × ${fmt(pkg.extraRate)} / sq.ft`, val: fmt(extraCharge) });
    }
    if (demolitionCost > 0) {
      bkdRows.push({ label: 'Demolition Work', sub: `${area.toFixed(1)} sq.ft × Rs. 1,000`, val: fmt(demolitionCost) });
    }
    if (designCost > 0) {
      bkdRows.push({ label: '3D Bathroom Design', sub: 'Fixed price', val: fmt(designCost) });
    }
    const tileSize = tileRate > 0 ? (TILE_SIZES[tileRate.toString()] || '') : '';
    if (tileCost > 0) {
      bkdRows.push({
        label: `Tile Supply — Rocell Tiles${tileSize ? ` (${tileSize})` : ''}`,
        sub: `Base area: ${baseTileArea.toFixed(1)} sq.ft (floor + wall) + 5% wastage = ${tileAreaWithWastage.toFixed(1)} sq.ft × Rs. ${tileRate.toLocaleString('en-IN')} / sq.ft`,
        val: fmt(tileCost),
      });
    }
    const bwPkg = bathwareCost > 0 ? (BW_PACKAGES[bwAmt.toString()] || null) : null;
    if (bathwareCost > 0) {
      bkdRows.push({
        label: `Bathware + Taps + Geyser${bwPkg ? ` — ${bwPkg.name}` : ''}`,
        sub: bwPkg ? bwPkg.items.map(i => `✓ ${i}`).join('<br>') : '✓ Swiss Bathware · Swiss Taps · Ferroli Geyser',
        val: fmt(bathwareCost),
      });
    }

    document.getElementById('rp-breakdown')!.innerHTML = `
      <div class="bkd-title">Price Breakdown</div>
      ${bkdRows.map(r => `
        <div class="bkd-row">
          <div class="bkd-left">
            <div class="bkd-label">${r.label}</div>
            <div class="bkd-sub">${r.sub}</div>
          </div>
          <div class="bkd-val">${r.val}</div>
        </div>`).join('')}
    `;

    // Services included (add-ons first)
    const allIncludes = [
      ...(demoChecked   ? ['Demolition Work']     : []),
      ...(designChecked ? ['3D Bathroom Design']   : []),
      ...pkg.includes,
    ];
    document.getElementById('r-includes')!.innerHTML =
      allIncludes.map(s => `<div class="rpi-item">${s}</div>`).join('');

    // Selected add-on brands
    const brandLines: string[] = [];
    if (tileCost > 0)    brandLines.push('Rocell Tiles');
    if (bathwareCost > 0) { brandLines.push('Swiss Bathware'); brandLines.push('Swiss Taps'); brandLines.push('Ferroli Geyser'); }

    const brandsEl = document.getElementById('r-brands') as HTMLElement;
    if (brandLines.length > 0) {
      brandsEl.innerHTML = `<div class="rpi-title rpi-title--brands">Selected Add-on Brands</div><div class="rpi-grid">${brandLines.map(b => `<div class="rpi-item rpi-item--brand">${b}</div>`).join('')}</div>`;
      brandsEl.style.display = 'block';
    } else {
      brandsEl.style.display = 'none';
    }

    // Payment schedule
    const PAY = [
      { label: 'Upfront / Deposit',        pct: 10, desc: 'Due before any work commences' },
      { label: 'On Starting Date',          pct: 60, desc: 'Due on the day work begins on site' },
      { label: 'After Tiling Completion',   pct: 30, desc: 'Due once all tiling is finished' },
