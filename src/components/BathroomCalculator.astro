    const breakdown = btn.dataset.breakdown || '';
    const tileInfo  = btn.dataset.tileInfo  || '';
    const bwInfo    = btn.dataset.bwInfo    || '';

    const lines = [
      `*TILERSHUB — Bathroom Renovation Estimate*`,
      ``,
      `*Client:* ${name}`,
