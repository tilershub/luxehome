---
---

<section class="bcalc-section" id="renovation-calculator">
  <div class="bcalc-inner">
    <div class="stag reveal">Instant Estimate</div>
    <h2 class="reveal">Bathroom Renovation Calculator</h2>
    <p class="sdesc reveal">
      Build your bathroom renovation — select a package and add-ons to see a live order total.
    </p>

    <div class="bcalc-layout">

      <!-- ── LEFT: Input Column ── -->
      <div class="bcalc-inputs">

        <!-- Client Details -->
        <div class="bc-card reveal" id="bc-details-card">
          <div class="bc-card-title">Your Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-name">Client Name</label>
              <input class="bc-input" type="text" id="bc-name" placeholder="Your full name" autocomplete="name" />
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-phone">Phone Number</label>
              <input class="bc-input" type="tel" id="bc-phone" placeholder="+94 7xx xxx xxx" autocomplete="tel" />
            </div>
          </div>
          <div class="bc-field">
            <label class="bc-label" for="bc-location">Project Location</label>
            <input class="bc-input" type="text" id="bc-location" placeholder="City / Town / District" autocomplete="address-level2" />
          </div>
        </div>

        <!-- Bathroom Details -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathroom Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-area">Floor Area</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-area" placeholder="e.g. 48" min="1" max="5000" step="0.1" />
                <span class="bc-area-unit">sq.ft</span>
              </div>
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-wall-area">Wall Area</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-wall-area" placeholder="e.g. 220" min="0" max="10000" step="0.1" />
                <span class="bc-area-unit">sq.ft</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Package Selection -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Select Package</div>
          <div class="pkg-grid" id="pkg-grid">

            <!-- Basic -->
            <label class="pkg-card" data-pkg="basic">
              <input type="radio" name="bcpkg" value="basic" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Basic</span>
                <div class="pkg-base-price">Rs. 450,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 5,000 / sq.ft over 40</div>
            </label>

            <!-- Standard -->
            <label class="pkg-card" data-pkg="standard">
              <input type="radio" name="bcpkg" value="standard" class="pkg-radio" />
              <div class="pkg-popular">Popular</div>
              <div class="pkg-header">
                <span class="pkg-name">Standard</span>
                <div class="pkg-base-price">Rs. 550,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 6,000 / sq.ft over 40</div>
            </label>

            <!-- Luxury -->
            <label class="pkg-card" data-pkg="luxury">
              <input type="radio" name="bcpkg" value="luxury" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Luxury</span>
                <div class="pkg-base-price">Rs. 650,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
                <li>Vanity Cupboard</li>
                <li>Shower Cubicle</li>
              </ul>
              <div class="pkg-extra">+Rs. 7,000 / sq.ft over 40</div>
            </label>

          </div>
        </div>

        <!-- Add-ons -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Optional Add-ons</div>
          <label class="addon-row">
            <input type="checkbox" id="addon-demo" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">Demolition Work</span>
              <span class="addon-price">Rs. 1,000 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="checkbox" id="addon-design" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">3D Bathroom Design</span>
              <span class="addon-price">Rs. 25,000 fixed</span>
            </div>
          </label>
        </div>

        <!-- Tile Supply Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Tile Supply (Add-on)</div>
          <p class="bc-addon-helper">Rocell Tiles &mdash; Rate applies to both floor &amp; wall area with 5% wastage allowance</p>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Tiles not included</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="600" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">60cm × 60cm</span>
              </div>
              <span class="addon-price">Rs. 600 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="700" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">45cm × 90cm</span>
              </div>
              <span class="addon-price">Rs. 700 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="800" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">120cm × 120cm</span>
              </div>
              <span class="addon-price">Rs. 800 / sq.ft</span>
            </div>
          </label>
        </div>

        <!-- Bathware + Taps + Geyser Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathware + Taps + Geyser (Add-on)</div>
          <p class="bc-addon-helper">Swiss Bathware &middot; Swiss Taps &middot; Ferroli Geyser</p>
          <label class="addon-row">
            <input type="radio" name="bc-bw" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Not included</span>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="300000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package A</span>
                <span class="addon-price">Rs. 300,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Back to Wall WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="350000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package B</span>
                <span class="addon-price">Rs. 350,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="400000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package C</span>
                <span class="addon-price">Rs. 400,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (BrushGold / Gun Gray) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
        </div>

      </div><!-- /bcalc-inputs -->

      <!-- ── RIGHT: Cart Column ── -->
      <div class="bcalc-cart-col">
        <div class="cart-panel" id="cart-panel">

          <!-- Cart Header -->
          <div class="cart-header">
            <div class="cart-header-left">
              <svg class="cart-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 001.97 1.61h9.72a2 2 0 001.97-1.61L23 6H6"/>
              </svg>
              <span class="cart-title">Your Order</span>
            </div>
            <span class="cart-badge" id="cart-badge" style="display:none">0</span>
          </div>

          <!-- Empty State -->
          <div class="cart-empty" id="cart-empty">
            <div class="ce-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h4"/>
              </svg>
            </div>
            <p class="ce-msg">Select a package to<br />start building your order</p>
          </div>

          <!-- Cart Items -->
          <div class="cart-items" id="cart-items" style="display:none"></div>

          <!-- Cart Footer: total + payment + checkout -->
          <div class="cart-footer" id="cart-footer" style="display:none">

            <div class="cart-subtotal-row">
              <span class="csr-label">Estimated Total</span>
              <span class="csr-value" id="cart-total">Rs. 0</span>
            </div>

            <div class="cart-payment-section">
              <div class="cps-header" id="cps-toggle">
                <span class="cps-title">Payment Schedule</span>
                <svg class="cps-chevron" id="cps-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
              <div class="cps-body" id="cps-body">
                <div class="cps-rows" id="cps-rows"></div>
              </div>
            </div>

            <div class="cart-error" id="cart-error" style="display:none"></div>

            <button class="btn-checkout" id="btn-checkout" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
              </svg>
              Confirm Booking on WhatsApp
            </button>

            <p class="cart-disclaimer">
              ⚠ Estimated cost — final price confirmed after site inspection.
            </p>

          </div><!-- /cart-footer -->

        </div><!-- /cart-panel -->
      </div><!-- /bcalc-cart-col -->

    </div><!-- /bcalc-layout -->
  </div>
</section>

<script>
  // ── Data ──────────────────────────────────────────────────────────────────

  const PACKAGES: Record<string, { name: string; basePrice: number; baseArea: number; extraRate: number; includes: string[] }> = {
    basic: {
      name: 'Basic',
      basePrice: 450000,
      baseArea: 40,
      extraRate: 5000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling'],
    },
    standard: {
      name: 'Standard',
      basePrice: 550000,
      baseArea: 40,
      extraRate: 6000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling'],
    },
    luxury: {
      name: 'Luxury',
      basePrice: 650000,
      baseArea: 40,
      extraRate: 7000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling', 'Vanity Cupboard', 'Shower Cubicle'],
    },
  };

  const TILE_SIZES: Record<string, string> = {
    '600': '60cm × 60cm',
    '700': '45cm × 90cm',
    '800': '120cm × 120cm',
  };

  const BW_PACKAGES: Record<string, { name: string; items: string[] }> = {
    '300000': {
      name: 'Package A',
      items: ['Swiss Back to Wall WC', 'Swiss Vanity Basin', 'Swiss Brass Shower & Taps (Stainless Steel)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
    '350000': {
      name: 'Package B',
      items: ['Swiss Wall Mount WC', 'Swiss Vanity Basin', 'Swiss Brass Concealed Shower & Taps (Stainless Steel)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
    '400000': {
      name: 'Package C',
      items: ['Swiss Wall Mount WC', 'Swiss Vanity Basin', 'Swiss Brass Concealed Shower & Taps (BrushGold / Gun Gray)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
  };

  const PAY = [
    { label: 'Upfront / Deposit',         pct: 10, desc: 'Due before any work commences' },
    { label: 'On Starting Date',           pct: 60, desc: 'Due on the day work begins on site' },
    { label: 'After Tiling Completion',    pct: 20, desc: 'Due once all tiling is finished' },
    { label: 'Final Payment on Handover',  pct: 10, desc: 'Due on project completion & handover' },
  ];

  // ── Helpers ───────────────────────────────────────────────────────────────

  function fmt(n: number): string {
    return 'Rs. ' + Math.round(n).toLocaleString('en-IN');
  }

  // ── Package card selected state ───────────────────────────────────────────

  document.querySelectorAll('.pkg-radio').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('pkg-card--active'));
      const checked = document.querySelector('.pkg-radio:checked') as HTMLInputElement | null;
      if (checked) checked.closest('.pkg-card')?.classList.add('pkg-card--active');
      renderCart();
    });
  });

  // ── Live listeners ────────────────────────────────────────────────────────

  ['bc-area', 'bc-wall-area'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', renderCart);
  });

  document.querySelectorAll('#addon-demo, #addon-design').forEach(el => {
    el.addEventListener('change', renderCart);
  });

  document.querySelectorAll('input[name="bc-tile"], input[name="bc-bw"]').forEach(el => {
    el.addEventListener('change', renderCart);
  });

  // ── Cart renderer ─────────────────────────────────────────────────────────

  function renderCart() {
    const pkgKey   = (document.querySelector('.pkg-radio:checked') as HTMLInputElement | null)?.value ?? '';
    const area     = parseFloat((document.getElementById('bc-area') as HTMLInputElement)?.value) || 0;
    const wallArea = parseFloat((document.getElementById('bc-wall-area') as HTMLInputElement)?.value) || 0;
    const demoOn   = (document.getElementById('addon-demo') as HTMLInputElement)?.checked;
    const designOn = (document.getElementById('addon-design') as HTMLInputElement)?.checked;
    const tileRate = parseInt((document.querySelector('input[name="bc-tile"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;
    const bwAmt    = parseFloat((document.querySelector('input[name="bc-bw"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;

    interface CartItem {
      key: string;
      name: string;
      desc: string;
      price: number | null;
      pending?: string;
    }

    const items: CartItem[] = [];
    let total = 0;

    // Package
    if (pkgKey && PACKAGES[pkgKey]) {
      const p = PACKAGES[pkgKey];
      if (area > 0) {
        const extraArea   = Math.max(0, area - p.baseArea);
        const extraCharge = Math.round(extraArea * p.extraRate);
        const pkgPrice    = p.basePrice + extraCharge;
        total += pkgPrice;

        items.push({
          key: 'pkg',
          name: `${p.name} Package`,
          desc: p.includes.join(' · '),
          price: p.basePrice,
        });

        if (extraCharge > 0) {
          items.push({
            key: 'extra',
            name: 'Area Surcharge',
            desc: `${extraArea} sq.ft over ${p.baseArea} sq.ft × ${fmt(p.extraRate)} / sq.ft`,
            price: extraCharge,
          });
        }
      } else {
        items.push({
          key: 'pkg',
          name: `${p.name} Package`,
          desc: p.includes.join(' · '),
          price: null,
          pending: 'Enter floor area above to calculate price',
        });
      }
    }

    // Demolition
    if (demoOn) {
      if (area > 0) {
        const cost = Math.round(area * 1000);
        total += cost;
        items.push({
          key: 'demo',
          name: 'Demolition Works',
          desc: `${area} sq.ft × Rs. 1,000 / sq.ft`,
          price: cost,
        });
      } else {
        items.push({
          key: 'demo',
          name: 'Demolition Works',
          desc: 'Rs. 1,000 / sq.ft',
          price: null,
          pending: 'Enter floor area above to calculate price',
        });
      }
    }

    // 3D Design
    if (designOn) {
      total += 25000;
      items.push({
        key: 'design',
        name: '3D Bathroom Design',
        desc: 'Design consultation & 3D rendering',
        price: 25000,
      });
    }

    // Tile Supply
    if (tileRate > 0) {
      const combined = area + wallArea;
      if (combined > 0) {
        const areaWithWaste = parseFloat((combined * 1.05).toFixed(2));
        const cost = Math.round(areaWithWaste * tileRate);
        total += cost;
        items.push({
          key: 'tiles',
          name: `Rocell Tile Supply — ${TILE_SIZES[String(tileRate)] ?? ''}`,
          desc: `${areaWithWaste} sq.ft (incl. 5% wastage) × ${fmt(tileRate)} / sq.ft`,
          price: cost,
        });
      } else {
        items.push({
          key: 'tiles',
          name: `Rocell Tile Supply — ${TILE_SIZES[String(tileRate)] ?? ''}`,
          desc: `${fmt(tileRate)} / sq.ft · enter floor & wall area above`,
          price: null,
          pending: 'Enter bathroom areas above to calculate price',
        });
      }
    }

    // Bathware
    if (bwAmt > 0) {
      const bw = BW_PACKAGES[String(bwAmt)];
      total += bwAmt;
      items.push({
        key: 'bw',
        name: `Swiss Bathware ${bw.name}`,
        desc: bw.items.join(' · '),
        price: Math.round(bwAmt),
      });
    }

    // ── Render ──
    const emptyEl  = document.getElementById('cart-empty')!;
    const itemsEl  = document.getElementById('cart-items')!;
    const footerEl = document.getElementById('cart-footer')!;
    const badgeEl  = document.getElementById('cart-badge')!;
    const errorEl  = document.getElementById('cart-error')!;

    if (items.length === 0) {
      emptyEl.style.display  = 'flex';
      itemsEl.style.display  = 'none';
      footerEl.style.display = 'none';
      badgeEl.style.display  = 'none';
      itemsEl.innerHTML = '';
      return;
    }

    const pricedCount = items.filter(i => i.price !== null).length;
    emptyEl.style.display  = 'none';
    itemsEl.style.display  = 'block';
    footerEl.style.display = 'block';
    badgeEl.style.display  = 'inline-flex';
    badgeEl.textContent    = String(items.length);
    errorEl.style.display  = 'none';

    // Cart items HTML
    itemsEl.innerHTML = items.map((item, i) => `
      <div class="cart-item${i < items.length - 1 ? ' cart-item--border' : ''}">
        <div class="ci-info">
          <div class="ci-name">${item.name}</div>
          <div class="ci-desc">${item.desc}</div>
          ${item.pending ? `<div class="ci-pending"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>${item.pending}</div>` : ''}
        </div>
        <div class="ci-price${item.price === null ? ' ci-price--pending' : ''}">${item.price !== null ? fmt(item.price) : '—'}</div>
      </div>
    `).join('');

    // Total
    document.getElementById('cart-total')!.textContent = total > 0 ? fmt(total) : '—';

    // Payment schedule rows
    document.getElementById('cps-rows')!.innerHTML = PAY.map(p => `
      <div class="cpr-row">
        <div class="cpr-left">
          <span class="cpr-pct">${p.pct}%</span>
          <div class="cpr-labels">
            <span class="cpr-label">${p.label}</span>
            <span class="cpr-desc">${p.desc}</span>
          </div>
        </div>
        <span class="cpr-amt">${total > 0 ? fmt(Math.round(total * p.pct / 100)) : '—'}</span>
      </div>
    `).join('');

    // Store total on checkout button
    (document.getElementById('btn-checkout') as HTMLButtonElement).dataset.total = String(total);
  }

  // ── Payment schedule toggle ───────────────────────────────────────────────

  document.getElementById('cps-toggle')?.addEventListener('click', () => {
    const body    = document.getElementById('cps-body')!;
    const chevron = document.getElementById('cps-chevron')!;
    const open    = body.classList.toggle('cps-body--open');
    chevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
  });

  // ── Checkout (WhatsApp) ───────────────────────────────────────────────────

  document.getElementById('btn-checkout')?.addEventListener('click', function () {
    const name     = (document.getElementById('bc-name') as HTMLInputElement).value.trim();
    const phone    = (document.getElementById('bc-phone') as HTMLInputElement).value.trim();
    const location = (document.getElementById('bc-location') as HTMLInputElement).value.trim();
    const errorEl  = document.getElementById('cart-error')!;

    // Validate details
    if (!name || !phone || !location) {
      errorEl.textContent  = '⚠ Please fill in your name, phone number, and location at the top of the form before confirming your booking.';
      errorEl.style.display = 'block';
      document.getElementById('bc-details-card')!.scrollIntoView({ behavior: 'smooth', block: 'center' });
      document.getElementById('bc-details-card')!.classList.add('bc-card--highlight');
      setTimeout(() => document.getElementById('bc-details-card')!.classList.remove('bc-card--highlight'), 2000);
      return;
    }

    errorEl.style.display = 'none';

    // Gather values
    const pkgKey   = (document.querySelector('.pkg-radio:checked') as HTMLInputElement | null)?.value ?? '';
    const area     = parseFloat((document.getElementById('bc-area') as HTMLInputElement)?.value) || 0;
    const wallArea = parseFloat((document.getElementById('bc-wall-area') as HTMLInputElement)?.value) || 0;
    const demoOn   = (document.getElementById('addon-demo') as HTMLInputElement)?.checked;
    const designOn = (document.getElementById('addon-design') as HTMLInputElement)?.checked;
    const tileRate = parseInt((document.querySelector('input[name="bc-tile"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;
    const bwAmt    = parseFloat((document.querySelector('input[name="bc-bw"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;
    const total    = parseFloat(this.dataset.total ?? '0') || 0;

    const pkg = pkgKey ? PACKAGES[pkgKey] : null;

    const lines: string[] = [];
    lines.push(`*TILERSHUB — Bathroom Renovation Booking*`);
    lines.push(`━━━━━━━━━━━━━━━━━━━━━━`);
    lines.push(`*Client:* ${name}`);
    lines.push(`*Phone:* ${phone}`);
    lines.push(`*Location:* ${location}`);
    lines.push(``);
    lines.push(`*Project Details:*`);
    if (area > 0)     lines.push(`• Floor Area: ${area} sq.ft`);
    if (wallArea > 0) lines.push(`• Wall Area: ${wallArea} sq.ft`);
    if (pkg)          lines.push(`• Package: ${pkg.name}`);
    lines.push(``);
    lines.push(`*Order Summary:*`);

    if (pkg && area > 0) {
      const extraArea   = Math.max(0, area - pkg.baseArea);
      const extraCharge = Math.round(extraArea * pkg.extraRate);
      lines.push(`• ${pkg.name} Package — ${fmt(pkg.basePrice)}`);
      if (extraCharge > 0) lines.push(`• Area Surcharge (${extraArea} sq.ft over ${pkg.baseArea}) — ${fmt(extraCharge)}`);
    }

    if (demoOn && area > 0) lines.push(`• Demolition Works — ${fmt(area * 1000)}`);
    if (designOn)           lines.push(`• 3D Bathroom Design — Rs. 25,000`);

    if (tileRate > 0 && (area + wallArea) > 0) {
      const areaWithWaste = parseFloat(((area + wallArea) * 1.05).toFixed(2));
      lines.push(`• Rocell Tile Supply (${TILE_SIZES[String(tileRate)] ?? ''}) — ${fmt(areaWithWaste * tileRate)}`);
      lines.push(`  ${areaWithWaste} sq.ft (5% wastage) × ${fmt(tileRate)}/sq.ft`);
    }

    if (bwAmt > 0) {
      const bw = BW_PACKAGES[String(bwAmt)];
      lines.push(`• Swiss Bathware ${bw.name} — ${fmt(bwAmt)}`);
    }

    lines.push(``);
    lines.push(`*Total Estimated Cost: ${fmt(total)}*`);
    lines.push(``);
    lines.push(`*Payment Schedule:*`);
    PAY.forEach(p => {
      lines.push(`• ${p.pct}% ${p.label} — ${fmt(Math.round(total * p.pct / 100))}`);
    });
    lines.push(``);
    lines.push(`_This is an estimated cost. Final price will be confirmed after site inspection._`);
    lines.push(``);
    lines.push(`TILERSHUB · tilershub.lk · +94 774 503 744`);

    const msg = lines.join('\n');
    window.open(`https://wa.me/94774503744?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>

