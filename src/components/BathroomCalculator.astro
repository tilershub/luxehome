    // Use a hidden iframe — no popup, no race condition with onload
    const existing = document.getElementById('_pdf_frame');
    if (existing) existing.remove();

    const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
    const blobUrl = URL.createObjectURL(blob);

    const frame = document.createElement('iframe');
    frame.id = '_pdf_frame';
    frame.style.cssText = 'position:fixed;left:-9999px;top:-9999px;width:1px;height:1px;opacity:0;border:0;';
    document.body.appendChild(frame);

    frame.onload = () => {
      frame.contentWindow!.focus();
      frame.contentWindow!.print();
      setTimeout(() => {
        frame.remove();
        URL.revokeObjectURL(blobUrl);
      }, 60000);
    };

    frame.src = blobUrl;
  });

  // WhatsApp
  document.getElementById('ra-wa').addEventListener('click', (e) => {
    const btn      = e.currentTarget as HTMLElement;
    const name     = btn.dataset.name;
    const phone    = btn.dataset.phone;
    const location = btn.dataset.location;
    const area     = btn.dataset.area;
    const pkg      = btn.dataset.pkg;
    const rate     = btn.dataset.rate;
    const total    = btn.dataset.total;
    const includes = btn.dataset.includes;
    const note     = btn.dataset.note;

    const msg = [
      `*TILERSHUB — Bathroom Renovation Estimate*`,
      ``,
      `*Client:* ${name}`,
      `*Phone:* ${phone}`,
      `*Location:* ${location}`,
      ``,
      `*Bathroom Area:* ${area} sq.ft`,
      `*Package:* ${pkg}`,
      `*Rate Applied:* ${rate}/sq.ft`,
      `*Estimated Total:* ${total}`,
      note ? `_${note}_` : null,
      ``,
      `*Services Included:* ${includes}`,
      ``,
      `*Payment Schedule:*`,
      `• 10% Upfront / Deposit`,
      `• 60% On Starting Date`,
      `• 30% After Tiling Completion`,
      `• 10% Final Payment on Handover`,
      ``,
      `_This is an estimated cost. Final quotation after site inspection._`,
      ``,
      `tilershub.lk | +94 774 503 744`,
    ].filter(l => l !== null).join('\n');

    const url = `https://wa.me/94774503744?text=${encodeURIComponent(msg)}`;
    window.open(url, '_blank', 'noopener');
  });
</script>

