---
---

<section class="bcalc-section" id="renovation-calculator">
  <div class="bcalc-inner">
    <div class="stag reveal">Instant Estimate</div>
    <h2 class="reveal">Bathroom Renovation Calculator</h2>
    <p class="sdesc reveal">
      Enter your bathroom size and select a package — get a cost estimate in seconds.
    </p>

    <div class="bcalc-layout">

      <!-- ── LEFT: Input Column ── -->
      <div class="bcalc-inputs">

        <!-- Client Details -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Your Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-name">Client Name</label>
              <input class="bc-input" type="text" id="bc-name" placeholder="Your full name" autocomplete="name" />
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-phone">Phone Number</label>
              <input class="bc-input" type="tel" id="bc-phone" placeholder="+94 7xx xxx xxx" autocomplete="tel" />
            </div>
          </div>
          <div class="bc-field">
            <label class="bc-label" for="bc-location">Project Location</label>
            <input class="bc-input" type="text" id="bc-location" placeholder="City / Town / District" autocomplete="address-level2" />
          </div>
        </div>

        <!-- Dimensions -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathroom Dimensions</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-length">Length (feet)</label>
              <input class="bc-input bc-dim" type="number" id="bc-length" placeholder="e.g. 8" min="1" max="100" step="0.5" />
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-width">Width (feet)</label>
              <input class="bc-input bc-dim" type="number" id="bc-width" placeholder="e.g. 6" min="1" max="100" step="0.5" />
            </div>
          </div>
          <div class="bc-area-preview" id="bc-area-preview">
            <span class="bcap-label">Calculated Area</span>
            <span class="bcap-value" id="bc-area-value">—</span>
            <span class="bcap-unit">sq.ft</span>
          </div>
        </div>

        <!-- Package Selection -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Select Package</div>
          <div class="pkg-grid" id="pkg-grid">

            <!-- Basic -->
            <label class="pkg-card" data-pkg="basic">
              <input type="radio" name="bcpkg" value="basic" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Basic</span>
                <div class="pkg-rate">Rs. 11,000 <span>/sq.ft</span></div>
              </div>
              <ul class="pkg-list">
                <li>Demolition</li>
                <li>Masonry Works</li>
                <li>Waterproofing</li>
                <li>Plumbing</li>
                <li>Electrical &amp; Lighting</li>
                <li>Tiling</li>
              </ul>
              <div class="pkg-min">Min. Rs. 450,000</div>
            </label>

            <!-- Standard -->
            <label class="pkg-card" data-pkg="standard">
              <input type="radio" name="bcpkg" value="standard" class="pkg-radio" />
              <div class="pkg-popular">Popular</div>
              <div class="pkg-header">
                <span class="pkg-name">Standard</span>
                <div class="pkg-rate">Rs. 13,000 <span>/sq.ft</span></div>
              </div>
              <ul class="pkg-list">
                <li>Bathroom Designing</li>
                <li>Demolition</li>
                <li>Masonry Works</li>
                <li>Waterproofing</li>
                <li>Plumbing</li>
                <li>Electrical &amp; Lighting</li>
                <li>Tiling</li>
                <li>Ceiling</li>
                <li>Painting</li>
              </ul>
              <div class="pkg-min">Min. Rs. 550,000</div>
            </label>

            <!-- Luxury -->
            <label class="pkg-card" data-pkg="luxury">
              <input type="radio" name="bcpkg" value="luxury" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Luxury</span>
                <div class="pkg-rate">Rs. 15,000 <span>/sq.ft</span></div>
              </div>
              <ul class="pkg-list">
                <li>Bathroom Designing</li>
                <li>Demolition</li>
                <li>Masonry Works</li>
                <li>Waterproofing</li>
                <li>Plumbing</li>
                <li>Electrical &amp; Lighting</li>
                <li>Tiling</li>
                <li>Ceiling</li>
                <li>Painting</li>
                <li>Vanity Cupboard</li>
                <li>Shower Cubicle</li>
              </ul>
              <div class="pkg-min">Min. Rs. 650,000</div>
            </label>

          </div>
        </div>

        <button class="bc-generate-btn" id="bc-generate-btn" type="button">
          Generate Quote →
        </button>
        <div class="bc-error" id="bc-error"></div>

      </div><!-- /bcalc-inputs -->

      <!-- ── RIGHT: Result Column ── -->
      <div class="bcalc-result-col">

        <!-- Placeholder state -->
        <div class="bcalc-placeholder" id="bcalc-placeholder">
          <div class="bcp-icon">📐</div>
          <div class="bcp-text">Fill in the form and click<br /><strong>Generate Quote</strong> to see your estimate</div>
        </div>

        <!-- Result card (hidden until generated) -->
        <div class="bcalc-result" id="bcalc-result">

          <!-- Printable area -->
          <div class="result-printable" id="result-printable">

            <div class="rp-header">
              <div class="rph-brand">
                <div class="rph-logo">TILERSHUB</div>
                <div class="rph-tagline">Premium Tiling &amp; Renovation · Sri Lanka</div>
              </div>
              <div class="rph-title">Renovation Estimate</div>
            </div>

            <div class="rp-client" id="rp-client"></div>

            <div class="rp-metrics">
              <div class="rp-metric">
                <span class="rpm-label">Bathroom Area</span>
                <span class="rpm-value" id="r-area"></span>
                <span class="rpm-unit">sq.ft</span>
              </div>
              <div class="rp-metric rp-metric--mid">
                <span class="rpm-label">Selected Package</span>
                <span class="rpm-value rpm-pkg" id="r-pkg"></span>
              </div>
              <div class="rp-metric">
                <span class="rpm-label">Rate Applied</span>
                <span class="rpm-value" id="r-rate"></span>
                <span class="rpm-unit">/sq.ft</span>
              </div>
            </div>

            <div class="rp-total-block">
              <div class="rptb-label">Estimated Total Cost</div>
              <div class="rptb-price" id="r-total"></div>
              <div class="rptb-note" id="r-note"></div>
            </div>

            <div class="rp-includes">
              <div class="rpi-title">Services Included</div>
              <div class="rpi-grid" id="r-includes"></div>
            </div>

            <div class="rp-payment">
              <div class="rpi-title">Payment Schedule</div>
              <div class="rp-pay-grid" id="r-payment"></div>
            </div>

            <div class="rp-disclaimer">
              ⚠ This is an estimated renovation cost. Final quotation will be confirmed after site inspection.
            </div>

            <div class="rp-footer">
              <div>TILERSHUB · tilershub.lk · +94 774 503 744</div>
              <div id="rp-date"></div>
            </div>

          </div><!-- /result-printable -->

          <div class="result-actions">
            <button class="ra-btn ra-pdf" id="ra-pdf" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PDF
            </button>
            <button class="ra-btn ra-wa" id="ra-wa" type="button">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/></svg>
              Share on WhatsApp
            </button>
          </div>

        </div><!-- /bcalc-result -->

      </div><!-- /bcalc-result-col -->

    </div><!-- /bcalc-layout -->
  </div>
</section>

<script>
  const PACKAGES = {
    basic: {
      name: 'Basic',
      rate: 11000,
      largeRate: 10500,
      min: 450000,
      includes: ['Demolition','Masonry Works','Waterproofing','Plumbing','Electrical & Lighting','Tiling'],
    },
    standard: {
      name: 'Standard',
      rate: 13000,
      largeRate: 12000,
      min: 550000,
      includes: ['Bathroom Designing','Demolition','Masonry Works','Waterproofing','Plumbing','Electrical & Lighting','Tiling','Ceiling','Painting'],
    },
    luxury: {
      name: 'Luxury',
      rate: 15000,
      largeRate: 14000,
      min: 650000,
      includes: ['Bathroom Designing','Demolition','Masonry Works','Waterproofing','Plumbing','Electrical & Lighting','Tiling','Ceiling','Painting','Vanity Cupboard','Shower Cubicle'],
    },
  };

  function fmt(n) {
    return 'Rs. ' + n.toLocaleString('en-IN');
  }

  // Live area preview
  const lenEl  = document.getElementById('bc-length');
  const widEl  = document.getElementById('bc-width');
  const areaEl = document.getElementById('bc-area-value');

  function updateAreaPreview() {
    const l = parseFloat((lenEl as HTMLInputElement).value);
    const w = parseFloat((widEl as HTMLInputElement).value);
    if (l > 0 && w > 0) {
      areaEl.textContent = (l * w).toFixed(1);
    } else {
      areaEl.textContent = '—';
    }
  }

  lenEl.addEventListener('input', updateAreaPreview);
  widEl.addEventListener('input', updateAreaPreview);

  // Package card selection highlight
  document.querySelectorAll('.pkg-card').forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('pkg-card--active'));
      card.classList.add('pkg-card--active');
    });
  });

  // Generate Quote
  document.getElementById('bc-generate-btn').addEventListener('click', () => {
    const name     = (document.getElementById('bc-name') as HTMLInputElement).value.trim();
    const phone    = (document.getElementById('bc-phone') as HTMLInputElement).value.trim();
    const location = (document.getElementById('bc-location') as HTMLInputElement).value.trim();
    const length   = parseFloat((lenEl as HTMLInputElement).value);
    const width    = parseFloat((widEl as HTMLInputElement).value);
    const pkgKey   = (document.querySelector('input[name="bcpkg"]:checked') as HTMLInputElement)?.value;
    const errorEl  = document.getElementById('bc-error');

    // Validation
    const errors: string[] = [];
    if (!name)              errors.push('Please enter your name.');
    if (!phone)             errors.push('Please enter your phone number.');
    if (!location)          errors.push('Please enter your project location.');
    if (!(length > 0))      errors.push('Please enter a valid bathroom length.');
    if (!(width > 0))       errors.push('Please enter a valid bathroom width.');
    if (!pkgKey)            errors.push('Please select a package.');

    if (errors.length) {
      errorEl.innerHTML = errors.map(e => `<span>${e}</span>`).join('');
      errorEl.style.display = 'flex';
      return;
    }
    errorEl.style.display = 'none';

    const area = length * width;
    const pkg  = PACKAGES[pkgKey];
    const rate = area > 100 ? pkg.largeRate : pkg.rate;
    const calc = area * rate;
    const total = Math.max(calc, pkg.min);
    const isMin    = total === pkg.min && calc < pkg.min;
    const isLarge  = area > 100;

    // Populate result
    // Client block
    const clientEl = document.getElementById('rp-client');
    clientEl.innerHTML = `
      <div class="rpc-row"><span class="rpc-label">Name</span><span class="rpc-val">${name}</span></div>
      <div class="rpc-row"><span class="rpc-label">Phone</span><span class="rpc-val">${phone}</span></div>
      <div class="rpc-row"><span class="rpc-label">Location</span><span class="rpc-val">${location}</span></div>
    `;

    (document.getElementById('r-area') as HTMLElement).textContent = area.toFixed(1);
    (document.getElementById('r-pkg') as HTMLElement).textContent  = pkg.name;
    (document.getElementById('r-rate') as HTMLElement).textContent = `Rs. ${rate.toLocaleString('en-IN')}`;
    (document.getElementById('r-total') as HTMLElement).textContent = fmt(total);

    const noteEl = document.getElementById('r-note');
    if (isMin) {
      noteEl.textContent = `Minimum project price applied (calculated: ${fmt(calc)})`;
      noteEl.style.display = 'block';
    } else if (isLarge) {
      noteEl.textContent = `Large bathroom discount applied (area > 100 sq.ft)`;
      noteEl.style.display = 'block';
    } else {
      noteEl.style.display = 'none';
    }

    // Services included
    const includesEl = document.getElementById('r-includes');
    includesEl.innerHTML = pkg.includes.map(s => `<div class="rpi-item">${s}</div>`).join('');

    // Payment schedule
    const PAY = [
      { label: 'Upfront / Deposit',          pct: 10, desc: 'Due before any work commences' },
      { label: 'On Starting Date',            pct: 60, desc: 'Due on the day work begins on site' },
      { label: 'After Tiling Completion',     pct: 30, desc: 'Due once all tiling is finished' },
      { label: 'Final Payment on Handover',   pct: 10, desc: 'Due on project completion & handover' },
    ];
    const payEl = document.getElementById('r-payment');
    payEl.innerHTML = PAY.map(p => {
      const amt = Math.round(total * p.pct / 100);
      return `
        <div class="rpay-row">
          <div class="rpay-left">
            <div class="rpay-label">${p.label}</div>
            <div class="rpay-desc">${p.desc}</div>
          </div>
          <div class="rpay-right">
            <span class="rpay-pct">${p.pct}%</span>
            <span class="rpay-amt">${fmt(amt)}</span>
          </div>
        </div>`;
    }).join('');

    // Date
    (document.getElementById('rp-date') as HTMLElement).textContent =
      new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

    // Store payment data for PDF
    const pdfBtn = document.getElementById('ra-pdf') as HTMLElement;
    pdfBtn.dataset.payRows = PAY.map(p =>
      `${p.pct}%|${p.label}|${p.desc}|${fmt(Math.round(total * p.pct / 100))}`
    ).join(';;');

    // Store for WhatsApp
    (document.getElementById('ra-wa') as HTMLElement).dataset.name     = name;
    (document.getElementById('ra-wa') as HTMLElement).dataset.phone    = phone;
    (document.getElementById('ra-wa') as HTMLElement).dataset.location = location;
    (document.getElementById('ra-wa') as HTMLElement).dataset.area     = area.toFixed(1);
    (document.getElementById('ra-wa') as HTMLElement).dataset.pkg      = pkg.name;
    (document.getElementById('ra-wa') as HTMLElement).dataset.rate     = `Rs. ${rate.toLocaleString('en-IN')}`;
    (document.getElementById('ra-wa') as HTMLElement).dataset.total    = fmt(total);
    (document.getElementById('ra-wa') as HTMLElement).dataset.includes = pkg.includes.join(', ');
    (document.getElementById('ra-wa') as HTMLElement).dataset.note     = isMin
      ? `Minimum project price applied.`
      : isLarge ? `Large bathroom discount applied.` : '';

    // Show result, hide placeholder
    (document.getElementById('bcalc-placeholder') as HTMLElement).style.display = 'none';
    (document.getElementById('bcalc-result') as HTMLElement).style.display = 'flex';

    // Smooth scroll to result on mobile
    if (window.innerWidth < 900) {
      document.getElementById('bcalc-result').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // PDF — injects a hidden iframe (no popup blocker), prints reliably
  document.getElementById('ra-pdf').addEventListener('click', () => {
    const waBtn  = document.getElementById('ra-wa') as HTMLElement;
    const pdfBtn = document.getElementById('ra-pdf') as HTMLElement;

    const name     = waBtn.dataset.name     || '';
    const phone    = waBtn.dataset.phone    || '';
    const location = waBtn.dataset.location || '';
    const area     = waBtn.dataset.area     || '';
    const pkgName  = waBtn.dataset.pkg      || '';
    const rate     = waBtn.dataset.rate     || '';
    const total    = waBtn.dataset.total    || '';
    const note     = waBtn.dataset.note     || '';
    const includes = waBtn.dataset.includes || '';
    const date     = (document.getElementById('rp-date') as HTMLElement).textContent || '';

    if (!name) { alert('Generate a quote first before downloading.'); return; }

    const scopeItems = includes.split(', ').map(s =>
      `<li><span class="chk">✓</span>${s}</li>`
    ).join('');

    const noteHtml = note
      ? `<div class="note-row"><span class="note-icon">ℹ</span>${note}</div>`
      : '';

    const payRows = (pdfBtn.dataset.payRows || '').split(';;').map((row, i) => {
      const [pct, label, desc, amt] = row.split('|');
      const bg = i % 2 === 0 ? '#faf7f2' : '#ffffff';
      return `<tr style="background:${bg}">
        <td class="pt-num">${i + 1}</td>
        <td class="pt-label">${label}</td>
        <td class="pt-desc">${desc}</td>
        <td class="pt-pct">${pct}</td>
        <td class="pt-amt">${amt}</td>
      </tr>`;
    }).join('');

    const html = `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<title>TILERSHUB — Renovation Estimate · ${name}</title>
<style>
  @page {
    size: A4 portrait;
    margin: 1.8cm 2cm 1.5cm;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  body {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 10pt;
    line-height: 1.55;
    color: #1e1a17;
    background: #fff;
  }

  /* ── Header ── */
  .hdr {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-bottom: 10pt;
    border-bottom: 2.5pt solid #c4784a;
    margin-bottom: 16pt;
  }
  .brand-name {
    font-size: 22pt;
    font-weight: 900;
    color: #c4784a;
    letter-spacing: 3pt;
    line-height: 1;
  }
  .brand-sub { font-size: 7.5pt; color: #999; margin-top: 3pt; }
  .doc-meta { text-align: right; }
  .doc-type {
    font-size: 9pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5pt;
    color: #555;
  }
  .doc-date { font-size: 8pt; color: #999; margin-top: 2pt; }

  /* ── Section heading ── */
  .sh {
    font-size: 7pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.8pt;
    color: #c4784a;
    margin-bottom: 6pt;
    padding-bottom: 3pt;
    border-bottom: 0.5pt solid #e8d9c0;
  }

  /* ── Client block ── */
  .client-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 14pt;
    background: #faf7f2;
    border: 0.5pt solid #e8d9c0;
    border-radius: 3pt;
  }
  .client-table td {
    padding: 6pt 10pt;
    font-size: 9.5pt;
    vertical-align: top;
    border-right: 0.5pt solid #e8d9c0;
  }
  .client-table td:last-child { border-right: none; }
  .cl { font-size: 7pt; text-transform: uppercase; letter-spacing: 1pt; color: #999; display: block; margin-bottom: 2pt; }
  .cv { font-weight: 600; color: #1e1a17; }

  /* ── Metrics strip ── */
  .metrics {
    display: flex;
    gap: 8pt;
    margin-bottom: 14pt;
  }
  .metric {
    flex: 1;
    border: 0.75pt solid #d4c4b0;
    border-radius: 3pt;
    padding: 9pt 10pt;
    text-align: center;
  }
  .m-label { font-size: 6.5pt; text-transform: uppercase; letter-spacing: 1pt; color: #999; margin-bottom: 4pt; }
  .m-val { font-size: 16pt; font-weight: 900; color: #1e1a17; line-height: 1; }
  .m-val.clay { color: #c4784a; }
  .m-unit { font-size: 7.5pt; color: #aaa; margin-top: 2pt; }

  /* ── Total block ── */
  .total-block {
    background: #fdf0e6;
    border: 1pt solid #c4784a;
    border-radius: 3pt;
    padding: 14pt 18pt;
    margin-bottom: 14pt;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tb-left { }
  .tb-label { font-size: 7.5pt; text-transform: uppercase; letter-spacing: 1.5pt; color: #888; margin-bottom: 2pt; }
  .tb-price { font-size: 28pt; font-weight: 900; color: #c4784a; line-height: 1; }
  .tb-right { text-align: right; }
  .tb-pkg-label { font-size: 7pt; text-transform: uppercase; letter-spacing: 1pt; color: #aaa; margin-bottom: 2pt; }
  .tb-pkg { font-size: 13pt; font-weight: 700; color: #1e1a17; }
  .note-row {
    display: flex;
    align-items: flex-start;
    gap: 5pt;
    font-size: 7.5pt;
    color: #777;
    font-style: italic;
    margin-top: 8pt;
    padding-top: 8pt;
    border-top: 0.5pt dashed #ddd;
  }
  .note-icon { font-style: normal; color: #c4784a; flex-shrink: 0; }

  /* ── Scope of work ── */
  .scope-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    list-style: none;
    margin-bottom: 14pt;
    border: 0.5pt solid #e8d9c0;
    border-radius: 3pt;
    overflow: hidden;
  }
  .scope-list li {
    display: flex;
    align-items: center;
    gap: 7pt;
    padding: 6pt 10pt;
    font-size: 9.5pt;
    border-bottom: 0.5pt solid #f0e8dc;
    background: #fff;
  }
  .scope-list li:nth-child(odd) { background: #faf7f2; }
  .scope-list li:last-child,
  .scope-list li:nth-last-child(2):nth-child(odd) { border-bottom: none; }
  .chk { color: #c4784a; font-weight: 700; font-size: 9pt; flex-shrink: 0; }

  /* ── Payment table ── */
  .pay-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 14pt;
