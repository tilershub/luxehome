---
---

<section class="bcalc-section" id="renovation-calculator">
  <div class="bcalc-inner">
    <div class="stag reveal">Instant Estimate</div>
    <h2 class="reveal">Bathroom Construction/Renovation Calculator</h2>
    <p class="sdesc reveal">
      Build your bathroom renovation — select a package and add-ons to see a live order total.
    </p>

    <div class="bcalc-layout">

      <!-- ── LEFT: Input Column ── -->
      <div class="bcalc-inputs">

        <!-- Client Details -->
        <div class="bc-card reveal" id="bc-details-card">
          <div class="bc-card-title">Your Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-name">Client Name</label>
              <input class="bc-input" type="text" id="bc-name" placeholder="Your full name" autocomplete="name" />
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-phone">Phone Number</label>
              <input class="bc-input" type="tel" id="bc-phone" placeholder="+94 7xx xxx xxx" autocomplete="tel" />
            </div>
          </div>
          <div class="bc-field">
            <label class="bc-label" for="bc-location">Project Location</label>
            <input class="bc-input" type="text" id="bc-location" placeholder="City / Town / District" autocomplete="address-level2" />
          </div>
          <div class="bc-field">
            <label class="bc-label" for="bc-email">Email Address <span class="bc-label-req">*</span></label>
            <input class="bc-input" type="email" id="bc-email" placeholder="your@email.com" autocomplete="email" />
            <div class="bc-label-hint">Your invoice will be sent to this address</div>
          </div>
        </div>

        <!-- Bathroom Details -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathroom Details</div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-length">Length</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-length" placeholder="e.g. 8" min="0.1" max="500" step="0.1" />
                <span class="bc-area-unit">ft</span>
              </div>
            </div>
            <div class="bc-field">
              <label class="bc-label" for="bc-width">Width</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-width" placeholder="e.g. 6" min="0.1" max="500" step="0.1" />
                <span class="bc-area-unit">ft</span>
              </div>
            </div>
          </div>
          <div class="bc-area-result" id="bc-area-result" hidden>
            Floor Area: <strong id="bc-area-display">—</strong> sq.ft
          </div>
          <div class="bc-row">
            <div class="bc-field">
              <label class="bc-label" for="bc-wall-area">Wall Area</label>
              <div class="bc-area-input-wrap">
                <input class="bc-input" type="number" id="bc-wall-area" placeholder="e.g. 220" min="0" max="10000" step="0.1" />
                <span class="bc-area-unit">sq.ft</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Package Selection -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Select Package</div>
          <div class="pkg-grid" id="pkg-grid">

            <!-- Basic -->
            <label class="pkg-card" data-pkg="basic">
              <input type="radio" name="bcpkg" value="basic" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Basic</span>
                <div class="pkg-base-price">Rs. 450,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 5,000 / sq.ft over 40</div>
            </label>

            <!-- Standard -->
            <label class="pkg-card" data-pkg="standard">
              <input type="radio" name="bcpkg" value="standard" class="pkg-radio" />
              <div class="pkg-popular">Popular</div>
              <div class="pkg-header">
                <span class="pkg-name">Standard</span>
                <div class="pkg-base-price">Rs. 550,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
              </ul>
              <div class="pkg-extra">+Rs. 6,000 / sq.ft over 40</div>
            </label>

            <!-- Luxury -->
            <label class="pkg-card" data-pkg="luxury">
              <input type="radio" name="bcpkg" value="luxury" class="pkg-radio" />
              <div class="pkg-header">
                <span class="pkg-name">Luxury</span>
                <div class="pkg-base-price">Rs. 650,000</div>
                <div class="pkg-base-note">up to 40 sq.ft</div>
              </div>
              <ul class="pkg-list">
                <li>Wall Niches / Vanity Top</li>
                <li>Plumbing</li>
                <li>Electrical Wiring</li>
                <li>Waterproofing</li>
                <li>Tiling</li>
                <li>Ceiling</li>
                <li>Vanity Cupboard</li>
                <li>Shower Cubicle</li>
              </ul>
              <div class="pkg-extra">+Rs. 7,000 / sq.ft over 40</div>
            </label>

          </div>
        </div>

        <!-- Add-ons -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Optional Add-ons</div>
          <label class="addon-row">
            <input type="checkbox" id="addon-demo" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">Demolition Work</span>
              <span class="addon-price">Rs. 1,000 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="checkbox" id="addon-design" class="addon-check" />
            <div class="addon-info">
              <span class="addon-name">3D Bathroom Design</span>
              <span class="addon-price">Rs. 25,000 fixed</span>
            </div>
          </label>
        </div>

        <!-- Tile Supply Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Tile Supply (Add-on)</div>
          <p class="bc-addon-helper">Rocell Tiles &mdash; Rate applies to both floor &amp; wall area with 5% wastage allowance</p>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Tiles not included</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="600" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">60cm × 60cm</span>
              </div>
              <span class="addon-price">Rs. 600 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="700" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">45cm × 90cm</span>
              </div>
              <span class="addon-price">Rs. 700 / sq.ft</span>
            </div>
          </label>
          <label class="addon-row">
            <input type="radio" name="bc-tile" value="800" class="addon-check" />
            <div class="addon-info">
              <div>
                <span class="addon-name">Rocell Tiles</span>
                <span class="addon-size">120cm × 120cm</span>
              </div>
              <span class="addon-price">Rs. 800 / sq.ft</span>
            </div>
          </label>
        </div>

        <!-- Bathware + Taps + Geyser Add-on -->
        <div class="bc-card reveal">
          <div class="bc-card-title">Bathware + Taps + Geyser (Add-on)</div>
          <p class="bc-addon-helper">Swiss Bathware &middot; Swiss Taps &middot; Ferroli Geyser</p>
          <label class="addon-row">
            <input type="radio" name="bc-bw" value="0" class="addon-check" checked />
            <div class="addon-info">
              <span class="addon-name">None</span>
              <span class="addon-price">Not included</span>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="300000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package A</span>
                <span class="addon-price">Rs. 300,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Back to Wall WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="350000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package B</span>
                <span class="addon-price">Rs. 350,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (Stainless Steel) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
          <label class="addon-row addon-row--pkg">
            <input type="radio" name="bc-bw" value="400000" class="addon-check addon-check--top" />
            <div class="addon-pkg-content">
              <div class="addon-info">
                <span class="addon-name">Package C</span>
                <span class="addon-price">Rs. 400,000</span>
              </div>
              <ul class="addon-pkg-list">
                <li>Swiss Wall Mount WC</li>
                <li>Swiss Vanity Basin</li>
                <li>Swiss Brass Concealed Shower &amp; Taps (BrushGold / Gun Gray) &mdash; 5yr corrosion-free warranty</li>
                <li>Ferroli 10L Geyser</li>
                <li>Mirrors &amp; Decorative Accessories</li>
              </ul>
            </div>
          </label>
        </div>

      </div><!-- /bcalc-inputs -->

      <!-- ── RIGHT: Cart Column ── -->
      <div class="bcalc-cart-col">
        <div class="cart-panel" id="cart-panel">

          <!-- Cart Header -->
          <div class="cart-header">
            <div class="cart-header-left">
              <svg class="cart-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 001.97 1.61h9.72a2 2 0 001.97-1.61L23 6H6"/>
              </svg>
              <span class="cart-title">Your Order</span>
            </div>
            <span class="cart-badge" id="cart-badge" style="display:none">0</span>
          </div>

          <!-- Empty State -->
          <div class="cart-empty" id="cart-empty">
            <div class="ce-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 13h4"/>
              </svg>
            </div>
            <p class="ce-msg">Select a package to<br />start building your order</p>
          </div>

          <!-- Cart Items -->
          <div class="cart-items" id="cart-items" style="display:none"></div>

          <!-- Cart Footer: total + payment + checkout -->
          <div class="cart-footer" id="cart-footer" style="display:none">

            <div class="cart-subtotal-row">
              <span class="csr-label">Estimated Total</span>
              <span class="csr-value" id="cart-total">Rs. 0</span>
            </div>

            <div class="cart-payment-section">
              <div class="cps-header" id="cps-toggle">
                <span class="cps-title">Payment Schedule</span>
                <svg class="cps-chevron" id="cps-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
              <div class="cps-body" id="cps-body">
                <div class="cps-rows" id="cps-rows"></div>
              </div>
            </div>

            <div class="cart-error" id="cart-error" style="display:none"></div>

            <button class="btn-checkout" id="btn-checkout" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 001.97 1.61h9.72a2 2 0 001.97-1.61L23 6H6"/>
              </svg>
              Place Order
            </button>

            <p class="cart-disclaimer">
              ⚠ Estimated cost — final price confirmed after site inspection. Confirm by paying 10% deposit.
            </p>

          </div><!-- /cart-footer -->

        </div><!-- /cart-panel -->
      </div><!-- /bcalc-cart-col -->

    </div><!-- /bcalc-layout -->
  </div>
</section>

<!-- ── Checkout Modal ── -->
<div id="checkout-overlay" class="checkout-overlay" style="display:none" aria-modal="true" role="dialog" aria-labelledby="cm-title">

  <div class="checkout-modal">

    <!-- State: Review -->
    <div id="checkout-review" class="checkout-state">
      <div class="cm-header">
        <div class="cm-header-left">
          <span class="cm-brand">LUXEHOME</span>
          <span class="cm-header-sub">Order Review</span>
        </div>
        <div class="cm-ref-badge" id="cm-ref">TH-000000-0000</div>
        <button class="cm-close" id="cm-close" type="button" aria-label="Close modal">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="cm-body">

        <!-- Order items -->
        <div class="cm-section">
          <div class="cm-section-title">Order Summary</div>
          <div id="cm-items" class="cm-items-list"></div>
          <div class="cm-total-row">
            <span class="cm-total-label">Estimated Total</span>
            <span class="cm-total-val" id="cm-total">—</span>
          </div>
        </div>

        <!-- Payment schedule -->
        <div class="cm-section">
          <div class="cm-section-title">Payment Schedule</div>
          <div id="cm-schedule" class="cm-schedule-list"></div>
        </div>

        <!-- Bank transfer -->
        <div class="cm-bank-box">
          <div class="cm-bank-title">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
            Bank Transfer Details — Pay 10% Deposit to Confirm
          </div>
          <div class="cm-bank-grid">
            <span class="cm-bank-key">Bank</span>         <span class="cm-bank-val">Dialog Finance</span>
            <span class="cm-bank-key">Account Name</span> <span class="cm-bank-val">LUXEHOME (Pvt) Ltd</span>
            <span class="cm-bank-key">Account No.</span>  <span class="cm-bank-val cm-bank-val--accent">001020003416</span>
            <span class="cm-bank-key">Branch</span>       <span class="cm-bank-val">Head Office</span>
          </div>
          <p class="cm-bank-note">
            After transferring the 10% deposit, send payment proof to
            <strong>luxehome@gmail.com</strong> or WhatsApp <strong>+94 774 503 744</strong>
            with your order reference.
          </p>
        </div>

        <div id="cm-error" class="cm-error" style="display:none"></div>

      </div>

      <div class="cm-footer">
        <button class="cm-btn-cancel" id="cm-cancel" type="button">Cancel</button>
        <button class="cm-btn-confirm" id="cm-confirm" type="button">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Confirm Order &amp; Send Invoice
        </button>
      </div>
    </div>

    <!-- State: Loading -->
    <div id="checkout-loading" class="checkout-state" style="display:none">
      <div class="cm-loading-state">
        <div class="cm-spinner"></div>
        <div class="cm-loading-title">Sending your invoice…</div>
        <div class="cm-loading-sub">Please wait a moment</div>
      </div>
    </div>

    <!-- State: Success -->
    <div id="checkout-success" class="checkout-state" style="display:none">
      <div class="cm-success-state">
        <div class="cm-success-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 class="cm-success-title" id="cm-title">Order Placed!</h3>
        <p class="cm-success-ref" id="cm-success-ref"></p>
        <p class="cm-success-email" id="cm-success-email"></p>
        <div class="cm-success-bank">
          <div class="cm-success-bank-label">Next: Transfer your 10% deposit to confirm your start date</div>
          <div class="cm-success-deposit" id="cm-success-deposit"></div>
          <div class="cm-success-bank-detail">
            Dialog Finance &nbsp;·&nbsp; LUXEHOME (Pvt) Ltd<br/>
            Acc: 001020003416 &nbsp;·&nbsp; Head Office
          </div>
        </div>
        <button class="cm-btn-done" id="cm-done" type="button">Done</button>
      </div>
    </div>

  </div>
</div>

<script>
  // ── Data ──────────────────────────────────────────────────────────────────

  const PACKAGES: Record<string, { name: string; basePrice: number; baseArea: number; extraRate: number; includes: string[] }> = {
    basic: {
      name: 'Basic',
      basePrice: 450000,
      baseArea: 40,
      extraRate: 5000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling'],
    },
    standard: {
      name: 'Standard',
      basePrice: 550000,
      baseArea: 40,
      extraRate: 6000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling'],
    },
    luxury: {
      name: 'Luxury',
      basePrice: 650000,
      baseArea: 40,
      extraRate: 7000,
      includes: ['Wall Niches / Vanity Top', 'Plumbing', 'Electrical Wiring', 'Waterproofing', 'Tiling', 'Ceiling', 'Vanity Cupboard', 'Shower Cubicle'],
    },
  };

  const TILE_SIZES: Record<string, string> = {
    '600': '60cm × 60cm',
    '700': '45cm × 90cm',
    '800': '120cm × 120cm',
  };

  const BW_PACKAGES: Record<string, { name: string; items: string[] }> = {
    '300000': {
      name: 'Package A',
      items: ['Swiss Back to Wall WC', 'Swiss Vanity Basin', 'Swiss Brass Shower & Taps (Stainless Steel)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
    '350000': {
      name: 'Package B',
      items: ['Swiss Wall Mount WC', 'Swiss Vanity Basin', 'Swiss Brass Concealed Shower & Taps (Stainless Steel)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
    '400000': {
      name: 'Package C',
      items: ['Swiss Wall Mount WC', 'Swiss Vanity Basin', 'Swiss Brass Concealed Shower & Taps (BrushGold / Gun Gray)', 'Ferroli 10L Geyser', 'Mirrors & Decorative Accessories'],
    },
  };

  const PAY = [
    { label: 'Upfront / Deposit',         pct: 10, desc: 'Due before any work commences' },
    { label: 'On Starting Date',           pct: 60, desc: 'Due on the day work begins on site' },
    { label: 'After Tiling Completion',    pct: 20, desc: 'Due once all tiling is finished' },
    { label: 'Final Payment on Handover',  pct: 10, desc: 'Due on project completion & handover' },
  ];

  // ── Helpers ───────────────────────────────────────────────────────────────

  function fmt(n: number): string {
    return 'Rs. ' + Math.round(n).toLocaleString('en-IN');
  }

  // ── Package card selected state ───────────────────────────────────────────

  document.querySelectorAll('.pkg-radio').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.pkg-card').forEach(c => c.classList.remove('pkg-card--active'));
      const checked = document.querySelector('.pkg-radio:checked') as HTMLInputElement | null;
      if (checked) checked.closest('.pkg-card')?.classList.add('pkg-card--active');
      renderCart();
    });
  });

  // ── Live listeners ────────────────────────────────────────────────────────

  // Auto-calculate floor area from length × width
  function updateFloorArea() {
    const length = parseFloat((document.getElementById('bc-length') as HTMLInputElement)?.value) || 0;
    const width  = parseFloat((document.getElementById('bc-width')  as HTMLInputElement)?.value) || 0;
    const area   = parseFloat((length * width).toFixed(2));
    const resultEl  = document.getElementById('bc-area-result');
    const displayEl = document.getElementById('bc-area-display');
    if (length > 0 && width > 0) {
      if (displayEl) displayEl.textContent = area.toString();
      if (resultEl)  resultEl.removeAttribute('hidden');
    } else {
      if (resultEl) resultEl.setAttribute('hidden', '');
    }
    renderCart();
  }

  ['bc-length', 'bc-width', 'bc-wall-area'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', id === 'bc-wall-area' ? renderCart : updateFloorArea);
  });

  document.querySelectorAll('#addon-demo, #addon-design').forEach(el => {
    el.addEventListener('change', renderCart);
  });

  document.querySelectorAll('input[name="bc-tile"], input[name="bc-bw"]').forEach(el => {
    el.addEventListener('change', renderCart);
  });

  // ── Cart renderer ─────────────────────────────────────────────────────────

  function renderCart() {
    const pkgKey   = (document.querySelector('.pkg-radio:checked') as HTMLInputElement | null)?.value ?? '';
    const length   = parseFloat((document.getElementById('bc-length') as HTMLInputElement)?.value) || 0;
    const width    = parseFloat((document.getElementById('bc-width')  as HTMLInputElement)?.value) || 0;
    const area     = parseFloat((length * width).toFixed(2));
    const wallArea = parseFloat((document.getElementById('bc-wall-area') as HTMLInputElement)?.value) || 0;
    const demoOn   = (document.getElementById('addon-demo') as HTMLInputElement)?.checked;
    const designOn = (document.getElementById('addon-design') as HTMLInputElement)?.checked;
    const tileRate = parseInt((document.querySelector('input[name="bc-tile"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;
    const bwAmt    = parseFloat((document.querySelector('input[name="bc-bw"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;

    interface CartItem {
      key: string;
      name: string;
      desc: string;
      price: number | null;
      pending?: string;
    }

    const items: CartItem[] = [];
    let total = 0;

    // Package
    if (pkgKey && PACKAGES[pkgKey]) {
      const p = PACKAGES[pkgKey];
      if (area > 0) {
        const extraArea   = Math.max(0, area - p.baseArea);
        const extraCharge = Math.round(extraArea * p.extraRate);
        const pkgPrice    = p.basePrice + extraCharge;
        total += pkgPrice;

        items.push({
          key: 'pkg',
          name: `${p.name} Package`,
          desc: p.includes.join(' · '),
          price: p.basePrice,
        });

        if (extraCharge > 0) {
          items.push({
            key: 'extra',
            name: 'Area Surcharge',
            desc: `${extraArea} sq.ft over ${p.baseArea} sq.ft × ${fmt(p.extraRate)} / sq.ft`,
            price: extraCharge,
          });
        }
      } else {
        items.push({
          key: 'pkg',
          name: `${p.name} Package`,
          desc: p.includes.join(' · '),
          price: null,
          pending: 'Enter floor area above to calculate price',
        });
      }
    }

    // Demolition
    if (demoOn) {
      if (area > 0) {
        const cost = Math.round(area * 1000);
        total += cost;
        items.push({
          key: 'demo',
          name: 'Demolition Works',
          desc: `${area} sq.ft × Rs. 1,000 / sq.ft`,
          price: cost,
        });
      } else {
        items.push({
          key: 'demo',
          name: 'Demolition Works',
          desc: 'Rs. 1,000 / sq.ft',
          price: null,
          pending: 'Enter floor area above to calculate price',
        });
      }
    }

    // 3D Design
    if (designOn) {
      total += 25000;
      items.push({
        key: 'design',
        name: '3D Bathroom Design',
        desc: 'Design consultation & 3D rendering',
        price: 25000,
      });
    }

    // Tile Supply
    if (tileRate > 0) {
      const combined = area + wallArea;
      if (combined > 0) {
        const areaWithWaste = parseFloat((combined * 1.05).toFixed(2));
        const cost = Math.round(areaWithWaste * tileRate);
        total += cost;
        items.push({
          key: 'tiles',
          name: `Rocell Tile Supply — ${TILE_SIZES[String(tileRate)] ?? ''}`,
          desc: `${areaWithWaste} sq.ft (incl. 5% wastage) × ${fmt(tileRate)} / sq.ft`,
          price: cost,
        });
      } else {
        items.push({
          key: 'tiles',
          name: `Rocell Tile Supply — ${TILE_SIZES[String(tileRate)] ?? ''}`,
          desc: `${fmt(tileRate)} / sq.ft · enter floor & wall area above`,
          price: null,
          pending: 'Enter bathroom areas above to calculate price',
        });
      }
    }

    // Bathware
    if (bwAmt > 0) {
      const bw = BW_PACKAGES[String(bwAmt)];
      total += bwAmt;
      items.push({
        key: 'bw',
        name: `Swiss Bathware ${bw.name}`,
        desc: bw.items.join(' · '),
        price: Math.round(bwAmt),
      });
    }

    // ── Render ──
    const emptyEl  = document.getElementById('cart-empty')!;
    const itemsEl  = document.getElementById('cart-items')!;
    const footerEl = document.getElementById('cart-footer')!;
    const badgeEl  = document.getElementById('cart-badge')!;
    const errorEl  = document.getElementById('cart-error')!;

    if (items.length === 0) {
      emptyEl.style.display  = 'flex';
      itemsEl.style.display  = 'none';
      footerEl.style.display = 'none';
      badgeEl.style.display  = 'none';
      itemsEl.innerHTML = '';
      return;
    }

    const pricedCount = items.filter(i => i.price !== null).length;
    emptyEl.style.display  = 'none';
    itemsEl.style.display  = 'block';
    footerEl.style.display = 'block';
    badgeEl.style.display  = 'inline-flex';
    badgeEl.textContent    = String(items.length);
    errorEl.style.display  = 'none';

    // Cart items HTML
    itemsEl.innerHTML = items.map((item, i) => `
      <div class="cart-item${i < items.length - 1 ? ' cart-item--border' : ''}">
        <div class="ci-info">
          <div class="ci-name">${item.name}</div>
          <div class="ci-desc">${item.desc}</div>
          ${item.pending ? `<div class="ci-pending"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>${item.pending}</div>` : ''}
        </div>
        <div class="ci-price${item.price === null ? ' ci-price--pending' : ''}">${item.price !== null ? fmt(item.price) : '—'}</div>
      </div>
    `).join('');

    // Total
    document.getElementById('cart-total')!.textContent = total > 0 ? fmt(total) : '—';

    // Payment schedule rows
    document.getElementById('cps-rows')!.innerHTML = PAY.map(p => `
      <div class="cpr-row">
        <div class="cpr-left">
          <span class="cpr-pct">${p.pct}%</span>
          <div class="cpr-labels">
            <span class="cpr-label">${p.label}</span>
            <span class="cpr-desc">${p.desc}</span>
          </div>
        </div>
        <span class="cpr-amt">${total > 0 ? fmt(Math.round(total * p.pct / 100)) : '—'}</span>
      </div>
    `).join('');

    // Store total on checkout button
    (document.getElementById('btn-checkout') as HTMLButtonElement).dataset.total = String(total);
  }

  // ── Payment schedule toggle ───────────────────────────────────────────────

  document.getElementById('cps-toggle')?.addEventListener('click', () => {
    const body    = document.getElementById('cps-body')!;
    const chevron = document.getElementById('cps-chevron')!;
    const open    = body.classList.toggle('cps-body--open');
    chevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
  });

  // ── Order ref generator ──────────────────────────────────────────────────

  function generateOrderRef(): string {
    const now = new Date();
    const yr  = now.getFullYear();
    const mo  = String(now.getMonth() + 1).padStart(2, '0');
    const rnd = Math.floor(1000 + Math.random() * 9000);
    return `TH-${yr}${mo}-${rnd}`;
  }

  // ── Modal state helpers ──────────────────────────────────────────────────

  function showCheckoutState(state: 'review' | 'loading' | 'success') {
    (['checkout-review', 'checkout-loading', 'checkout-success'] as const).forEach(id => {
      const el = document.getElementById(id) as HTMLElement;
      el.style.display = id === `checkout-${state}` ? 'block' : 'none';
    });
  }

  function closeCheckoutModal() {
    const overlay = document.getElementById('checkout-overlay')!;
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  // ── Open checkout modal ───────────────────────────────────────────────────

  document.getElementById('btn-checkout')?.addEventListener('click', () => {
    const name     = (document.getElementById('bc-name')     as HTMLInputElement).value.trim();
    const phone    = (document.getElementById('bc-phone')    as HTMLInputElement).value.trim();
    const email    = (document.getElementById('bc-email')    as HTMLInputElement).value.trim();
    const location = (document.getElementById('bc-location') as HTMLInputElement).value.trim();
    const errorEl  = document.getElementById('cart-error')!;

    if (!name || !phone || !email || !location) {
      errorEl.textContent  = '⚠ Please fill in your name, phone, email address, and location before placing your order.';
      errorEl.style.display = 'block';
      const card = document.getElementById('bc-details-card')!;
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      card.classList.add('bc-card--highlight');
      setTimeout(() => card.classList.remove('bc-card--highlight'), 2000);
      return;
    }

    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRe.test(email)) {
      errorEl.textContent  = '⚠ Please enter a valid email address so we can send your invoice.';
      errorEl.style.display = 'block';
      document.getElementById('bc-email')?.focus();
      return;
    }

    errorEl.style.display = 'none';

    // Gather all order data (mirrors renderCart logic)
    const pkgKey   = (document.querySelector('.pkg-radio:checked')          as HTMLInputElement | null)?.value ?? '';
    const length   = parseFloat((document.getElementById('bc-length') as HTMLInputElement)?.value) || 0;
    const width    = parseFloat((document.getElementById('bc-width')  as HTMLInputElement)?.value) || 0;
    const area     = parseFloat((length * width).toFixed(2));
    const wallArea = parseFloat((document.getElementById('bc-wall-area')     as HTMLInputElement)?.value) || 0;
    const demoOn   = (document.getElementById('addon-demo')                  as HTMLInputElement)?.checked;
    const designOn = (document.getElementById('addon-design')                as HTMLInputElement)?.checked;
    const tileRate = parseInt((document.querySelector('input[name="bc-tile"]:checked') as HTMLInputElement | null)?.value ?? '0') || 0;
    const bwAmt    = parseFloat((document.querySelector('input[name="bc-bw"]:checked')  as HTMLInputElement | null)?.value ?? '0') || 0;
    const total    = parseFloat((document.getElementById('btn-checkout') as HTMLButtonElement).dataset.total ?? '0') || 0;

    const pkg = pkgKey ? PACKAGES[pkgKey] : null;

    const orderItems: { name: string; desc: string; price: number }[] = [];

    if (pkg && area > 0) {
      const extraArea   = Math.max(0, area - pkg.baseArea);
      const extraCharge = Math.round(extraArea * pkg.extraRate);
      orderItems.push({ name: `${pkg.name} Package`, desc: pkg.includes.join(' · '), price: pkg.basePrice });
      if (extraCharge > 0) {
        orderItems.push({ name: 'Area Surcharge', desc: `${extraArea} sq.ft over ${pkg.baseArea} sq.ft × Rs. ${pkg.extraRate.toLocaleString('en-IN')}/sq.ft`, price: extraCharge });
      }
    }

    if (demoOn && area > 0) {
      orderItems.push({ name: 'Demolition Works', desc: `${area} sq.ft × Rs. 1,000/sq.ft`, price: Math.round(area * 1000) });
    }

    if (designOn) {
      orderItems.push({ name: '3D Bathroom Design', desc: 'Design consultation & full 3D rendering', price: 25000 });
    }

    if (tileRate > 0 && (area + wallArea) > 0) {
      const combined = parseFloat(((area + wallArea) * 1.05).toFixed(2));
      orderItems.push({
        name: `Rocell Tile Supply — ${TILE_SIZES[String(tileRate)] ?? ''}`,
        desc: `${combined} sq.ft (incl. 5% wastage) × Rs. ${tileRate.toLocaleString('en-IN')}/sq.ft`,
        price: Math.round(combined * tileRate),
      });
    }

    if (bwAmt > 0) {
      const bw = BW_PACKAGES[String(bwAmt)];
      orderItems.push({ name: `Swiss Bathware ${bw.name}`, desc: bw.items.join(' · '), price: Math.round(bwAmt) });
    }

    const paySchedule = PAY.map(p => ({ ...p, amount: Math.round(total * p.pct / 100) }));
    const orderRef    = generateOrderRef();
    const orderDate   = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

    // Store on overlay for submission
    const overlay = document.getElementById('checkout-overlay')! as HTMLElement & { _order?: unknown };
    overlay._order = { orderRef, orderDate, name, email, phone, location, items: orderItems, total, paySchedule };

    // Populate modal
    document.getElementById('cm-ref')!.textContent = orderRef;

    document.getElementById('cm-items')!.innerHTML = orderItems.map(item => `
      <div class="cm-item">
        <div class="cm-item-info">
          <div class="cm-item-name">${item.name}</div>
          <div class="cm-item-desc">${item.desc}</div>
        </div>
        <div class="cm-item-price">${fmt(item.price)}</div>
      </div>
    `).join('');

    document.getElementById('cm-total')!.textContent = fmt(total);

    document.getElementById('cm-schedule')!.innerHTML = paySchedule.map((p, i) => `
      <div class="cm-sched-row${i === 0 ? ' cm-sched-row--deposit' : ''}">
        <div class="cm-sched-left">
          <span class="cm-sched-pct">${p.pct}%</span>
          <div class="cm-sched-info">
            <span class="cm-sched-label">${p.label}${i === 0 ? '<span class="cm-pay-now">Pay Now</span>' : ''}</span>
            <span class="cm-sched-desc">${p.desc}</span>
          </div>
        </div>
        <span class="cm-sched-amt">${fmt(p.amount)}</span>
      </div>
    `).join('');

    document.getElementById('cm-error')!.style.display = 'none';
    showCheckoutState('review');
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  });

  // ── Submit order ──────────────────────────────────────────────────────────

  document.getElementById('cm-confirm')?.addEventListener('click', async () => {
    const overlay  = document.getElementById('checkout-overlay')! as HTMLElement & { _order?: unknown };
    const errorEl  = document.getElementById('cm-error')!;
    const orderData = overlay._order as Record<string, unknown>;

    showCheckoutState('loading');

    try {
      const res  = await fetch('/api/order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(orderData),
      });

      let json: { success?: boolean; error?: string; note?: string } = {};
      try { json = await res.json(); } catch { /* non-JSON response */ }

      if (!res.ok || json.error) {
        showCheckoutState('review');
        errorEl.textContent  = json.error ?? `Server error (${res.status}). Please contact us on WhatsApp.`;
        errorEl.style.display = 'block';
        return;
      }

      // Success
      const data = orderData as { orderRef: string; email: string; paySchedule: { amount: number }[] };
      document.getElementById('cm-success-ref')!.textContent   = `Order Reference: ${data.orderRef}`;
      document.getElementById('cm-success-email')!.textContent  = `Invoice sent to: ${data.email}`;
      document.getElementById('cm-success-deposit')!.textContent = fmt(data.paySchedule[0].amount);
      showCheckoutState('success');

    } catch {
      showCheckoutState('review');
      errorEl.textContent  = 'Connection error. Please check your internet and try again.';
      errorEl.style.display = 'block';
    }
  });

  // ── Modal close / backdrop ────────────────────────────────────────────────

  document.getElementById('cm-close')?.addEventListener('click',  closeCheckoutModal);
  document.getElementById('cm-cancel')?.addEventListener('click', closeCheckoutModal);
  document.getElementById('cm-done')?.addEventListener('click',   closeCheckoutModal);

  document.getElementById('checkout-overlay')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('checkout-overlay')) closeCheckoutModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeCheckoutModal();
  });
</script>

