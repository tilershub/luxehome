---

<section id="why-us">
  <div class="inner">

    <div class="wu-left reveal">
      <div class="stag">Why LUXEHOME</div>
      <h2>Built Around You —<br />Wherever You Are</h2>
      <p class="wu-intro">
        LUXEHOME manages design, planning, construction and finishing from start to handover,
        so your bathroom, floor or staircase upgrade feels organised, transparent and beautifully executed.
      </p>
      <div class="wu-stats">
        <div class="stat">
          <strong>500+</strong>
          <span>Projects Completed</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <strong>5★</strong>
          <span>Client Rating</span>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <strong>Island-wide</strong>
          <span>Coverage</span>
        </div>
      </div>
    </div>

    <div class="wu-right reveal">
      <ul class="checklist" role="list">
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Complete Interior Renovation Solution</strong>
            <span>One team coordinates design, civil work, waterproofing, tiling, flooring, staircase finishes, fixtures and handover.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Premium Materials & Finishes</strong>
            <span>Reliable waterproofing, tile adhesive systems, Swisstek grout, quality fixtures and careful finishing — no hidden substitutions.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Professional Project Management</strong>
            <span>A dedicated project manager oversees every stage so nothing falls through the cracks.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Weekly Progress Updates</strong>
            <span>Photos and status reports sent every week — stay informed from anywhere in the world.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Transparent Pricing</strong>
            <span>Fixed quotes before work begins. No hidden charges, no surprises on completion.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Quality Workmanship</strong>
            <span>Skilled tradespeople with a proven track record delivering premium results consistently.</span>
          </div>
        </li>
        <li>
          <div class="check-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="check-text">
            <strong>Designed for Sri Lankans Living Abroad</strong>
            <span>Manage your renovation remotely with full confidence — we handle everything on the ground.</span>
          </div>
        </li>
      </ul>
    </div>

  </div>
</section>

<style>
  section {
    background: var(--off-white);
    padding: 5.5rem 4rem;
    position: relative;
    overflow: hidden;
  }

  section::after {
    content: '◆';
    position: absolute;
    right: -1.5rem;
    bottom: -2.5rem;
    font-size: 20rem;
    color: rgba(61, 79, 66, .035);
    line-height: 1;
    pointer-events: none;
    font-family: serif;
    user-select: none;
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Left ── */

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.15;
    margin-bottom: 1.2rem;
  }

  .wu-intro {
    font-size: .92rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--warm-gray);
    max-width: 44ch;
    margin-bottom: 2.4rem;
  }

  .wu-stats {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: .2rem;
    padding-right: 1.8rem;
  }

  .stat:not(:first-child) {
    padding-left: 1.8rem;
  }

  .stat strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1;
  }

  .stat span {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .09em;
    color: var(--warm-gray);
  }

  .stat-sep {
    width: 1px;
    height: 2.2rem;
    background: var(--stone);
    flex-shrink: 0;
  }

  /* ── Right: checklist ── */

  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--stone);
  }

  .checklist li:first-child {
    border-top: 1px solid var(--stone);
  }

  .check-icon {
    width: 1.75rem;
    height: 1.75rem;
    background: rgba(184,148,90,.12);
    border: 1px solid rgba(184,148,90,.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay);
    flex-shrink: 0;
    margin-top: .1rem;
  }

  .check-text {
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .check-text strong {
    font-size: .88rem;
    font-weight: 600;
    color: var(--charcoal);
    line-height: 1.3;
  }

  .check-text span {
    font-size: .8rem;
    font-weight: 300;
    color: var(--warm-gray);
    line-height: 1.65;
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .inner { gap: 3.5rem; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .inner { grid-template-columns: 1fr; gap: 3rem; }
    .wu-intro { max-width: none; }
  }
</style>
