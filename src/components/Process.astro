---
const steps = [
  {
    num: '01',
    title: 'Consultation',
    desc: 'Discuss your vision, requirements, and budget. We understand your goals before recommending anything.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3-8.59A2 2 0 0 1 3.61 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.4a16 16 0 0 0 6.29 6.29l.95-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
  {
    num: '02',
    title: 'Site Inspection',
    desc: 'We visit your space for precise measurements and a thorough assessment. Rs. 10,000 — credited against your project.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
  {
    num: '03',
    title: 'Design',
    desc: 'Our team produces a 3D visualisation and civil plan tailored to your space. You review and approve before any work begins.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/><path d="M15 5l4 4"/></svg>`,
  },
  {
    num: '04',
    title: 'Detailed Quotation',
    desc: 'A line-by-line written quotation covering every element of the scope. Fixed price, no hidden charges.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    num: '05',
    title: 'Material Selection',
    desc: 'Choose tiles, fixtures, and finishes from our curated selection or your own supplier. We guide every decision.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
  },
  {
    num: '06',
    title: 'Construction',
    desc: 'Our skilled team executes the full renovation. Daily progress photos and updates shared throughout.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    num: '07',
    title: 'Quality Inspection',
    desc: 'A thorough inspection covers every surface, fitting, and finish. Any snagging is resolved before we close the project.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>`,
  },
  {
    num: '08',
    title: 'Handover',
    desc: 'Your space is handed over clean and complete. Full documentation, care guidance, and warranty provided.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
];
---

<section id="process" class="process-section">
  <div class="process-inner">

    <div class="section-head reveal">
      <div class="stag">How It Works</div>
      <h2>From First Call to<br />Final Handover</h2>
      <p class="sdesc">A clear, structured process so you always know exactly where your project stands — whether you're in Sri Lanka or overseas.</p>
    </div>

    <div class="steps">
      {steps.map((s) => (
        <div class="step reveal">
          <div class="step-num">{s.num}</div>
          <div class="step-icon" aria-hidden="true" set:html={s.icon} />
          <div class="step-body">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="process-cta reveal">
      <a href="/contact" class="btn-primary">Book Your Free Consultation</a>
    </div>

  </div>
</section>

<style>
  .process-section {
    background: var(--cream, #fff);
    padding: 5.5rem 4rem;
  }

  .process-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    max-width: 56ch;
    margin-bottom: 4rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--charcoal, #1e1a17);
    line-height: 1.15;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: var(--warm-gray, #6f6f6f);
    line-height: 1.75;
  }

  /* ── Steps: 4-column grid ── */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .step {
    padding: 2rem 1.8rem 2rem 0;
    border-right: 1px solid var(--stone, #e7e7e7);
    display: flex;
    flex-direction: column;
    gap: .85rem;
    position: relative;
  }

  .step:nth-child(4n) { border-right: none; padding-right: 0; }
  .step:not(:nth-child(4n)) { padding-right: 1.8rem; }
  .step:nth-child(4n+2),
  .step:nth-child(4n+3),
  .step:nth-child(4n) { padding-left: 1.8rem; }
  .step:first-child { padding-left: 0; }

  /* Row 2 (steps 5-8) — top border */
  .step:nth-child(n+5) {
    border-top: 1px solid var(--stone, #e7e7e7);
    padding-top: 2rem;
  }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 800;
    color: rgba(184,137,42,.14);
    line-height: 1;
    letter-spacing: -.04em;
  }

  .step-icon {
    width: 2.6rem;
    height: 2.6rem;
    background: rgba(184,137,42,.08);
    border: 1px solid rgba(184,137,42,.18);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay, #b8892a);
    flex-shrink: 0;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: .98rem;
    font-weight: 700;
    color: var(--charcoal, #1e1a17);
    line-height: 1.25;
  }

  p {
    font-size: .8rem;
    font-weight: 300;
    color: var(--warm-gray, #6f6f6f);
    line-height: 1.78;
  }

  /* ── CTA ── */
  .process-cta {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--charcoal, #1e1a17);
    color: var(--cream, #fff);
    padding: .9rem 2.4rem;
    border-radius: 3px;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 50px;
    transition: background .2s, transform .2s;
  }

  .btn-primary:hover { background: var(--clay, #b8892a); transform: translateY(-2px); }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .process-section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .steps { grid-template-columns: repeat(2, 1fr); }

    .step { padding: 1.8rem 1.8rem 1.8rem 0; }
    .step:nth-child(2n) { border-right: none; padding-right: 0; padding-left: 1.8rem; }
    .step:nth-child(2n+1) { padding-left: 0; border-right: 1px solid var(--stone, #e7e7e7); }
    .step:nth-child(n+3) { border-top: 1px solid var(--stone, #e7e7e7); padding-top: 1.8rem; }
    .step:nth-child(4n) { border-right: 1px solid var(--stone, #e7e7e7); }
    .step:nth-child(4n),
    .step:nth-child(4n+2) { border-right: none; }
  }

  @media (max-width: 768px) {
    .process-section { padding: 4rem 1.5rem; }
    .steps { grid-template-columns: 1fr; }
    .step {
      border-right: none !important;
      border-top: 1px solid var(--stone, #e7e7e7) !important;
      padding: 1.6rem 0 !important;
    }
    .step:first-child { border-top: none !important; padding-top: 0 !important; }
  }
</style>
