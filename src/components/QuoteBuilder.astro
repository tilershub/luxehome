    background: transparent;
    color: var(--warm-gray);
    font-size: .82rem;
    font-weight: 500;
    border-radius: 5px;
    cursor: pointer;
    transition: all .2s;
    white-space: nowrap;
  }

  .qb-cat:hover { color: var(--clay); }
  .qb-cat.active {
    background: var(--charcoal);
    color: var(--cream);
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
  }

  /* ── Service Grid ── */
  .qb-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  /* Grouped categories (bathroom) */
  .qb-group { grid-column: 1 / -1; }

  .qb-group-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    border-bottom: 1.5px solid rgba(184,148,90,.2);
    padding-bottom: .55rem;
    margin-bottom: 1rem;
  }

  .qb-group-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .9rem;
  }

  @media (max-width: 600px) {
    .qb-group-grid { grid-template-columns: 1fr; }
  }

  .qb-svc-card {
    background: #fff;
    border: 1.5px solid rgba(212,201,188,.65);
    border-radius: 10px;
    padding: 1.5rem;
    position: relative;
    transition: border-color .2s, box-shadow .2s, transform .2s;
    box-shadow: 0 2px 8px rgba(0,0,0,.04);
  }

  .qb-svc-card:hover {
    border-color: rgba(184,148,90,.4);
    box-shadow: 0 8px 32px rgba(184,148,90,.1);
    transform: translateY(-2px);
  }

  .qb-svc-card.in-cart {
    border-color: var(--clay);
    background: #fef9f4;
    box-shadow: 0 4px 20px rgba(184,148,90,.12);
  }

  .qb-popular {
    position: absolute;
    top: -.75rem;
    right: 1rem;
    background: var(--clay);
    color: #fff;
    font-size: .65rem;
    font-weight: 700;
