---
interface Props { singleCat?: string; }
const { singleCat } = Astro.props;
---

<section id="quote-builder" class="qb" data-single-cat={singleCat ?? ''}>
  <div class="qb-inner">

    <div class="qb-head reveal">
      <div class="stag">Book Online</div>
      <h2>Get Your Price &amp; Book Today</h2>
      <p class="qb-sub">Add services below, see live pricing, then pay the 10% advance to secure your booking.</p>
    </div>

    <div class="qb-layout">

      <!-- LEFT: Service Selector -->
      <div class="qb-left">
        <div class="qb-step-label">
          <span class="qb-step-num">1</span>
          Choose Your Services
        </div>
        {!singleCat && (
          <div class="qb-cats" role="tablist" aria-label="Service categories">
            <button class="qb-cat active" data-cat="flooring" role="tab">Flooring</button>
            <button class="qb-cat" data-cat="bathroom" role="tab">Bathroom</button>
            <button class="qb-cat" data-cat="kitchen" role="tab">Kitchen</button>
          </div>
        )}
        <div class="qb-grid" id="qb-grid"></div>
      </div>

      <!-- RIGHT: Cart (sticky) -->
      <div class="qb-right">
        <div class="qb-cart-box">
          <div class="qb-cart-title">Your Quote</div>
          <div id="qb-empty-state" class="qb-empty-state">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            <p>Select a service to build your quote</p>
          </div>
          <div id="qb-items" class="qb-items-list" style="display:none"></div>
          <div id="qb-totals" class="qb-totals" style="display:none">
            <div class="qb-totals-row">
              <span>Estimated Total</span>
              <strong id="qb-total-val">Rs. 0</strong>
            </div>
            <div class="qb-totals-advance">
              <span>10% Advance (pay now)</span>
              <strong id="qb-advance-val">Rs. 0</strong>
            </div>
            <p class="qb-totals-note">* Estimate — final price confirmed after free site inspection</p>
            <a class="qb-proceed-btn" href="#qb-checkout" id="qb-proceed">Proceed to Book →</a>
          </div>
        </div>
      </div>

    </div>

    <!-- CHECKOUT: Contact + Payment -->
    <div id="qb-checkout" class="qb-checkout" style="display:none">

      <div class="qb-section-label">
        <span class="qb-step-num">2</span>
        Your Details
      </div>

      <div class="qb-fields">
        <label class="qb-field">
          <span>Full Name *</span>
          <input id="qb-name" type="text" placeholder="Your name" autocomplete="name">
        </label>
        <label class="qb-field">
          <span>Phone *</span>
          <input id="qb-phone" type="tel" placeholder="+94 77 XXX XXXX" autocomplete="tel">
        </label>
        <label class="qb-field">
          <span>Email *</span>
          <input id="qb-email" type="email" placeholder="you@example.com" autocomplete="email">
        </label>
        <label class="qb-field">
          <span>Project Location *</span>
          <input id="qb-location" type="text" placeholder="City / Area" autocomplete="address-level2">
        </label>
      </div>

      <div class="qb-section-label" style="margin-top:2.5rem">
        <span class="qb-step-num">3</span>
        Payment Method
      </div>

      <div class="qb-pay-tabs">
        <button class="qb-pay-tab active" data-tab="payhere">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="1" y="4" width="22" height="16" rx="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
          <div>
            <div class="qb-pay-tab-name">Pay Online</div>
            <div class="qb-pay-tab-sub">Credit / Debit Card · Instant</div>
          </div>
        </button>
        <button class="qb-pay-tab" data-tab="bank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <div>
            <div class="qb-pay-tab-name">Bank Transfer</div>
            <div class="qb-pay-tab-sub">Dialog Finance · Manual</div>
          </div>
        </button>
      </div>

      <!-- PayHere Panel -->
      <div id="qb-panel-payhere" class="qb-pay-panel">
        <p class="qb-pay-desc">
          Pay <strong id="qb-ph-advance"></strong> now via credit or debit card to secure your booking.
          The balance is paid in 3 stages during the project.
        </p>
        <button id="qb-btn-payhere" class="qb-submit-btn" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <rect x="1" y="4" width="22" height="16" rx="2"/>
            <line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
          Pay <span id="qb-ph-btn-amt"></span> Now
        </button>
        <p class="qb-pay-trust">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Secured by PayHere · Sri Lanka's trusted payment gateway
        </p>
      </div>

      <!-- Bank Transfer Panel -->
      <div id="qb-panel-bank" class="qb-pay-panel" style="display:none">
        <p class="qb-pay-desc">
          Submit your order, then transfer <strong id="qb-bank-advance"></strong> to our account.
          Send payment proof to confirm and lock in your booking.
        </p>
        <div class="qb-bank-box">
          <div class="qb-bank-row"><span>Bank</span><strong>Dialog Finance</strong></div>
          <div class="qb-bank-row"><span>Account Name</span><strong>LUXEHOME (Pvt) Ltd</strong></div>
          <div class="qb-bank-row"><span>Account No.</span><strong>001020003416</strong></div>
          <div class="qb-bank-row"><span>Branch</span><strong>Head Office</strong></div>
        </div>
        <button id="qb-btn-bank" class="qb-submit-btn" type="button">
          Submit Order →
        </button>
      </div>

      <div id="qb-error-msg" class="qb-error-msg" role="alert" style="display:none"></div>

    </div>

    <!-- SUCCESS SCREEN -->
    <div id="qb-success" class="qb-success-panel" style="display:none"></div>

  </div>
</section>

<script is:inline>
(function () {

  /* ─── SERVICE DATA ─────────────────────────────────────────── */
  var SERVICES = [
    // FLOORING
    { id:'floor-std',    cat:'flooring', name:'Floor Tiling', tier:'Standard',      sub:'Up to 4×2 tiles · Spacer joint · Swisstek grout',      unit:'sq.ft', rate:350, skirtRate:250 },
    { id:'floor-med',    cat:'flooring', name:'Floor Tiling', tier:'Medium Tiles',  sub:'Router edge · Precision levelling · Large format',      unit:'sq.ft', rate:500, skirtRate:350 },
    { id:'floor-large',  cat:'flooring', name:'Floor Tiling', tier:'Large / Slabs', sub:'Levelling clips · Expert handling · Seamless finish',   unit:'sq.ft', rate:700, skirtRate:450 },
    // BATHROOM — Renovation packages
    { id:'bath-basic',   cat:'bathroom', group:'pkg',      name:'Bathroom Renovation', tier:'Basic',    sub:'Masonry · Waterproofing · Tiling · Plumbing · Electrical · Ceiling', unit:'pkg', rate:450000, baseArea:40, overageRate:5000 },
    { id:'bath-std',     cat:'bathroom', group:'pkg',      name:'Bathroom Renovation', tier:'Standard', sub:'Most popular · Full scope from demolition to handover',               unit:'pkg', rate:550000, baseArea:40, overageRate:6000, popular:true },
    { id:'bath-lux',     cat:'bathroom', group:'pkg',      name:'Bathroom Renovation', tier:'Luxury',   sub:'Premium finishes · Full scope from demolition to handover',           unit:'pkg', rate:650000, baseArea:40, overageRate:7000 },
    // BATHROOM — Tiles (combined floor + wall area)
    { id:'tile-60',      cat:'bathroom', group:'tile', name:'Tiles 60×60',   sub:'Standard format · Floor & wall',  unit:'sq.ft', rate:600, areaLabel:'Total area (floor + wall)' },
    { id:'tile-45',      cat:'bathroom', group:'tile', name:'Tiles 45×90',   sub:'Tall format · Modern look',       unit:'sq.ft', rate:700, areaLabel:'Total area (floor + wall)' },
    { id:'tile-120',     cat:'bathroom', group:'tile', name:'Tiles 120×120', sub:'Large format · Seamless finish',  unit:'sq.ft', rate:800, areaLabel:'Total area (floor + wall)' },
    // BATHROOM — Add-ons (demo & plastering auto-calculated from pkg area)
    { id:'bath-demo',    cat:'bathroom', group:'addon', name:'Demolition Work', sub:'Full demolition of existing bathroom · Debris removal', unit:'sq.ft', rate:1000, autoCalc:true },
    { id:'bath-plaster', cat:'bathroom', group:'addon', name:'Wall Plastering', sub:'Skim coat · Level finish · Ready for tiling',           unit:'sq.ft', rate:1000, autoCalc:true },
    { id:'bath-3d',      cat:'bathroom', group:'addon', name:'3D Design',       sub:'Full 3D rendering before work begins',                  unit:'fixed', rate:25000 },
    // BATHROOM — Fixtures (3 options)
    { id:'fix-a', cat:'bathroom', group:'fixtures', name:'Fixtures Package A', sub:'Swiss Bathware · Swiss Tapware · Accessories · SS finish · Mirror',            unit:'fixed', rate:300000 },
    { id:'fix-b', cat:'bathroom', group:'fixtures', name:'Fixtures Package B', sub:'Swiss Bathware · Swiss Tapware · Accessories · Concealed fittings · Mirror',   unit:'fixed', rate:350000, popular:true },
    { id:'fix-c', cat:'bathroom', group:'fixtures', name:'Fixtures Package C', sub:'Swiss Bathware · Swiss Tapware · Accessories · Brush Gold finish · Mirror',    unit:'fixed', rate:400000 },
    // BATHROOM — Geyser (3 options)
    { id:'geyser-std', cat:'bathroom', group:'geyser', name:'Ferroli Geyser',      tier:'15L Electric', sub:'15L capacity · Wall-mounted · Includes installation', unit:'fixed', rate:32000 },
    { id:'geyser-mid', cat:'bathroom', group:'geyser', name:'Ferroli Geyser',      tier:'25L Electric', sub:'25L capacity · Most popular · Includes installation', unit:'fixed', rate:45000, popular:true },
    { id:'geyser-ins', cat:'bathroom', group:'geyser', name:'Instant Water Heater',tier:'Tankless',     sub:'On-demand hot water · Space-saving · Includes installation', unit:'fixed', rate:62000 },
    // BATHROOM — Shower Cubicle & Vanity Cupboard (standalone)
    { id:'shower', cat:'bathroom', group:'extras', name:'Shower Cubicle',   sub:'Tempered glass · Aluminium frame · 90×90 cm · Includes installation',   unit:'fixed',  rate:85000 },
    { id:'vanity', cat:'bathroom', group:'extras', name:'Vanity Cupboard',  sub:'PVC board · Mirror cabinet · Standard fitting · Includes installation',  unit:'lin.ft', rate:18000 },
    // KITCHEN
    { id:'kitchen', cat:'kitchen', name:'Kitchen', sub:'Pantry tiling + Cupboard · Eco board · Melamine · Mcoco · Quartz top', unit:'lin.ft', rate:45000 },
  ];

  /* ─── STATE ────────────────────────────────────────────────── */
  var cart = [];
  var activeCat = 'flooring';
  var payMethod = 'payhere';
  var pkgArea   = 0; // bathroom floor area from renovation package — drives auto-calc pricing

  /* ─── UTILS ─────────────────────────────────────────────────── */
  function fmt(n) {
    return 'Rs.\u00a0' + Math.round(n).toLocaleString('en-IN');
  }

  function genRef() {
    var d = new Date();
    var yy = d.getFullYear().toString().slice(-2);
    var mm = String(d.getMonth() + 1).padStart(2, '0');
    var dd = String(d.getDate()).padStart(2, '0');
    var r = Math.floor(Math.random() * 9000) + 1000;
    return 'TH-' + yy + mm + dd + '-' + r;
  }

  function buildPaySchedule(total) {
    return [
      { label:'Advance Deposit',       pct:10, amount:total * 0.1, desc:'Pay now to secure your booking' },
      { label:'After Site Inspection', pct:30, amount:total * 0.3, desc:'After inspection & final price confirmed' },
      { label:'During Work',           pct:40, amount:total * 0.4, desc:'Progress payment at project midpoint' },
      { label:'On Completion',         pct:20, amount:total * 0.2, desc:'Final payment on project handover' },
    ];
  }

  function getTotal()   { return cart.reduce(function(s, i) { return s + i.price; }, 0); }
  function getAdvance() { return getTotal() * 0.1; }

  /* ─── RENDER SERVICE CARDS ──────────────────────────────────── */
  function renderCard(s) {
    var inCart     = cart.some(function(c) { return c.id === s.id; });
    var isPkg      = s.unit === 'pkg';
    var isFixed    = s.unit === 'fixed';
    var isAutoCalc = !!s.autoCalc;

    var priceLabel;
    if (isAutoCalc) {
      priceLabel = pkgArea > 0
        ? fmt(pkgArea * s.rate) + ' (' + pkgArea + '\u00a0sq.ft)'
        : 'Calculated from renovation area';
    } else if (isPkg || isFixed) {
      priceLabel = fmt(s.rate);
    } else {
      priceLabel = fmt(s.rate) + '\u00a0/\u00a0' + s.unit;
    }

    var addedBadge = [
      '<div class="qb-svc-added">',
        '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>',
        'Added to quote',
      '</div>',
    ].join('');

    var fixedBtn = '<button class="qb-add-btn" onclick="qbAddFixed(\'' + s.id + '\')">Add</button>';

    var autoCalcControl = pkgArea > 0
      ? '<button class="qb-add-btn" onclick="qbAddAutoCalc(\'' + s.id + '\')">Add</button>'
      : '<div class="qb-auto-hint">Add a renovation package above to enable</div>';

    var pkgForm = [
      '<div class="qb-qty-form">',
        '<div class="qb-qty-row">',
          '<label>Bathroom Area</label>',
          '<div class="qb-qty-wrap">',
            '<input type="number" id="qty-' + s.id + '" min="1" placeholder="e.g. 45" class="qb-qty-in qb-pkg-input" data-id="' + s.id + '">',
            '<span class="qb-qty-unit">sq.ft</span>',
          '</div>',
        '</div>',
        '<div class="qb-pkg-preview" id="preview-' + s.id + '">',
          'Base: ' + fmt(s.rate) + ' (up to ' + s.baseArea + '\u00a0sq.ft) \u00b7 +' + fmt(s.overageRate) + '/sq.ft over',
        '</div>',
        '<button class="qb-add-btn" onclick="qbAddPkg(\'' + s.id + '\')">Add to Quote</button>',
      '</div>',
    ].join('');

    var areaLabel = s.areaLabel || (s.unit === 'sq.ft' ? 'Area' : 'Length');
    var qtyForm = [
      '<div class="qb-qty-form">',
        '<div class="qb-qty-row">',
          '<label>' + areaLabel + '</label>',
          '<div class="qb-qty-wrap">',
            '<input type="number" id="qty-' + s.id + '" min="1" placeholder="0" class="qb-qty-in">',
            '<span class="qb-qty-unit">' + s.unit + '</span>',
          '</div>',
        '</div>',
        (s.skirtRate ? [
          '<div class="qb-qty-row">',
            '<label>Skirting <span class="qb-opt">(optional)</span></label>',
            '<div class="qb-qty-wrap">',
              '<input type="number" id="skirt-' + s.id + '" min="0" placeholder="0" class="qb-qty-in">',
              '<span class="qb-qty-unit">lin.ft</span>',
            '</div>',
          '</div>',
        ].join('') : ''),
        '<button class="qb-add-btn" onclick="qbAddQty(\'' + s.id + '\')">Add</button>',
      '</div>',
    ].join('');

    var control;
    if (inCart)          { control = addedBadge; }
    else if (isAutoCalc) { control = autoCalcControl; }
    else if (isPkg)      { control = pkgForm; }
    else if (isFixed)    { control = fixedBtn; }
    else                 { control = qtyForm; }

    return [
      '<div class="qb-svc-card' + (inCart ? ' in-cart' : '') + '" data-id="' + s.id + '">',
        (s.popular ? '<div class="qb-popular">Most Popular</div>' : ''),
        '<div class="qb-svc-name">' + s.name + (s.tier ? '<span class="qb-svc-tier"> \u2014 ' + s.tier + '</span>' : '') + '</div>',
        '<div class="qb-svc-sub">' + s.sub + '</div>',
        '<div class="qb-svc-price' + (isAutoCalc && pkgArea === 0 ? ' qb-svc-price--dim' : '') + '">' + priceLabel + '</div>',
        control,
      '</div>',
    ].join('');
  }

  var GROUP_LABELS = {
    pkg:'Renovation Package', tile:'Tiles', addon:'Add-ons',
    fixtures:'Bathroom Fixtures', geyser:'Geyser', extras:'Shower Cubicle & Vanity Cupboard',
  };

  function renderServices(cat) {
    var grid = document.getElementById('qb-grid');
    var svcs = SERVICES.filter(function(s) { return s.cat === cat; });
    var hasGroups = svcs.some(function(s) { return s.group; });

    if (!hasGroups) {
      grid.innerHTML = svcs.map(renderCard).join('');
      return;
    }

    var groupOrder = [];
    var groupMap   = {};
    svcs.forEach(function(s) {
      var g = s.group || 'other';
      if (!groupMap[g]) { groupMap[g] = []; groupOrder.push(g); }
      groupMap[g].push(s);
    });

    grid.innerHTML = groupOrder.map(function(g) {
      return [
        '<div class="qb-group">',
          '<div class="qb-group-label">' + (GROUP_LABELS[g] || g) + '</div>',
          '<div class="qb-group-grid">',
            groupMap[g].map(renderCard).join(''),
          '</div>',
        '</div>',
      ].join('');
    }).join('');
  }

  /* ─── ADD TO CART ───────────────────────────────────────────── */
  window.qbAddFixed = function(id) {
    var s = SERVICES.find(function(x) { return x.id === id; });
    if (!s) return;
    if (cart.some(function(c) { return c.id === id; })) return;
    cart.push({
      id: s.id,
      name: s.name + (s.tier ? ' \u2014 ' + s.tier : ''),
      desc: s.sub || 'Fixed price',
      price: s.rate,
    });
    renderServices(activeCat);
    renderCart();
  };

  window.qbAddQty = function(id) {
    var s = SERVICES.find(function(x) { return x.id === id; });
    if (!s) return;
    var qtyEl = document.getElementById('qty-' + id);
    var qty = parseFloat((qtyEl && qtyEl.value) || '0');
    if (!qty || qty <= 0) { if (qtyEl) qtyEl.focus(); return; }

    var skirtEl = document.getElementById('skirt-' + id);
    var skirtQty = skirtEl ? parseFloat(skirtEl.value || '0') : 0;

    var price = qty * s.rate + skirtQty * (s.skirtRate || 0);
    var desc = qty + ' ' + s.unit + ' @ ' + fmt(s.rate) + '/' + s.unit;
    if (skirtQty > 0) desc += ' + ' + skirtQty + ' lin.ft skirting @ ' + fmt(s.skirtRate) + '/lin.ft';

    var idx = cart.findIndex(function(c) { return c.id === id; });
    var item = { id: s.id, name: s.name + (s.tier ? ' \u2014 ' + s.tier : ''), desc: desc, price: price };
    if (idx >= 0) { cart[idx] = item; } else { cart.push(item); }

    renderServices(activeCat);
    renderCart();
  };

  /* Package (bathroom reno) — area-based pricing; sets pkgArea for auto-calc items */
  window.qbAddPkg = function(id) {
    var s = SERVICES.find(function(x) { return x.id === id; });
    if (!s) return;
    var qtyEl = document.getElementById('qty-' + id);
    var area = parseFloat((qtyEl && qtyEl.value) || '0');
    if (!area || area <= 0) { if (qtyEl) qtyEl.focus(); return; }

    // Only one renovation package at a time — replace existing if any
    cart = cart.filter(function(c) {
      var cs = SERVICES.find(function(x) { return x.id === c.id; });
      return !cs || cs.unit !== 'pkg';
    });

    pkgArea = area;

    // Update any auto-calc items already in cart
    cart = cart.map(function(c) {
      var cs = SERVICES.find(function(x) { return x.id === c.id; });
      if (cs && cs.autoCalc) {
        return { id:c.id, name:c.name, desc:pkgArea + ' sq.ft \u00d7 ' + fmt(cs.rate) + '/sq.ft', price:pkgArea * cs.rate };
      }
      return c;
    });

    var extraArea   = Math.max(0, area - s.baseArea);
    var extraCharge = extraArea * s.overageRate;
    var totalPrice  = s.rate + extraCharge;

    var desc = area + '\u00a0sq.ft \u00b7 Package ' + fmt(s.rate) + ' (up to ' + s.baseArea + '\u00a0sq.ft)';
    if (extraArea > 0) {
      desc += ' + ' + extraArea + '\u00a0sq.ft overage \u00d7 ' + fmt(s.overageRate) + '/sq.ft';
    }

    cart.push({ id: s.id, name: s.name + (s.tier ? ' \u2014 ' + s.tier : ''), desc: desc, price: totalPrice });
    renderServices(activeCat);
    renderCart();
  };

  /* Auto-calc items (demolition, plastering) — price derived from pkgArea */
  window.qbAddAutoCalc = function(id) {
    var s = SERVICES.find(function(x) { return x.id === id; });
    if (!s || pkgArea <= 0) return;
    var price = pkgArea * s.rate;
    var desc  = pkgArea + ' sq.ft \u00d7 ' + fmt(s.rate) + '/sq.ft';
    var item  = { id: s.id, name: s.name, desc: desc, price: price };
    var idx   = cart.findIndex(function(c) { return c.id === id; });
    if (idx >= 0) { cart[idx] = item; } else { cart.push(item); }
    renderServices(activeCat);
    renderCart();
  };

  /* Live price preview for pkg inputs */
  document.addEventListener('input', function(e) {
    var el = e.target;
    if (!el || !el.classList || !el.classList.contains('qb-pkg-input')) return;
    var id = el.dataset.id;
    var s  = SERVICES.find(function(x) { return x.id === id; });
    if (!s) return;
    var preview = document.getElementById('preview-' + id);
    if (!preview) return;

    var area = parseFloat(el.value || '0');
    if (!area || area <= 0) {
      preview.textContent = 'Base: ' + fmt(s.rate) + ' (up to ' + s.baseArea + '\u00a0sq.ft) \u00b7 +' + fmt(s.overageRate) + '/sq.ft over';
      preview.classList.remove('qb-pkg-preview--active');
      return;
    }

    var extraArea  = Math.max(0, area - s.baseArea);
    var totalPrice = s.rate + extraArea * s.overageRate;
    if (extraArea > 0) {
      preview.textContent = fmt(s.rate) + ' + ' + extraArea + '\u00a0sq.ft \u00d7 ' + fmt(s.overageRate) + ' = ' + fmt(totalPrice);
    } else {
      preview.textContent = 'Total: ' + fmt(totalPrice) + ' \u2014 within included 40\u00a0sq.ft';
    }
    preview.classList.add('qb-pkg-preview--active');
  });

  window.qbRemove = function(id) {
    var removedSvc = SERVICES.find(function(x) { return x.id === id; });
    cart = cart.filter(function(c) { return c.id !== id; });

    // If a renovation package was removed and no other pkg remains, clear pkgArea
    // and drop any auto-calc items (their price no longer makes sense)
    if (removedSvc && removedSvc.unit === 'pkg') {
      var hasPkg = cart.some(function(c) {
        var cs = SERVICES.find(function(x) { return x.id === c.id; });
        return cs && cs.unit === 'pkg';
      });
      if (!hasPkg) {
        pkgArea = 0;
        cart = cart.filter(function(c) {
          var cs = SERVICES.find(function(x) { return x.id === c.id; });
          return !cs || !cs.autoCalc;
        });
      }
    }

    renderServices(activeCat);
    renderCart();
  };

  /* ─── RENDER CART ───────────────────────────────────────────── */
  function renderCart() {
    var emptyState = document.getElementById('qb-empty-state');
    var itemsList  = document.getElementById('qb-items');
    var totals     = document.getElementById('qb-totals');
    var checkout   = document.getElementById('qb-checkout');
    var total      = getTotal();
    var advance    = getAdvance();

    if (cart.length === 0) {
      emptyState.style.display = '';
      itemsList.style.display  = 'none';
      totals.style.display     = 'none';
      checkout.style.display   = 'none';
      document.dispatchEvent(new CustomEvent('qb-cart-update', { detail: { count: 0 } }));
      return;
    }

    emptyState.style.display = 'none';
    itemsList.style.display  = '';
    totals.style.display     = '';
    checkout.style.display   = '';

    itemsList.innerHTML = cart.map(function(item) {
      return [
        '<div class="qb-cart-item">',
          '<div class="qb-cart-item-info">',
            '<div class="qb-cart-item-name">' + item.name + '</div>',
            '<div class="qb-cart-item-desc">' + item.desc + '</div>',
          '</div>',
          '<div class="qb-cart-item-right">',
            '<div class="qb-cart-item-price">' + fmt(item.price) + '</div>',
            '<button class="qb-remove" onclick="qbRemove(\'' + item.id + '\')" aria-label="Remove">\u00d7</button>',
          '</div>',
        '</div>',
      ].join('');
    }).join('');

    document.getElementById('qb-total-val').textContent   = fmt(total);
    document.getElementById('qb-advance-val').textContent  = fmt(advance);
    document.getElementById('qb-ph-advance').textContent   = fmt(advance);
    document.getElementById('qb-ph-btn-amt').textContent   = fmt(advance);
    document.getElementById('qb-bank-advance').textContent = fmt(advance);

    document.dispatchEvent(new CustomEvent('qb-cart-update', { detail: { count: cart.length } }));
  }

  /* ─── VALIDATION ─────────────────────────────────────────────── */
  function validate() {
    var name     = document.getElementById('qb-name').value.trim();
    var phone    = document.getElementById('qb-phone').value.trim();
    var email    = document.getElementById('qb-email').value.trim();
    var location = document.getElementById('qb-location').value.trim();

    if (!name)                       { showError('Please enter your name.');                     document.getElementById('qb-name').focus();     return null; }
    if (!phone)                      { showError('Please enter your phone number.');              document.getElementById('qb-phone').focus();    return null; }
    if (!email || !email.includes('@')) { showError('Please enter a valid email address.');       document.getElementById('qb-email').focus();    return null; }
    if (!location)                   { showError('Please enter your project location.');          document.getElementById('qb-location').focus(); return null; }
    if (cart.length === 0)           { showError('Please add at least one service to your quote.'); return null; }

    hideError();
    return { name: name, phone: phone, email: email, location: location };
  }

  function showError(msg) {
    var el = document.getElementById('qb-error-msg');
    el.textContent = msg;
    el.style.display = '';
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    document.getElementById('qb-error-msg').style.display = 'none';
  }

  /* ─── SUBMIT ORDER ───────────────────────────────────────────── */
  function submitOrder(orderRef, paymentMethod, paymentRef, details) {
    var total   = getTotal();
    var payload = {
      orderRef:      orderRef,
      orderDate:     new Date().toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' }),
      name:          details.name,
      email:         details.email,
      phone:         details.phone,
      location:      details.location,
      paymentMethod: paymentMethod,
      paymentRef:    paymentRef || null,
      items:         cart.map(function(item) { return { name:item.name, desc:item.desc, price:item.price }; }),
      total:         total,
      paySchedule:   buildPaySchedule(total),
    };

    return fetch('/api/order', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload),
    }).then(function(res) {
      if (!res.ok) throw new Error('Server error');
      showSuccess(orderRef, paymentMethod, getAdvance(), details);
      return true;
    }).catch(function() {
      showError('Failed to send your order. Please try again or contact us on WhatsApp.');
      return false;
    });
  }

  /* ─── SUCCESS SCREEN ─────────────────────────────────────────── */
  function showSuccess(orderRef, method, advance, details) {
    document.querySelector('.qb-layout').style.display = 'none';
    document.getElementById('qb-checkout').style.display = 'none';

    var bankSection = method === 'bank' ? [
      '<div class="qb-succ-bank">',
        '<div class="qb-succ-bank-head">Transfer ' + fmt(advance) + ' to</div>',
        '<div class="qb-succ-bank-grid">',
          '<span>Bank</span><strong>Dialog Finance</strong>',
          '<span>Account Name</span><strong>LUXEHOME (Pvt) Ltd</strong>',
          '<span>Account No.</span><strong>001020003416</strong>',
          '<span>Branch</span><strong>Head Office</strong>',
        '</div>',
        '<p>After transferring, send payment proof to <a href="mailto:luxehome@gmail.com">luxehome@gmail.com</a> or WhatsApp <a href="https://wa.me/94774503744">+94 774 503 744</a> with your order reference <strong>' + orderRef + '</strong>.</p>',
      '</div>',
    ].join('') : [
      '<div class="qb-succ-paid">',
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>',
        fmt(advance) + ' paid online \u2014 booking secured.',
      '</div>',
    ].join('');

    var el = document.getElementById('qb-success');
    el.innerHTML = [
      '<div class="qb-succ-icon">',
        '<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>',
      '</div>',
      '<h3>Order Confirmed \u2014 ' + orderRef + '</h3>',
      '<p class="qb-succ-sub">A full invoice has been sent to <strong>' + details.email + '</strong>. We\'ll be in touch to arrange your free site inspection.</p>',
      bankSection,
      '<div class="qb-succ-steps">',
        '<div class="qb-succ-steps-title">What happens next</div>',
        '<ol>',
          '<li>' + (method === 'bank' ? 'Transfer the 10% deposit and send payment proof to confirm' : 'Your 10% deposit has been paid — booking confirmed') + '</li>',
          '<li>We arrange a free site inspection at your convenience</li>',
          '<li>Final price is agreed after inspection, then we schedule your start date</li>',
          '<li>Project is completed in stages with milestone payments</li>',
        '</ol>',
      '</div>',
    ].join('');
    el.style.display = '';
    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  /* ─── PAYHERE ────────────────────────────────────────────────── */
  function loadPayHere() {
    return new Promise(function(resolve) {
      if (window.payhere) { resolve(); return; }
      var s = document.createElement('script');
      s.src = 'https://www.payhere.lk/lib/payhere.js';
      s.onload = resolve;
      s.onerror = resolve;
      document.head.appendChild(s);
    });
  }

  document.getElementById('qb-btn-payhere').addEventListener('click', function() {
    var details = validate();
    if (!details) return;

    var btn = document.getElementById('qb-btn-payhere');
    btn.disabled = true;
    btn.textContent = 'Loading payment\u2026';

    var advance  = getAdvance();
    var orderRef = genRef();

    loadPayHere().then(function() {
      if (!window.payhere) {
        showError('Payment gateway failed to load. Please use bank transfer or contact us directly.');
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ' + fmt(advance) + ' Now';
        return;
      }

      return fetch('/api/payhere-init', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ orderId: orderRef, amount: advance.toFixed(2) }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.hash) throw new Error('no hash');

        payhere.onCompleted = function(paidOrderId) {
          submitOrder(orderRef, 'payhere', paidOrderId, details);
        };
        payhere.onDismissed = function() {
          btn.disabled = false;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ' + fmt(advance) + ' Now';
        };
        payhere.onError = function(err) {
          showError('Payment error. Please try again or use bank transfer.');
          btn.disabled = false;
          btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ' + fmt(advance) + ' Now';
        };

        payhere.startPayment({
          sandbox:     false,
          merchant_id: data.merchantId,
          return_url:  window.location.origin,
          cancel_url:  window.location.href,
          notify_url:  window.location.origin + '/api/payhere-notify',
          order_id:    orderRef,
          items:       'LUXEHOME Services — ' + orderRef,
          amount:      advance.toFixed(2),
          currency:    'LKR',
          hash:        data.hash,
          first_name:  details.name.split(' ')[0],
          last_name:   details.name.split(' ').slice(1).join(' ') || '.',
          email:       details.email,
          phone:       details.phone,
          address:     details.location,
          city:        details.location,
          country:     'Sri Lanka',
        });

        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ' + fmt(advance) + ' Now';
      })
      .catch(function() {
        showError('Could not initialise payment. Please use bank transfer or contact us directly.');
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ' + fmt(advance) + ' Now';
      });
    });
  });

  document.getElementById('qb-btn-bank').addEventListener('click', function() {
    var details = validate();
    if (!details) return;

    var btn = document.getElementById('qb-btn-bank');
    btn.disabled = true;
    btn.textContent = 'Submitting\u2026';

    submitOrder(genRef(), 'bank-transfer', null, details).then(function(ok) {
      if (!ok) {
        btn.disabled = false;
        btn.textContent = 'Submit Order \u2192';
      }
    });
  });

  /* ─── CATEGORY TABS ──────────────────────────────────────────── */
  document.querySelectorAll('.qb-cat').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.qb-cat').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeCat = btn.dataset.cat;
      renderServices(activeCat);
    });
  });

  /* ─── PAYMENT METHOD TABS ────────────────────────────────────── */
  document.querySelectorAll('.qb-pay-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.qb-pay-tab').forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      payMethod = tab.dataset.tab;
      document.getElementById('qb-panel-payhere').style.display = payMethod === 'payhere' ? '' : 'none';
      document.getElementById('qb-panel-bank').style.display     = payMethod === 'bank'    ? '' : 'none';
    });
  });

  /* ─── INIT ───────────────────────────────────────────────────── */
  var singleCat = document.getElementById('quote-builder').dataset.singleCat;
  if (singleCat) {
    activeCat = singleCat;
    renderServices(singleCat);
  } else {
    renderServices('flooring');
    // Auto-select category from URL hash (e.g. #book=bathroom)
    (function() {
      var hash = window.location.hash;
      var m = hash.match(/^#book=(\w+)/);
      if (!m) return;
      var cat = m[1];
      var catBtn = document.querySelector('.qb-cat[data-cat="' + cat + '"]');
      if (!catBtn) return;
      catBtn.click();
      setTimeout(function() {
        document.getElementById('quote-builder').scrollIntoView({ behavior: 'smooth' });
      }, 50);
    })();
  }

})();
</script>

<style>
  .qb {
    background: #faf8f4;
    padding: 7rem 4rem;
    position: relative;
  }

  .qb::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 320px;
    background: radial-gradient(ellipse at top, rgba(184,148,90,.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .qb-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
  }

  /* ── Head ── */
  .qb-head {
    text-align: center;
    margin-bottom: 4rem;
  }

  .qb-head h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--charcoal);
    margin-bottom: .65rem;
    letter-spacing: -.02em;
  }

  .qb-sub {
    color: var(--warm-gray);
    font-size: .95rem;
    font-weight: 300;
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.78;
  }

  /* ── Layout ── */
  .qb-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Step label ── */
  .qb-step-label {
    display: flex;
    align-items: center;
    gap: .75rem;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-bottom: 1.4rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(184,148,90,.18);
  }

  .qb-step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    background: var(--charcoal);
    color: #fff;
    border-radius: 50%;
    font-size: .72rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Category Tabs ── */
  .qb-cats {
    display: flex;
    gap: .3rem;
    margin-bottom: 1.6rem;
    background: rgba(184,148,90,.06);
