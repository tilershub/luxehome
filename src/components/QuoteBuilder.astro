  }

  .qb-qty-unit {
    font-size: .72rem;
    color: var(--warm-gray);
    white-space: nowrap;
  }

  /* Package price preview */
  .qb-pkg-preview {
    font-size: .72rem;
    color: var(--warm-gray);
    background: rgba(61, 79, 66, .06);
    border: 1px solid rgba(61, 79, 66, .18);
    border-radius: 2px;
    padding: .4rem .6rem;
    line-height: 1.4;
  }

  .qb-pkg-preview--active {
    background: rgba(61, 79, 66, .12);
    border-color: rgba(61, 79, 66, .35);
    color: var(--charcoal);
    font-weight: 600;
  }

  /* Add button */
  .qb-add-btn {
    width: 100%;
    margin-top: .5rem;
    padding: .58rem .8rem;
    background: var(--charcoal);
    color: var(--cream);
    border: none;
    border-radius: 6px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    transition: background .2s, transform .15s;
  }

  .qb-add-btn:hover { background: var(--clay); transform: translateY(-1px); }

  .qb-svc-price--dim {
    color: rgba(140,123,110,.5);
    font-style: italic;
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem;
    font-weight: 400;
  }

  .qb-auto-hint {
    font-size: .73rem;
    color: rgba(140,123,110,.6);
    background: rgba(184,148,90,.05);
    border: 1px dashed rgba(184,148,90,.25);
    border-radius: 5px;
    padding: .5rem .7rem;
    text-align: center;
    line-height: 1.45;
  }

  .qb-svc-added {
    display: flex;
    align-items: center;
    gap: .45rem;
    color: var(--clay);
    font-size: .8rem;
    font-weight: 600;
    background: rgba(184,148,90,.08);
    border-radius: 5px;
    padding: .45rem .7rem;
  }

  /* ── Cart Box ── */
  .qb-right { position: relative; }

  .qb-cart-box {
    position: sticky;
    top: 5rem;
    background: var(--charcoal);
    border-radius: 12px;
    overflow: hidden;
    color: var(--cream);
    box-shadow: 0 16px 48px rgba(30,26,23,.22);
  }

  .qb-cart-title {
    padding: 1.2rem 1.6rem;
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: rgba(245,240,232,.4);
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .qb-empty-state {
    padding: 2.8rem 1.6rem;
    text-align: center;
    color: rgba(245,240,232,.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .85rem;
  }

  .qb-empty-state p { font-size: .82rem; line-height: 1.55; }

  .qb-items-list { padding: .4rem 0; }

  .qb-cart-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1rem 1.6rem;
    border-bottom: 1px solid rgba(255,255,255,.055);
    gap: .5rem;
  }

  .qb-cart-item-name {
    font-size: .8rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: .22rem;
  }

  .qb-cart-item-desc {
    font-size: .68rem;
    color: rgba(245,240,232,.4);
    line-height: 1.45;
  }

