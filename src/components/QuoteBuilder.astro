  }

  .qb-svc-name {
    font-size: .92rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: .28rem;
    line-height: 1.3;
  }

  .qb-svc-tier {
    font-weight: 400;
    color: var(--clay);
  }

  .qb-svc-sub {
    font-size: .73rem;
    color: var(--warm-gray);
    line-height: 1.55;
    margin-bottom: .75rem;
  }

  .qb-svc-price {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: .95rem;
  }

  /* Quantity form */
  .qb-qty-form { display: flex; flex-direction: column; gap: .5rem; }

  .qb-qty-row {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
  }

  .qb-qty-row label {
    white-space: nowrap;
    color: var(--warm-gray);
    font-weight: 500;
    min-width: 52px;
  }

  .qb-opt { color: var(--warm-gray); font-weight: 300; }

  .qb-qty-wrap {
    display: flex;
    align-items: center;
    gap: .3rem;
    flex: 1;
  }

  .qb-qty-in {
    width: 70px;
    border: 1.5px solid rgba(212,201,188,.7);
    border-radius: 5px;
    padding: .42rem .5rem;
    font-size: .82rem;
