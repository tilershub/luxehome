---
---

<!-- Section is hidden by default; JS reveals it when YouTube URLs are found in Supabase -->
<section id="featured-videos" class="videos-section" style="display:none">
  <div class="videos-inner">

    <div class="videos-head">
      <div class="stag">Behind Every Renovation</div>
      <h2>The Full Transformation Story</h2>
      <p class="sdesc">Follow each project from the old space to the completed reveal — documented in two episodes.</p>
    </div>

    <div class="videos-grid" id="videos-grid"></div>

    <div class="videos-footer">
      <a href="https://youtube.com/@luxehome" target="_blank" rel="noopener noreferrer" class="btn-yt">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Subscribe on YouTube →
      </a>
    </div>

  </div>
</section>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function ytIdFromUrl(url) {
    if (!url) return null;
    const m = url.match(/(?:youtu\.be\/|v=|embed\/)([a-zA-Z0-9_-]{11})/);
    return m ? m[1] : null;
  }

  function thumbUrl(customThumb, youtubeId) {
    if (customThumb) return customThumb;
    if (youtubeId) return `https://img.youtube.com/vi/${youtubeId}/maxresdefault.jpg`;
    return null;
  }

  function renderVideoCard(title, episodeLabel, thumb, youtubeId) {
    return `
      <div class="video-card" data-yt-id="${youtubeId || ''}">
        <div class="video-thumb">
          ${thumb ? `<img src="${thumb}" alt="${title}" loading="lazy" width="640" height="360" />` : '<div class="thumb-placeholder"></div>'}
          <div class="video-overlay" aria-hidden="true"></div>
          <button class="play-btn" aria-label="Play video: ${title}">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
        <div class="video-meta">
          <div class="episode-label">${episodeLabel}</div>
          <div class="video-title">${title}</div>
        </div>
      </div>`;
  }

  async function loadVideos() {
    if (!SB_URL || !SB_KEY) return;
    try {
      const sb = createClient(SB_URL, SB_KEY);
      const { data } = await sb
        .from('projects')
        .select('title,location,episode_01_youtube,episode_02_youtube,episode_01_thumbnail,episode_02_thumbnail')
        .or('episode_01_youtube.not.is.null,episode_02_youtube.not.is.null')
        .in('status', ['published', 'featured'])
        .order('completion_year', { ascending: false })
        .limit(2);

      if (!data || data.length === 0) return;

      const cards = [];
      for (const p of data) {
        if (p.episode_01_youtube) {
          const id = ytIdFromUrl(p.episode_01_youtube);
          const thumb = thumbUrl(p.episode_01_thumbnail, id);
          cards.push(renderVideoCard(
            `${p.title} — ${p.location}`,
            'Episode 01 · Old Space to 3D Design',
            thumb, id
          ));
        }
        if (p.episode_02_youtube && cards.length < 4) {
          const id = ytIdFromUrl(p.episode_02_youtube);
          const thumb = thumbUrl(p.episode_02_thumbnail, id);
          cards.push(renderVideoCard(
            `${p.title} — ${p.location}`,
            'Episode 02 · Completed Project Tour',
            thumb, id
          ));
        }
        if (cards.length >= 4) break;
      }

      if (cards.length === 0) return;

      const section = document.getElementById('featured-videos');
      const grid = document.getElementById('videos-grid');
      grid.innerHTML = cards.join('');
      section.style.display = '';

      // Lazy YouTube embed on play click
      grid.querySelectorAll('.video-card').forEach(card => {
        const ytId = card.dataset.ytId;
        if (!ytId) return;
        card.querySelector('.play-btn')?.addEventListener('click', () => {
          const thumbEl = card.querySelector('.video-thumb');
          thumbEl.innerHTML = `<iframe
            src="https://www.youtube-nocookie.com/embed/${ytId}?autoplay=1&rel=0"
            allow="autoplay; encrypted-media; fullscreen"
            allowfullscreen
            frameborder="0"
            loading="lazy"
            title="LUXEhome project video"
          ></iframe>`;
        });
      });
    } catch {
      // silently fail
    }
  }

  document.addEventListener('DOMContentLoaded', loadVideos);
</script>

<style>
  .videos-section {
    background: var(--charcoal, #1e1a17);
    padding: 5.5rem 4rem;
    border-top: 1px solid rgba(255,255,255,.05);
  }

  .videos-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .videos-head {
    max-width: 56ch;
    margin-bottom: 3rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream, #f0ece0);
    line-height: 1.15;
    margin-bottom: .8rem;
  }

  .sdesc {
    font-size: .92rem;
    color: rgba(240,236,224,.65);
    line-height: 1.75;
  }

  /* ── Video grid ── */
  .videos-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .video-card {
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.07);
    background: rgba(255,255,255,.03);
    transition: transform .3s, box-shadow .3s;
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0,0,0,.45);
  }

  .video-thumb {
    position: relative;
    aspect-ratio: 16/9;
    background: #0d0b09;
    overflow: hidden;
    cursor: pointer;
  }

  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.85);
    transition: filter .3s;
  }

  .video-card:hover .video-thumb img { filter: brightness(.92); }

  .video-thumb iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e1a17, #111);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.6) 0%, transparent 50%);
  }

  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    background: rgba(184,137,42,.88);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, transform .2s;
    backdrop-filter: blur(4px);
  }

  .play-btn:hover {
    background: var(--clay, #b8892a);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .play-btn svg { margin-left: 3px; }

  .video-meta {
    padding: 1.2rem 1.4rem 1.4rem;
  }

  .episode-label {
    font-size: .64rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .35rem;
  }

  .video-title {
    font-family: 'Playfair Display', serif;
    font-size: .95rem;
    font-weight: 700;
    color: rgba(240,236,224,.92);
    line-height: 1.35;
  }

  /* ── Footer ── */
  .videos-footer {
    display: flex;
    justify-content: center;
  }

  .btn-yt {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    color: rgba(240,236,224,.75);
    border: 1px solid rgba(255,255,255,.12);
    padding: .8rem 1.8rem;
    border-radius: 3px;
    font-size: .78rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-decoration: none;
    transition: color .2s, border-color .2s;
  }

  .btn-yt:hover { color: #f00; border-color: rgba(255,0,0,.35); }

  @media (max-width: 1100px) {
    .videos-section { padding-left: 2.5rem; padding-right: 2.5rem; }
  }

  @media (max-width: 768px) {
    .videos-section { padding: 4rem 1.5rem; }
    .videos-grid { grid-template-columns: 1fr; }
    .play-btn { width: 52px; height: 52px; }
  }
</style>
