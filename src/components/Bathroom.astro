<section id="bathroom">
  <div class="bath-inner">

    <div class="bath-text">
      <div class="stag reveal">Full-Scope Renovation</div>
      <h2 class="reveal">Complete Bathroom<br />Transformations</h2>
      <p class="sdesc reveal">
        Every trade under one team — from demolition to final fittings.
        You supply tiles, bathware, and tapware. Everything else is on us.
      </p>
      <div class="scope-pills reveal">
        <span>Design & Planning</span>
        <span>Demo</span>
        <span>Mason</span>
        <span>Plumbing</span>
        <span>Waterproofing</span>
        <span>Electrical</span>
        <span>Tiling</span>
        <span>Ceiling</span>
        <span>Fixtures</span>
        <span>Vanity Cupboard</span>
      </div>
      <div class="bath-ctas reveal">
        <a
          href="https://wa.me/94774503744?text=Hello%20TILERSHUB%2C%20I%20am%20interested%20in%20a%20bathroom%20renovation%20quote."
          class="btn-primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          WhatsApp for a Quote
        </a>
        <a href="tel:+94774503744" class="btn-ghost">📞 Call Us</a>
      </div>
    </div>

    <div class="bath-card reveal">
      <div class="bcard-label">Starting from</div>
      <div class="bcard-price">Rs. 15,000</div>
      <div class="bcard-unit">per sq.ft · all-inclusive</div>
      <div class="bcard-note">
        Client supplies tiles, bathware fittings, and tapware only.
        All labour and materials for every other trade are included.
      </div>
      <a
        href="https://wa.me/94774503744?text=Hello%2C%20I%20am%20interested%20in%20a%20bathroom%20renovation%20quote."
        class="bcard-cta"
      >Get Bathroom Quote →</a>
    </div>

  </div>
</section>

<style>
  section {
    background: var(--sand);
    padding: 5.5rem 4rem;
  }

  .bath-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Scope pills ── */

  .scope-pills {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-bottom: 2rem;
  }

  .scope-pills span {
    font-size: .75rem;
    font-weight: 500;
    letter-spacing: .05em;
    color: var(--warm-gray);
    background: rgba(196, 120, 74, .08);
    border: 1px solid rgba(196, 120, 74, .2);
    padding: .28rem .75rem;
    border-radius: 20px;
  }

  /* ── CTA row ── */

  .bath-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Pricing card ── */

  .bath-card {
    background: var(--charcoal);
    padding: 2.2rem;
    border-radius: 4px;
  }

  .bcard-label {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(245, 240, 232, .65);
    margin-bottom: .6rem;
  }

  .bcard-price {
    font-family: 'Playfair Display', serif;
    font-size: 2.7rem;
    font-weight: 900;
    color: var(--clay);
    line-height: 1;
  }

  .bcard-unit {
    font-size: .78rem;
    color: rgba(245, 240, 232, .65);
    margin-top: .35rem;
    margin-bottom: 1.4rem;
  }

  .bcard-note {
    font-size: .78rem;
    color: rgba(245, 240, 232, .5);
    line-height: 1.65;
    padding: .9rem;
    background: rgba(255, 255, 255, .04);
    border-radius: 3px;
    margin-bottom: 1.3rem;
  }

  .bcard-cta {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--clay);
    color: var(--cream);
    text-decoration: none;
    padding: .9rem;
    border-radius: 2px;
    font-size: .86rem;
    font-weight: 500;
    transition: background .2s;
  }

  .bcard-cta:hover { background: var(--terracotta); }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .bath-inner { grid-template-columns: 1fr; gap: 3rem; }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .bath-ctas { flex-direction: column; }
    .bath-ctas .btn-primary,
    .bath-ctas .btn-ghost { text-align: center; justify-content: center; }
  }
</style>
