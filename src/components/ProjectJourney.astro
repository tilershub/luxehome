---
const steps = [
  {
    num: '01',
    label: 'Old Space',
    desc: 'We document the existing space before any work begins — raw, honest, and real.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    num: '02',
    label: '3D Design',
    desc: 'Every project is visualised in 3D before construction begins — so you can see exactly what you\'re getting.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
  },
  {
    num: '03',
    label: 'Construction',
    desc: 'Our team executes with precision. Progress is photographed and shared at every stage.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    num: '04',
    label: 'Final Reveal',
    desc: 'The completed transformation — photographed, toured, and handed over to a delighted client.',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  },
];
---

<section class="journey-section">
  <div class="journey-inner">

    <div class="journey-head reveal">
      <div class="stag">The LUXEhome Story</div>
      <h2>Every Project Is a<br /><em>Transformation Story</em></h2>
      <p class="sdesc">We document every renovation from the empty space to the completed reveal — so you can follow the full journey, not just see the finished result.</p>
    </div>

    <div class="steps-row">
      {steps.map((s, i) => (
        <div class="journey-step reveal">
          <div class="step-num">{s.num}</div>
          {i < steps.length - 1 && <div class="step-arrow" aria-hidden="true">→</div>}
          <div class="step-icon" aria-hidden="true" set:html={s.icon} />
          <div class="step-label">{s.label}</div>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="journey-cta reveal">
      <a href="/projects" class="btn-outline">View All Projects →</a>
    </div>

  </div>
</section>

<style>
  .journey-section {
    background: var(--off-white, #fbfbf9);
    padding: 5.5rem 4rem;
  }

  .journey-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .journey-head {
    max-width: 60ch;
    margin-bottom: 4rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--charcoal, #1e1a17);
    line-height: 1.15;
    margin-bottom: .9rem;
  }

  h2 em {
    font-style: italic;
    font-weight: 400;
    color: var(--clay, #b8892a);
  }

  .sdesc {
    font-size: .95rem;
    color: var(--warm-gray, #6f6f6f);
    line-height: 1.78;
  }

  /* ── Steps ── */
  .steps-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .journey-step {
    position: relative;
    padding: 2.5rem 2rem 2.5rem 0;
    border-right: 1px solid var(--stone, #e7e7e7);
    display: flex;
    flex-direction: column;
    gap: .9rem;
  }

  .journey-step:first-child { padding-left: 0; }
  .journey-step:not(:first-child) { padding-left: 2rem; }
  .journey-step:last-child { border-right: none; padding-right: 0; }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    font-weight: 800;
    color: rgba(184,137,42,.12);
    line-height: 1;
    letter-spacing: -.04em;
  }

  .step-arrow {
    position: absolute;
    right: -.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.1rem;
    color: rgba(184,137,42,.35);
    z-index: 1;
    background: var(--off-white, #fbfbf9);
    padding: .2rem 0;
    line-height: 1;
  }

  .step-icon {
    width: 3rem;
    height: 3rem;
    background: rgba(184,137,42,.08);
    border: 1px solid rgba(184,137,42,.18);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay, #b8892a);
    flex-shrink: 0;
  }

  .step-label {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--charcoal, #1e1a17);
    line-height: 1.25;
  }

  .step-desc {
    font-size: .82rem;
    font-weight: 300;
    color: var(--warm-gray, #6f6f6f);
    line-height: 1.78;
  }

  /* ── CTA ── */
  .journey-cta {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    color: var(--charcoal, #1e1a17);
    border: 1px solid var(--stone, #e7e7e7);
    padding: .85rem 2.2rem;
    border-radius: 3px;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 48px;
    transition: border-color .2s, color .2s;
  }

  .btn-outline:hover {
    border-color: var(--clay, #b8892a);
    color: var(--clay, #b8892a);
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .journey-section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .steps-row { grid-template-columns: repeat(2, 1fr); }
    .journey-step:nth-child(2) { border-right: none; }
    .journey-step:nth-child(n+3) { border-top: 1px solid var(--stone, #e7e7e7); padding-top: 2.5rem; }
    .journey-step:nth-child(even) { padding-right: 0; }
    .journey-step:nth-child(odd) { padding-left: 0; }
    .step-arrow { display: none; }
  }

  @media (max-width: 768px) {
    .journey-section { padding: 4rem 1.5rem; }
    .steps-row { grid-template-columns: 1fr; }
    .journey-step {
      border-right: none !important;
      border-top: 1px solid var(--stone, #e7e7e7) !important;
      padding: 1.8rem 0 !important;
    }
    .journey-step:first-child { border-top: none !important; padding-top: 0 !important; }
  }
</style>
