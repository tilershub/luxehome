---
---

<section id="projects" style="display:none">
  <div class="inner">

    <div class="section-head reveal" id="proj-head">
      <div class="stag">Featured Projects</div>
      <h2>Completed Work<br />We're Proud Of</h2>
      <p class="sdesc">Every project shown is a real completed renovation — the final result delivered to our clients.</p>
    </div>

    <div class="projects-grid" id="projects-grid">

      <!-- Cards injected by JS when real projects exist in Supabase -->

    </div>

    <div class="projects-footer reveal">
      <a href="/projects" class="btn-ghost" id="proj-cta">View All Projects →</a>
    </div>

  </div>
</section>

<script>
  import { createClient } from '@supabase/supabase-js';

  const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const CAT_LABELS = {
    bathroom: 'Luxury Bathroom Renovation',
    flooring: 'Designer Floors',
    staircase: 'Designer Staircases',
    kitchen: 'Luxury Kitchens',
  };

  const SERVICE_LINKS = {
    bathroom: '/services/bathroom',
    flooring: '/services/flooring',
    staircase: '/services/staircase-tiling',
    kitchen: '/services/kitchen',
  };

  function locationIcon() {
    return `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`;
  }

  function renderCard(p) {
    const hasBefore = p.before_images && p.before_images.length > 0;
    const hasAfter  = p.after_images  && p.after_images.length  > 0;
    const coverImg  = p.cover_image || '';
    const serviceLink = SERVICE_LINKS[p.category] || '/services/bathroom';

    let mediaHTML;
    if (hasBefore || hasAfter) {
      const beforeSrc = hasBefore ? p.before_images[0] : coverImg;
      const afterSrc  = hasAfter  ? p.after_images[0]  : coverImg;
      mediaHTML = `
        <div class="media-split">
          <div class="media-before">
            <img src="${beforeSrc}" alt="Before — ${p.title}" loading="lazy" width="700" height="520" />
            <span class="media-label">Before</span>
          </div>
          <div class="media-after">
            <img src="${afterSrc}" alt="After — ${p.title}" loading="lazy" width="700" height="520" />
            <span class="media-label after-label">After</span>
          </div>
        </div>`;
    } else if (coverImg) {
      mediaHTML = `
        <div class="media-single">
          <img src="${coverImg}" alt="${p.title}" loading="lazy" width="1400" height="520" />
        </div>`;
    } else {
      mediaHTML = `<div class="media-placeholder">🏗️</div>`;
    }

    const year = p.completion_year ? p.completion_year : '';
    const excerpt = (p.project_overview || '').slice(0, 140) + (p.project_overview?.length > 140 ? '…' : '');

    return `
      <div class="project-card reveal">
        <a href="/projects/${p.slug}" class="card-link">
          <div class="card-media">${mediaHTML}</div>
          <div class="card-body">
            <div class="card-meta">
              <span class="meta-pill">${locationIcon()}${p.location}</span>
              ${year ? `<span class="meta-pill">${year}</span>` : ''}
            </div>
            <h3>${p.title}</h3>
            ${excerpt ? `<p>${excerpt}</p>` : ''}
            <div class="card-type">${CAT_LABELS[p.category] || p.category}</div>
            <span class="card-btn">View Project →</span>
          </div>
        </a>
      </div>`;
  }

  async function loadFeaturedProjects() {
    if (!SB_URL || !SB_KEY) return;
    try {
      const sb = createClient(SB_URL, SB_KEY);
      const { data, error } = await sb
        .from('projects')
        .select('slug,title,category,location,completion_year,cover_image,before_images,after_images,project_overview')
        .eq('status', 'featured')
        .order('completion_year', { ascending: false })
        .limit(3);

      if (error || !data || data.length === 0) return;

      const grid = document.getElementById('projects-grid');
      const section = document.getElementById('projects');
      if (!grid || !section) return;

      grid.innerHTML = data.map(renderCard).join('');
      section.style.display = '';
    } catch {
      // Silently fall back to static cards on any error
    }
  }

  document.addEventListener('DOMContentLoaded', loadFeaturedProjects);
</script>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    max-width: 52ch;
    margin-bottom: 3.5rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.78);
    line-height: 1.72;
  }

  /* ── Grid ── */

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Card ── */

  .project-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .3s ease, box-shadow .3s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 48px rgba(0,0,0,.4);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  /* ── Before/After split ── */

  .card-media {
    position: relative;
    overflow: hidden;
  }

  .media-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 240px;
    gap: 1.5px;
    background: rgba(255,255,255,.08);
  }

  .media-before,
  .media-after {
    position: relative;
    overflow: hidden;
  }

  .media-before img,
  .media-after img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }

  .media-before img {
    filter: brightness(.75) saturate(.65);
  }

  .media-after img {
    filter: brightness(.88) saturate(.95);
  }

  .media-single {
    height: 240px;
    overflow: hidden;
  }

  .media-single img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(.85) saturate(.9);
    transition: transform .5s ease;
  }

  .media-placeholder {
    height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    background: rgba(255,255,255,.04);
    opacity: .5;
  }

  .project-card:hover .media-before img,
  .project-card:hover .media-after img,
  .project-card:hover .media-single img {
    transform: scale(1.05);
  }

  .media-label {
    position: absolute;
    bottom: .7rem;
    left: .7rem;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    background: rgba(30,26,23,.82);
    color: rgba(240,236,224,.88);
    padding: .22rem .6rem;
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .after-label {
    background: rgba(184,148,90,.88);
    color: #fff;
    left: auto;
    right: .7rem;
  }

  /* ── Card body ── */

  .card-body {
    padding: 1.6rem 1.5rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    font-size: .66rem;
    font-weight: 500;
    letter-spacing: .06em;
    color: rgba(240,236,224,.68);
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    padding: .2rem .6rem;
    border-radius: 20px;
  }

  .meta-pill svg {
    flex-shrink: 0;
    opacity: .7;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.25;
  }

  p {
    font-size: .82rem;
    font-weight: 300;
    color: rgba(240,236,224,.72);
    line-height: 1.75;
    flex: 1;
  }

  .card-type {
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(184,148,90,.7);
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: .7rem;
  }

  .card-btn {
    display: inline-flex;
    align-items: center;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--clay);
    text-decoration: none;
    transition: letter-spacing .2s;
  }

  .card-btn:hover { letter-spacing: .1em; }

  /* ── Footer CTA ── */

  .projects-footer {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    color: rgba(240,236,224,.88);
    border: 1px solid rgba(240,236,224,.28);
    padding: .82rem 2.2rem;
    border-radius: 2px;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 48px;
    transition: border-color .2s, color .2s;
  }

  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .projects-grid { grid-template-columns: 1fr; }
    .media-split { height: 200px; }
    .media-single { height: 200px; }
  }
</style>
