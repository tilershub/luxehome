---

<section id="projects">
  <div class="inner">

    <div class="section-head reveal">
      <div class="stag">Featured Projects</div>
      <h2>Bathrooms, Floors<br />& Staircases</h2>
      <p class="sdesc">A focused look at the renovation work LUXEHOME delivers across bathrooms, flooring and staircase finishes.</p>
    </div>

    <div class="projects-grid">

      <div class="project-card reveal">
        <div class="card-media">
          <div class="media-split">
            <div class="media-before">
              <img src="https://images.pexels.com/photos/6585765/pexels-photo-6585765.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="Before — Colombo 7 master ensuite" loading="lazy" width="700" height="520" />
              <span class="media-label">Before</span>
            </div>
            <div class="media-after">
              <img src="https://images.pexels.com/photos/7031571/pexels-photo-7031571.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="After — Colombo 7 master ensuite" loading="lazy" width="700" height="520" />
              <span class="media-label after-label">After</span>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Colombo 7
            </span>
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              21 Days
            </span>
          </div>
          <h3>Master Ensuite Renovation</h3>
          <p>Complete transformation of a master ensuite — freestanding bath, frameless shower, custom vanity, and large-format porcelain tiles throughout.</p>
          <div class="card-type">Luxury Bathroom Renovation</div>
          <a href="/services/bathroom" class="card-btn">View Service →</a>
        </div>
      </div>

      <div class="project-card reveal">
        <div class="card-media">
          <div class="media-split">
            <div class="media-before">
              <img src="https://images.pexels.com/photos/6920614/pexels-photo-6920614.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="Before — Nugegoda floor renovation" loading="lazy" width="700" height="520" />
              <span class="media-label">Before</span>
            </div>
            <div class="media-after">
              <img src="https://images.pexels.com/photos/7045299/pexels-photo-7045299.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="After — Nugegoda floor renovation" loading="lazy" width="700" height="520" />
              <span class="media-label after-label">After</span>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Nugegoda
            </span>
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              18 Days
            </span>
          </div>
          <h3>Open-Plan Floor Upgrade</h3>
          <p>Large-format floor tiling with careful setting out, leveling system installation, clean skirting, and consistent grout lines through the main living space.</p>
          <div class="card-type">Floor Tiling & Finishing</div>
          <a href="/services/flooring" class="card-btn">View Service →</a>
        </div>
      </div>

      <div class="project-card reveal">
        <div class="card-media">
          <div class="media-split">
            <div class="media-before">
              <img src="https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="Before — Battaramulla staircase" loading="lazy" width="700" height="520" />
              <span class="media-label">Before</span>
            </div>
            <div class="media-after">
              <img src="https://images.pexels.com/photos/6538892/pexels-photo-6538892.jpeg?auto=compress&cs=tinysrgb&w=700&h=520&fit=crop" alt="After — Battaramulla staircase" loading="lazy" width="700" height="520" />
              <span class="media-label after-label">After</span>
            </div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Battaramulla
            </span>
            <span class="meta-pill">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              14 Days
            </span>
          </div>
          <h3>Staircase Finish Upgrade</h3>
          <p>A sharper staircase finish with coordinated tread and riser tiles, refined nosing details, side elevation work, and durable skirting.</p>
          <div class="card-type">Staircase Tiling</div>
          <a href="/services/staircase-tiling" class="card-btn">View Service →</a>
        </div>
      </div>

    </div>

    <div class="projects-footer reveal">
      <a href="/contact" class="btn-ghost">Discuss Your Project →</a>
    </div>

  </div>
</section>

<style>
  section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
  }

  .inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-head {
    max-width: 52ch;
    margin-bottom: 3.5rem;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.15;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.78);
    line-height: 1.72;
  }

  /* ── Grid ── */

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── Card ── */

  .project-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .3s ease, box-shadow .3s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 48px rgba(0,0,0,.4);
  }

  /* ── Before/After split ── */

  .card-media {
    position: relative;
    overflow: hidden;
  }

  .media-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 240px;
    gap: 1.5px;
    background: rgba(255,255,255,.08);
  }

  .media-before,
  .media-after {
    position: relative;
    overflow: hidden;
  }

  .media-before img,
  .media-after img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }

  .media-before img {
    filter: brightness(.55) saturate(.4) sepia(.2);
  }

  .media-after img {
    filter: brightness(.7) saturate(.85);
  }

  .project-card:hover .media-before img,
  .project-card:hover .media-after img {
    transform: scale(1.05);
  }

  .media-label {
    position: absolute;
    bottom: .7rem;
    left: .7rem;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    background: rgba(30,26,23,.82);
    color: rgba(240,236,224,.88);
    padding: .22rem .6rem;
    border-radius: 2px;
    backdrop-filter: blur(4px);
  }

  .after-label {
    background: rgba(184,148,90,.88);
    color: #fff;
    left: auto;
    right: .7rem;
  }

  /* ── Card body ── */

  .card-body {
    padding: 1.6rem 1.5rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    font-size: .66rem;
    font-weight: 500;
    letter-spacing: .06em;
    color: rgba(240,236,224,.68);
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.08);
    padding: .2rem .6rem;
    border-radius: 20px;
  }

  .meta-pill svg {
    flex-shrink: 0;
    opacity: .7;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.25;
  }

  p {
    font-size: .82rem;
    font-weight: 300;
    color: rgba(240,236,224,.72);
    line-height: 1.75;
    flex: 1;
  }

  .card-type {
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: rgba(184,148,90,.7);
    border-top: 1px solid rgba(255,255,255,.06);
    padding-top: .7rem;
  }

  .card-btn {
    display: inline-flex;
    align-items: center;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--clay);
    text-decoration: none;
    transition: letter-spacing .2s;
  }

  .card-btn:hover { letter-spacing: .1em; }

  /* ── Footer CTA ── */

  .projects-footer {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    color: rgba(240,236,224,.88);
    border: 1px solid rgba(240,236,224,.28);
    padding: .82rem 2.2rem;
    border-radius: 2px;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 48px;
    transition: border-color .2s, color .2s;
  }

  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    section { padding: 4rem 1.5rem; }
    .projects-grid { grid-template-columns: 1fr; }
    .media-split { height: 200px; }
  }
</style>
