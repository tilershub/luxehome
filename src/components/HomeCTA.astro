<style>
  .home-cta-section {
    background: var(--charcoal, #1e1a17);
    padding: 6rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,.06);
  }

  .home-cta-section::before {
    content: '';
    position: absolute;
    top: -8rem;
    left: 50%;
    transform: translateX(-50%);
    width: 60rem;
    height: 60rem;
    background: radial-gradient(circle, rgba(184,137,42,.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .home-cta-inner {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .9rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--cream, #f0ece0);
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .cta-desc {
    font-size: .95rem;
    font-weight: 300;
    color: rgba(240,236,224,.72);
    line-height: 1.82;
    margin-bottom: 2.2rem;
  }

  .cta-btns {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--clay, #b8892a);
    color: #fff;
    padding: .95rem 2.2rem;
    border-radius: 3px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 52px;
    transition: background .2s, transform .2s;
  }

  .btn-primary:hover { background: #9a7222; transform: translateY(-2px); }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    background: rgba(37,211,102,.12);
    color: #25d366;
    border: 1px solid rgba(37,211,102,.3);
    padding: .95rem 2.2rem;
    border-radius: 3px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-decoration: none;
    min-height: 52px;
    transition: background .2s, border-color .2s;
  }

  .btn-wa:hover { background: rgba(37,211,102,.2); border-color: rgba(37,211,102,.5); }

  .cta-note {
    font-size: .74rem;
    color: rgba(240,236,224,.4);
    letter-spacing: .04em;
  }

  @media (max-width: 1100px) {
    .home-cta-section { padding-left: 2.5rem; padding-right: 2.5rem; }
  }

  @media (max-width: 768px) {
    .home-cta-section { padding: 4rem 1.5rem; }
    .cta-btns { flex-direction: column; align-items: stretch; }
    .btn-primary, .btn-wa { justify-content: center; }
  }
</style>
