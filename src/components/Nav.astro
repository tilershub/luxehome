---
---

<nav aria-label="Main navigation">
  <a href="/" class="logo" aria-label="LUXEHOME — Home">LUXE<em>home</em></a>

  <ul id="nav-menu" role="list">
    <li><a href="/services/flooring">Flooring</a></li>
    <li><a href="/services/bathroom">Bathroom</a></li>
    <li><a href="/services/kitchen">Kitchen</a></li>
    <li><a href="/blog">Journal</a></li>
  </ul>

  <div class="nav-end">
    <a href="/contact" class="nav-cta">Book Now</a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</nav>

<script>
  const nav    = document.querySelector('nav');
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('nav-menu');

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 60;
    nav.style.padding = scrolled
      ? (window.innerWidth > 1100 ? '.75rem 4rem' : '.75rem 2.5rem')
      : '';
    nav.style.boxShadow = scrolled ? '0 1px 24px rgba(30,26,23,.08)' : '';
  });

  function closeMenu() {
    menu.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    toggle.classList.remove('active');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    toggle.classList.toggle('active', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target) && menu.classList.contains('open')) {
      closeMenu();
    }
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 4rem;
    padding-left: max(4rem, env(safe-area-inset-left));
    padding-right: max(4rem, env(safe-area-inset-right));
    background: rgba(250, 247, 242, .94);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(212, 196, 176, .45);
    transition: padding .3s ease, box-shadow .3s ease;
  }

  ul {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }

  ul a {
    text-decoration: none;
    font-size: .74rem;
    font-weight: 500;
    letter-spacing: .11em;
    text-transform: uppercase;
    color: var(--warm-gray);
    transition: color .2s;
    position: relative;
    padding-bottom: .2rem;
  }

  ul a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .28s ease;
  }

  ul a:hover { color: var(--charcoal); }
  ul a:hover::after { transform: scaleX(1); }

  .nav-end {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .nav-cta {
    background: var(--charcoal);
    color: var(--cream) !important;
    text-decoration: none;
    font-size: .74rem;
    font-weight: 600;
    letter-spacing: .09em;
    text-transform: uppercase;
    padding: .58rem 1.3rem;
    border-radius: 2px;
    transition: background .2s;
    white-space: nowrap;
  }

  .nav-cta:hover { background: var(--clay) !important; }
  .nav-cta::after { display: none !important; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: .25rem;
    border-radius: 3px;
    transition: background .2s;
    margin-left: .3rem;
  }

  .menu-toggle:hover { background: rgba(61, 79, 66, .1); }

  .bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--charcoal);
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
    transform-origin: center;
  }

  .menu-toggle.active .bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-toggle.active .bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 1100px) {
    nav { padding: 1rem 2.5rem; }
  }

  @media (max-width: 768px) {
    nav {
      padding: 1rem 1.5rem;
      padding-left: max(1.5rem, env(safe-area-inset-left));
      padding-right: max(1.5rem, env(safe-area-inset-right));
    }
    .menu-toggle { display: flex; }

    ul {
      display: none;
      position: absolute;
      top: 100%; left: 0; right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(250, 247, 242, .98);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--stone);
      box-shadow: 0 8px 24px rgba(30, 40, 32, .1);
      padding: .25rem 0;
      padding-bottom: max(.25rem, env(safe-area-inset-bottom));
    }

    ul.open { display: flex; }

    ul a {
      display: block;
      padding: .9rem 1.5rem;
      min-height: 44px;
      display: flex;
      align-items: center;
      font-size: .8rem;
      border-bottom: 1px solid rgba(212, 196, 176, .25);
    }

    ul a::after { display: none; }
    ul li:last-child a { border-bottom: none; }

    .nav-cta {
      padding: .5rem 1rem;
      font-size: .7rem;
      min-height: 36px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>
