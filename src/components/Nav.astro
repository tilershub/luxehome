---
---

<nav aria-label="Main navigation">
  <a href="/" class="logo" aria-label="LUXEHOME — Home">LUXE<em>home</em></a>

  <ul id="nav-menu" role="list">
    <li><a href="/services/bathroom">Bathroom</a></li>

    <li class="has-dropdown">
      <a href="/services/flooring" class="nav-parent">
        Floor
        <svg class="chevron" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <ul class="dropdown" role="list">
        <li><a href="/services/floor-tiling">Tiling</a></li>
      </ul>
    </li>

    <li><a href="/services/staircase-tiling">Staircase</a></li>

    <li class="has-dropdown">
      <a href="/services/kitchen" class="nav-parent">
        Kitchen
        <svg class="chevron" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <ul class="dropdown" role="list">
        <li><a href="/services/kitchen-pantry">Pantry</a></li>
      </ul>
    </li>

    <li><a href="/blog">Journal</a></li>
  </ul>

  <div class="nav-end">
    <a href="/contact" class="nav-cta">Book Now</a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="nav-menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>
</nav>

<script>
  const nav    = document.querySelector('nav');
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('nav-menu');

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 60;
    nav.style.padding = scrolled
      ? (window.innerWidth > 1100 ? '.75rem 4rem' : '.75rem 2.5rem')
      : '';
    nav.style.boxShadow = scrolled ? '0 1px 24px rgba(30,40,32,.08)' : '';
  });

  function closeMenu() {
    menu.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    toggle.classList.remove('active');
    document.body.style.overflow = '';
    // Close all dropdowns
    menu.querySelectorAll('.has-dropdown.open').forEach(li => li.classList.remove('open'));
  }

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    toggle.classList.toggle('active', isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  // Mobile: tap parent link toggles dropdown instead of navigating
  menu.querySelectorAll('.has-dropdown > .nav-parent').forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        const li = link.closest('.has-dropdown');
        const wasOpen = li.classList.contains('open');
        menu.querySelectorAll('.has-dropdown.open').forEach(el => el.classList.remove('open'));
        if (!wasOpen) li.classList.add('open');
      }
    });
  });

  // Close menu on any sub-link click
  menu.querySelectorAll('a').forEach(link => {
    if (!link.classList.contains('nav-parent')) {
      link.addEventListener('click', closeMenu);
    }
  });

  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target) && menu.classList.contains('open')) {
      closeMenu();
    }
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 4rem;
    padding-left: max(4rem, env(safe-area-inset-left));
    padding-right: max(4rem, env(safe-area-inset-right));
    background: rgba(250, 248, 243, .94);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(207, 201, 188, .5);
    transition: padding .3s ease, box-shadow .3s ease;
  }

  ul {
    display: flex;
    gap: 2.4rem;
    list-style: none;
  }

  ul a {
    text-decoration: none;
    font-size: .74rem;
    font-weight: 500;
    letter-spacing: .11em;
    text-transform: uppercase;
    color: var(--warm-gray);
    transition: color .2s;
    position: relative;
    padding-bottom: .2rem;
  }

  ul a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5px;
    background: var(--clay);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .28s ease;
  }

  ul a:hover { color: var(--charcoal); }
  ul a:hover::after { transform: scaleX(1); }

  /* ── Dropdown parent ── */
  .has-dropdown { position: relative; }

  .nav-parent {
    display: flex;
    align-items: center;
    gap: .28rem;
    cursor: pointer;
  }

  .chevron {
    width: .55rem;
    height: .55rem;
    transition: transform .22s ease;
    flex-shrink: 0;
    margin-top: .05em;
  }

  .has-dropdown:hover .chevron,
  .has-dropdown.open .chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown panel (desktop) ── */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + .75rem);
    left: 50%;
    transform: translateX(-50%);
    flex-direction: column;
    gap: 0;
    min-width: 9rem;
    background: var(--off-white);
    border: 1px solid var(--stone);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(30, 40, 32, .12);
    padding: .4rem 0;
    z-index: 200;
  }

  .has-dropdown:hover .dropdown {
    display: flex;
  }

  .dropdown li { list-style: none; }

  .dropdown a {
    display: block;
    padding: .55rem 1.1rem;
    white-space: nowrap;
    letter-spacing: .09em;
    font-size: .72rem;
    border-bottom: none;
  }

  .dropdown a::after { display: none; }

  .dropdown a:hover {
    background: rgba(61, 79, 66, .06);
    color: var(--forest);
  }

  /* ── Nav end ── */
  .nav-end {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .nav-cta {
    background: var(--charcoal);
    color: var(--cream) !important;
    text-decoration: none;
    font-size: .74rem;
    font-weight: 600;
    letter-spacing: .09em;
    text-transform: uppercase;
    padding: .58rem 1.3rem;
    border-radius: 2px;
    transition: background .2s;
    white-space: nowrap;
  }

  .nav-cta:hover { background: var(--clay) !important; }
  .nav-cta::after { display: none !important; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: .25rem;
    border-radius: 3px;
    transition: background .2s;
    margin-left: .3rem;
  }

  .menu-toggle:hover { background: rgba(61, 79, 66, .1); }

  .bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--charcoal);
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
    transform-origin: center;
  }

  .menu-toggle.active .bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle.active .bar:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-toggle.active .bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 1100px) {
    nav { padding: 1rem 2.5rem; }
  }

  @media (max-width: 768px) {
    nav {
      padding: 1rem 1.5rem;
      padding-left: max(1.5rem, env(safe-area-inset-left));
      padding-right: max(1.5rem, env(safe-area-inset-right));
    }
    .menu-toggle { display: flex; }

    ul {
      display: none;
      position: absolute;
      top: 100%; left: 0; right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(250, 248, 243, .98);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--stone);
      box-shadow: 0 8px 24px rgba(30, 40, 32, .1);
      padding: .25rem 0;
      padding-bottom: max(.25rem, env(safe-area-inset-bottom));
    }

    ul.open { display: flex; }

    ul > li > a,
    ul > li > .nav-parent {
      display: flex;
      align-items: center;
      padding: .9rem 1.5rem;
      min-height: 44px;
      font-size: .8rem;
      border-bottom: 1px solid rgba(207, 201, 188, .25);
    }

    ul > li:last-child > a { border-bottom: none; }

    ul a::after { display: none; }

    /* Mobile dropdown — inline sub-items */
    .dropdown {
      display: none;
      position: static;
      transform: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      background: rgba(61, 79, 66, .05);
      padding: 0;
      min-width: unset;
      flex-direction: column;
    }

    .has-dropdown.open .dropdown { display: flex; }

    .dropdown a {
      padding: .75rem 1.5rem .75rem 2.2rem;
      min-height: 40px;
      font-size: .76rem;
      border-bottom: 1px solid rgba(207, 201, 188, .2);
      color: var(--forest);
    }

    .dropdown a:hover { background: none; }

    .nav-cta {
      padding: .5rem 1rem;
      font-size: .7rem;
      min-height: 36px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>
