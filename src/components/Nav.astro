---
---

<nav aria-label="Main navigation">
  <a href="/" class="logo" aria-label="TILERSHUB — Home">TILERS<span>HUB</span></a>
  <ul id="nav-menu" role="list">
    <li><a href="/#services">Services</a></li>
    <li><a href="/#materials">Materials</a></li>
    <li><a href="/services/bathroom">Bathroom</a></li>
    <li><a href="/blog">Blog</a></li>
    <li>
      <a
        href="/contact"
        class="nav-cta"
      >Get a Quote</a>
    </li>
  </ul>
  <button
    class="menu-toggle"
    id="menu-toggle"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="nav-menu"
  >
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
</nav>

<script>
  const nav = document.querySelector('nav');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('nav-menu');

  // Shrink nav on scroll
  window.addEventListener('scroll', () => {
    nav.style.padding = window.scrollY > 60 ? '.8rem 4rem' : '1.2rem 4rem';
  });

  // Mobile menu toggle
  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    toggle.classList.toggle('active', isOpen);
  });

  // Close menu on link click
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
      toggle.classList.remove('active');
    });
  });

  // Close menu on outside click
  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target) && menu.classList.contains('open')) {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
      toggle.classList.remove('active');
    }
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 4rem;
    background: rgba(245, 240, 232, .93);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--stone);
    transition: padding .3s;
  }

  ul {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  ul a {
    text-decoration: none;
    font-size: .78rem;
    font-weight: 500;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--warm-gray);
    transition: color .2s;
  }

  ul a:hover {
    color: var(--clay);
  }

  .nav-cta {
    background: var(--charcoal) !important;
    color: var(--cream) !important;
    padding: .5rem 1.2rem;
    border-radius: 2px;
  }

  .nav-cta:hover {
    background: var(--clay) !important;
  }

  /* ── Hamburger button ── */

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: .25rem;
    border-radius: 3px;
    transition: background .2s;
  }

  .menu-toggle:hover {
    background: rgba(196, 120, 74, .1);
  }

  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--charcoal);
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
    transform-origin: center;
  }

  .menu-toggle.active .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active .bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .menu-toggle.active .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 1100px) {
    nav {
      padding: 1rem 2.5rem;
    }
  }

  @media (max-width: 768px) {
    nav {
      padding: 1rem 1.5rem;
    }

    .menu-toggle {
      display: flex;
    }

    ul {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(245, 240, 232, .97);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--stone);
      padding: .5rem 0;
      box-shadow: 0 8px 24px rgba(30, 26, 23, .12);
    }

    ul.open {
      display: flex;
    }

    ul li {
      width: 100%;
    }

    ul a {
      display: block;
      padding: .85rem 1.5rem;
      font-size: .82rem;
      border-bottom: 1px solid rgba(196, 120, 74, .08);
    }

    ul li:last-child a {
      border-bottom: none;
    }

    .nav-cta {
      margin: .5rem 1.5rem .75rem !important;
      display: block !important;
      text-align: center !important;
      padding: .7rem 1.2rem !important;
      border-radius: 2px !important;
    }
  }
</style>
