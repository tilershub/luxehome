<script>
  const nav         = document.getElementById('main-nav');
  const toggle      = document.getElementById('menu-toggle');
  const mobilePanel = document.getElementById('mobile-panel');
  const overlay     = document.getElementById('mobile-overlay');
  const closeBtn    = document.getElementById('mobile-close');

  // Scroll effect — transparent on hero, solid after
  function updateNavStyle() {
    const scrolled = window.scrollY > 80;
    nav.classList.toggle('nav-scrolled', scrolled);
  }
  window.addEventListener('scroll', updateNavStyle, { passive: true });
  updateNavStyle();

  // Desktop: services dropdown via button
  const svcToggle = document.querySelector('.has-dropdown .nav-parent');
  const svcDropdown = document.getElementById('services-dropdown');
  const hasDropdown = document.querySelector('.has-dropdown');

  if (svcToggle && svcDropdown) {
    // Show on hover (desktop)
    hasDropdown.addEventListener('mouseenter', () => {
      if (window.innerWidth > 900) svcDropdown.classList.add('open');
    });
    hasDropdown.addEventListener('mouseleave', () => {
      if (window.innerWidth > 900) svcDropdown.classList.remove('open');
    });
    // Also toggle on button click
    svcToggle.addEventListener('click', () => {
      const isOpen = svcDropdown.classList.toggle('open');
      svcToggle.setAttribute('aria-expanded', String(isOpen));
    });
  }

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!hasDropdown?.contains(e.target)) {
      svcDropdown?.classList.remove('open');
      svcToggle?.setAttribute('aria-expanded', 'false');
    }
  });

  // Mobile panel
  function openMobileMenu() {
    mobilePanel.classList.add('open');
    overlay.classList.add('open');
    mobilePanel.setAttribute('aria-hidden', 'false');
    overlay.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
    document.body.style.overflow = 'hidden';
  }

  window.closeMobileMenu = function () {
    mobilePanel.classList.remove('open');
    overlay.classList.remove('open');
    mobilePanel.setAttribute('aria-hidden', 'true');
    overlay.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    document.body.style.overflow = '';
  };

  toggle.addEventListener('click', openMobileMenu);
  closeBtn.addEventListener('click', closeMobileMenu);
  overlay.addEventListener('click', closeMobileMenu);

  // Mobile services accordion
  const mobSvcToggle = document.getElementById('mob-svc-toggle');
  const mobSvcSub    = document.getElementById('mob-svc-sub');
  mobSvcToggle?.addEventListener('click', () => {
    const isOpen = mobSvcSub.classList.toggle('open');
    mobSvcToggle.setAttribute('aria-expanded', String(isOpen));
    mobSvcToggle.classList.toggle('expanded', isOpen);
  });

  // Close on mobile link click
  document.querySelectorAll('.mob-link:not(.mob-expand), .mob-sub-link, .mob-cta, .mob-wa').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 4rem;
    background: transparent;
    transition: background .3s ease, padding .3s ease, backdrop-filter .3s ease;
  }

  nav.nav-scrolled {
    background: rgba(17,17,17,.96);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: .85rem 4rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .logo {
    font-size: .95rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--cream, #f0ece0);
    flex-shrink: 0;
    transition: opacity .2s;
  }
  .logo em { font-style: normal; color: var(--clay, #b8892a); }
  .logo:hover { opacity: .8; }

  /* ── Desktop menu ── */
  #nav-menu {
    display: flex;
    align-items: center;
    gap: .1rem;
    list-style: none;
    margin: 0 auto;
    padding: 0 2rem;
  }

  #nav-menu > li { position: relative; }

  #nav-menu > li > a,
  #nav-menu > li > .nav-parent {
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(240,236,224,.8);
    transition: color .2s;
    padding: .6rem .85rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: .28rem;
    white-space: nowrap;
  }

  #nav-menu > li > a:hover,
  #nav-menu > li > .nav-parent:hover {
    color: var(--cream, #f0ece0);
    background: rgba(255,255,255,.07);
  }

  .chevron {
    width: .5rem;
    height: .5rem;
    transition: transform .22s ease;
    flex-shrink: 0;
  }

  .has-dropdown:hover .chevron,
  .dropdown.open ~ button .chevron { transform: rotate(180deg); }

  /* ── Services Dropdown ── */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + .6rem);
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    background: #1a1714;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 12px;
    box-shadow: 0 32px 80px rgba(0,0,0,.55);
    padding: .5rem;
    z-index: 300;
    animation: dropIn .18s ease;
  }

  .dropdown.open { display: block; }

  @keyframes dropIn {
    from { opacity: 0; transform: translateX(-50%) translateY(-6px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  .drop-item {
    display: flex;
    align-items: center;
    gap: .9rem;
    padding: .85rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background .18s;
  }

  .drop-item:hover { background: rgba(255,255,255,.06); }

  .drop-icon {
    width: 2.4rem;
    height: 2.4rem;
    background: rgba(184,137,42,.12);
    border: 1px solid rgba(184,137,42,.2);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clay, #b8892a);
    flex-shrink: 0;
  }

  .drop-text {
    display: flex;
    flex-direction: column;
    gap: .15rem;
  }

  .drop-text strong {
    font-size: .8rem;
    font-weight: 600;
    color: rgba(240,236,224,.95);
    line-height: 1.2;
  }

  .drop-text span {
    font-size: .72rem;
    color: rgba(240,236,224,.5);
    line-height: 1.3;
  }

  /* ── Nav end ── */
  .nav-end {
    display: flex;
    align-items: center;
    gap: .75rem;
    flex-shrink: 0;
  }

  .nav-cta {
    background: var(--clay, #b8892a);
    color: #fff;
    text-decoration: none;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .7rem 1.35rem;
    border-radius: 3px;
    transition: background .2s, transform .2s;
    white-space: nowrap;
  }

  .nav-cta:hover { background: #9a7222; transform: translateY(-1px); }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: .25rem;
    border-radius: 4px;
  }

  .bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: rgba(240,236,224,.88);
    border-radius: 2px;
    transition: transform .3s, opacity .3s;
    transform-origin: center;
  }

  /* ── Mobile overlay + panel ── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.6);
    z-index: 300;
    backdrop-filter: blur(3px);
  }
  .mobile-overlay.open { display: block; }

  .mobile-panel {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(340px, 90vw);
    background: #111;
    z-index: 400;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform .32s cubic-bezier(.4,0,.2,1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mobile-panel.open { transform: translateX(0); }

  .mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  .mobile-close {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(240,236,224,.7);
    padding: .3rem;
    border-radius: 4px;
    transition: color .2s;
  }
  .mobile-close:hover { color: #fff; }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: .75rem 0;
    flex: 1;
  }

  .mob-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .9rem 1.5rem;
    font-size: .84rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.82);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: 'DM Sans', sans-serif;
    border-bottom: 1px solid rgba(255,255,255,.05);
    transition: color .2s, background .2s;
    min-height: 52px;
  }

  .mob-link:hover { color: #fff; background: rgba(255,255,255,.04); }

  .mob-chevron {
    width: .5rem;
    height: .5rem;
    transition: transform .22s;
  }

  .mob-expand.expanded .mob-chevron { transform: rotate(180deg); }

  .mob-sub {
    display: none;
    flex-direction: column;
    background: rgba(255,255,255,.03);
    border-bottom: 1px solid rgba(255,255,255,.05);
  }

  .mob-sub.open { display: flex; }

  .mob-sub-link {
    padding: .75rem 1.5rem .75rem 2.2rem;
    font-size: .8rem;
    color: rgba(240,236,224,.65);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.04);
    transition: color .2s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .mob-sub-link:hover { color: var(--clay, #b8892a); }

  .mobile-footer {
    padding: 1.5rem;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .mob-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clay, #b8892a);
    color: #fff;
    padding: .95rem;
    border-radius: 3px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 50px;
    transition: background .2s;
  }
  .mob-cta:hover { background: #9a7222; }

  .mob-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6rem;
    background: rgba(37,211,102,.12);
    border: 1px solid rgba(37,211,102,.3);
    color: #25d366;
    padding: .85rem;
    border-radius: 3px;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-decoration: none;
    min-height: 48px;
    transition: background .2s;
  }
  .mob-wa:hover { background: rgba(37,211,102,.2); }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    nav { padding: 1rem 2.5rem; }
    nav.nav-scrolled { padding: .8rem 2.5rem; }
    #nav-menu { padding: 0 1rem; gap: 0; }
    #nav-menu > li > a,
    #nav-menu > li > .nav-parent { padding: .55rem .65rem; font-size: .68rem; }
  }

  @media (max-width: 900px) {
    #nav-menu { display: none; }
    .menu-toggle { display: flex; }
    nav { padding: 1rem 1.5rem; }
    nav.nav-scrolled { padding: .8rem 1.5rem; }
    .nav-cta { display: none; }
  }

  @media print { nav { display: none; } }
</style>
