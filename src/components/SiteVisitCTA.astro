---
const { service = 'your project' } = Astro.props;
---

<section class="svc-cta-section">
  <div class="svc-cta-inner">
    <div class="svc-tag">First Step</div>
    <h2>Start with a Professional Site Assessment</h2>
    <p class="svc-desc">
      We visit your space, take precise measurements, and deliver a detailed custom quotation
      within 48 hours. Every quote is tailored to your exact project — no guesswork, no surprises.
    </p>

    <ul class="svc-includes">
      <li>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="rgba(184,137,42,.15)"/><path d="M4.5 8L7 10.5L11.5 6" stroke="#b8892a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        On-site measurement &amp; full assessment
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="rgba(184,137,42,.15)"/><path d="M4.5 8L7 10.5L11.5 6" stroke="#b8892a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Material &amp; finish recommendations
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="rgba(184,137,42,.15)"/><path d="M4.5 8L7 10.5L11.5 6" stroke="#b8892a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Detailed written quotation
      </li>
      <li>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="rgba(184,137,42,.15)"/><path d="M4.5 8L7 10.5L11.5 6" stroke="#b8892a" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        No obligation to proceed
      </li>
    </ul>

    <div class="svc-fee">
      Site visit fee: <strong>Rs. 10,000</strong>
    </div>

    <div class="svc-btns">
      <a href="/contact" class="btn-primary">Book a Site Visit →</a>
      <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
    </div>
  </div>
</section>

<style>
  .svc-cta-section {
    background: var(--charcoal, #1e1a17);
    border-top: 1px solid rgba(184,137,42,.18);
    padding: 5rem 4rem;
  }

  .svc-cta-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .svc-tag {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay, #b8892a);
    margin-bottom: .8rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream, #f0ece0);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .svc-desc {
    font-size: .97rem;
    color: rgba(240,236,224,.80);
    line-height: 1.75;
    max-width: 55ch;
    margin: 0 auto 2rem;
  }

  .svc-includes {
    list-style: none;
    padding: 0;
    margin: 0 auto 1.8rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .7rem 1.5rem;
    max-width: 480px;
    text-align: left;
  }

  .svc-includes li {
    display: flex;
    align-items: center;
    gap: .55rem;
    font-size: .86rem;
    color: rgba(240,236,224,.85);
  }

  .svc-includes svg { flex-shrink: 0; }

  .svc-fee {
    font-size: .88rem;
    color: rgba(240,236,224,.65);
    margin-bottom: 2rem;
    letter-spacing: .02em;
  }

  .svc-fee strong {
    color: var(--clay, #b8892a);
    font-weight: 700;
    font-size: 1rem;
  }

  .svc-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--clay, #b8892a);
    color: #fff;
    padding: .8rem 1.8rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #9a7222; transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream, #f0ece0);
    padding: .8rem 1.8rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.3);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay, #b8892a); color: var(--clay, #b8892a); }

  @media (max-width: 768px) {
    .svc-cta-section { padding: 4rem 1.5rem; }
    .svc-includes { grid-template-columns: 1fr; }
    .svc-btns { flex-direction: column; align-items: center; }
  }
</style>
