---
---

<section id="cta">
  <div>
    <h2>Ready to Transform<br />Your Space?</h2>
    <p class="cta-sub">Build your quote online and pay 10% advance to lock in your booking — instantly.</p>
    <p class="cta-form-link">Prefer to talk? <a href="https://wa.me/94774503744?text=Hello%20LUXEhome%2C%20I%20would%20like%20a%20free%20site%20visit." target="_blank" rel="noopener noreferrer">WhatsApp us →</a></p>
  </div>
  <div class="cta-btns">
    <a href="/contact" class="btn-light">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
      Get a Price &amp; Book Online
    </a>
    <a href="tel:+94774503744" class="btn-outline">📞 0774 503 744</a>
  </div>
</section>

<style>
  section {
    background: var(--clay);
    padding: 5rem 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    position: relative;
    overflow: hidden;
  }

  /* Decorative background text */
  section::before {
    content: 'TH';
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Playfair Display', serif;
    font-size: 16rem;
    font-weight: 900;
    color: rgba(255, 255, 255, .055);
    line-height: 1;
    pointer-events: none;
  }

  h2 {
    color: var(--charcoal);
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    margin-bottom: .45rem;
  }

  .cta-sub {
    color: var(--charcoal);
    font-size: .88rem;
    font-weight: 300;
  }

  .cta-form-link {
    font-size: .78rem;
    font-weight: 300;
    color: var(--charcoal);
    margin-top: .5rem;
  }

  .cta-form-link a {
    color: var(--charcoal);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color .2s;
  }

  .cta-form-link a:hover {
    color: rgba(30, 26, 23, .65);
  }

  .cta-btns {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .btn-light {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    background: var(--charcoal);
    color: var(--cream);
    text-decoration: none;
    padding: .92rem 1.8rem;
    border-radius: 2px;
    font-size: .86rem;
    font-weight: 500;
    transition: background .2s, transform .2s;
  }

  .btn-light:hover {
    background: #2e2622;
    transform: translateY(-2px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    background: transparent;
    color: var(--charcoal);
    text-decoration: none;
    padding: .92rem 1.8rem;
    border-radius: 2px;
    border: 1.5px solid rgba(30, 26, 23, .45);
    font-size: .86rem;
    font-weight: 500;
    transition: border-color .2s;
  }

  .btn-outline:hover {
    border-color: var(--charcoal);
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section {
      flex-direction: column;
      align-items: flex-start;
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 4rem 1.5rem;
    }

    .cta-btns {
      flex-direction: column;
      width: 100%;
    }

    .btn-light,
    .btn-outline {
      justify-content: center;
    }
  }
</style>
