---
---

<section id="materials">

  <!-- Left: real tile photo with grid overlay -->
  <div class="mat-visual reveal">
    <div class="mat-photo-wrap">
      <img
        class="mat-photo"
        src="https://images.pexels.com/photos/1080721/pexels-photo-1080721.jpeg?auto=compress&cs=tinysrgb&w=800&h=800&fit=crop"
        alt="Premium tiling materials and craftsmanship"
        loading="lazy"
        width="800"
        height="800"
      />
      <!-- Tile grid overlay — matches brand aesthetic -->
      <div class="mat-grid" aria-hidden="true"></div>
    </div>
    <div class="grade-badge"><strong>5★</strong>Grade<br />Materials<br />Only</div>
  </div>

  <!-- Right: text + material list -->
  <div>
    <div class="stag reveal">What Goes In</div>
    <h2 class="reveal">Only the Best<br />Materials, Always</h2>
    <p class="sdesc reveal" style="margin-bottom: 1.8rem;">
      We never cut corners on what goes behind the tile. Every project uses
      industry-leading products for bonds that last decades.
    </p>
    <div class="mat-list reveal">
      <div class="mat-item">River Sand — Clean washed aggregate for strong mortar beds</div>
      <div class="mat-item">Tokyo Cement — High-strength OPC for durable base work</div>
      <div class="mat-item">Tokyo Super Tile Adhesive — Enhanced bonding for all tile types</div>
      <div class="mat-item">Tile Leveling System — Perfect flatness, zero lippage</div>
      <div class="mat-item">Swisstek Grout — Stain-resistant, colour-consistent joints</div>
    </div>
  </div>

</section>

<style>
  section {
    background: var(--cream);
    padding: 5.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── Photo visual ── */

  .mat-visual {
    position: relative;
  }

  .mat-photo-wrap {
    position: relative;
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 24px 56px rgba(30, 26, 23, .18);
  }

  .mat-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.88) saturate(.8);
    transition: transform .6s ease;
  }

  .mat-visual:hover .mat-photo {
    transform: scale(1.03);
  }

  /* Tile grid overlay — evokes large-format tile installation */
  .mat-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(245, 240, 232, .18) 3px, transparent 3px),
      linear-gradient(90deg, rgba(245, 240, 232, .18) 3px, transparent 3px);
    background-size: 33.333% 33.333%;
    pointer-events: none;
  }

  .grade-badge {
    position: absolute;
    top: -1.5rem;
    right: -1.5rem;
    background: var(--charcoal);
    color: var(--cream);
    width: 6.5rem;
    height: 6.5rem;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    font-weight: 500;
    line-height: 1.45;
  }

  .grade-badge strong {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--clay);
  }

  /* ── Material list ── */

  .mat-list {
    display: flex;
    flex-direction: column;
    gap: .62rem;
    margin-top: 1.8rem;
  }

  .mat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: .85rem 1.25rem;
    background: var(--off-white);
    border-radius: 3px;
    border-left: 3px solid var(--stone);
    font-size: .86rem;
    color: var(--charcoal);
    transition: border-color .2s, transform .2s;
  }

  .mat-item:hover {
    border-color: var(--clay);
    transform: translateX(4px);
  }

  .mat-item::before {
    content: '◆';
    font-size: .44rem;
    color: var(--clay);
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    section {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    section {
      padding: 4rem 1.5rem;
    }
  }
</style>
