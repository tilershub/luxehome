---
import '../styles/global.css';
import Cart from '../components/Cart.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'LUXEHOME — Premium Tiling & Renovation Sri Lanka',
  description = 'Sri Lanka\'s premium bathroom renovation and floor tiling specialists. Complete home transformations across Colombo, Kandy, Galle & all Sri Lanka. Trusted by Sri Lankans worldwide.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#faf7f2" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <!-- Mark JS as active before body parses so .reveal elements are hidden only when JS runs -->
    <script>document.documentElement.classList.add('js');</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="LUXEHOME" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1200" />
    <meta property="og:locale" content="en_LK" />
    <meta name="geo.region" content="LK" />
    <meta name="geo.placename" content="Sri Lanka" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "HomeAndConstructionBusiness",
            "@id": "https://luxehome.lk/#business",
            "name": "LUXEHOME",
            "alternateName": ["Luxe Home Sri Lanka", "LuxeHome Renovations"],
            "description": "Sri Lanka's premium bathroom renovation and floor tiling specialists. Trusted by Sri Lankans worldwide — complete home transformations across Colombo, Kandy, Galle, Negombo, Kurunegala and all of Sri Lanka.",
            "url": "https://luxehome.lk",
            "telephone": "+94774503744",
            "email": "luxehome@gmail.com",
            "logo": {
              "@type": "ImageObject",
              "url": "https://luxehome.lk/favicon.svg"
            },
            "image": "https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1200",
            "address": {
              "@type": "PostalAddress",
              "addressCountry": "LK",
              "addressRegion": "Western Province",
              "addressLocality": "Colombo"
            },
            "areaServed": [
              {"@type": "City", "name": "Colombo"},
              {"@type": "City", "name": "Kandy"},
              {"@type": "City", "name": "Galle"},
              {"@type": "City", "name": "Negombo"},
              {"@type": "City", "name": "Kurunegala"},
              {"@type": "City", "name": "Matara"},
              {"@type": "City", "name": "Jaffna"},
              {"@type": "Country", "name": "Sri Lanka"}
            ],
            "priceRange": "LKR 985,000 – LKR 1,570,000",
            "hasOfferCatalog": {
              "@type": "OfferCatalog",
              "name": "Home Renovation Services — Sri Lanka",
              "itemListElement": [
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": "Bathroom Renovation Sri Lanka",
                    "description": "Complete bathroom renovation packages from LKR 985,000 including waterproofing, tiling, plumbing, electrical, fixtures and free 3D design. Serving all Sri Lanka.",
                    "url": "https://luxehome.lk/services/bathroom"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": "Floor Tiling Sri Lanka",
                    "description": "Professional floor tiling across Sri Lanka from Rs. 350 per sq.ft using Swisstek grout and Tokyo cement.",
                    "url": "https://luxehome.lk/services/flooring"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": "Staircase Tiling Sri Lanka",
                    "description": "Precision staircase tiling with double-nosing from Rs. 2,400 per linear ft. Serving all Sri Lanka.",
                    "url": "https://luxehome.lk/services/staircase-tiling"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": "Kitchen Renovation Sri Lanka",
                    "description": "Kitchen pantry tiling and cupboard installation across Sri Lanka.",
                    "url": "https://luxehome.lk/services/kitchen"
                  }
                }
              ]
            }
          }
        ]
      }
    </script>

    <!-- Google Analytics — loaded after page is interactive, never blocks render -->
    <script>
      window.addEventListener('load', function () {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-DLJDBQZ8N2';
        s.async = true;
        document.head.appendChild(s);
        s.onload = function () {
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', 'G-DLJDBQZ8N2');
        };
      });
    </script>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>

    <Cart />

    <!-- Scroll-reveal: activates .reveal elements as they enter the viewport.
         Elements already visible on load are activated immediately (no delay)
         so the LCP element is never held at opacity:0. -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.reveal').forEach((el) => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          // Already in viewport — make visible immediately, no JS delay
          el.classList.add('visible');
        } else {
          observer.observe(el);
        }
      });
    </script>
  </body>
</html>
