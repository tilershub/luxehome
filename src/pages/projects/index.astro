---
export const prerender = false;
import { createServerSupabase } from '../../lib/supabase';

const sb = createServerSupabase(import.meta.env as Record<string, string | undefined>);

const CAT_LABELS: Record<string, string> = {
  bathroom: 'Luxury Bathroom Renovation',
  flooring: 'Designer Floors',
  staircase: 'Designer Staircases',
  kitchen: 'Luxury Kitchens',
};
const STYLE_LABELS: Record<string, string> = {
  modern: 'Modern', minimalist: 'Minimalist', luxury: 'Luxury', contemporary: 'Contemporary',
};

const { searchParams } = Astro.url;
const filterCat      = searchParams.get('category') || '';
const filterYear     = searchParams.get('year') || '';
const filterStyle    = searchParams.get('style') || '';
const filterLocation = searchParams.get('location') || '';
const filterFeatured = searchParams.get('featured') === '1';

let query = sb
  ? sb.from('projects')
      .select('id,slug,title,category,location,completion_year,design_style,status,cover_image,project_overview')
      .in('status', ['published', 'featured'])
      .order('completion_year', { ascending: false })
  : null;

if (query && filterCat)      query = query.eq('category', filterCat);
if (query && filterYear)     query = query.eq('completion_year', Number(filterYear));
if (query && filterStyle)    query = query.eq('design_style', filterStyle);
if (query && filterLocation) query = query.ilike('location', `%${filterLocation}%`);
if (query && filterFeatured) query = query.eq('status', 'featured');

const { data: projects } = (await query) ?? { data: [] };

// Derive available years for filter dropdown
const allYears = [...new Set((projects ?? []).map((p: any) => p.completion_year).filter(Boolean))].sort((a, b) => b - a);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Our Projects — LUXEHOME</title>
  <meta name="description" content="Explore LUXEHOME's portfolio of luxury bathroom renovations, designer floors, and premium construction projects across Sri Lanka." />
  <meta property="og:title" content="Our Projects — LUXEHOME" />
  <meta property="og:description" content="Premium bathroom renovations, designer floors, and luxury kitchens in Sri Lanka." />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --charcoal: #161c1a; --cream: #f0ece0; --clay: #b8945a;
      --muted: rgba(240,236,224,.65); --border: rgba(255,255,255,.08);
    }
    body { background: var(--charcoal); color: var(--cream); font-family: 'DM Sans', system-ui, sans-serif; }
    a { color: inherit; text-decoration: none; }

    /* Nav stub */
    .site-nav {
      background: var(--charcoal); border-bottom: 1px solid var(--border);
      padding: 0 2rem; display: flex; align-items: center; height: 64px; gap: 16px;
    }
    .site-nav .logo { font-size: 1.1rem; font-weight: 800; letter-spacing: .04em; }
    .site-nav .logo span { color: var(--clay); }
    .nav-links { display: flex; gap: 24px; margin-left: auto; font-size: .85rem; color: var(--muted); }
    .nav-links a:hover { color: var(--cream); }

    /* Hero */
    .hero {
      background: linear-gradient(135deg, #1e2422 0%, #161c1a 100%);
      padding: 5rem 2rem 4rem; text-align: center; border-bottom: 1px solid var(--border);
    }
    .hero .stag {
      font-size: .68rem; font-weight: 700; letter-spacing: .2em;
      text-transform: uppercase; color: var(--clay); margin-bottom: .8rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 700; line-height: 1.1;
      font-family: 'Playfair Display', Georgia, serif; margin-bottom: 1rem;
    }
    .hero p { font-size: 1rem; color: var(--muted); max-width: 520px; margin: 0 auto; }

    /* Breadcrumb */
    .breadcrumb {
      padding: .9rem 2rem; font-size: .78rem; color: var(--muted);
      border-bottom: 1px solid var(--border);
      display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
    }
    .breadcrumb a:hover { color: var(--clay); }
    .breadcrumb .sep { opacity: .4; }

    /* Filters */
    .filters-bar {
      padding: 1.2rem 2rem; display: flex; flex-wrap: wrap; gap: 10px;
      border-bottom: 1px solid var(--border); background: rgba(255,255,255,.02);
      position: sticky; top: 0; z-index: 20; backdrop-filter: blur(8px);
    }
    .filter-sel {
      padding: 8px 12px; border-radius: 8px;
      border: 1px solid var(--border); background: rgba(255,255,255,.05);
      color: var(--cream); font-size: .82rem; cursor: pointer;
    }
    .filter-sel:focus { outline: none; border-color: var(--clay); }
    .filter-sel option { background: #1e2422; }
    .filter-input {
      padding: 8px 12px; border-radius: 8px;
      border: 1px solid var(--border); background: rgba(255,255,255,.05);
      color: var(--cream); font-size: .82rem;
    }
    .filter-input:focus { outline: none; border-color: var(--clay); }
    .filter-pill {
      padding: 8px 14px; border-radius: 8px; cursor: pointer;
      border: 1px solid var(--border); background: rgba(255,255,255,.05);
      color: var(--muted); font-size: .82rem; font-weight: 500;
    }
    .filter-pill.active { background: var(--clay); border-color: var(--clay); color: #fff; }
    .clear-link { font-size: .8rem; color: var(--clay); cursor: pointer; padding: 8px 4px; }

    /* Grid */
    .projects-section { padding: 2.5rem 2rem 5rem; max-width: 1280px; margin: 0 auto; }
    .results-count { font-size: .82rem; color: var(--muted); margin-bottom: 1.5rem; }
    .project-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
    }
    .proj-card {
      border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
      background: rgba(255,255,255,.03);
      transition: transform .3s, box-shadow .3s, border-color .3s;
      display: flex; flex-direction: column;
    }
    .proj-card:hover { transform: translateY(-6px); box-shadow: 0 24px 56px rgba(0,0,0,.4); border-color: rgba(184,148,90,.3); }
    .proj-img {
      position: relative; height: 240px; overflow: hidden;
      background: #252c29;
    }
    .proj-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
    .proj-card:hover .proj-img img { transform: scale(1.06); }
    .proj-cat-tag {
      position: absolute; top: 12px; left: 12px;
      font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      background: var(--clay); color: #fff; padding: 4px 9px; border-radius: 4px;
    }
    .proj-body { padding: 1.4rem 1.4rem 1.6rem; flex: 1; display: flex; flex-direction: column; }
    .proj-title {
      font-size: 1rem; font-weight: 700;
      font-family: 'Playfair Display', Georgia, serif;
      margin-bottom: .4rem; line-height: 1.3;
    }
    .proj-meta { font-size: .78rem; color: var(--muted); margin-bottom: 1rem; }
    .proj-excerpt { font-size: .85rem; color: var(--muted); line-height: 1.7; flex: 1; margin-bottom: 1.2rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .proj-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      color: var(--clay); transition: gap .2s;
    }
    .proj-card:hover .proj-link { gap: 10px; }

    /* Empty state */
    .empty { text-align: center; padding: 5rem 2rem; color: var(--muted); }
    .empty h2 { font-size: 1.2rem; margin-bottom: .5rem; color: var(--cream); }

    /* Footer stub */
    .footer { border-top: 1px solid var(--border); padding: 2rem; text-align: center; font-size: .8rem; color: var(--muted); }

    @media (max-width: 900px) { .project-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 580px) {
      .project-grid { grid-template-columns: 1fr; }
      .filters-bar { padding: .9rem 1rem; }
      .projects-section { padding: 1.5rem 1rem 4rem; }
      .hero { padding: 3.5rem 1.2rem 3rem; }
      .site-nav { padding: 0 1rem; }
      .nav-links { display: none; }
    }
  </style>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
</head>
<body>

  <nav class="site-nav">
    <a href="/" class="logo">LUXE<span>HOME</span></a>
    <div class="nav-links">
      <a href="/services/bathroom">Bathrooms</a>
      <a href="/services/flooring">Flooring</a>
      <a href="/projects" style="color:var(--clay)">Projects</a>
      <a href="/contact">Contact</a>
    </div>
  </nav>

  <div class="breadcrumb">
    <a href="/">Home</a>
    <span class="sep">/</span>
    <span>Projects</span>
    {filterCat && <><span class="sep">/</span><span>{CAT_LABELS[filterCat] || filterCat}</span></>}
  </div>

  <section class="hero">
    <div class="stag">Portfolio</div>
    <h1>Our Projects</h1>
    <p>Premium renovation and construction work across Sri Lanka — every project a case study in quality.</p>
  </section>

  <form class="filters-bar" method="get" action="/projects">
    <select name="category" class="filter-sel" onchange="this.form.submit()">
      <option value="">All Categories</option>
      {Object.entries(CAT_LABELS).map(([v, l]) => (
        <option value={v} selected={filterCat === v}>{l}</option>
      ))}
    </select>
    <select name="year" class="filter-sel" onchange="this.form.submit()">
      <option value="">All Years</option>
      {allYears.map(y => <option value={String(y)} selected={filterYear === String(y)}>{y}</option>)}
    </select>
    <select name="style" class="filter-sel" onchange="this.form.submit()">
      <option value="">All Styles</option>
      {Object.entries(STYLE_LABELS).map(([v, l]) => (
        <option value={v} selected={filterStyle === v}>{l}</option>
      ))}
    </select>
    <input class="filter-input" name="location" placeholder="Location…" value={filterLocation} />
    <button type="submit" class="filter-pill">Search</button>
    <input type="hidden" name="featured" value={filterFeatured ? '1' : ''} />
    <a class="filter-pill{filterFeatured ? ' active' : ''}" href={`/projects?${new URLSearchParams({...(filterCat?{category:filterCat}:{}), ...(filterYear?{year:filterYear}:{}), ...(filterStyle?{style:filterStyle}:{}), ...(filterLocation?{location:filterLocation}:{}), featured: filterFeatured ? '' : '1'})}`}>
      ★ Featured
    </a>
    {(filterCat || filterYear || filterStyle || filterLocation || filterFeatured) && (
      <a class="clear-link" href="/projects">Clear filters</a>
    )}
  </form>

  <section class="projects-section">
    <div class="results-count">
      {(projects ?? []).length} project{(projects ?? []).length !== 1 ? 's' : ''} found
    </div>
    {(!projects || projects.length === 0) ? (
      <div class="empty">
        <h2>No projects found</h2>
        <p>Try adjusting your filters or check back soon.</p>
      </div>
    ) : (
      <div class="project-grid">
        {projects.map((p: any) => (
          <a class="proj-card" href={`/projects/${p.slug}`}>
            <div class="proj-img">
              {p.cover_image
                ? <img src={p.cover_image} alt={p.title} loading="lazy" width="600" height="400" />
                : <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:2rem;color:rgba(255,255,255,.2)">🏗️</div>
              }
              <span class="proj-cat-tag">{CAT_LABELS[p.category] || p.category}</span>
            </div>
            <div class="proj-body">
              <div class="proj-title">{p.title}</div>
              <div class="proj-meta">{p.location}{p.completion_year ? ` · ${p.completion_year}` : ''}{p.design_style ? ` · ${STYLE_LABELS[p.design_style] || p.design_style}` : ''}</div>
              {p.project_overview && <p class="proj-excerpt">{p.project_overview}</p>}
              <span class="proj-link">View Project →</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <footer class="footer">
    <p>© {new Date().getFullYear()} LUXEHOME · Premium Renovation Sri Lanka</p>
    <p style="margin-top:6px"><a href="/">Home</a> · <a href="/projects">Projects</a> · <a href="/contact">Contact</a></p>
  </footer>

</body>
</html>
