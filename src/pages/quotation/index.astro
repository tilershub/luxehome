/* ── PDF — 3-Package Comparison ─────────────────────────── */
function printComparisonPDF(q: Quotation) {
  const ref = (q as any).ref || 'LH-QTN';
  const bdB = calculateQuotation({ ...q, package: 'basic',     plumbing: 'basic' });
  const bdP = calculateQuotation({ ...q, package: 'premium',   plumbing: 'premium' });
  const bdS = calculateQuotation({ ...q, package: 'signature', plumbing: 'signature' });


  type FeatRow = { label: string; b: string[]; p: string[]; s: string[]; hide?: boolean };
  const featRows: FeatRow[] = [
    { label: 'Tiling & Grouting',
      b: ['Indian tiles', 'Swisstek adhesive', 'Swisstek grout'],
      p: ['Mega tiles', 'Swisstek adhesive', 'Swisstek grout'],
      s: ['Rocell tiles', 'Swisstek adhesive', 'Swisstek grout'] },
    { label: 'Ceiling Installation',
      b: ['Standard PVC ceiling', 'Rs. 800/sqft'],
      p: ['Premium PVC ceiling', 'Rs. 1,000/sqft'],
      s: ['High-grade PVC ceiling', 'Rs. 1,200/sqft'],
      hide: !q.hasCeiling },
    { label: 'Plumbing Works',
      b: ['Basic plumbing package', 'Slon pipes & fittings'],
      p: ['Premium plumbing package', 'Slon pipes & fittings'],
      s: ['Signature plumbing package', 'Slon pipes & fittings'] },
    { label: 'Light Fixtures',
      b: ['Standard light fittings', 'ACL cables'],
      p: ['Mid-range light fittings', 'ACL cables'],
      s: ['Premium light fittings', 'ACL cables'],
      hide: q.wiringPoints === 0 },
    { label: 'Vanity Cupboard',
      b: ['Standard vanity'], p: ['Premium vanity'], s: ['Custom vanity'] },
    { label: 'Mirror',
      b: ['Standard mirror'], p: ['Premium mirror'], s: ['Designer mirror'] },
    { label: 'Bathware & Tapware',
      b: ['Swiss Standard bathware & tapware'],
      p: ['Swiss Premium bathware & tapware'],
      s: ['Swiss Signature bathware & tapware'] },
    { label: 'Door Works',
      b: ['Standard door works'], p: ['Premium door works'], s: ['Premium door works'],
      hide: !q.hasDoor },
    { label: 'Window Works',
      b: ['Standard window works'], p: ['Premium window works'], s: ['Premium window works'],
      hide: !q.hasWindow },
  ].filter(r => !r.hide);

  function cell(lines: string[]): string {
    return `<td>${lines.map((l, i) => `<span class="${i===0?'feat-main':'feat-sub'}">${l}</span>`).join('<br>')}</td>`;
  }

  const baseInclusions: string[] = [
    'Bathroom design & planning',
    'Floor concrete works',
    'Tokyo Super 2K waterproofing',
    'Electrical wiring — ACL cables',
    ...(q.projectType === 'renovation' ? ['Demolition & debris removal'] : []),
    ...(q.wallNiches > 0 ? [`Wall niches (${q.wallNiches})`] : []),
    ...(q.dummyWallArea > 0 ? ['Dummy wall construction'] : []),
    ...(q.hasGeyser ? ['Geyser / water heater installation'] : []),
    ...(q.showerCubicle !== 'none' ? ['Shower glass cubicle installation'] : []),
    ...(!q.hasCeiling ? ['Basic ceiling works (flat rate)'] : []),
  ];

  const html = `<!DOCTYPE html><html><head>
  <meta charset="utf-8">
  <title>${ref} — LUXEHOME Package Comparison</title>
  <style>
    @page { size: A4; margin: 12mm 14mm; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #111; font-size: 9pt; line-height: 1.5; }
    .header { display: flex; justify-content: space-between; align-items: flex-end; padding-bottom: 9pt; border-bottom: 2pt solid #111; margin-bottom: 12pt; }
    .logo { font-size: 17pt; font-weight: 900; letter-spacing: .08em; line-height: 1; }
    .logo-sub { font-size: 7pt; color: #999; letter-spacing: .1em; text-transform: uppercase; margin-top: 3pt; }
    .ref-block { text-align: right; }
    .ref-no { font-size: 11pt; font-weight: 800; }
    .ref-meta { font-size: 7.5pt; color: #777; margin-top: 2pt; line-height: 1.5; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; margin-bottom: 12pt; }
    .info-cell { padding-right: 16pt; }
    .info-cell + .info-cell { padding-right: 0; padding-left: 16pt; border-left: 1pt solid #e8e8e8; }
    .info-label { font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: .14em; color: #999; margin-bottom: 3pt; }
    .info-name { font-size: 10pt; font-weight: 700; }
    .info-detail { font-size: 8.5pt; color: #555; margin-top: 2pt; }
    .section-title { font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: .14em; color: #999; padding-bottom: 4pt; border-bottom: 1pt solid #e0e0e0; margin-bottom: 8pt; margin-top: 12pt; break-after: avoid; }
    .cmp-table { width: 100%; border-collapse: collapse; }
    .cmp-table colgroup col:first-child { width: 22%; }
    .cmp-table th { padding: 7pt 8pt; font-size: 7.5pt; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; text-align: left; border-bottom: 1.5pt solid #111; }
    .cmp-table th:first-child { color: #999; }
    .cmp-table th.basic { color: #555; }
    .cmp-table th.premium { color: #7c5540; }
    .cmp-table th.sig { color: #b8892a; }
    .cmp-table td { padding: 7pt 8pt; border-bottom: .5pt solid #efefef; vertical-align: top; }
    .cmp-table td:first-child { font-size: 8pt; font-weight: 700; color: #444; }
    .feat-main { font-size: 8pt; font-weight: 600; color: #111; }
    .feat-sub { font-size: 7.5pt; color: #777; }
    .cmp-table tr:nth-child(even) td { background: #fafafa; }
    .pkg-boxes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8pt; margin-top: 12pt; break-inside: avoid; }
    .pkg-box { border-radius: 4pt; padding: 10pt 8pt; text-align: center; }
    .pkg-box.basic { border: 1pt solid #ddd; }
    .pkg-box.premium { border: 1.5pt solid #7c5540; }
    .pkg-box.sig { background: #111; color: #fff; }
    .pkg-name { font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; opacity: .6; margin-bottom: 5pt; }
    .pkg-price { font-size: 15pt; font-weight: 900; line-height: 1; }
    .pkg-diff { font-size: 7.5pt; margin-top: 4pt; opacity: .5; }
    .base-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0 14pt; }
    .base-item { font-size: 8pt; color: #555; padding: 3pt 0; display: flex; align-items: baseline; gap: 5pt; border-bottom: .5pt solid #f5f5f5; }
    .base-check { color: #b8892a; font-size: 7.5pt; font-weight: 700; flex-shrink: 0; }
    .terms-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 7pt; break-inside: avoid; }
    .term-box { border: 1pt solid #ddd; border-radius: 4pt; padding: 8pt 6pt; text-align: center; break-inside: avoid; }
    .term-pct { font-size: 15pt; font-weight: 900; color: #111; line-height: 1; }
    .term-lbl { font-size: 7pt; color: #777; margin-top: 3pt; line-height: 1.3; }
    .term-amt { font-size: 8.5pt; font-weight: 700; color: #b8892a; margin-top: 3pt; }
    .brands-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1pt 12pt; break-inside: avoid; }
    .brand-item { font-size: 8pt; color: #444; padding: 3pt 0; display: flex; align-items: center; gap: 5pt; border-bottom: .5pt solid #f2f2f2; }
    .brand-dot { width: 3pt; height: 3pt; background: #b8892a; border-radius: 50%; flex-shrink: 0; }
    .note { font-size: 7.5pt; color: #999; font-style: italic; margin-top: 12pt; line-height: 1.5; }
    .footer { margin-top: 9pt; padding-top: 7pt; border-top: 1pt solid #e0e0e0; font-size: 6.5pt; color: #bbb; text-align: center; letter-spacing: .08em; text-transform: uppercase; }
  </style>
  </head><body>

  <div class="header">
    <div>
      <div class="logo">LUXE<span style="color:#b8892a">HOME</span></div>
      <div class="logo-sub">Premium Bathroom Renovation · Sri Lanka</div>
    </div>
    <div class="ref-block">
      <div class="ref-no">${ref}</div>
      <div class="ref-meta">${fmtDate(q.quotationDate)}<br>3-Package Comparison · ${q.projectType === 'renovation' ? 'Renovation' : 'New Construction'}</div>
    </div>
  </div>

  <div class="info-grid">
    <div class="info-cell">
      <div class="info-label">Prepared For</div>
      <div class="info-name">${q.clientName}</div>
      ${q.clientPhone ? `<div class="info-detail">${q.clientPhone}</div>` : ''}
    </div>
    <div class="info-cell">
      <div class="info-label">Project</div>
      <div class="info-name">${q.projectName || q.projectLocation}</div>
      ${q.projectName && q.projectLocation ? `<div class="info-detail">${q.projectLocation}</div>` : ''}
    </div>
  </div>

  <div class="section-title">Package Comparison</div>
  <table class="cmp-table">
    <colgroup><col><col><col><col></colgroup>
    <thead>
      <tr>
        <th>Work Item</th>
        <th class="basic">⭐ Basic</th>
        <th class="premium">⭐⭐ Premium</th>
        <th class="sig">👑 Signature</th>
      </tr>
    </thead>
    <tbody>
      ${featRows.map(r => `<tr><td>${r.label}</td>${cell(r.b)}${cell(r.p)}${cell(r.s)}</tr>`).join('')}
    </tbody>
  </table>

  <div class="section-title">Included in All Packages</div>
  <div class="base-grid">
    ${baseInclusions.map(item => `<div class="base-item"><span class="base-check">✓</span><span>${item}</span></div>`).join('')}
  </div>

  <div class="section-title">Total Investment</div>
  <div class="pkg-boxes">
    <div class="pkg-box basic">
      <div class="pkg-name">⭐ Basic</div>
      <div class="pkg-price">${fmtRs(bdB.finalAmount)}</div>
      <div class="pkg-diff">Base package</div>
    </div>
    <div class="pkg-box premium">
      <div class="pkg-name" style="color:#7c5540">⭐⭐ Premium</div>
      <div class="pkg-price">${fmtRs(bdP.finalAmount)}</div>
      <div class="pkg-diff">+${fmtRs(bdP.finalAmount - bdB.finalAmount)} vs Basic</div>
    </div>
    <div class="pkg-box sig">
      <div class="pkg-name">👑 Signature</div>
      <div class="pkg-price">${fmtRs(bdS.finalAmount)}</div>
      <div class="pkg-diff">+${fmtRs(bdS.finalAmount - bdB.finalAmount)} vs Basic</div>
    </div>
  </div>

  <div class="section-title">Payment Schedule</div>
  <div style="font-size:7.5pt;color:#888;margin-bottom:6pt">Amounts shown for Basic package. Same schedule applies proportionally to all.</div>
  <div class="terms-grid">
    ${q.paymentTerms.map(t => `
      <div class="term-box">
        <div class="term-pct">${t.percentage}%</div>
        <div class="term-lbl">${t.label}</div>
        <div class="term-amt">${fmtRs(bdB.finalAmount * t.percentage / 100)}</div>
      </div>`).join('')}
  </div>

  <div class="section-title">Brands &amp; Materials</div>
  <div class="brands-grid">
    ${q.brands.map(b => `<div class="brand-item"><div class="brand-dot"></div>${b}</div>`).join('')}
  </div>

  <div class="note">This comparison is valid for 30 days from the date above. All packages cover the same full scope — the difference is in tile grade, fixture quality, vanity, and bathware. Prices subject to change based on actual site conditions.</div>

  <div class="footer">LUXEHOME &nbsp;·&nbsp; Luxury Bathroom Renovation &nbsp;·&nbsp; Sri Lanka</div>
  <script>window.onload=function(){window.print();}<\/script>
  </body></html>`;

  const w = window.open('', '_blank');
  if (w) { w.document.write(html); w.document.close(); }
}
