---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { providers, TYPE_LABELS } from '../../data/providers';
import type { Provider, ProviderType } from '../../data/providers';

export function getStaticPaths() {
  return providers.map(p => ({ params: { slug: p.slug }, props: { provider: p } }));
}

const { provider: p } = Astro.props as { provider: Provider };

const typeColors: Record<ProviderType, string> = {
  brand:        '#7c5540',
  professional: '#4a90d9',
  contractor:   '#4caf50',
  shop:         '#f5a623',
};

const serviceLinks: Record<string, string> = {
  'Essential Bath':          '/services/bathroom-essential',
  'Comfort Bath':            '/services/bathroom-comfort',
  'Signature Bath':          '/services/bathroom-signature',
  'Floor Tiling':            '/services/floor-tiling',
  'Bathroom Tiling':         '/services/bathroom-tiling',
  'Bathroom Waterproofing':  '/services/bathroom-waterproofing',
  'Bathroom Plumbing':       '/services/bathroom-plumbing',
  'Bathroom Electrical':     '/services/bathroom-electrical',
  'Bathroom Ceiling':        '/services/bathroom-ceiling',
  'Staircase Tiling':        '/services/staircase-tiling',
  'Kitchen Pantry Cupboard': '/services/kitchen-pantry-cupboard',
};

const typeBg   = typeColors[p.type] + '18';
const typeBdr  = typeColors[p.type] + '40';
const typeClr  = typeColors[p.type];
---

<Layout
  title={`${p.name} — Trusted Partner — LUXEHOME Sri Lanka`}
  description={p.tagline + ' ' + p.description.slice(0, 120) + '…'}
>
  <Nav />

  <!-- Hero -->
  <section class="provider-hero">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a><span>›</span>
        <a href="/providers">Providers</a><span>›</span>
        <span>{p.name}</span>
      </div>

      <div class="hero-meta">
        <span class="type-badge" style={`background:${typeBg};color:${typeClr};border-color:${typeBdr}`}>
          {TYPE_LABELS[p.type]}
        </span>
        {p.origin && <span class="origin-tag">{p.origin}</span>}
        {p.featured && <span class="featured-tag">★ Featured Partner</span>}
      </div>

      <h1>{p.name}</h1>
      <p class="hero-tagline">{p.tagline}</p>

      <div class="hero-actions">
        {p.website && (
          <a href={p.website} target="_blank" rel="noopener noreferrer" class="btn-website">
            Visit Website
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        )}
        {p.phone && (
          <a href={`tel:${p.phone}`} class="btn-contact">{p.phone}</a>
        )}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="content-section">
    <div class="content-inner">

      <!-- About -->
      <div class="content-block">
        <div class="block-label">About</div>
        <p class="description">{p.description}</p>
      </div>

      <!-- Products / What they supply -->
      <div class="content-block">
        <div class="block-label">Products &amp; Materials</div>
        <ul class="product-list">
          {p.products.map(pr => (
            <li class="product-item">
              <div class="product-name">{pr.name}</div>
              {pr.description && <div class="product-desc">{pr.description}</div>}
            </li>
          ))}
        </ul>
      </div>

      <!-- Used in -->
      <div class="content-block">
        <div class="block-label">Used in These Services</div>
        <div class="service-tags">
          {p.usedIn.map(svc => {
            const href = serviceLinks[svc];
            return href
              ? <a href={href} class="service-tag">{svc} →</a>
              : <span class="service-tag">{svc}</span>;
          })}
        </div>
      </div>

      <!-- Contact (if available) -->
      {(p.address || p.email) && (
        <div class="content-block">
          <div class="block-label">Contact</div>
          <div class="contact-body">
            {p.address && <p class="contact-line">{p.address}</p>}
            {p.email   && <a href={`mailto:${p.email}`} class="contact-link">{p.email}</a>}
          </div>
        </div>
      )}

      <!-- Back link -->
      <a href="/providers" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        All Providers
      </a>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .provider-hero {
    background: var(--charcoal);
    padding: 0 4rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .provider-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 840px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.55);
    margin-bottom: 1.4rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(240,236,224,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: .6rem;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }

  .type-badge {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .24rem .7rem;
    border-radius: 999px;
    border: 1px solid;
  }

  .origin-tag {
    font-size: .72rem;
    color: rgba(240,236,224,.6);
    letter-spacing: .05em;
  }

  .featured-tag {
    font-size: .7rem;
    font-weight: 600;
    color: var(--clay);
    letter-spacing: .05em;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: .9rem;
  }

  .hero-tagline {
    font-size: 1.05rem;
    color: rgba(240,236,224,.82);
    line-height: 1.65;
    max-width: 56ch;
    margin-bottom: 1.8rem;
  }

  .hero-actions {
    display: flex;
    gap: .8rem;
    flex-wrap: wrap;
  }

  .btn-website {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--clay);
    color: #fff;
    text-decoration: none;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: .65rem 1.3rem;
    border-radius: 3px;
    min-height: 42px;
    transition: background .2s;
  }
  .btn-website:hover { background: var(--terracotta); }

  .btn-contact {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: rgba(240,236,224,.8);
    text-decoration: none;
    font-size: .78rem;
    font-weight: 500;
    padding: .65rem 1.3rem;
    border: 1px solid rgba(240,236,224,.2);
    border-radius: 3px;
    min-height: 42px;
    transition: border-color .2s, color .2s;
  }
  .btn-contact:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Content section ── */
  .content-section {
    background: var(--off-white);
    padding: 4rem 4rem 6rem;
  }

  .content-inner {
    max-width: 840px;
    display: flex;
    flex-direction: column;
    gap: 2.8rem;
  }

  .content-block {
    display: flex;
    flex-direction: column;
    gap: .9rem;
  }

  .block-label {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    padding-bottom: .6rem;
    border-bottom: 1px solid var(--stone);
  }

  .description {
    font-size: .95rem;
    color: var(--charcoal);
    line-height: 1.82;
    max-width: 70ch;
  }

  /* ── Products ── */
  .product-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .product-item {
    display: flex;
    flex-direction: column;
    gap: .15rem;
    padding: .85rem 0;
    border-bottom: 1px solid var(--stone);
  }

  .product-item:last-child { border-bottom: none; }

  .product-name {
    font-size: .9rem;
    font-weight: 600;
    color: var(--charcoal);
  }

  .product-desc {
    font-size: .82rem;
    color: var(--warm-gray);
    line-height: 1.55;
  }

  /* ── Service tags ── */
  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
  }

  .service-tag {
    display: inline-block;
    font-size: .8rem;
    font-weight: 500;
    color: var(--charcoal);
    background: #fff;
    border: 1px solid var(--stone);
    padding: .35rem .9rem;
    border-radius: 999px;
    text-decoration: none;
    transition: border-color .2s, color .2s, background .2s;
  }

  a.service-tag:hover {
    border-color: var(--clay);
    color: var(--clay);
    background: rgba(124,85,64,.04);
  }

  /* ── Contact ── */
  .contact-body {
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }

  .contact-line {
    font-size: .9rem;
    color: var(--warm-gray);
  }

  .contact-link {
    font-size: .9rem;
    color: var(--clay);
    text-decoration: none;
  }
  .contact-link:hover { text-decoration: underline; }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--warm-gray);
    text-decoration: none;
    transition: color .2s;
    padding-top: 1rem;
    border-top: 1px solid var(--stone);
  }
  .back-link:hover { color: var(--clay); }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .provider-hero  { padding: 0 2.5rem 3.5rem; }
    .content-section { padding: 3rem 2.5rem 5rem; }
  }

  @media (max-width: 768px) {
    .provider-hero  { padding: 0 1.5rem 3rem; }
    .content-section { padding: 2.5rem 1.5rem 4rem; }
  }

  @media (max-width: 480px) {
    .provider-hero  { padding: 0 1.2rem 2.5rem; }
    .hero-inner     { padding-top: calc(5rem + env(safe-area-inset-top, 0px)); }
    .content-section { padding: 2rem 1.2rem 3.5rem; }
    h1              { font-size: clamp(1.9rem, 8vw, 2.4rem); }
  }
</style>
