---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { providers, CATEGORY_LABELS, TYPE_LABELS } from '../../data/providers';
import type { ProviderCategory, ProviderType } from '../../data/providers';

const categories = Object.entries(CATEGORY_LABELS) as [ProviderCategory, string][];
const types = Object.entries(TYPE_LABELS) as [ProviderType, string][];

// Group providers by category
const byCategory = categories
  .map(([cat, label]) => ({ cat, label, items: providers.filter(p => p.category === cat) }))
  .filter(g => g.items.length > 0);

const typeColors: Record<ProviderType, string> = {
  brand:        '#7c5540',
  professional: '#4a90d9',
  contractor:   '#4caf50',
  shop:         '#f5a623',
};
---

<Layout
  title="Our Trusted Partners & Suppliers — LUXEHOME Sri Lanka"
  description="The brands, shops, professionals, and contractors LUXEHOME trusts for every bathroom renovation and floor tiling project across Sri Lanka."
>
  <Nav />

  <section class="page-hero">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a><span>›</span><span>Providers</span>
      </div>
      <h1>Our Trusted Partners &amp; Suppliers</h1>
      <p class="hero-desc">
        Every material, fitting, and component in a LUXEHOME project is sourced from
        carefully selected brands and suppliers. Here's who we work with and why.
      </p>
    </div>
  </section>

  <!-- Filter bar (JS) -->
  <div class="filter-bar">
    <div class="filter-inner">
      <button class="filter-pill active" data-filter="all">All</button>
      {types.map(([type, label]) => (
        <button class="filter-pill" data-filter={type}
          style={`--dot:${typeColors[type]}`}>
          <span class="dot"></span>{label}s
        </button>
      ))}
    </div>
  </div>

  <!-- Provider grid by category -->
  <section class="providers-section">
    <div class="providers-inner">
      {byCategory.map(({ cat, label, items }) => (
        <div class="cat-group" data-cat={cat}>
          <h2 class="cat-heading">{label}</h2>
          <div class="provider-grid">
            {items.map(p => (
              <a class="provider-card" href={`/providers/${p.slug}`}
                data-type={p.type}
                aria-label={`${p.name} — ${TYPE_LABELS[p.type]}`}>
                <div class="card-top">
                  <div class="card-name-row">
                    <span class="provider-name">{p.name}</span>
                    {p.featured && <span class="featured-dot" title="Featured partner"></span>}
                  </div>
                  <span class="type-badge" style={`background:${typeColors[p.type]}18;color:${typeColors[p.type]};border-color:${typeColors[p.type]}40`}>
                    {TYPE_LABELS[p.type]}
                  </span>
                </div>
                {p.origin && (
                  <div class="card-origin">{p.origin}</div>
                )}
                <p class="card-tagline">{p.tagline}</p>
                <div class="card-products">
                  {p.products.slice(0, 3).map(pr => (
                    <span class="product-pill">{pr.name}</span>
                  ))}
                  {p.products.length > 3 && (
                    <span class="product-pill product-pill--more">+{p.products.length - 3} more</span>
                  )}
                </div>
                <div class="card-cta">
                  View details
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLAnchorElement>('.provider-card');
  const groups = document.querySelectorAll<HTMLDivElement>('.cat-group');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.filter!;
      cards.forEach(c => {
        c.hidden = filter !== 'all' && c.dataset.type !== filter;
      });
      groups.forEach(g => {
        const visible = g.querySelectorAll('.provider-card:not([hidden])').length;
        (g as HTMLElement).style.display = visible ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* ── Hero ── */
  .page-hero {
    min-height: 38vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 3.5rem;
    background: var(--charcoal);
    position: relative;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.012) 60px, rgba(255,255,255,.012) 61px);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    width: 100%;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.65);
    margin-bottom: 1.4rem;
  }
  .breadcrumb a { color: rgba(240,236,224,.65); text-decoration: none; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: .95rem;
    color: rgba(240,236,224,.82);
    line-height: 1.72;
    max-width: 60ch;
  }

  /* ── Filter bar ── */
  .filter-bar {
    background: #fff;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: .9rem 4rem;
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    height: 32px;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1.5px solid #e0e0da;
    background: #fff;
    font-size: .78rem;
    font-weight: 600;
    color: #666;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
  }

  .filter-pill .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--dot);
    flex-shrink: 0;
  }

  .filter-pill.active,
  .filter-pill:hover {
    background: var(--charcoal);
    border-color: var(--charcoal);
    color: #fff;
  }

  .filter-pill.active .dot,
  .filter-pill:hover .dot {
    opacity: .7;
  }

  /* ── Section ── */
  .providers-section {
    background: var(--off-white);
    padding: 4rem 4rem 6rem;
  }

  .providers-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  /* ── Category group ── */
  .cat-heading {
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 1.2rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--stone);
  }

  .provider-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* ── Provider card ── */
  .provider-card {
    display: flex;
    flex-direction: column;
    gap: .7rem;
    background: #fff;
    border: 1px solid var(--stone);
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
    transition: transform .25s, box-shadow .25s, border-color .25s;
  }

  .provider-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0,0,0,.08);
    border-color: rgba(124,85,64,.3);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .5rem;
  }

  .card-name-row {
    display: flex;
    align-items: center;
    gap: .5rem;
  }

  .provider-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal);
    letter-spacing: -.01em;
    line-height: 1.2;
  }

  .featured-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--clay);
    flex-shrink: 0;
  }

  .type-badge {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .2rem .55rem;
    border-radius: 999px;
    border: 1px solid;
    flex-shrink: 0;
  }

  .card-origin {
    font-size: .72rem;
    color: var(--warm-gray);
    letter-spacing: .04em;
  }

  .card-tagline {
    font-size: .85rem;
    color: var(--charcoal);
    line-height: 1.5;
    font-weight: 400;
    flex: 1;
  }

  .card-products {
    display: flex;
    flex-wrap: wrap;
    gap: .3rem;
    margin-top: .2rem;
  }

  .product-pill {
    font-size: .67rem;
    font-weight: 500;
    color: var(--warm-gray);
    background: var(--off-white);
    border: 1px solid var(--stone);
    padding: .18rem .55rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .product-pill--more {
    color: var(--clay);
    background: rgba(124,85,64,.06);
    border-color: rgba(124,85,64,.2);
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--clay);
    margin-top: auto;
    padding-top: .8rem;
    border-top: 1px solid var(--stone);
    transition: gap .2s;
  }

  .provider-card:hover .card-cta {
    gap: .7rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1100px) {
    .page-hero       { padding: 0 2.5rem 3rem; }
    .filter-inner    { padding: .75rem 2.5rem; }
    .providers-section { padding: 3rem 2.5rem 5rem; }
  }

  @media (max-width: 768px) {
    .page-hero       { padding: 0 1.5rem 2.5rem; }
    .filter-inner    { padding: .65rem 1.5rem; }
    .providers-section { padding: 2.5rem 1.5rem 4rem; }
    .provider-grid   { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .page-hero       { padding: 0 1.2rem 2rem; min-height: auto; }
    .hero-inner      { padding-top: calc(5rem + env(safe-area-inset-top, 0px)); }
    .providers-section { padding: 2rem 1.2rem 3.5rem; }
  }
</style>
