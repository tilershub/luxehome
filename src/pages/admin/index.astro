/* ── Save quotation ──────────────────────────────────────── */
function saveQuotation() {
  const isCmp = (wizardData as any).isComparison;
  const bd = calculateQuotation(isCmp ? { ...wizardData, package: 'basic', plumbing: 'basic' } : wizardData);
  const qtns: Quotation[] = load(KEYS.qtns);
  const counters = getCounters();

  if (editingId) {
    const idx = qtns.findIndex(q => q.id === editingId);
    if (idx >= 0) {
      qtns[idx] = {
        ...qtns[idx], ...wizardData, breakdown: bd,
        updatedAt: new Date().toISOString(),
      };
      if (isCmp) (qtns[idx] as any).isComparison = true;
    }
  } else {
    counters.qtn++;
    saveCounters(counters);
    const newQ: Quotation = {
      ...wizardData, id: crypto.randomUUID(),
      createdAt: new Date().toISOString(), updatedAt: new Date().toISOString(),
      status: 'draft', breakdown: bd,
    };
    (newQ as any).ref = qtnNumber(counters.qtn);
    if (isCmp) (newQ as any).isComparison = true;
    qtns.unshift(newQ);
  }

  save(KEYS.qtns, qtns);
  toast(editingId ? 'Quotation updated' : 'Quotation saved');
  editingId = null;
  viewHistory = [];
  navigate('quotations');
}

