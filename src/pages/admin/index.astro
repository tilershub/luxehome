        ${brands.map((b, i) => `
          <div class="brand-row">
            <input type="text" value="${esc(b)}" data-idx="${i}" class="brand-input">
            <button class="brand-del" data-idx="${i}">×</button>
          </div>
        `).join('')}
      </div>
      <button class="brand-add-btn" id="add-brand-btn" style="margin-top:8px">+ Add Brand</button>

      <div class="dash-title" style="margin-top:24px;margin-bottom:8px">Payment Schedule</div>
      <div id="terms-container">
        ${terms.map((t, i) => `
          <div class="term-row">
            <input type="text" class="field-input term-label-inp" style="height:38px;flex:1;margin:0" value="${esc(t.label)}" data-idx="${i}">
            <div class="stepper-ctrl" style="margin-left:10px">
              <button class="stepper-btn" data-term="${i}" data-dir="-1">−</button>
              <span class="stepper-val" id="term-pct-${i}">${t.percentage}%</span>
              <button class="stepper-btn" data-term="${i}" data-dir="1">+</button>
            </div>
          </div>
        `).join('')}
      </div>
      <div id="terms-total" style="font-size:.8rem;color:${termsTotal===100?'#16a34a':'#dc2626'};margin-top:6px;font-weight:700">
        Total: ${termsTotal}% ${termsTotal===100?'✓':'(must equal 100%)'}
      </div>

      <div class="dash-title" style="margin-top:24px;margin-bottom:8px">Final Price Override</div>
      <div class="override-section" style="padding:0">
        <input class="field-input" id="f-override" type="number" min="0" step="1000"
          placeholder="Leave blank to use calculated price"
          value="${wizardData.finalPriceOverride ?? ''}">
        <div class="override-note">If set, this replaces the calculated selling price on the PDF.</div>
      </div>
    </div>
  `;

  // Brand edits
  document.querySelectorAll<HTMLInputElement>('.brand-input').forEach(inp => {
    inp.addEventListener('input', () => {
      wizardData.brands[parseInt(inp.dataset.idx!)] = inp.value;
    });
  });
  document.querySelectorAll<HTMLButtonElement>('.brand-del').forEach(btn => {
    btn.addEventListener('click', () => {
      wizardData.brands.splice(parseInt(btn.dataset.idx!), 1);
      renderStep10();
    });
  });
  document.getElementById('add-brand-btn')!.addEventListener('click', () => {
    wizardData.brands.push('');
    renderStep10();
  });

  // Term label edits
  document.querySelectorAll<HTMLInputElement>('.term-label-inp').forEach(inp => {
    inp.addEventListener('input', () => {
      wizardData.paymentTerms[parseInt(inp.dataset.idx!)].label = inp.value;
    });
