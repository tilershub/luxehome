---
// LUXEHOME Admin — mobile-first SPA, no auth required
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="robots" content="noindex, nofollow">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <title>Admin — LUXEHOME</title>
  <link rel="stylesheet" href="/qmk.css">
</head>
<body>

<!-- Header -->
<header id="app-header">
  <button id="header-back" aria-label="Back">←</button>
  <h1 id="app-title">LUXEHOME</h1>
  <button id="header-action"></button>
</header>

<!-- Progress (wizard only) -->
<div id="wizard-progress">
  <div class="progress-label">
    <span id="step-label">Step 1 of 11</span>
    <span id="step-name" class="gold"></span>
  </div>
  <div class="progress-track">
    <div class="progress-fill" id="progress-fill" style="width:9%"></div>
  </div>
</div>

<!-- Main content -->
<main id="main"></main>

<!-- Bottom nav -->
<nav id="bottom-nav">
  <button class="tab-btn active" data-view="dashboard">
    <span class="tab-icon">🏠</span><span>Home</span>
  </button>
  <button class="tab-btn" data-view="quotations">
    <span class="tab-icon">📋</span><span>Quotes</span>
  </button>
  <button class="tab-btn" data-view="invoices">
    <span class="tab-icon">💳</span><span>Invoices</span>
  </button>
  <button class="tab-btn" data-view="clients">
    <span class="tab-icon">👥</span><span>Clients</span>
  </button>
  <button class="tab-btn" data-view="inquiries">
    <span class="tab-icon">📝</span><span>Inquiries</span>
  </button>
  <button class="tab-btn" data-view="settings">
    <span class="tab-icon">⚙️</span><span>Settings</span>
  </button>
</nav>

<!-- Wizard nav -->
<div id="wizard-nav">
  <button id="wizard-back-btn">Back</button>
  <button id="wizard-next-btn">Next</button>
</div>

<!-- Toast -->
<div id="toast"></div>

<!-- Modal -->
<div id="modal-overlay">
  <div id="modal-box"></div>
</div>

<script>
import {
  calculateQuotation, generateScopeOfWork,
  fmtRs, fmtDate, fmtDateShort, qtnNumber, invNumber,
  defaultInputs, packageLabel, statusColor,
  DEFAULT_BRANDS, DEFAULT_PAYMENT_TERMS,
  RATES,
} from '../../lib/quotation-calc';
import type {
  QuotationInputs, QuotationBreakdown, Quotation, Invoice,
  PaymentTerm, Payment, PackageType, ProjectType, PlumbingType, ShowerType,
} from '../../lib/quotation-calc';

/* ── Inquiry types ───────────────────────────────────────── */
type InquiryStatus = 'new' | 'contacted' | 'site_visit' | 'quoted' | 'won' | 'lost';
interface Inquiry {
  id: string;
  createdAt: string;
  name: string;
  phone: string;
  service: string;
  location: string;
  notes: string;
  status: InquiryStatus;
}
function inqStatusColor(s: InquiryStatus): string {
  return { new:'#4a90d9', contacted:'#f5a623', site_visit:'#9b59b6', quoted:'#7c5540', won:'#4caf50', lost:'#aaa' }[s] ?? '#999';
}
function inqStatusLabel(s: InquiryStatus): string {
  return { new:'New', contacted:'Contacted', site_visit:'Site Visit', quoted:'Quoted', won:'Won', lost:'Lost' }[s] ?? s;
}

/* ── Storage ──────────────────────────────────────────────── */
const KEYS = { qtns: 'lh_qtns', invs: 'lh_invs', ctrs: 'lh_ctrs', inqs: 'lh_inqs' };

function load<T>(key: string): T[] {
  try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch { return []; }
}
function save<T>(key: string, data: T[]): void {
  localStorage.setItem(key, JSON.stringify(data));
}
function getCounters(): { qtn: number; inv: number } {
  try { return JSON.parse(localStorage.getItem(KEYS.ctrs) || '{"qtn":0,"inv":0}'); }
  catch { return { qtn: 0, inv: 0 }; }
}
function saveCounters(c: { qtn: number; inv: number }): void {
  localStorage.setItem(KEYS.ctrs, JSON.stringify(c));
}

/* ── State ───────────────────────────────────────────────── */
let currentView = 'dashboard';
let viewHistory: string[] = [];
let wizardStep = 1;
const WIZARD_STEPS = 11;
let wizardData: QuotationInputs = defaultInputs();
let editingId: string | null = null;

/* ── DOM refs ────────────────────────────────────────────── */
const main = document.getElementById('main')!;
const bottomNav = document.getElementById('bottom-nav')!;
const wizardNav = document.getElementById('wizard-nav')!;
const wizardProgress = document.getElementById('wizard-progress')!;
const headerBack = document.getElementById('header-back') as HTMLButtonElement;
const headerAction = document.getElementById('header-action') as HTMLButtonElement;
const appTitle = document.getElementById('app-title')!;
const progressFill = document.getElementById('progress-fill')!;
const stepLabel = document.getElementById('step-label')!;
const stepName = document.getElementById('step-name')!;

/* ── Navigation ──────────────────────────────────────────── */
function navigate(view: string, pushHistory = true) {
  if (pushHistory && currentView !== view) viewHistory.push(currentView);
  currentView = view;

  const inWizard = view === 'wizard';
  bottomNav.style.display = inWizard ? 'none' : '';
  wizardNav.classList.toggle('visible', inWizard);
  wizardProgress.classList.toggle('visible', inWizard);
  main.classList.toggle('wizard-mode', inWizard);

  headerBack.style.display = viewHistory.length > 0 ? '' : 'none';

  // Tab active state
  document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.view === view);
  });

  const titles: Record<string, string> = {
    dashboard: 'LUXEHOME', quotations: 'Quotations', invoices: 'Invoices',
    clients: 'Clients', inquiries: 'Inquiries', settings: 'Settings',
    wizard: 'New Quotation', qtn_detail: 'Quotation', inv_detail: 'Invoice',
    inq_detail: 'Inquiry',
  };
  appTitle.textContent = titles[view] || 'LUXEHOME';

  headerAction.style.display = 'none';
  render();
}

function goBack() {
  if (viewHistory.length === 0) return;
  const prev = viewHistory.pop()!;
  navigate(prev, false);
}

/* ── Render dispatcher ───────────────────────────────────── */
function render() {
  switch (currentView) {
    case 'dashboard':    renderDashboard(); break;
    case 'quotations':   renderQuotations(); break;
    case 'invoices':     renderInvoices(); break;
    case 'clients':      renderClients(); break;
    case 'inquiries':    renderInquiries(); break;
    case 'inq_detail':   renderInquiryDetail(); break;
    case 'settings':     renderSettings(); break;
    case 'wizard':       renderWizard(); break;
    case 'qtn_detail':   renderQtnDetail(); break;
    case 'inv_detail':   renderInvDetail(); break;
    default:             renderDashboard();
  }
}

/* ── DASHBOARD ───────────────────────────────────────────── */
function renderDashboard() {
  const qtns: Quotation[] = load(KEYS.qtns);
  const invs: Invoice[]  = load(KEYS.invs);
  const inqs: Inquiry[]  = load(KEYS.inqs);
  const totalRevenue = invs.filter(i => i.status === 'paid').reduce((s, i) => s + i.finalAmount, 0);
  const pending = invs.filter(i => i.status === 'sent' || i.status === 'partially-paid');
  const newInqs = inqs.filter(i => i.status === 'new').length;

  const recent = [...qtns].sort((a,b) => b.createdAt.localeCompare(a.createdAt)).slice(0,5);

  main.innerHTML = `
    <div class="dash-section">
      <button class="dash-cta" id="dash-new-qtn">
        ＋ New Quotation
      </button>
      <button class="dash-cta" id="dash-cmp-qtn" style="background:var(--surface);color:var(--clay);border:1.5px solid var(--clay);margin-top:10px">
        ⊞ 3-Package Comparison
      </button>

      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-val">${qtns.length}</div>
          <div class="stat-lbl">Total Quotations</div>
        </div>
        <div class="stat-card">
          <div class="stat-val">${invs.length}</div>
          <div class="stat-lbl">Invoices</div>
        </div>
        <div class="stat-card">
          <div class="stat-val gold">${fmtRs(totalRevenue)}</div>
          <div class="stat-lbl">Revenue Collected</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" style="color:#d97706">${pending.length}</div>
          <div class="stat-lbl">Pending Invoices</div>
        </div>
        <div class="stat-card" style="cursor:pointer" id="dash-inq-card">
          <div class="stat-val" style="color:${newInqs > 0 ? '#4a90d9' : ''}">${inqs.length}</div>
          <div class="stat-lbl">Inquiries${newInqs > 0 ? ` · <span style="color:#4a90d9">${newInqs} new</span>` : ''}</div>
        </div>
      </div>

      ${recent.length === 0 ? `
        <div class="empty-state">
          <div class="empty-icon">📋</div>
          <div class="empty-title">No quotations yet</div>
          <div class="empty-text">Tap "New Quotation" to get started.</div>
        </div>
      ` : `
        <div class="dash-title">Recent Quotations</div>
        ${recent.map(q => `
          <div class="recent-card" data-qtn="${q.id}">
            <span class="recent-icon">📋</span>
            <div class="recent-body">
              <div class="recent-name">${q.clientName || '(No name)'}</div>
              <div class="recent-sub">${q.projectName || q.projectLocation || '—'} · ${fmtDateShort(q.quotationDate)}</div>
            </div>
            <span class="recent-badge" style="color:${statusColor(q.status)}">${q.status}</span>
          </div>
        `).join('')}
      `}
    </div>
  `;

  document.getElementById('dash-new-qtn')!.addEventListener('click', () => startWizard());
  document.getElementById('dash-cmp-qtn')!.addEventListener('click', startComparisonWizard);
  document.getElementById('dash-inq-card')?.addEventListener('click', () => navigate('inquiries'));
  document.querySelectorAll<HTMLElement>('[data-qtn]').forEach(el => {
    el.addEventListener('click', () => openQtnDetail(el.dataset.qtn!));
  });
}

/* ── QUOTATIONS LIST ─────────────────────────────────────── */
function renderQuotations() {
  const qtns: Quotation[] = load<Quotation>(KEYS.qtns)
    .sort((a,b) => b.createdAt.localeCompare(a.createdAt));

  main.innerHTML = `
    <div class="page-header">
      <h2>Quotations</h2>
      <button class="add-btn" id="new-qtn-btn">＋</button>
    </div>
    <button class="card-btn" id="cmp-qtn-btn" style="width:100%;margin-bottom:12px;height:42px;color:var(--clay);border-color:var(--clay)">⊞ 3-Package Comparison</button>
    ${qtns.length === 0 ? `
      <div class="empty-state">
        <div class="empty-icon">📋</div>
        <div class="empty-title">No quotations</div>
        <div class="empty-text">Tap ＋ to create your first quotation.</div>
      </div>
    ` : qtns.map(q => `
      <div class="list-card" data-qtn="${q.id}">
        <div class="list-card-row">
          <div>
            <div class="list-card-title">${q.clientName || '(No name)'}</div>
            <div class="list-card-sub">${q.projectName || q.projectLocation || '—'}</div>
          </div>
          <div style="text-align:right">
            <div class="list-card-amount">${fmtRs(q.breakdown.finalAmount)}</div>
            ${(q as any).isComparison ? `<span style="font-size:.65rem;background:#f0e8d8;color:#7c5540;padding:2px 7px;border-radius:20px;font-weight:600">3-PKG</span>` : ''}
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px;">
          <span class="status-pill" style="color:${statusColor(q.status)};background:${statusColor(q.status)}18">${q.status.toUpperCase()}</span>
          <span style="font-size:.72rem;color:#888">${fmtDateShort(q.quotationDate)}</span>
        </div>
      </div>
    `).join('')}
  `;

  document.getElementById('new-qtn-btn')!.addEventListener('click', () => startWizard());
  document.getElementById('cmp-qtn-btn')!.addEventListener('click', startComparisonWizard);
  document.querySelectorAll<HTMLElement>('[data-qtn]').forEach(el => {
    el.addEventListener('click', () => openQtnDetail(el.dataset.qtn!));
  });
}

/* ── INVOICES LIST ───────────────────────────────────────── */
function renderInvoices() {
  const invs: Invoice[] = load<Invoice>(KEYS.invs)
    .sort((a,b) => b.createdAt.localeCompare(a.createdAt));

  main.innerHTML = `
    <div class="page-header">
      <h2>Invoices</h2>
    </div>
    ${invs.length === 0 ? `
      <div class="empty-state">
        <div class="empty-icon">💳</div>
        <div class="empty-title">No invoices yet</div>
        <div class="empty-text">Convert a quotation to an invoice from the Quotation detail page.</div>
      </div>
    ` : invs.map(i => {
      const pct = i.finalAmount > 0 ? Math.round(i.paidAmount / i.finalAmount * 100) : 0;
      return `
        <div class="list-card" data-inv="${i.id}">
          <div class="list-card-row">
            <div>
              <div class="list-card-title">${i.clientName || '(No name)'}</div>
              <div class="list-card-sub">${i.quotationRef}</div>
            </div>
            <div class="list-card-amount">${fmtRs(i.finalAmount)}</div>
          </div>
          <div style="margin-top:8px;display:flex;align-items:center;gap:10px">
            <span class="status-pill" style="color:${statusColor(i.status)};background:${statusColor(i.status)}18">${i.status.toUpperCase()}</span>
            <span style="font-size:.72rem;color:#888">${pct}% paid</span>
          </div>
        </div>
      `;
    }).join('')}
  `;

  document.querySelectorAll<HTMLElement>('[data-inv]').forEach(el => {
    el.addEventListener('click', () => openInvDetail(el.dataset.inv!));
  });
}

/* ── CLIENTS LIST ────────────────────────────────────────── */
function renderClients() {
  const qtns: Quotation[] = load(KEYS.qtns);
  const clientMap = new Map<string, { phone: string; qtns: number; total: number }>();
  qtns.forEach(q => {
    const key = q.clientName?.trim().toLowerCase() || '?';
    const existing = clientMap.get(key);
    if (existing) {
      existing.qtns++;
      existing.total += q.breakdown.finalAmount;
    } else {
      clientMap.set(key, { phone: q.clientPhone, qtns: 1, total: q.breakdown.finalAmount });
    }
  });

  const clients = [...clientMap.entries()].sort((a,b) => b[1].total - a[1].total);

  main.innerHTML = `
    <div class="page-header"><h2>Clients</h2></div>
    ${clients.length === 0 ? `
      <div class="empty-state">
        <div class="empty-icon">👥</div>
        <div class="empty-title">No clients yet</div>
        <div class="empty-text">Clients are created automatically when you save a quotation.</div>
      </div>
    ` : clients.map(([name, data]) => `
      <div class="list-card">
        <div class="list-card-row">
          <div>
            <div class="list-card-title" style="text-transform:capitalize">${name}</div>
            <div class="list-card-sub">${data.phone || '—'}</div>
          </div>
          <div class="list-card-amount" style="font-size:.85rem;color:#666">${fmtRs(data.total)}</div>
        </div>
        <div class="client-stat" style="margin-top:8px">
          <span class="client-chip">${data.qtns} quotation${data.qtns !== 1 ? 's' : ''}</span>
          ${data.phone ? `<a href="tel:${data.phone}" class="client-chip" style="text-decoration:none;color:inherit">📞 Call</a>` : ''}
          ${data.phone ? `<a href="https://wa.me/94${data.phone.replace(/^0/,'')}" target="_blank" class="client-chip" style="text-decoration:none;color:inherit">💬 WhatsApp</a>` : ''}
        </div>
      </div>
    `).join('')}
  `;
}

/* ── SETTINGS ────────────────────────────────────────────── */
function renderSettings() {
  main.innerHTML = `
    <div class="page-header"><h2>Settings</h2></div>
    <div style="padding:0 16px 16px">
      <div class="dash-title">Data</div>
      <button class="card-btn" id="export-btn" style="width:100%;margin-bottom:10px;height:44px">📤 Export All Data (JSON)</button>
      <button class="card-btn danger" id="clear-btn" style="width:100%;height:44px">🗑 Clear All Data</button>
      <div style="margin-top:24px" class="dash-title">About</div>
      <div class="section-card" style="margin:0">
        <div class="inv-detail-row" style="padding:12px 16px">
          <span class="inv-detail-key">Version</span>
          <span class="inv-detail-val">1.0</span>
        </div>
        <div class="inv-detail-row" style="padding:12px 16px">
          <span class="inv-detail-key">Storage</span>
          <span class="inv-detail-val">Local device only</span>
        </div>
        <div class="inv-detail-row" style="padding:12px 16px;border-bottom:none">
          <span class="inv-detail-key">Profit margin</span>
          <span class="inv-detail-val">${(RATES.profitMargin * 100).toFixed(0)}%</span>
        </div>
      </div>
    </div>
  `;

  document.getElementById('export-btn')!.addEventListener('click', () => {
    const data = {
      quotations: load(KEYS.qtns),
      invoices: load(KEYS.invs),
      inquiries: load(KEYS.inqs),
      counters: getCounters(),
      exportedAt: new Date().toISOString(),
    };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `luxehome-export-${Date.now()}.json`;
    a.click(); URL.revokeObjectURL(url);
  });

  document.getElementById('clear-btn')!.addEventListener('click', () => {
    showModal('Clear All Data', `
      <p style="color:#666;font-size:.9rem;line-height:1.5">This will permanently delete all quotations, invoices, inquiries, and client data from this device. This cannot be undone.</p>
    `, [
      { label: 'Cancel', cls: 'modal-cancel', action: closeModal },
      { label: 'Clear Everything', cls: 'modal-confirm danger', action: () => {
        [KEYS.qtns, KEYS.invs, KEYS.ctrs, KEYS.inqs].forEach(k => localStorage.removeItem(k));
        closeModal(); toast('All data cleared'); renderSettings();
      }},
    ]);
  });
}

/* ── INQUIRIES LIST ──────────────────────────────────────── */
let inqFilter: InquiryStatus | 'all' = 'all';

function renderInquiries() {
  const all: Inquiry[] = load<Inquiry>(KEYS.inqs)
    .sort((a, b) => b.createdAt.localeCompare(a.createdAt));
  const shown = inqFilter === 'all' ? all : all.filter(i => i.status === inqFilter);

  const filterBtn = (f: InquiryStatus | 'all', label: string) =>
    `<button class="pill-filter${inqFilter === f ? ' active' : ''}" data-filter="${f}">${label}</button>`;

  main.innerHTML = `
    <div class="page-header" style="display:flex;justify-content:space-between;align-items:center">
      <h2>Inquiries</h2>
      <button class="card-btn" id="add-inq-btn" style="padding:8px 14px;font-size:.85rem">＋ Add</button>
    </div>
    <div style="display:flex;gap:6px;padding:0 16px 12px;overflow-x:auto;white-space:nowrap">
      ${filterBtn('all','All')}
      ${filterBtn('new','New')}
      ${filterBtn('contacted','Contacted')}
      ${filterBtn('site_visit','Site Visit')}
      ${filterBtn('quoted','Quoted')}
      ${filterBtn('won','Won')}
      ${filterBtn('lost','Lost')}
    </div>
    <div style="padding:0 16px 80px">
      ${shown.length === 0 ? `
        <div class="empty-state">
          <div class="empty-icon">📝</div>
          <div class="empty-title">No inquiries${inqFilter !== 'all' ? ' with this status' : ''}</div>
          <div class="empty-text">Tap ＋ Add to record a new inquiry.</div>
        </div>
      ` : shown.map(i => `
        <div class="recent-card" style="cursor:pointer" data-inq="${i.id}">
          <span class="recent-icon" style="font-size:1.3rem">📝</span>
          <div class="recent-body">
            <div class="recent-name">${i.name || '(No name)'}</div>
            <div class="recent-sub">${i.service || '—'}${i.location ? ' · ' + i.location : ''}</div>
            ${i.notes ? `<div style="font-size:.78rem;color:#999;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:200px">${i.notes}</div>` : ''}
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0">
            <span style="font-size:.72rem;font-weight:700;color:${inqStatusColor(i.status)}">${inqStatusLabel(i.status)}</span>
            <a href="tel:${i.phone}" style="font-size:.8rem;color:#4a90d9" onclick="event.stopPropagation()">${i.phone}</a>
          </div>
        </div>
      `).join('')}
    </div>
  `;

  document.getElementById('add-inq-btn')!.addEventListener('click', () => {
    detailInqId = null;
    navigate('inq_detail');
  });

  document.querySelectorAll<HTMLElement>('[data-filter]').forEach(btn => {
    btn.addEventListener('click', () => {
      inqFilter = btn.dataset.filter as InquiryStatus | 'all';
      renderInquiries();
    });
  });

  document.querySelectorAll<HTMLElement>('[data-inq]').forEach(el => {
    el.addEventListener('click', () => {
      detailInqId = el.dataset.inq!;
      navigate('inq_detail');
    });
  });
}

/* ── INQUIRY DETAIL / ADD ────────────────────────────────── */
function renderInquiryDetail() {
  const all: Inquiry[] = load<Inquiry>(KEYS.inqs);
  const inq: Inquiry = detailInqId
    ? (all.find(i => i.id === detailInqId) ?? { id: '', createdAt: '', name: '', phone: '', service: '', location: '', notes: '', status: 'new' })
    : { id: '', createdAt: '', name: '', phone: '', service: '', location: '', notes: '', status: 'new' };
  const isNew = !detailInqId;

  const statusDotColor = inqStatusColor(inq.status);

  main.innerHTML = `
    <div style="padding:20px 16px 100px">

      ${!isNew ? `
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px">
          <span style="width:10px;height:10px;border-radius:50%;background:${statusDotColor};flex-shrink:0;display:inline-block"></span>
          <span style="font-size:.8rem;color:#888">Logged ${fmtDate(inq.createdAt)}</span>
        </div>
      ` : ''}

      <div class="inq-form-card">
        <div class="field-group">
          <label class="field-label">Name</label>
          <input id="inq-name" class="field-input" type="text" placeholder="Client name" value="${inq.name}" autocomplete="off">
        </div>
        <div class="field-group">
          <label class="field-label">Phone / WhatsApp</label>
          <input id="inq-phone" class="field-input" type="tel" placeholder="+94 7X XXX XXXX" value="${inq.phone}">
        </div>
      </div>

      <div class="inq-form-card">
        <div class="field-group">
          <label class="field-label">Service / Interest</label>
          <input id="inq-service" class="field-input" type="text" placeholder="e.g. Bathroom renovation, Tiling…" value="${inq.service}" autocomplete="off">
        </div>
        <div class="field-group">
          <label class="field-label">Location / Area</label>
          <input id="inq-location" class="field-input" type="text" placeholder="e.g. Colombo 7, Nugegoda…" value="${inq.location}" autocomplete="off">
        </div>
      </div>

      <div class="inq-form-card">
        <div class="field-group">
          <label class="field-label">Status</label>
          <div style="position:relative">
            <select id="inq-status" class="field-input" style="appearance:none;-webkit-appearance:none;padding-right:36px;font-weight:600;color:${statusDotColor}">
              ${(['new','contacted','site_visit','quoted','won','lost'] as InquiryStatus[]).map(s =>
                `<option value="${s}"${inq.status === s ? ' selected' : ''} style="color:${inqStatusColor(s)};font-weight:600">${inqStatusLabel(s)}</option>`
              ).join('')}
            </select>
            <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);pointer-events:none;color:#888;font-size:.75rem">▼</span>
          </div>
        </div>
        <div class="field-group" style="margin-bottom:0">
          <label class="field-label">Notes</label>
          <textarea id="inq-notes" class="field-textarea" rows="4" placeholder="Details, follow-up reminders, budget discussed…">${inq.notes}</textarea>
        </div>
      </div>

      <button class="dash-cta" id="inq-save-btn">
        ${isNew ? '＋ Save Inquiry' : '✓ Save Changes'}
      </button>
      ${!isNew ? `
        <button class="inq-delete-btn" id="inq-delete-btn">
          🗑 Delete Inquiry
        </button>
      ` : ''}
    </div>
  `;

  // Update select colour when changed
  const statusSel = document.getElementById('inq-status') as HTMLSelectElement;
  statusSel.addEventListener('change', () => {
    statusSel.style.color = inqStatusColor(statusSel.value as InquiryStatus);
  });

  document.getElementById('inq-save-btn')!.addEventListener('click', () => {
    const name     = (document.getElementById('inq-name') as HTMLInputElement).value.trim();
    const phone    = (document.getElementById('inq-phone') as HTMLInputElement).value.trim();
    const service  = (document.getElementById('inq-service') as HTMLInputElement).value.trim();
    const location = (document.getElementById('inq-location') as HTMLInputElement).value.trim();
    const status   = statusSel.value as InquiryStatus;
    const notes    = (document.getElementById('inq-notes') as HTMLTextAreaElement).value.trim();

    if (!name && !phone) { toast('Enter at least a name or phone number'); return; }

    const inqs2: Inquiry[] = load<Inquiry>(KEYS.inqs);
    if (isNew) {
      inqs2.unshift({ id: crypto.randomUUID(), createdAt: new Date().toISOString(), name, phone, service, location, notes, status });
    } else {
      const idx = inqs2.findIndex(i => i.id === detailInqId);
      if (idx >= 0) inqs2[idx] = { ...inqs2[idx], name, phone, service, location, notes, status };
    }
    save(KEYS.inqs, inqs2);
    toast(isNew ? 'Inquiry saved' : 'Changes saved');
    viewHistory = [];
    navigate('inquiries', false);
  });

  document.getElementById('inq-delete-btn')?.addEventListener('click', () => {
    showModal('Delete Inquiry', `
      <p style="color:#666;font-size:.9rem;line-height:1.5">Delete this inquiry? This cannot be undone.</p>
    `, [
      { label: 'Cancel', cls: 'modal-cancel', action: closeModal },
      { label: 'Delete', cls: 'modal-confirm danger', action: () => {
        const inqs2: Inquiry[] = load<Inquiry>(KEYS.inqs).filter(i => i.id !== detailInqId);
        save(KEYS.inqs, inqs2);
        closeModal();
        toast('Inquiry deleted');
        viewHistory = [];
        navigate('inquiries', false);
      }},
    ]);
  });
}

/* ── WIZARD ──────────────────────────────────────────────── */
let _currentQtnId: string | null = null;

function startWizard(qtn?: Quotation) {
  editingId = qtn?.id || null;
  wizardData = qtn ? { ...defaultInputs(), ...qtn } : defaultInputs();
  wizardData.brands = [...(qtn?.brands ?? DEFAULT_BRANDS)];
  wizardData.paymentTerms = (qtn?.paymentTerms ?? DEFAULT_PAYMENT_TERMS).map(t => ({ ...t }));
  wizardStep = 1;
  navigate('wizard');
}

function startComparisonWizard() {
  startWizard();
  (wizardData as any).isComparison = true;
}

function renderWizard() {
  progressFill.style.width = `${(wizardStep / WIZARD_STEPS) * 100}%`;
  stepLabel.textContent = `Step ${wizardStep} of ${WIZARD_STEPS}`;

  const stepNames = [
    'Client Details', 'Project Type', 'Package', 'Areas', 'Quantities',
    'Plumbing', 'Shower', 'Extras', 'Difficulty', 'Brands & Terms', 'Review',
  ];
  stepName.textContent = stepNames[wizardStep - 1] || '';

  document.getElementById('wizard-back-btn')!.textContent = wizardStep === 1 ? 'Cancel' : '← Back';
  document.getElementById('wizard-next-btn')!.textContent = wizardStep === WIZARD_STEPS ? '✓ Save' : 'Next →';

  switch (wizardStep) {
    case 1:  renderStep1(); break;
    case 2:  renderStep2(); break;
    case 3:  renderStep3(); break;
    case 4:  renderStep4(); break;
    case 5:  renderStep5(); break;
    case 6:  renderStep6(); break;
    case 7:  renderStep7(); break;
    case 8:  renderStep8(); break;
    case 9:  renderStep9(); break;
    case 10: renderStep10(); break;
    case 11: renderStep11(); break;
  }
}

