        </div>
      </div>

      <div class="step-q">Difficulty / complexity</div>
      <div class="step-hint">Adjust for site challenges. 1.00 = standard. Applied to all costs before profit.</div>
      <div class="slider-current" id="diff-display">${(val / 100).toFixed(2)}×</div>
      <div class="slider-wrap">
        <input type="range" class="slider-inp" id="diff-slider"
          min="80" max="150" step="1" value="${val}">
        <div class="slider-labels">
          <span>0.80× Easy</span>
          <span>1.00× Standard</span>
          <span>1.50× Complex</span>
        </div>
      </div>

      <div class="step-q" style="margin-top:2rem">Profit margin (%)</div>
      <div class="step-hint">Percentage added on top of the difficulty-adjusted cost.</div>
      <input type="number" id="profit-input" class="field-input" min="0" max="50" step="1"
        value="${profitPct}" style="max-width:140px;font-size:1.1rem;font-weight:600;text-align:center">

      <div class="step-q" style="margin-top:2rem">Other Cost (optional)</div>
      <div class="step-hint">Custom line item — enter a label and amount. Appears on the PDF.</div>
      <input type="text" id="other-cost-label" class="field-input"
        placeholder="e.g. Tile Design Fee" value="${(wizardData as any).otherCostLabel || ''}"
        style="margin-bottom:8px">
      <input type="number" id="other-cost-amount" class="field-input" min="0" step="500"
        value="${(wizardData as any).otherCost || ''}" placeholder="Amount (Rs.)">
