  `;
  const slider = document.getElementById('diff-slider') as HTMLInputElement;
  const display = document.getElementById('diff-display')!;
  slider.addEventListener('input', () => {
    const score = parseInt(slider.value, 10) / 100;
    wizardData.difficultyScore = score;
    display.textContent = `${score.toFixed(2)}×`;
  });
  document.querySelectorAll<HTMLElement>('[data-tier]').forEach(card => {
