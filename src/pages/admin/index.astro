/* ── WhatsApp sharing ────────────────────────────────────── */
function shareQuotationWA(q: Quotation) {
  const bd = q.breakdown;
  const ref = (q as any).ref || 'LH-QTN';
  const text = [
    `*LUXEHOME Quotation — ${ref}*`,
    ``,
    `Client: ${q.clientName}`,
    `Project: ${q.projectName || q.projectLocation}`,
    `Date: ${fmtDate(q.quotationDate)}`,
    `Package: ${packageLabel(q.package)}`,
    ``,
    `*Total Investment: ${fmtRs(bd.finalAmount)}*`,
    ``,
    `Payment Terms:`,
    ...q.paymentTerms.map(t => `• ${t.label}: ${t.percentage}% (${fmtRs(bd.finalAmount * t.percentage / 100)})`),
    ``,
    `_This quotation is valid for 30 days._`,
  ].join('\n');

  const phone = q.clientPhone?.replace(/\D/g, '') || '';
  const waPhone = phone.startsWith('94') ? phone : phone.startsWith('0') ? '94' + phone.slice(1) : '';
  const url = `https://wa.me/${waPhone}?text=${encodeURIComponent(text)}`;
  window.open(url, '_blank');
}

