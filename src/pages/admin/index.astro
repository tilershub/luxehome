  document.querySelectorAll<HTMLButtonElement>('[data-invstatus]').forEach(btn => {
    btn.addEventListener('click', () => {
      const invs2: Invoice[] = load(KEYS.invs);
      const idx = invs2.findIndex(x => x.id === detailInvId);
      if (idx >= 0) { invs2[idx].status = btn.dataset.invstatus as any; save(KEYS.invs, invs2); }
      toast(`Status: ${btn.dataset.invstatus}`); renderInvDetail();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-delpayment]').forEach(btn => {
    btn.addEventListener('click', () => {
      const invs2: Invoice[] = load(KEYS.invs);
      const idx = invs2.findIndex(x => x.id === detailInvId);
      if (idx >= 0) {
        const pi = parseInt(btn.dataset.delpayment!);
        invs2[idx].payments.splice(pi, 1);
        invs2[idx].paidAmount = invs2[idx].payments.reduce((s, p) => s + p.amount, 0);
        if (invs2[idx].paidAmount <= 0) invs2[idx].status = 'sent';
        else if (invs2[idx].paidAmount < invs2[idx].finalAmount) invs2[idx].status = 'partially-paid';
        else invs2[idx].status = 'paid';
        save(KEYS.invs, invs2);
      }
      toast('Payment removed'); renderInvDetail();
    });
  });

  document.getElementById('add-pay-btn')!.addEventListener('click', () => {
    const amount = parseFloat((document.getElementById('pay-amount') as HTMLInputElement).value);
    if (isNaN(amount) || amount <= 0) { toast('Enter a valid amount'); return; }
    const date = (document.getElementById('pay-date') as HTMLInputElement).value || new Date().toISOString().split('T')[0];
    const note = (document.getElementById('pay-note') as HTMLInputElement).value.trim();
    const invs2: Invoice[] = load(KEYS.invs);
    const idx = invs2.findIndex(x => x.id === detailInvId);
    if (idx >= 0) {
      invs2[idx].payments.push({ date, amount, note });
      invs2[idx].paidAmount = invs2[idx].payments.reduce((s, p) => s + p.amount, 0);
      if (invs2[idx].paidAmount >= invs2[idx].finalAmount) invs2[idx].status = 'paid';
      else invs2[idx].status = 'partially-paid';
      save(KEYS.invs, invs2);
    }
    toast('Payment recorded'); renderInvDetail();
  });

  document.getElementById('inv-pdf-btn')!.addEventListener('click', () => printInvoicePDF(inv));
  document.getElementById('inv-wa-btn')!.addEventListener('click', () => shareInvoiceWA(inv));
  document.getElementById('inv-del-btn')!.addEventListener('click', () => {
    showModal('Delete Invoice', `<p style="color:#666;font-size:.9rem">Delete this invoice?</p>`, [
      { label: 'Cancel', cls: 'modal-cancel', action: closeModal },
      { label: 'Delete', cls: 'modal-confirm danger', action: () => {
        const invs2: Invoice[] = load(KEYS.invs);
        save(KEYS.invs, invs2.filter(x => x.id !== detailInvId));
        closeModal(); toast('Invoice deleted');
        viewHistory = []; navigate('invoices');
      }},
    ]);
  });
}

/* ── Convert to invoice ──────────────────────────────────── */
function convertToInvoice(q: Quotation) {
  const invs: Invoice[] = load(KEYS.invs);
  const existing = invs.find(i => i.quotationId === q.id);
  if (existing) {
    toast('Invoice already exists'); openInvDetail(existing.id); return;
  }
  const counters = getCounters();
  counters.inv++;
  saveCounters(counters);
  const ref = (q as any).ref || qtnNumber(counters.inv);
  const today = new Date();
  const due = new Date(today); due.setDate(due.getDate() + 30);
  const inv: Invoice = {
    id: crypto.randomUUID(),
    quotationId: q.id,
    quotationRef: ref,
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    status: 'draft',
    invoiceDate: today.toISOString().split('T')[0],
    dueDate: due.toISOString().split('T')[0],
    finalAmount: q.breakdown.finalAmount,
    paidAmount: 0,
    payments: [],
    clientName: q.clientName,
    clientPhone: q.clientPhone,
    projectLocation: q.projectLocation,
    projectName: q.projectName,
    package: q.package,
    projectType: q.projectType,
    paymentTerms: q.paymentTerms,
  };
  invs.unshift(inv);
  save(KEYS.invs, invs);

  // Mark quotation converted
  const qtns: Quotation[] = load(KEYS.qtns);
  const idx = qtns.findIndex(x => x.id === q.id);
  if (idx >= 0) { qtns[idx].status = 'converted'; save(KEYS.qtns, qtns); }

  toast('Invoice created'); openInvDetail(inv.id);
}

