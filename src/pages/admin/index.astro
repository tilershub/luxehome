  { val: 'l-swing',     icon: '📐', label: 'L-Shape Swing' },
  { val: 'l-sliding',   icon: '📐', label: 'L-Shape Sliding' },
  { val: 'panel-swing', icon: '▬',  label: 'Panel Swing' },
  { val: 'panel-sliding',icon: '▬', label: 'Panel Sliding' },
