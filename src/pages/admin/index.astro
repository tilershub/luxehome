  const profitPct = Math.round((wizardData.profitMargin ?? 0.10) * 100);
  const tier = (wizardData as any).packageTier || '';
  main.innerHTML = `
    <div class="step-content">
      <div class="step-q">Package tier (optional)</div>
      <div class="step-hint">Selected tier appears on the PDF quotation.</div>
      <div class="option-grid" style="grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:1.4rem">
        <div class="opt-card ${!tier ? 'selected' : ''}" data-tier="">
          <span class="opt-label" style="font-size:.8rem">None</span>
        </div>
        <div class="opt-card ${tier==='economy' ? 'selected' : ''}" data-tier="economy">
          <span class="opt-label" style="font-size:.8rem">Economy</span>
        </div>
        <div class="opt-card ${tier==='premium' ? 'selected' : ''}" data-tier="premium">
          <span class="opt-label" style="font-size:.8rem">Premium</span>
        </div>
