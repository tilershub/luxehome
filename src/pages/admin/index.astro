/* ── Wizard helpers ──────────────────────────────────────── */
function setupSingleSelect(selector: string, field: keyof QuotationInputs) {
  document.querySelectorAll<HTMLElement>(selector).forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll(selector).forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      (wizardData as any)[field] = card.dataset.val;
    });
  });
}

function stepper(label: string, sub: string, key: string, val: number, min: number, max: number): string {
  return `
    <div class="stepper-row">
      <div><div class="stepper-label">${label}</div><div class="stepper-sub">${sub}</div></div>
      <div class="stepper-ctrl">
        <button class="stepper-btn" data-step="${key}" data-dir="-1" data-min="${min}" data-max="${max}">−</button>
        <span class="stepper-val" id="step-val-${key}">${val}</span>
        <button class="stepper-btn" data-step="${key}" data-dir="1" data-min="${min}" data-max="${max}">+</button>
      </div>
    </div>
  `;
}

function setupSteppers(map: Record<string, keyof QuotationInputs>) {
  document.querySelectorAll<HTMLButtonElement>('[data-step][data-dir]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.step!;
      const dir = parseInt(btn.dataset.dir!);
      const min = parseInt(btn.dataset.min || '0');
      const max = parseInt(btn.dataset.max || '999');
      const field = map[key];
      if (!field) return;
      const cur = (wizardData[field] as number) || 0;
      const next = Math.max(min, Math.min(max, cur + dir));
      (wizardData as any)[field] = next;
      const el = document.getElementById(`step-val-${key}`);
      if (el) el.textContent = String(next);
    });
  });
}

function toggle(label: string, sub: string, key: string, val: boolean): string {
  return `
    <div class="toggle-row" data-toggle="${key}">
      <div><div class="toggle-label">${label}</div><div class="toggle-sub">${sub}</div></div>
      <div class="toggle-switch ${val ? 'on' : ''}" id="sw-${key}"></div>
    </div>
  `;
}

function setupToggles(map: Record<string, keyof QuotationInputs>) {
  document.querySelectorAll<HTMLElement>('[data-toggle]').forEach(row => {
    row.addEventListener('click', () => {
      const key = row.dataset.toggle!;
      const field = map[key];
      if (!field) return;
      const next = !((wizardData as any)[field]);
      (wizardData as any)[field] = next;
      const sw = document.getElementById(`sw-${key}`)!;
      sw.classList.toggle('on', next);
    });
  });
}

/* ── Collect step data ───────────────────────────────────── */
function collectCurrentStep(): boolean {
  switch (wizardStep) {
    case 1:  return collectStep1();
    case 3:  return collectStep3();
    case 4:  return collectStep4();
    case 6:  return collectStep6();
    case 7:  return collectStep7();
    case 8:  return collectStep8();
    case 9:  return collectStep9();
    case 10: return collectStep10();
    default: return true;
  }
}

/* ── Wizard navigation ───────────────────────────────────── */
document.getElementById('wizard-back-btn')!.addEventListener('click', () => {
  if (wizardStep === 1) { viewHistory = []; navigate('quotations'); return; }
  wizardStep--;
  renderWizard();
});

document.getElementById('wizard-next-btn')!.addEventListener('click', () => {
  if (!collectCurrentStep()) return;
  if (wizardStep === WIZARD_STEPS) { saveQuotation(); return; }
  wizardStep++;
  renderWizard();
});

/* ── Modal helpers ───────────────────────────────────────── */
type ModalBtn = { label: string; cls: string; action: () => void };
function showModal(title: string, body: string, buttons: ModalBtn[]) {
  const overlay = document.getElementById('modal-overlay')!;
  const box = document.getElementById('modal-box')!;
  box.innerHTML = `
    <div class="modal-title">${title}</div>
    ${body}
    <div class="modal-actions">
      ${buttons.map((b, i) => `<button class="${b.cls}" data-modal-btn="${i}">${b.label}</button>`).join('')}
    </div>
  `;
  overlay.classList.add('open');
  buttons.forEach((b, i) => {
    box.querySelector<HTMLButtonElement>(`[data-modal-btn="${i}"]`)!
      .addEventListener('click', b.action);
  });
  overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); }, { once: true });
}
function closeModal() {
  document.getElementById('modal-overlay')!.classList.remove('open');
}

/* ── Toast ───────────────────────────────────────────────── */
let _toastTimer: ReturnType<typeof setTimeout>;
function toast(msg: string) {
  const el = document.getElementById('toast')!;
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(_toastTimer);
  _toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

/* ── Escape helper ───────────────────────────────────────── */
function esc(s: string | null | undefined): string {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ── Bottom nav clicks ───────────────────────────────────── */
document.querySelectorAll<HTMLButtonElement>('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    viewHistory = [];
    navigate(btn.dataset.view || 'dashboard', false);
  });
});

/* ── Header back button ──────────────────────────────────── */
headerBack.addEventListener('click', () => {
  if (currentView === 'wizard') {
    if (wizardStep > 1) { wizardStep--; renderWizard(); }
    else { viewHistory = []; navigate('quotations'); }
  } else {
    goBack();
  }
});

/* ── Boot ────────────────────────────────────────────────── */
navigate('dashboard', false);
</script>
