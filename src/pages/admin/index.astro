  const slider = document.getElementById('diff-slider') as HTMLInputElement;
  const display = document.getElementById('diff-display')!;
  slider.addEventListener('input', () => {
    const score = parseInt(slider.value, 10) / 100;
    wizardData.difficultyScore = score;
    display.textContent = `${score.toFixed(2)}×`;
  });
}

function collectStep9(): boolean {
  const raw = parseInt((document.getElementById('diff-slider') as HTMLInputElement | null)?.value || '100', 10);
  const score = Math.max(80, Math.min(150, isNaN(raw) ? 100 : raw)) / 100;
  wizardData.difficultyScore = score;
  const pct = parseFloat((document.getElementById('profit-input') as HTMLInputElement | null)?.value || '15');
  wizardData.profitMargin = Math.max(0, Math.min(0.5, (isNaN(pct) ? 15 : pct) / 100));
  const ocLabel = (document.getElementById('other-cost-label') as HTMLInputElement | null)?.value?.trim() || '';
  const ocAmt   = parseFloat((document.getElementById('other-cost-amount') as HTMLInputElement | null)?.value || '');
  (wizardData as any).otherCostLabel = ocLabel;
  (wizardData as any).otherCost = (!isNaN(ocAmt) && ocAmt > 0) ? ocAmt : 0;
  return true;
}

