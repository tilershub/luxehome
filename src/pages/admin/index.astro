        const invs2: Invoice[] = load(KEYS.invs);
        save(KEYS.invs, invs2.filter(x => x.id !== detailInvId));
        closeModal(); toast('Invoice deleted');
        viewHistory = []; navigate('invoices');
      }},
    ]);
  });
}

/* ── Convert to invoice ──────────────────────────────────── */
function convertToInvoice(q: Quotation) {
  const invs: Invoice[] = load(KEYS.invs);
  const existing = invs.find(i => i.quotationId === q.id);
  if (existing) {
    toast('Invoice already exists'); openInvDetail(existing.id); return;
  }
  const counters = getCounters();
  counters.inv++;
  saveCounters(counters);
  const ref = (q as any).ref || qtnNumber(counters.inv);
  const today = new Date();
  const due = new Date(today); due.setDate(due.getDate() + 30);
  const inv: Invoice = {
    id: crypto.randomUUID(),
    quotationId: q.id,
    quotationRef: ref,
    createdAt: new Date().toISOString(),
    updatedAt: new Date().toISOString(),
    status: 'draft',
    invoiceDate: today.toISOString().split('T')[0],
    dueDate: due.toISOString().split('T')[0],
    finalAmount: q.breakdown.finalAmount,
    paidAmount: 0,
    payments: [],
    clientName: q.clientName,
    clientPhone: q.clientPhone,
    projectLocation: q.projectLocation,
    projectName: q.projectName,
    projectType: q.projectType,
    paymentTerms: q.paymentTerms,
  };
  invs.unshift(inv);
  save(KEYS.invs, invs);

  // Mark quotation converted
  const qtns: Quotation[] = load(KEYS.qtns);
  const idx = qtns.findIndex(x => x.id === q.id);
  if (idx >= 0) { qtns[idx].status = 'converted'; save(KEYS.qtns, qtns); }

  toast('Invoice created'); openInvDetail(inv.id);
}

