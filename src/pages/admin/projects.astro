---
// Project management SPA — client-side only, no server-side code
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Projects — LUXEHOME Admin</title>
  <link rel="icon" href="/favicon.svg" />
</head>
<body>
  <div id="app">
    <header id="hdr">
      <a href="/admin" class="back-lnk">← Admin</a>
      <span id="hdr-title">Projects</span>
      <button id="new-btn" class="hdr-action">＋ New</button>
    </header>
    <main id="main"></main>
    <div id="toast" aria-live="polite"></div>
  </div>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #161c1a;
      --surface: #1e2422;
      --surface2: #252c29;
      --border: rgba(255,255,255,.08);
      --cream: #f0ece0;
      --muted: rgba(240,236,224,.6);
      --clay: #b8945a;
      --green: #22c55e;
      --red: #ef4444;
      --blue: #4a90d9;
    }
    html, body { height: 100%; background: var(--bg); color: var(--cream); font-family: 'DM Sans', system-ui, sans-serif; font-size: 15px; }
    #app { display: flex; flex-direction: column; height: 100%; }
    #hdr {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px; background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 50;
    }
    .back-lnk { color: var(--clay); text-decoration: none; font-size: .85rem; white-space: nowrap; }
    #hdr-title { flex: 1; font-weight: 600; font-size: .95rem; }
    .hdr-action {
      padding: 7px 14px; border-radius: 6px; border: none;
      background: var(--clay); color: #fff; font-weight: 600; font-size: .82rem;
      cursor: pointer; white-space: nowrap;
    }
    .hdr-action:disabled { opacity: .5; }
    #main { flex: 1; overflow-y: auto; }

    /* ── List view ── */
    .list-toolbar {
      display: flex; gap: 8px; padding: 14px 16px;
      border-bottom: 1px solid var(--border); background: var(--surface);
      position: sticky; top: 57px; z-index: 40;
    }
    .search-box {
      flex: 1; padding: 8px 12px; border-radius: 7px;
      border: 1px solid var(--border); background: var(--bg);
      color: var(--cream); font-size: .85rem;
    }
    .filter-sel {
      padding: 8px 10px; border-radius: 7px;
      border: 1px solid var(--border); background: var(--bg);
      color: var(--cream); font-size: .82rem; cursor: pointer;
    }
    .project-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }
    .proj-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 14px 16px;
      display: flex; align-items: center; gap: 12px; cursor: pointer;
      transition: border-color .2s;
    }
    .proj-card:hover { border-color: var(--clay); }
    .proj-thumb {
      width: 52px; height: 52px; border-radius: 7px; object-fit: cover;
      background: var(--surface2); flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
    }
    .proj-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 7px; }
    .proj-body { flex: 1; min-width: 0; }
    .proj-title { font-weight: 600; font-size: .92rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .proj-meta { font-size: .78rem; color: var(--muted); margin-top: 3px; }
    .status-pill {
      font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
      padding: 3px 8px; border-radius: 20px; white-space: nowrap; flex-shrink: 0;
    }
    .empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
    .empty-state .ei { font-size: 2.5rem; margin-bottom: 12px; }
    .empty-state h3 { font-size: 1rem; margin-bottom: 6px; color: var(--cream); }

    /* ── Editor ── */
    .tab-bar {
      display: flex; overflow-x: auto; gap: 2px;
      padding: 10px 16px 0; background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: sticky; top: 57px; z-index: 40;
      scrollbar-width: none;
    }
    .tab-bar::-webkit-scrollbar { display: none; }
    .tab-btn {
      padding: 8px 14px; border: none; background: none; color: var(--muted);
      font-size: .8rem; font-weight: 600; cursor: pointer; white-space: nowrap;
      border-bottom: 2px solid transparent; transition: color .2s, border-color .2s;
    }
    .tab-btn.active { color: var(--clay); border-bottom-color: var(--clay); }
    .tab-btn.has-error { color: var(--red); }
    .tab-content { padding: 20px 16px 80px; }

    /* ── Form elements ── */
    .field { margin-bottom: 18px; }
    .field label { display: block; font-size: .75rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 6px; }
    .field label .req { color: var(--clay); }
    .field input, .field select, .field textarea {
      width: 100%; padding: 10px 12px; border-radius: 8px;
      border: 1px solid var(--border); background: var(--surface2);
      color: var(--cream); font-size: .9rem; font-family: inherit;
    }
    .field input:focus, .field select:focus, .field textarea:focus {
      outline: none; border-color: var(--clay);
    }
    .field input.error, .field textarea.error { border-color: var(--red); }
    .field textarea { min-height: 100px; resize: vertical; }
    .field .hint { font-size: .72rem; color: var(--muted); margin-top: 5px; }
    .field .char-count { font-size: .72rem; color: var(--muted); margin-top: 4px; text-align: right; }
    .char-count.over { color: var(--red); }
    .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    select option { background: var(--surface2); }

    /* ── Image upload ── */
    .img-upload-area {
      border: 2px dashed var(--border); border-radius: 10px;
      padding: 20px; text-align: center; cursor: pointer;
      transition: border-color .2s;
    }
    .img-upload-area:hover { border-color: var(--clay); }
    .img-preview {
      width: 100%; max-height: 180px; object-fit: cover;
      border-radius: 8px; margin-bottom: 8px;
    }
    .img-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
    .img-item {
      position: relative; width: 80px; height: 80px; border-radius: 7px; overflow: hidden;
      background: var(--surface2); flex-shrink: 0;
    }
    .img-item img { width: 100%; height: 100%; object-fit: cover; }
    .img-rm {
      position: absolute; top: 2px; right: 2px;
      background: rgba(0,0,0,.7); border: none; color: #fff;
      width: 20px; height: 20px; border-radius: 50%; font-size: .7rem;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .upload-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 8px 14px; border-radius: 7px;
      border: 1px solid var(--border); background: var(--surface2);
      color: var(--cream); font-size: .82rem; cursor: pointer;
    }
    .upload-btn:hover { border-color: var(--clay); }
    .upload-progress { font-size: .78rem; color: var(--clay); margin-top: 6px; }

    /* ── Dynamic lists ── */
    .dyn-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 10px; }
    .dyn-row {
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: 8px; padding: 12px;
    }
    .dyn-row-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .dyn-row-label { font-size: .78rem; font-weight: 600; color: var(--muted); }
    .rm-row-btn { background: none; border: none; color: var(--red); cursor: pointer; font-size: .85rem; padding: 2px 6px; }
    .add-row-btn {
      width: 100%; padding: 9px; border-radius: 8px;
      border: 1px dashed var(--border); background: none;
      color: var(--clay); font-size: .82rem; cursor: pointer;
    }
    .add-row-btn:hover { border-color: var(--clay); background: rgba(184,148,90,.07); }

    /* ── Toggle switch ── */
    .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); }
    .toggle-label { font-size: .88rem; }
    .toggle-sub { font-size: .75rem; color: var(--muted); margin-top: 2px; }
    .toggle {
      position: relative; width: 44px; height: 24px; flex-shrink: 0;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute; inset: 0; border-radius: 24px;
      background: var(--border); transition: background .2s; cursor: pointer;
    }
    .toggle-slider::after {
      content: ''; position: absolute; width: 18px; height: 18px;
      left: 3px; top: 3px; border-radius: 50%; background: #fff;
      transition: transform .2s;
    }
    .toggle input:checked + .toggle-slider { background: var(--clay); }
    .toggle input:checked + .toggle-slider::after { transform: translateX(20px); }

    /* ── Publishing / Save bar ── */
    .save-bar {
      position: fixed; bottom: 0; left: 0; right: 0;
      background: var(--surface); border-top: 1px solid var(--border);
      padding: 12px 16px; display: flex; gap: 10px; z-index: 100;
    }
    .save-btn {
      flex: 1; padding: 12px; border-radius: 8px; border: none;
      background: var(--clay); color: #fff; font-weight: 700; font-size: .9rem; cursor: pointer;
    }
    .save-btn:disabled { opacity: .5; cursor: not-allowed; }
    .preview-btn {
      padding: 12px 16px; border-radius: 8px;
      border: 1px solid var(--border); background: none;
      color: var(--cream); font-size: .85rem; cursor: pointer; white-space: nowrap;
    }
    .status-select {
      padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border);
      background: var(--surface2); color: var(--cream); font-size: .88rem; cursor: pointer;
    }

    /* ── Toast ── */
    #toast {
      position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%);
      background: #333; color: var(--cream); padding: 10px 20px; border-radius: 8px;
      font-size: .85rem; z-index: 200; opacity: 0; transition: opacity .25s;
      pointer-events: none; white-space: nowrap;
    }
    #toast.show { opacity: 1; }
    #toast.success { background: #1a472a; border: 1px solid var(--green); }
    #toast.error { background: #4a1a1a; border: 1px solid var(--red); }

    /* ── Delete confirm ── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.6);
      display: flex; align-items: center; justify-content: center;
      z-index: 300; padding: 20px;
    }
    .modal {
      background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
      padding: 24px; max-width: 340px; width: 100%;
    }
    .modal h3 { font-size: 1rem; margin-bottom: 8px; }
    .modal p { font-size: .85rem; color: var(--muted); margin-bottom: 20px; }
    .modal-btns { display: flex; gap: 10px; }
    .btn-danger { flex: 1; padding: 11px; border-radius: 8px; border: none; background: var(--red); color: #fff; font-weight: 600; cursor: pointer; }
    .btn-cancel { flex: 1; padding: 11px; border-radius: 8px; border: 1px solid var(--border); background: none; color: var(--cream); cursor: pointer; }

    @media (min-width: 640px) {
      .tab-content { max-width: 720px; margin: 0 auto; }
      .project-list { max-width: 720px; margin: 0 auto; }
      .list-toolbar { max-width: 720px; margin: 0 auto; }
    }
  </style>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const BUCKET = 'project-media';

    const CAT_LABELS = { bathroom: 'Luxury Bathroom Renovation', flooring: 'Designer Floors', staircase: 'Designer Staircases', kitchen: 'Luxury Kitchens' };
    const STYLE_LABELS = { modern: 'Modern', minimalist: 'Minimalist', luxury: 'Luxury', contemporary: 'Contemporary' };
    const STATUS_COLORS = { draft: '#888', published: '#22c55e', featured: '#b8945a' };
    const TABS = ['Basic Details', 'Media', 'Story & Scope', 'Timeline', 'Testimonial', 'SEO', 'Publishing'];
    const REQUIRED_FIELDS = { 0: ['title','category','location'], 1: ['cover_image'], 2: ['project_overview'], 5: ['meta_title','meta_description'] };

    let sb, main, hdrTitle, newBtn;
    let projects = [];
    let proj = null; // current project being edited
    let view = 'list';
    let activeTab = 0;
    let saving = false;
    let filterStatus = 'all';
    let filterSearch = '';

    function blankProject() {
      return {
        id: null, title: '', slug: '', category: 'bathroom', location: '',
        reference_id: '', area_label: '', completion_month: '',
        completion_date: '', completion_year: new Date().getFullYear(),
        design_style: 'modern', status: 'draft',
        cover_image: '', hero_video: '', youtube_short: '',
        before_images: [], after_images: [], progress_images: [], gallery_images: [],
        old_space_images: [], design_3d_images: [],
        episode_01_youtube: '', episode_02_youtube: '',
        episode_01_thumbnail: '', episode_02_thumbnail: '',
        project_overview: '', client_requirements: '', design_concept: '',
        scope_of_work: '', materials_brands: '',
        project_timeline: [], challenges_solutions: '',
        testimonial_text: '', testimonial_author: '', testimonial_role: '',
        cost_range: '', faqs: [], related_projects: [],
        cta_book_consultation: true, cta_whatsapp: true,
        meta_title: '', meta_description: '', og_image: '', canonical_url: '',
        breadcrumb_title: '', include_in_sitemap: true,
        homepage_display: false
      };
    }

    // ── Supabase helpers ──────────────────────────────────────────────────

    async function loadProjects() {
      if (!sb) return;
      const { data, error } = await sb.from('projects')
        .select('id,title,slug,category,location,completion_year,status,cover_image,created_at')
        .order('created_at', { ascending: false });
      if (!error) projects = data || [];
    }

    async function saveProject() {
      if (!sb || saving) return;
      collectCurrentTab();
      if (!validateProject()) return;
      saving = true;
      renderSaveBar();
      const payload = { ...proj };
      delete payload.id;
      delete payload.created_at;
      delete payload.updated_at;
      let error;
      if (proj.id) {
        ({ error } = await sb.from('projects').update(payload).eq('id', proj.id));
      } else {
        const { data, error: e } = await sb.from('projects').insert(payload).select().single();
        error = e;
        if (data) proj.id = data.id;
      }
      saving = false;
      if (error) {
        toast('Save failed: ' + error.message, 'error');
      } else {
        toast('Project saved', 'success');
        await loadProjects();
      }
      renderSaveBar();
    }

    async function deleteProject(id) {
      if (!sb) return;
      const { error } = await sb.from('projects').delete().eq('id', id);
      if (error) { toast('Delete failed', 'error'); return; }
      toast('Project deleted', 'success');
      await loadProjects();
      goList();
    }

    async function uploadImage(file, existingId) {
      if (!sb) return null;
      const pId = existingId || proj.id || 'new-' + Date.now();
      const path = `${pId}/${Date.now()}-${file.name.replace(/[^a-z0-9.\-_]/gi,'_')}`;
      const { data, error } = await sb.storage.from(BUCKET).upload(path, file, { upsert: false });
      if (error) { toast('Upload failed: ' + error.message, 'error'); return null; }
      const { data: { publicUrl } } = sb.storage.from(BUCKET).getPublicUrl(data.path);
      return publicUrl;
    }

    // ── Validation ────────────────────────────────────────────────────────

    function validateProject() {
      const errors = [];
      if (!proj.title.trim())          errors.push('Title is required (Basic Details)');
      if (!proj.category)              errors.push('Category is required (Basic Details)');
      if (!proj.location.trim())       errors.push('Location is required (Basic Details)');
      if (!proj.cover_image)           errors.push('Cover image is required (Media)');
      if (!proj.project_overview?.trim()) errors.push('Project overview is required (Story & Scope)');
      if (!proj.meta_title?.trim())    errors.push('Meta title is required (SEO)');
      if (!proj.meta_description?.trim()) errors.push('Meta description is required (SEO)');
      if (errors.length) {
        toast(errors[0], 'error', 4000);
        return false;
      }
      return true;
    }

    // ── Slug generator ────────────────────────────────────────────────────

    function toSlug(str) {
      return str.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }

    // ── View navigation ───────────────────────────────────────────────────

    function goList() {
      view = 'list';
      proj = null;
      activeTab = 0;
      hdrTitle.textContent = 'Projects';
      newBtn.style.display = '';
      renderList();
    }

    function goEditor(p = null) {
      view = 'editor';
      proj = p ? { ...p, before_images: p.before_images || [], after_images: p.after_images || [], progress_images: p.progress_images || [], gallery_images: p.gallery_images || [], old_space_images: p.old_space_images || [], design_3d_images: p.design_3d_images || [], project_timeline: p.project_timeline || [], faqs: p.faqs || [], related_projects: p.related_projects || [] } : blankProject();
      activeTab = 0;
      hdrTitle.textContent = proj.id ? 'Edit Project' : 'New Project';
      newBtn.style.display = 'none';
      renderEditor();
    }

    // ── Collect helpers ───────────────────────────────────────────────────

    function g(id) { return document.getElementById(id); }
    function gv(id, fallback = '') { return g(id)?.value ?? fallback; }
    function gc(id) { return g(id)?.checked ?? false; }

    function collectCurrentTab() {
      switch (activeTab) {
        case 0: collectTab0(); break;
        case 1: collectTab1(); break;
        case 2: collectTab2(); break;
        case 3: collectTab3(); break;
        case 4: collectTab4(); break;
        case 5: collectTab5(); break;
        case 6: collectTab6(); break;
      }
    }

    function collectTab0() {
      proj.title            = gv('f-title');
      proj.slug             = gv('f-slug');
      proj.category         = gv('f-category');
      proj.location         = gv('f-location');
      proj.reference_id     = gv('f-ref-id');
      proj.area_label       = gv('f-area-label');
      proj.completion_date  = gv('f-date');
      proj.completion_year  = parseInt(gv('f-year')) || new Date().getFullYear();
      proj.completion_month = parseInt(gv('f-month')) || null;
      proj.design_style     = gv('f-style');
    }

    function collectTab1() {
      proj.cover_image          = gv('f-cover');
      proj.hero_video           = gv('f-video');
      proj.youtube_short        = gv('f-yt-short');
      proj.episode_01_youtube   = gv('f-ep1-yt');
      proj.episode_02_youtube   = gv('f-ep2-yt');
      proj.episode_01_thumbnail = gv('f-ep1-thumb');
      proj.episode_02_thumbnail = gv('f-ep2-thumb');
      // multi-image arrays are updated live via the add/remove handlers
    }

    function collectTab2() {
      proj.project_overview    = gv('f-overview');
      proj.client_requirements = gv('f-requirements');
      proj.design_concept      = gv('f-concept');
      proj.scope_of_work       = gv('f-scope');
      proj.materials_brands    = gv('f-materials');
    }

    function collectTab3() {
      const rows = document.querySelectorAll('.timeline-row');
      proj.project_timeline = Array.from(rows).map(row => ({
        phase:       row.querySelector('.tl-phase')?.value || '',
        duration:    row.querySelector('.tl-duration')?.value || '',
        description: row.querySelector('.tl-desc')?.value || ''
      }));
      proj.challenges_solutions = gv('f-challenges');
    }

    function collectTab4() {
      proj.testimonial_text   = gv('f-testimonial');
      proj.testimonial_author = gv('f-author');
      proj.testimonial_role   = gv('f-role');
      proj.cost_range         = gv('f-cost-range');
      const faqRows = document.querySelectorAll('.faq-row');
      proj.faqs = Array.from(faqRows).map(row => ({
        question: row.querySelector('.faq-q')?.value || '',
        answer:   row.querySelector('.faq-a')?.value || ''
      })).filter(f => f.question.trim());
      const relVal = gv('f-related').trim();
      proj.related_projects = relVal ? relVal.split(',').map(s => s.trim()).filter(Boolean) : [];
      proj.cta_book_consultation = gc('f-cta-book');
      proj.cta_whatsapp          = gc('f-cta-wa');
    }

    function collectTab5() {
      proj.meta_title         = gv('f-meta-title');
      proj.meta_description   = gv('f-meta-desc');
      proj.og_image           = gv('f-og-image');
      proj.canonical_url      = gv('f-canonical');
      proj.breadcrumb_title   = gv('f-breadcrumb');
      proj.include_in_sitemap = gc('f-sitemap');
    }

    function collectTab6() {
      proj.status           = gv('f-status');
      proj.homepage_display = gc('f-homepage-display');
    }

    // ── List view ─────────────────────────────────────────────────────────

    function renderList() {
      const filtered = projects.filter(p => {
        if (filterStatus !== 'all' && p.status !== filterStatus) return false;
        if (filterSearch) {
          const q = filterSearch.toLowerCase();
          return p.title.toLowerCase().includes(q) || p.location?.toLowerCase().includes(q);
        }
        return true;
      });

      main.innerHTML = `
        <div class="list-toolbar">
          <input class="search-box" type="search" id="search-box" placeholder="Search…" value="${filterSearch}" />
          <select class="filter-sel" id="status-filter">
            <option value="all">All</option>
            <option value="draft">Draft</option>
            <option value="published">Published</option>
            <option value="featured">Featured</option>
          </select>
        </div>
        <div class="project-list">
          ${filtered.length === 0 ? `
            <div class="empty-state">
              <div class="ei">📁</div>
              <h3>${projects.length === 0 ? 'No projects yet' : 'No results'}</h3>
              <p>${projects.length === 0 ? 'Tap + New to create your first case study.' : 'Try a different filter.'}</p>
            </div>
          ` : filtered.map(p => `
            <div class="proj-card" data-id="${p.id}">
              <div class="proj-thumb">
                ${p.cover_image ? `<img src="${p.cover_image}" alt="" loading="lazy" />` : '🏗️'}
              </div>
              <div class="proj-body">
                <div class="proj-title">${p.title}</div>
                <div class="proj-meta">${CAT_LABELS[p.category] || p.category} · ${p.location}${p.completion_year ? ' · ' + p.completion_year : ''}</div>
              </div>
              <span class="status-pill" style="background:${STATUS_COLORS[p.status]}22;color:${STATUS_COLORS[p.status]}">${p.status}</span>
            </div>
          `).join('')}
        </div>
      `;

      g('search-box').value = filterSearch;
      g('status-filter').value = filterStatus;

      g('search-box').addEventListener('input', e => { filterSearch = e.target.value; renderList(); });
      g('status-filter').addEventListener('change', e => { filterStatus = e.target.value; renderList(); });

      document.querySelectorAll('.proj-card').forEach(card => {
        card.addEventListener('click', () => {
          const p = projects.find(x => x.id === card.dataset.id);
          if (p) goEditor(p);
        });
      });
    }

    // ── Editor shell ──────────────────────────────────────────────────────

    function renderEditor() {
      main.innerHTML = `
        <div class="tab-bar" id="tab-bar">
          ${TABS.map((t, i) => `<button class="tab-btn${i === activeTab ? ' active' : ''}" data-tab="${i}">${t}</button>`).join('')}
        </div>
        <div class="tab-content" id="tab-content"></div>
        ${renderSaveBarHTML()}
      `;

      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          collectCurrentTab();
          activeTab = parseInt(btn.dataset.tab);
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          renderTabContent();
          document.getElementById('tab-content').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      });

      renderTabContent();
      attachSaveBarEvents();
    }

    function renderSaveBarHTML() {
      return `
        <div class="save-bar">
          <select class="status-select" id="sb-status">
            <option value="draft"${proj.status==='draft'?' selected':''}>Draft</option>
            <option value="published"${proj.status==='published'?' selected':''}>Published</option>
            <option value="featured"${proj.status==='featured'?' selected':''}>Featured</option>
          </select>
          ${proj.id && proj.status !== 'draft' ? `<a class="preview-btn" href="/projects/${proj.slug}" target="_blank">Preview ↗</a>` : ''}
          <button class="save-btn" id="save-btn" ${saving ? 'disabled' : ''}>${saving ? 'Saving…' : 'Save Project'}</button>
        </div>
      `;
    }

    function renderSaveBar() {
      const bar = document.querySelector('.save-bar');
      if (!bar) return;
      bar.outerHTML = renderSaveBarHTML();
      attachSaveBarEvents();
    }

    function attachSaveBarEvents() {
      g('sb-status')?.addEventListener('change', e => { proj.status = e.target.value; });
