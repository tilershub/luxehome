    // ── Tab content renderer ──────────────────────────────────────────────

    function renderTabContent() {
      const tc = g('tab-content');
      if (!tc) return;
      switch (activeTab) {
        case 0: tc.innerHTML = renderTab0(); attachTab0Events(); break;
        case 1: tc.innerHTML = renderTab1(); attachTab1Events(); break;
        case 2: tc.innerHTML = renderTab2(); break;
        case 3: tc.innerHTML = renderTab3(); attachTab3Events(); break;
        case 4: tc.innerHTML = renderTab4(); attachTab4Events(); break;
        case 5: tc.innerHTML = renderTab5(); attachTab5Events(); break;
        case 6: tc.innerHTML = renderTab6(); attachTab6Events(); break;
      }
    }

    // ── Tab event handlers ────────────────────────────────────────────────

    function attachTab0Events() {
      g('f-title')?.addEventListener('input', e => {
        if (!proj.slug) {
          const slugEl = g('f-slug');
          if (slugEl) slugEl.value = toSlug(e.target.value);
        }
      });
    }

    function attachTab1Events() {
      // Cover image upload
      g('cover-upload-btn')?.addEventListener('click', () => g('cover-file')?.click());
      g('cover-file')?.addEventListener('change', async e => {
        const file = e.target.files?.[0];
        if (!file) return;
        const prog = g('cover-progress');
        prog.style.display = 'block';
        prog.textContent = 'Uploading…';
        const url = await uploadImage(file, proj.id);
        if (url) {
          proj.cover_image = url;
          g('f-cover').value = url;
          prog.textContent = '✓ Uploaded';
          // refresh preview
          const prev = tc => { const el = g('tab-content'); if (el) el.querySelector('.img-preview')?.remove(); };
          const img = document.createElement('img');
          img.className = 'img-preview'; img.src = url; img.alt = '';
          g('f-cover')?.parentNode?.insertBefore(img, g('f-cover'));
        } else {
          prog.textContent = 'Upload failed.';
        }
      });

      // Array image uploads
      document.querySelectorAll('.arr-upload-btn').forEach(btn => {
        const key = btn.dataset.key;
        btn.addEventListener('click', () => document.querySelector(`.arr-file-input[data-key="${key}"]`)?.click());
      });
      document.querySelectorAll('.arr-file-input').forEach(input => {
        const key = input.dataset.key;
        input.addEventListener('change', async e => {
          const files = Array.from(e.target.files || []);
          const prog = g('prog-' + key);
          prog.style.display = 'block';
          for (let i = 0; i < files.length; i++) {
            prog.textContent = `Uploading ${i+1}/${files.length}…`;
            const url = await uploadImage(files[i], proj.id);
            if (url) {
              if (!Array.isArray(proj[key])) proj[key] = [];
              proj[key].push(url);
              const grid = g('grid-' + key);
              if (grid) {
                const idx = proj[key].length - 1;
                const item = document.createElement('div');
                item.className = 'img-item';
                item.dataset.key = key;
                item.dataset.idx = String(idx);
                item.innerHTML = `<img src="${url}" alt="" loading="lazy" /><button class="img-rm rm-img" data-key="${key}" data-idx="${idx}">×</button>`;
                item.querySelector('.rm-img')?.addEventListener('click', handleImgRemove);
                grid.appendChild(item);
              }
            }
          }
          prog.textContent = `✓ ${files.length} image${files.length>1?'s':''} uploaded`;
          input.value = '';
        });
      });

      // Remove image buttons (existing)
      document.querySelectorAll('.rm-img').forEach(btn => btn.addEventListener('click', handleImgRemove));
    }

    function handleImgRemove(e) {
      const btn = e.currentTarget;
      const key = btn.dataset.key;
      const idx = parseInt(btn.dataset.idx);
      if (!Array.isArray(proj[key])) return;
      proj[key].splice(idx, 1);
      // Re-render all image grids for this key
      const grid = g('grid-' + key);
      if (grid) {
        grid.innerHTML = proj[key].map((url, i) => `
          <div class="img-item" data-key="${key}" data-idx="${i}">
            <img src="${url}" alt="" loading="lazy" />
            <button class="img-rm rm-img" data-key="${key}" data-idx="${i}">×</button>
          </div>
        `).join('');
        grid.querySelectorAll('.rm-img').forEach(b => b.addEventListener('click', handleImgRemove));
      }
    }

    function attachTab3Events() {
      g('add-tl-btn')?.addEventListener('click', () => {
        collectTab3();
        proj.project_timeline.push({ phase: '', duration: '', description: '' });
        const list = g('tl-list');
        if (list) {
          const i = proj.project_timeline.length - 1;
          const div = document.createElement('div');
          div.innerHTML = renderTimelineRow({}, i);
          const row = div.firstElementChild;
          row.querySelector('.rm-tl')?.addEventListener('click', () => removeTlRow(i));
          list.appendChild(row);
        }
      });
      document.querySelectorAll('.rm-tl').forEach(btn => {
        btn.addEventListener('click', () => removeTlRow(parseInt(btn.dataset.idx)));
      });
    }

    function removeTlRow(idx) {
      collectTab3();
      proj.project_timeline.splice(idx, 1);
      const list = g('tl-list');
      if (list) {
        list.innerHTML = proj.project_timeline.map((item, i) => renderTimelineRow(item, i)).join('');
        attachTab3Events();
      }
    }

    function attachTab4Events() {
      g('add-faq-btn')?.addEventListener('click', () => {
        collectTab4();
        proj.faqs.push({ question: '', answer: '' });
        const list = g('faq-list');
        if (list) {
          const i = proj.faqs.length - 1;
          const div = document.createElement('div');
          div.innerHTML = renderFaqRow({}, i);
          const row = div.firstElementChild;
          row.querySelector('.rm-faq')?.addEventListener('click', () => removeFaqRow(i));
          list.appendChild(row);
        }
      });
      document.querySelectorAll('.rm-faq').forEach(btn => {
        btn.addEventListener('click', () => removeFaqRow(parseInt(btn.dataset.idx)));
      });
    }

    function removeFaqRow(idx) {
      collectTab4();
      proj.faqs.splice(idx, 1);
      const list = g('faq-list');
      if (list) {
        list.innerHTML = proj.faqs.map((faq, i) => renderFaqRow(faq, i)).join('');
        attachTab4Events();
      }
    }

    function attachTab5Events() {
      g('f-meta-title')?.addEventListener('input', e => {
        const cc = e.target.parentNode.querySelector('.char-count');
        if (cc) { const l = e.target.value.length; cc.textContent = `${l}/60 characters recommended`; cc.className = 'char-count' + (l > 60 ? ' over' : ''); }
      });
      g('f-meta-desc')?.addEventListener('input', e => {
        const cc = e.target.parentNode.querySelector('.char-count');
        if (cc) { const l = e.target.value.length; cc.textContent = `${l}/160 characters recommended`; cc.className = 'char-count' + (l > 160 ? ' over' : ''); }
      });
    }

    function attachTab6Events() {
      g('f-status')?.addEventListener('change', e => {
        proj.status = e.target.value;
        const sbSel = g('sb-status');
        if (sbSel) sbSel.value = e.target.value;
      });
      g('delete-btn')?.addEventListener('click', () => showDeleteModal());
    }

    // ── Delete modal ──────────────────────────────────────────────────────

    function showDeleteModal() {
      const overlay = document.createElement('div');
      overlay.className = 'modal-overlay';
      overlay.innerHTML = `
        <div class="modal">
          <h3>Delete Project?</h3>
          <p>This will permanently delete "${proj.title}" and cannot be undone.</p>
          <div class="modal-btns">
            <button class="btn-cancel" id="cancel-del">Cancel</button>
            <button class="btn-danger" id="confirm-del">Delete</button>
          </div>
        </div>
      `;
      document.body.appendChild(overlay);
      g('cancel-del')?.addEventListener('click', () => overlay.remove());
      g('confirm-del')?.addEventListener('click', async () => {
        overlay.remove();
        await deleteProject(proj.id);
      });
    }

    // ── Toast ─────────────────────────────────────────────────────────────

    let toastTimer;
    function toast(msg, type = '', duration = 2500) {
      const el = g('toast');
      if (!el) return;
      el.textContent = msg;
      el.className = `show ${type}`;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { el.className = ''; }, duration);
    }

    // ── Escape HTML ───────────────────────────────────────────────────────

    function esc(str) {
      return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Init ──────────────────────────────────────────────────────────────

    document.addEventListener('DOMContentLoaded', async () => {
      main     = document.getElementById('main');
      hdrTitle = document.getElementById('hdr-title');
      newBtn   = document.getElementById('new-btn');

      if (!SB_URL || !SB_KEY) {
        main.innerHTML = `<div class="empty-state"><div class="ei">⚠️</div><h3>Supabase not configured</h3><p>Set PUBLIC_SUPABASE_URL and PUBLIC_SUPABASE_ANON_KEY environment variables.</p></div>`;
        return;
      }

      sb = createClient(SB_URL, SB_KEY);
      main.innerHTML = `<div class="empty-state"><div class="ei">⏳</div><h3>Loading…</h3></div>`;
      await loadProjects();
      renderList();

      newBtn.addEventListener('click', () => goEditor());
    });
  </script>
</body>
</html>
