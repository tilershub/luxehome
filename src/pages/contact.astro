---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Book a Site Inspection — TILERSHUB',
  description: 'Book a professional site inspection across Sri Lanka. Rs. 10,000 fee. Our team visits, measures, and prepares an accurate quote within 24 hours.',
  url: 'https://tilershub.com/contact',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: 'TILERSHUB',
    telephone: '+94774503744',
    email: 'tilershub@gmail.com',
    url: 'https://tilershub.com',
    address: { '@type': 'PostalAddress', addressCountry: 'LK' },
    areaServed: 'Sri Lanka',
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],
      opens: '08:00',
      closes: '18:00',
    },
  },
});
---

<Layout
  title="Book a Site Inspection — TILERSHUB Sri Lanka"
  description="Book a professional site inspection for tiling, bathroom renovation, staircase or pantry work across Sri Lanka. Rs. 10,000 fee — our team visits, measures, and delivers an accurate quote."
>
  <Nav />

  <main>
    <script type="application/ld+json" set:html={jsonLd}></script>

    <!-- ── Hero ── -->
    <header class="hero">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="hero-inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span>Site Inspection</span>
        </nav>
        <div class="hero-tag">Book Now</div>
        <h1>Book a<br /><em>Site Inspection</em></h1>
        <p class="hero-desc">
          Our team visits your location, takes accurate measurements, and delivers
          a detailed quote — usually within 24 hours of the visit.
        </p>
        <div class="fee-badge">
          <div class="fee-amt">Rs. 10,000</div>
          <div class="fee-note">Inspection fee · Covers all Sri Lanka</div>
        </div>
      </div>
    </header>

    <!-- ── Process strip ── -->
    <div class="process-strip">
      <div class="process-inner">
        <div class="ps-step">
          <div class="ps-num">01</div>
          <div class="ps-content">
            <div class="ps-title">Fill the form</div>
            <div class="ps-desc">Tell us your service, location & any details</div>
          </div>
        </div>
        <div class="ps-arrow" aria-hidden="true">→</div>
        <div class="ps-step">
          <div class="ps-num">02</div>
          <div class="ps-content">
            <div class="ps-title">We visit your site</div>
            <div class="ps-desc">Agreed time — we measure and assess on-site</div>
          </div>
        </div>
        <div class="ps-arrow" aria-hidden="true">→</div>
        <div class="ps-step">
          <div class="ps-num">03</div>
          <div class="ps-content">
            <div class="ps-title">Accurate quote</div>
            <div class="ps-desc">Detailed price within 24 hrs of inspection</div>
          </div>
        </div>
        <div class="ps-arrow" aria-hidden="true">→</div>
        <div class="ps-step">
          <div class="ps-num">04</div>
          <div class="ps-content">
            <div class="ps-title">Work begins</div>
            <div class="ps-desc">Book with 10% deposit — we handle the rest</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Main content ── -->
    <section class="main-section">
      <div class="main-inner">

        <!-- Form column -->
        <div class="col-form">
          <div class="form-header">
            <div class="form-header-title">Inspection Request</div>
            <div class="form-header-sub">Fill in your details and we'll confirm a visit time via WhatsApp.</div>
          </div>
          <ContactForm />
        </div>

        <!-- Sidebar -->
        <aside class="col-aside">

          <!-- Fee card -->
          <div class="aside-card aside-card--fee">
            <div class="aside-card-label">Inspection Fee</div>
            <div class="aside-card-value">Rs. 10,000</div>
            <p>Payable on the day of inspection. Covers travel, site measurement, and assessment anywhere in Sri Lanka.</p>
          </div>

          <!-- WhatsApp -->
          <div class="aside-card aside-card--wa">
            <div class="wa-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
              </svg>
            </div>
            <div class="aside-card-label">Prefer to message?</div>
            <div class="aside-card-value aside-card-value--sm">WhatsApp Us Directly</div>
            <a
              href="https://wa.me/94774503744?text=Hi%20TILERSHUB%2C%20I%20would%20like%20to%20book%20a%20site%20inspection."
              class="btn-wa"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
              </svg>
              Open WhatsApp
            </a>
          </div>

          <!-- Call -->
          <div class="aside-card aside-card--info">
            <div class="aside-card-label">Call Us</div>
            <a href="tel:+94774503744" class="aside-phone">0774 503 744</a>
            <p>Mon – Sat · 8 am – 6 pm</p>
          </div>

        </aside>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */

  .hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(160deg, rgba(18,14,11,.92) 0%, rgba(30,24,18,.75) 55%, rgba(18,14,11,.92) 100%),
      url('https://images.pexels.com/photos/7937644/pexels-photo-7937644.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop') center/cover no-repeat;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: calc(7rem + env(safe-area-inset-top, 0px)) 4rem 4.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(245,240,232,.45);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: rgba(245,240,232,.45);
    text-decoration: none;
    transition: color .2s;
  }

  .breadcrumb a:hover { color: var(--clay); }

  .hero-tag {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: .28rem .8rem;
    border-radius: 2px;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 1.08;
    letter-spacing: -.02em;
    margin-bottom: 1.1rem;
  }

  h1 em {
    font-style: italic;
    color: var(--clay);
  }

  .hero-desc {
    font-size: .96rem;
    font-weight: 300;
    color: rgba(245,240,232,.72);
    line-height: 1.78;
    max-width: 52ch;
    margin-bottom: 1.8rem;
  }

  .fee-badge {
    display: inline-flex;
    align-items: baseline;
    gap: .7rem;
    background: rgba(196,120,74,.12);
    border: 1px solid rgba(196,120,74,.3);
    border-radius: 4px;
    padding: .65rem 1.1rem;
  }

  .fee-amt {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--clay);
  }

  .fee-note {
    font-size: .75rem;
    color: rgba(245,240,232,.55);
    font-weight: 300;
  }

  /* ── Process strip ── */

  .process-strip {
    background: #1e1a17;
    border-top: 1px solid rgba(196,120,74,.12);
    border-bottom: 1px solid rgba(196,120,74,.12);
    padding: 2rem 4rem;
  }

  .process-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .ps-step {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    flex: 1;
    min-width: 0;
  }

  .ps-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 900;
    color: rgba(196,120,74,.3);
    line-height: 1;
    flex-shrink: 0;
    padding-top: .05rem;
  }

  .ps-title {
    font-size: .82rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: .2rem;
    line-height: 1.3;
  }

  .ps-desc {
    font-size: .72rem;
    color: rgba(245,240,232,.45);
    line-height: 1.55;
    font-weight: 300;
  }

  .ps-arrow {
    color: rgba(196,120,74,.35);
    font-size: 1.1rem;
    flex-shrink: 0;
    padding: 0 1rem;
    align-self: center;
  }

  /* ── Main section ── */

  .main-section {
    background: #f3efe8;
    padding: 4rem 4rem 6rem;
  }

  .main-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  /* ── Form column header ── */

  .form-header {
    margin-bottom: 1.5rem;
  }

  .form-header-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: .35rem;
  }

  .form-header-sub {
    font-size: .85rem;
    color: var(--warm-gray);
    line-height: 1.65;
  }

  /* ── Sidebar ── */

  .col-aside {
    display: flex;
    flex-direction: column;
    gap: .85rem;
    position: sticky;
    top: 5.5rem;
  }

  .aside-card {
    border-radius: 10px;
    padding: 1.3rem 1.4rem;
  }

  .aside-card--fee {
    background: var(--charcoal);
  }

  .aside-card--wa {
    background: #fff;
    border: 1px solid rgba(196,120,74,.18);
  }

  .aside-card--info {
    background: #fff;
    border: 1px solid rgba(196,120,74,.18);
  }

  .aside-card-label {
    font-size: .67rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .13em;
    margin-bottom: .35rem;
  }

  .aside-card--fee .aside-card-label { color: rgba(245,240,232,.4); }
  .aside-card--wa .aside-card-label,
  .aside-card--info .aside-card-label { color: var(--warm-gray); }

  .aside-card-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--clay);
    margin-bottom: .6rem;
    line-height: 1.1;
  }

  .aside-card-value--sm {
    font-size: 1rem;
    color: var(--charcoal);
  }

  .aside-card--fee p {
    font-size: .76rem;
    color: rgba(245,240,232,.45);
    line-height: 1.65;
    font-weight: 300;
  }

  .aside-card--wa p,
  .aside-card--info p {
    font-size: .76rem;
    color: var(--warm-gray);
    line-height: 1.65;
    font-weight: 300;
    margin-bottom: 0;
  }

  .wa-icon {
    color: #25d366;
    margin-bottom: .5rem;
  }

  .btn-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    width: 100%;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem;
    font-weight: 700;
    padding: .75rem 1rem;
    border-radius: 8px;
    margin-top: .85rem;
    transition: background .2s, transform .15s;
    min-height: 44px;
    touch-action: manipulation;
    box-shadow: 0 3px 12px rgba(37,211,102,.25);
  }

  .btn-wa:hover { background: #1ebe5d; transform: translateY(-1px); }

  .aside-phone {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--clay);
    text-decoration: none;
    margin-bottom: .4rem;
    transition: color .2s;
  }

  .aside-phone:hover { color: #b56a3e; }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    .hero-inner { padding: calc(6rem + env(safe-area-inset-top, 0px)) 2.5rem 4rem; }
    .process-strip { padding: 2rem 2.5rem; }
    .main-section { padding: 3.5rem 2.5rem 5rem; }
    .main-inner { grid-template-columns: 1fr 280px; gap: 2.5rem; }
  }

  @media (max-width: 900px) {
    .main-inner { grid-template-columns: 1fr; }
    .col-aside {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .85rem;
    }
    .aside-card--fee { grid-column: 1 / -1; }
    .process-inner { flex-wrap: wrap; gap: 1rem; }
    .ps-arrow { display: none; }
    .ps-step { flex: 1 1 40%; }
  }

  @media (max-width: 640px) {
    .hero { min-height: auto; }
    .hero-inner { padding: calc(5.5rem + env(safe-area-inset-top, 0px)) 1.25rem 3rem; }
    .process-strip { padding: 1.8rem 1.25rem; }
    .main-section { padding: 2.5rem 1.25rem 4rem; }
    h1 { font-size: clamp(2.2rem, 8vw, 2.8rem); }
    .hero-desc { font-size: .88rem; }
    .fee-badge { flex-direction: column; gap: .2rem; }
    .col-aside { grid-template-columns: 1fr; }
    .aside-card--fee { grid-column: auto; }
    .ps-step { flex: 1 1 100%; }
  }
</style>
