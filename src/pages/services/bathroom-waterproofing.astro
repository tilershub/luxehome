---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Waterproofing — Rs. 350/sq.ft — Tokyo Super 2K — LUXEHOME Sri Lanka"
  description="Professional bathroom waterproofing with Tokyo Super 2K membrane. Rs. 350/sq.ft — fibre net reinforced edges, full wet-area coverage, and guaranteed protection before tiling."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/4953232/pexels-photo-4953232.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/services/bathroom">Bathroom</a>
        <span>›</span>
        <span>Bathroom Waterproofing</span>
      </div>
      <h1 class="reveal">Bathroom Waterproofing</h1>
      <p class="hero-desc reveal">
        Proper waterproofing is the foundation of every long-lasting bathroom.
        We apply Tokyo Super 2K membrane across all wet surfaces with fibre net
        reinforcement at every joint and edge — before a single tile goes down.
      </p>
      <div class="price-tag reveal">
        <span class="p-amt">Rs. 350</span>
        <span class="p-unit">/ sq.ft &mdash; full wet-area coverage</span>
      </div>
      <div class="hero-cta reveal">
        <a href="#get-a-quote" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          Get a Quote
        </a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="details-section">
    <div class="section-inner">
      <div class="col-content">
        <div class="stag">What's Covered</div>
        <h2>Full Protection at<br />Rs. 350 / sq.ft</h2>
        <p class="sdesc">
          One rate covers the full waterproofing scope — membrane application,
          fibre net reinforcement, and all labour. Applied to floor and wall
          wet areas before tiling commences.
        </p>
        <ul class="include-list">
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Tokyo Super 2K Waterproofing Membrane</strong>
              <span>Two-component cementitious waterproofing membrane — flexible, crack-bridging, and proven for wet areas</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Fibre Net Reinforcement at Edges &amp; Joints</strong>
              <span>Alkali-resistant fibre mesh embedded at all floor-wall junctions, pipe penetrations, and corners to prevent crack propagation</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Full Floor &amp; Wall Wet-Area Coverage</strong>
              <span>Complete membrane application across all wet surfaces — shower zone, floor, and wall splash areas</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Surface Preparation</strong>
              <span>Substrate cleaning and priming before membrane application to ensure maximum adhesion</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Curing &amp; Inspection</strong>
              <span>Adequate curing time allowed before tiling proceeds — no shortcuts that compromise the membrane</span>
            </div>
          </li>
        </ul>
      </div>

      <aside class="col-aside">
        <div class="aside-card">
          <div class="aside-title">Rate</div>
          <div class="aside-price">Rs. 350 <span>/ sq.ft</span></div>
          <div class="aside-note">Floor + wall wet areas</div>
        </div>
        <div class="aside-card">
          <div class="aside-title">Membrane</div>
          <div class="aside-spec">Tokyo Super 2K</div>
          <div class="aside-note">Two-component cementitious</div>
        </div>
        <div class="aside-card">
          <div class="aside-title">Reinforcement</div>
          <div class="aside-spec">Fibre Net</div>
          <div class="aside-note">All edges, joints &amp; corners</div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Materials -->
  <section class="materials-section">
    <div class="mat-inner">
      <div class="stag">Materials Used</div>
      <h2>Proven Waterproofing<br />Products</h2>
      <div class="mat-grid">
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Tokyo Super 2K</div>
          <div class="mat-desc">Two-component flexible waterproofing membrane — cement and polymer-based for superior crack bridging in wet areas</div>
        </div>
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Fibre Net Mesh</div>
          <div class="mat-desc">Alkali-resistant fibreglass mesh embedded at all junction points, edges, and pipe penetrations</div>
        </div>
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Surface Primer</div>
          <div class="mat-desc">Penetrating primer applied before membrane to ensure full bond to concrete and masonry substrates</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-inner">
      <div class="stag">FAQ</div>
      <h2>Common Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Why is waterproofing done before tiling?</summary>
          <p>The waterproofing membrane must be applied and fully cured on the bare substrate before tiles go down. Applying it over tiles or grout defeats its purpose — it needs direct contact with the wall and floor surfaces.</p>
        </details>
        <details class="faq-item">
          <summary>What is Tokyo Super 2K?</summary>
          <p>Tokyo Super 2K is a two-component (cement + liquid polymer) flexible waterproofing membrane. It is formulated for bathrooms, balconies, and wet areas — providing crack-bridging flexibility and long-term water resistance.</p>
        </details>
        <details class="faq-item">
          <summary>Why do you use fibre net at edges?</summary>
          <p>Floor-wall junctions and corners are the most vulnerable points for water ingress. Embedding alkali-resistant fibre mesh at these joints reinforces the membrane and prevents cracking caused by structural movement.</p>
        </details>
        <details class="faq-item">
          <summary>Is waterproofing included in the Bathroom Construction/Renovation package?</summary>
          <p>Yes — waterproofing is a core part of all LUXEHOME bathroom renovation packages. If you only need waterproofing as a standalone service (e.g. before tiling an existing bathroom), this Rs. 350/sq.ft rate applies.</p>
        </details>
        <details class="faq-item">
          <summary>How long does the membrane need to cure before tiling?</summary>
          <p>Tokyo Super 2K typically requires a minimum of 24–48 hours curing time before tiling can proceed. We always allow adequate curing and never rush this step.</p>
        </details>
      </div>
    </div>
  </section>

  <QuoteForm id="get-a-quote" />
  <CTA />
  <Footer />
</Layout>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.48) 60%, rgba(30,26,23,.75) 100%);
  }
  .hero-inner { position: relative; z-index: 1; max-width: 700px; padding-top: 7rem; }
  .breadcrumb {
    display: flex; gap: .4rem; align-items: center;
    font-size: .72rem; letter-spacing: .06em; text-transform: uppercase;
    color: rgba(245,240,232,.55); margin-bottom: 1.2rem;
  }
  .breadcrumb a { color: rgba(245,240,232,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700; color: var(--cream); line-height: 1.1; margin-bottom: 1.1rem;
  }
  .hero-desc { font-size: 1rem; color: rgba(245,240,232,.8); line-height: 1.72; max-width: 55ch; margin-bottom: 1.4rem; }
  .price-tag { display: flex; align-items: baseline; gap: .5rem; margin-bottom: 1.8rem; flex-wrap: wrap; }
  .p-amt { font-family: 'Playfair Display', serif; font-size: 2.4rem; font-weight: 700; color: var(--clay); }
  .p-unit { font-size: .82rem; color: rgba(245,240,232,.65); }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: .5rem;
    background: #25d366; color: #fff; padding: .75rem 1.6rem; border-radius: 2px;
    font-size: .82rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase;
    text-decoration: none; transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #1fb855; transform: translateY(-2px); }
  .btn-ghost {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--cream); padding: .75rem 1.6rem; border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35); font-size: .82rem; font-weight: 500;
    letter-spacing: .06em; text-transform: uppercase; text-decoration: none; transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* Details section */
  .details-section { background: var(--cream); padding: 5.5rem 4rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: start; }
  .stag { font-size: .72rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--clay); margin-bottom: .75rem; }
  h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; color: var(--charcoal); line-height: 1.2; margin-bottom: 1rem; }
  .sdesc { font-size: .95rem; color: var(--warm-gray); line-height: 1.72; max-width: 58ch; margin-bottom: 2rem; }
  .include-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1.2rem; }
  .include-list li { display: flex; gap: 1rem; align-items: flex-start; }
  .check { color: var(--clay); font-weight: 700; font-size: 1rem; flex-shrink: 0; margin-top: .1rem; }
  .include-list strong { display: block; font-size: .9rem; color: var(--charcoal); margin-bottom: .2rem; }
  .include-list span { font-size: .82rem; color: var(--warm-gray); line-height: 1.6; }
  .col-aside { display: flex; flex-direction: column; gap: 1rem; }
  .aside-card { background: #fff; border: 1px solid var(--stone); padding: 1.4rem 1.6rem; border-radius: 2px; }
  .aside-title { font-size: .68rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--warm-gray); margin-bottom: .5rem; }
  .aside-price { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; color: var(--clay); }
  .aside-price span { font-size: .78rem; font-family: 'DM Sans', sans-serif; font-weight: 400; color: var(--warm-gray); }
  .aside-spec { font-size: 1rem; font-weight: 600; color: var(--charcoal); }
  .aside-note { font-size: .75rem; color: var(--warm-gray); margin-top: .25rem; }

  /* Materials section */
  .materials-section { background: var(--off-white); padding: 5rem 4rem; }
  .mat-inner { max-width: 1200px; margin: 0 auto; }
  .mat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2.5rem; }
  .mat-card { background: #fff; border: 1px solid var(--stone); padding: 2rem; border-radius: 2px; }
  .mat-icon { font-size: 1.4rem; color: var(--clay); margin-bottom: 1rem; }
  .mat-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--charcoal); margin-bottom: .6rem; }
  .mat-desc { font-size: .82rem; color: var(--warm-gray); line-height: 1.65; }

  /* FAQ section */
  .faq-section { background: var(--cream); padding: 5rem 4rem; }
  .faq-inner { max-width: 820px; margin: 0 auto; }
  .faq-list { margin-top: 2.5rem; display: flex; flex-direction: column; gap: .5rem; }
  .faq-item { border: 1px solid var(--stone); border-radius: 2px; overflow: hidden; }
  .faq-item summary {
    padding: 1.1rem 1.4rem; cursor: pointer; font-size: .9rem; font-weight: 600;
    color: var(--charcoal); list-style: none; display: flex; justify-content: space-between;
    align-items: center; transition: background .2s;
  }
  .faq-item summary:hover { background: var(--off-white); }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--clay); font-weight: 300; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: .2rem 1.4rem 1.2rem; font-size: .85rem; color: var(--warm-gray); line-height: 1.72; margin: 0; }

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .details-section, .materials-section, .faq-section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .section-inner { grid-template-columns: 1fr; }
    .col-aside { flex-direction: row; flex-wrap: wrap; }
    .aside-card { flex: 1; min-width: 160px; }
  }
  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .details-section, .materials-section, .faq-section { padding: 4rem 1.5rem; }
    .mat-grid { grid-template-columns: 1fr; }
    .col-aside { flex-direction: column; }
  }
</style>
