---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Renovation — Essential, Comfort & Signature Packages — LUXEhome Sri Lanka"
  description="Complete bathroom renovation across Sri Lanka. Three packages from Rs. 4,50,000 — Wall Niches, Plumbing, Wiring, Waterproofing, Tiling, Fixtures, Lighting. Optional Demolition, Wall Plastering, and 3D Design."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#shop">Services</a>
        <span>›</span>
        <span>Bathroom</span>
      </div>
      <h1 class="reveal">Bathroom Renovation</h1>
      <p class="hero-desc reveal">
        Full scope renovation — demolition to handover. Three packages to match your budget,
        each covering the complete bathroom. You supply tiles, bathware &amp; tapware.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Book Site Inspection — Rs. 10,000</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Packages + Calculator -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">Packages</div>
      <h2 class="reveal">Three Packages, Full Scope on Every One</h2>
      <p class="sdesc reveal">Packages are based on a 40 sq.ft bathroom. Enter your floor area below to see your exact price.</p>

      <!-- Area calculator -->
      <div class="area-input-row reveal">
        <label class="area-label" for="bathArea">Your bathroom floor area</label>
        <div class="area-field">
          <input type="number" id="bathArea" class="area-input" min="1" max="999" placeholder="e.g. 45" inputmode="decimal" aria-label="Bathroom floor area in sq.ft" />
          <span class="area-unit">sq.ft</span>
        </div>
        <span class="area-hint" id="areaHint"></span>
      </div>

      <div class="pkg-grid reveal">

        <!-- Essential Bath -->
        <div class="pkg-card">
          <div class="pkg-name">Essential Bath</div>
          <div class="pkg-price bath-price" data-base="450000" data-rate="5000">Rs. 4,50,000</div>
          <div class="pkg-price-note bath-note">up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Lighting</li>
          </ul>
          <button class="pkg-btn atc-pkg" data-pkg-name="Essential Bath" data-base="450000" data-rate="5000">Add to Cart</button>
        </div>

        <!-- Comfort Bath -->
        <div class="pkg-card pkg-card--mid">
          <div class="pkg-badge">Most Popular</div>
          <div class="pkg-name">Comfort Bath</div>
          <div class="pkg-price bath-price" data-base="550000" data-rate="6000">Rs. 5,50,000</div>
          <div class="pkg-price-note bath-note">up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Lighting</li>
            <li>Plain Ceiling</li>
            <li>3ft Glass Panel</li>
          </ul>
          <button class="pkg-btn atc-pkg" data-pkg-name="Comfort Bath" data-base="550000" data-rate="6000">Add to Cart</button>
        </div>

        <!-- Signature Bath -->
        <div class="pkg-card">
          <div class="pkg-name">Signature Bath</div>
          <div class="pkg-price bath-price" data-base="650000" data-rate="7000">Rs. 6,50,000</div>
          <div class="pkg-price-note bath-note">up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Wall Niches</li>
            <li>Plumbing</li>
            <li>Wiring</li>
            <li>Waterproofing</li>
            <li>Tiling</li>
            <li>Install Fixtures</li>
            <li>Ambience Lighting</li>
            <li>Design Ceiling</li>
            <li>Shower Cubicle</li>
            <li>Vanity Cupboard</li>
          </ul>
          <button class="pkg-btn atc-pkg" data-pkg-name="Signature Bath" data-base="650000" data-rate="7000">Add to Cart</button>
        </div>

      </div>

      <!-- Add-ons -->
      <div class="addons-section reveal">
        <div class="addons-head">Optional Add-ons</div>
        <div class="addons-grid">
          <div class="addon-card">
            <div class="addon-name">Demolition Works</div>
            <div class="addon-price addon-calc" data-rate="1000">Rs. 1,000 <em>/sq.ft</em></div>
            <div class="addon-desc">Full bathroom strip-out — walls, floor, fixtures</div>
            <button class="addon-atc atc-addon" data-addon-name="Demolition Works" data-rate="1000">Add to Cart</button>
          </div>
          <div class="addon-card">
            <div class="addon-name">Wall Plastering</div>
            <div class="addon-price addon-calc" data-rate="700">Rs. 700 <em>/sq.ft</em></div>
            <div class="addon-desc">Smooth plaster finish on all wall surfaces</div>
            <button class="addon-atc atc-addon" data-addon-name="Wall Plastering" data-rate="700">Add to Cart</button>
          </div>
          <div class="addon-card">
            <div class="addon-name">3D Design</div>
            <div class="addon-price addon-flat">Rs. 25,000</div>
            <div class="addon-desc">Detailed 3D render before any work begins</div>
            <button class="addon-atc atc-addon-flat" data-addon-name="3D Design" data-price="25000">Add to Cart</button>
          </div>
        </div>
      </div>

      <div class="not-included reveal">
        <strong>Not included:</strong> Tiles, bathware, tapware, geyser, mirrors — you source your preferred products. Our team handles all installation and finishing.
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
(function () {
  function formatRs(n) {
    return 'Rs.\u00a0' + Math.round(n).toLocaleString('en-IN');
  }

  function calcPrice(base, rate, area) {
    if (!area || area <= 0) return base;
    return base + Math.max(0, area - 40) * rate;
  }

  var areaInput = document.getElementById('bathArea');

  function getArea() { return parseFloat(areaInput.value) || 0; }

  areaInput.addEventListener('input', function () {
    var area = getArea();

    document.querySelectorAll('.bath-price').forEach(function (el) {
      el.textContent = formatRs(calcPrice(parseInt(el.dataset.base, 10), parseInt(el.dataset.rate, 10), area));
    });

    document.querySelectorAll('.bath-note').forEach(function (el) {
      el.textContent = area > 0 ? area + ' sq.ft total' : 'up to 40 sq.ft';
    });

    document.querySelectorAll('.addon-calc').forEach(function (el) {
      var rate = parseInt(el.dataset.rate, 10);
      el.innerHTML = area > 0 ? formatRs(area * rate) : 'Rs.\u00a0' + rate.toLocaleString('en-IN') + ' <em>/sq.ft</em>';
    });

    var hint = document.getElementById('areaHint');
    if (hint) hint.textContent = area > 0 ? 'Showing price for ' + area + ' sq.ft' : '';
  });

  /* ── Add to Cart: packages ── */
  document.querySelectorAll('.atc-pkg').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var base = parseInt(btn.dataset.base, 10);
      var rate = parseInt(btn.dataset.rate, 10);
      var area = getArea();
      var price = calcPrice(base, rate, area);
      var details = area > 0 ? area + ' sq.ft' : 'up to 40 sq.ft (base price)';
      window.LHCart.add({ name: btn.dataset.pkgName, details: details, price: price });
    });
  });

  /* ── Add to Cart: area-based addons ── */
  document.querySelectorAll('.atc-addon').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var area = getArea();
      if (area <= 0) {
        areaInput.focus();
        areaInput.style.borderColor = 'var(--clay)';
        setTimeout(function () { areaInput.style.borderColor = ''; }, 1500);
        return;
      }
      var rate = parseInt(btn.dataset.rate, 10);
      window.LHCart.add({
        name: btn.dataset.addonName,
        details: area + ' sq.ft',
        price: area * rate
      });
    });
  });

  /* ── Add to Cart: flat addons ── */
  document.querySelectorAll('.atc-addon-flat').forEach(function (btn) {
    btn.addEventListener('click', function () {
      window.LHCart.add({
        name: btn.dataset.addonName,
        details: 'Per bathroom',
        price: parseInt(btn.dataset.price, 10)
      });
    });
  });
})();
</script>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(245,240,232,.55);
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(245,240,232,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(245,240,232,.8);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: background .2s;
  }
  .btn-primary:hover { background: #b5673c; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Pricing section ── */

  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(245,240,232,.6);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  /* ── Area input ── */

  .area-input-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(196,120,74,.06);
    border: 1px solid rgba(196,120,74,.22);
    border-radius: 4px;
    padding: .85rem 1.2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .area-label {
    font-size: .72rem;
    color: rgba(245,240,232,.5);
    text-transform: uppercase;
    letter-spacing: .09em;
    font-weight: 500;
    flex: 1;
    min-width: 140px;
  }

  .area-field {
    display: flex;
    align-items: center;
    gap: .45rem;
  }

  .area-input {
    width: 90px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(196,120,74,.35);
    border-radius: 3px;
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    padding: .42rem .65rem;
    text-align: center;
    outline: none;
    min-height: 40px;
    -webkit-appearance: none;
  }

  .area-input:focus { border-color: var(--clay); }

  .area-unit {
    font-size: .75rem;
    color: rgba(245,240,232,.4);
  }

  .area-hint {
    font-size: .72rem;
    color: var(--clay);
    font-style: italic;
    margin-left: auto;
  }

  /* ── Package grid ── */

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .pkg-card {
    background: rgba(255,255,255,.03);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    position: relative;
  }

  .pkg-card--mid {
    background: rgba(196,120,74,.07);
    border-left: 1px solid rgba(196,120,74,.18);
    border-right: 1px solid rgba(196,120,74,.18);
  }

  .pkg-badge {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .18rem .6rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: .2rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
  }

  .pkg-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
    margin-top: .2rem;
    transition: all .15s;
  }

  .pkg-price-note {
    font-size: .68rem;
    color: rgba(245,240,232,.38);
    font-weight: 300;
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding-bottom: .75rem;
    margin-bottom: .2rem;
  }

  .pkg-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    flex: 1;
  }

  .pkg-includes li {
    font-size: .75rem;
    color: rgba(245,240,232,.6);
    display: flex;
    align-items: center;
    gap: .5rem;
    line-height: 1.3;
  }

  .pkg-includes li::before {
    content: '◆';
    font-size: .28rem;
    color: var(--clay);
    flex-shrink: 0;
  }

  .pkg-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: .8rem;
    background: var(--clay);
    border: none;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .6rem 1rem;
    border-radius: 3px;
    cursor: pointer;
    width: 100%;
    min-height: 44px;
    transition: background .2s;
  }

  .pkg-btn:hover { background: #b5673c; }

  /* ── Add-ons ── */

  .addons-section {
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 4px;
    padding: 1.6rem;
    margin-bottom: 1.6rem;
  }

  .addons-head {
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    font-weight: 600;
    color: rgba(245,240,232,.35);
    margin-bottom: 1rem;
  }

  .addons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 3px;
    overflow: hidden;
  }

  .addon-card {
    background: rgba(255,255,255,.03);
    padding: 1.2rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .addon-name {
    font-size: .72rem;
    color: rgba(245,240,232,.5);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .07em;
  }

  .addon-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--clay);
    transition: all .15s;
  }

  .addon-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    color: rgba(245,240,232,.38);
    margin-left: .1rem;
  }

  .addon-desc {
    font-size: .7rem;
    color: rgba(245,240,232,.38);
    line-height: 1.5;
    margin-bottom: .2rem;
  }

  .addon-atc {
    margin-top: .4rem;
    background: none;
    border: 1px solid rgba(196,120,74,.35);
    color: var(--clay);
    font-family: 'DM Sans', sans-serif;
    font-size: .67rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: .4rem .7rem;
    border-radius: 3px;
    cursor: pointer;
    width: 100%;
    min-height: 38px;
    transition: background .2s, border-color .2s;
  }

  .addon-atc:hover {
    background: rgba(196,120,74,.1);
    border-color: var(--clay);
  }

  /* ── Not included notice ── */

  .not-included {
    font-size: .8rem;
    color: rgba(245,240,232,.5);
    padding: 1rem 1.2rem;
    background: rgba(196,120,74,.05);
    border-left: 3px solid rgba(196,120,74,.4);
    border-radius: 0 3px 3px 0;
    line-height: 1.65;
  }

  .not-included strong { color: rgba(245,240,232,.7); }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .pricing-section { padding: 4.5rem 2.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
    .pkg-card--mid {
      border-left: none;
      border-right: none;
      border-top: 1px solid rgba(196,120,74,.18);
      border-bottom: 1px solid rgba(196,120,74,.18);
    }
    .addons-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .pricing-section { padding: 4rem 1.5rem; }
    .area-input-row { flex-direction: column; align-items: flex-start; gap: .6rem; }
    .area-hint { margin-left: 0; }
  }

  @media (max-width: 480px) {
    .page-hero {
      padding: 0 1rem 2rem;
      min-height: auto;
    }
    .hero-inner {
      padding-top: calc(5rem + env(safe-area-inset-top, 0px));
    }
    .pricing-section { padding: 2.5rem 1rem; }

    h1 { font-size: clamp(2rem, 8vw, 2.4rem); margin-bottom: .8rem; }
    .hero-desc { font-size: .88rem; margin-bottom: 1.4rem; }

    .hero-cta { flex-direction: column; gap: .7rem; }
    .btn-primary, .btn-ghost { width: 100%; justify-content: center; }

    .area-input-row { padding: .65rem .9rem; }
    .area-input { min-height: 44px; width: 80px; font-size: 1.1rem; }

    .pkg-card { padding: 1.4rem 1.1rem; }
    .pkg-price { font-size: 1.45rem; }

    .addons-section { padding: 1.2rem; }
    .addon-card { padding: 1rem 1rem; }
    .addon-atc { min-height: 44px; }
  }
</style>
