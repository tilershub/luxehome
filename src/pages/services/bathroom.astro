---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Renovation — Full Scope Packages — TILERSHUB Sri Lanka"
  description="Complete bathroom renovation across Sri Lanka. Three packages from Rs. 450,000 — masonry, waterproofing, tiling, plumbing, electrical, and ceiling. Optional tiles, demolition, 3D design, and material packages."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#services">Services</a>
        <span>›</span>
        <span>Bathroom</span>
      </div>
      <h1 class="reveal">Bathroom Renovation</h1>
      <p class="hero-desc reveal">
        Full scope, demolition to handover — three renovation packages plus optional tiles,
        demolition, 3D design, and material packages.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Get a Quote →</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">What's Included</div>
      <h2 class="reveal">Every Package Covers the Full Scope</h2>
      <p class="sdesc reveal">Waterproofing is included in every package. Packages are based on a 40 sq.ft bathroom — overage is charged per sq.ft above that.</p>

      <div class="pkg-grid reveal">

        <div class="pkg-card">
          <div class="pkg-name">Basic</div>
          <div class="pkg-price-main">Rs. 450,000</div>
          <div class="pkg-overage">+Rs. 5,000 / sq.ft over 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>✓ Masonry & waterproofing</li>
            <li>✓ Full tiling (walls & floor)</li>
            <li>✓ Plumbing & electrical</li>
            <li>✓ iPanel ceiling</li>
          </ul>
        </div>

        <div class="pkg-card pkg-card--mid">
          <div class="pkg-badge">Most Popular</div>
          <div class="pkg-name">Standard</div>
          <div class="pkg-price-main">Rs. 550,000</div>
          <div class="pkg-overage">+Rs. 6,000 / sq.ft over 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>✓ Masonry & waterproofing</li>
            <li>✓ Full tiling (walls & floor)</li>
            <li>✓ Plumbing & electrical</li>
            <li>✓ iPanel ceiling</li>
            <li>✓ Enhanced finish quality</li>
          </ul>
        </div>

        <div class="pkg-card">
          <div class="pkg-name">Luxury</div>
          <div class="pkg-price-main">Rs. 650,000</div>
          <div class="pkg-overage">+Rs. 7,000 / sq.ft over 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>✓ Masonry & waterproofing</li>
            <li>✓ Full tiling (walls & floor)</li>
            <li>✓ Plumbing & electrical</li>
            <li>✓ iPanel ceiling</li>
            <li>✓ Premium finishes throughout</li>
          </ul>
        </div>

      </div>

      <!-- Addons overview -->
      <div class="addons-row reveal">
        <div class="addon-tag">+ Add-ons available</div>
        <div class="addon-items">
          <span>Demolition work · Rs. 1,000/sq.ft</span>
          <span>Wall Plastering · Rs. 1,000/sq.ft</span>
          <span>3D Design</span>
          <span>Tiles (60×60 · 45×90 · 120×120)</span>
          <span>Material Package A / B / C</span>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(245,240,232,.55);
    margin-bottom: 1.2rem;
  }
  .breadcrumb a { color: rgba(245,240,232,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(245,240,232,.8);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #b5673c; transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* Pricing section */
  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(245,240,232,.6);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2.8rem;
  }

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .pkg-card {
    background: rgba(255,255,255,.03);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    position: relative;
  }

  .pkg-card--mid {
    background: rgba(196,120,74,.07);
    border-left: 1px solid rgba(196,120,74,.18);
    border-right: 1px solid rgba(196,120,74,.18);
  }

  .pkg-badge {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .2rem .6rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: .3rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
  }

  .pkg-price-main {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
    margin-top: .3rem;
  }

  .pkg-overage {
    font-size: .72rem;
    color: rgba(245,240,232,.4);
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding-bottom: .8rem;
    margin-bottom: .3rem;
  }

  .pkg-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .pkg-includes li {
    font-size: .78rem;
    color: rgba(245,240,232,.6);
    line-height: 1.4;
  }

  /* Addons strip */
  .addons-row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
    background: rgba(196,120,74,.06);
    border: 1px solid rgba(196,120,74,.2);
    border-radius: 3px;
    padding: 1rem 1.4rem;
  }

  .addon-tag {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--clay);
    white-space: nowrap;
  }

  .addon-items {
    display: flex;
    gap: .7rem;
    flex-wrap: wrap;
  }

  .addon-items span {
    font-size: .78rem;
    color: rgba(245,240,232,.6);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    padding: .25rem .65rem;
    border-radius: 20px;
  }

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .pricing-section { padding: 4.5rem 2.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
    .pkg-card--mid { border-left: none; border-right: none; border-top: 1px solid rgba(196,120,74,.18); border-bottom: 1px solid rgba(196,120,74,.18); }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .pricing-section { padding: 4rem 1.5rem; }
  }
</style>
