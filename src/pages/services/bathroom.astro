---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Renovation — Essential, Comfort & Signature Packages — LUXEHOME Sri Lanka"
  description="Complete bathroom renovation across Sri Lanka. Three packages from Rs. 4,50,000 — Wall Niches, Plumbing, Wiring, Waterproofing, Tiling, Fixtures, Lighting. Optional Demolition, Wall Plastering, and 3D Design."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#shop">Services</a>
        <span>›</span>
        <span>Bathroom</span>
      </div>
      <h1 class="reveal">Bathroom Renovation</h1>
      <p class="hero-desc reveal">
        Full scope renovation — demolition to handover. Three packages to match your budget,
        each covering the complete bathroom. You supply tiles, bathware &amp; tapware.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Book Site Inspection — Rs. 10,000</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Packages + Calculator -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">Packages</div>
      <h2 class="reveal">Three Packages, Full Scope on Every One</h2>
      <p class="sdesc reveal">All packages include up to 40 sq.ft. Enter your dimensions below to see your exact price.</p>
      <p class="pkg-design-tagline reveal">All packages include complete design support with 3D visualization.</p>

      <!-- Area calculator -->
      <div class="area-input-row reveal">
        <label class="area-label">Bathroom Size</label>
        <div class="area-fields">
          <div class="area-field">
            <input type="number" id="bathLength" class="area-input" min="0.1" max="999" placeholder="Length" inputmode="decimal" aria-label="Bathroom length in feet" />
            <span class="area-unit">ft</span>
          </div>
          <span class="area-multiply">×</span>
          <div class="area-field">
            <input type="number" id="bathWidth" class="area-input" min="0.1" max="999" placeholder="Width" inputmode="decimal" aria-label="Bathroom width in feet" />
            <span class="area-unit">ft</span>
          </div>
        </div>
        <span class="area-hint" id="areaHint"></span>
      </div>

      <div class="pkg-grid reveal">

        <!-- Essential Bath -->
        <div class="pkg-card">
          <div class="pkg-badge pkg-badge--design">Free Design Included</div>
          <div class="pkg-name">Essential Bath</div>
          <div class="pkg-desc">Perfect for modern, functional bathrooms</div>
          <div class="pkg-price bath-price" data-base="985000" data-rate="7600">LKR 985,000</div>
          <div class="pkg-price-note bath-note">base price up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Structural preparation <em>(floor concrete, niche, vanity top)</em></li>
            <li>Water system installation</li>
            <li>Advanced waterproofing system</li>
            <li>Premium surface finishing <em>(tiles included)</em></li>
            <li>Ambient lighting system</li>
            <li>Standard bathware collection</li>
            <li>10L geyser</li>
          </ul>
          <div class="pkg-design">
            <div class="pkg-design-label">Design Package</div>
            <div class="pkg-design-items">Civil plan · Plumbing layout · Wiring diagram · 3D visualization</div>
          </div>
          <button class="pkg-btn pkg-btn--primary atc-pkg" data-pkg-name="Essential Bath" data-base="985000" data-rate="7600">Get Quotation</button>
          <a href="/contact" class="pkg-btn pkg-btn--ghost">Book Site Inspection</a>
        </div>

        <!-- Comfort Bath -->
        <div class="pkg-card pkg-card--mid">
          <div class="pkg-badge">Most Popular</div>
          <div class="pkg-badge pkg-badge--design">Free Design Included</div>
          <div class="pkg-name">Comfort Bath</div>
          <div class="pkg-desc">Balanced design with premium upgrades</div>
          <div class="pkg-price bath-price" data-base="1225000" data-rate="8600">LKR 1,225,000</div>
          <div class="pkg-price-note bath-note">base price up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Everything in Essential Bath</li>
            <li>Tempered glass shower panel</li>
            <li>iPanel ceiling finish</li>
            <li>Upgraded surface finishing</li>
            <li>Premium bathware collection <em>(Brushed Gold / Gun Grey)</em></li>
          </ul>
          <div class="pkg-design">
            <div class="pkg-design-label">Design Package</div>
            <div class="pkg-design-items">Civil plan · Plumbing layout · Wiring diagram · 3D visualization</div>
          </div>
          <button class="pkg-btn pkg-btn--primary atc-pkg" data-pkg-name="Comfort Bath" data-base="1225000" data-rate="8600">Get Quotation</button>
          <a href="/contact" class="pkg-btn pkg-btn--ghost">Book Site Inspection</a>
        </div>

        <!-- Signature Bath -->
        <div class="pkg-card">
          <div class="pkg-badge pkg-badge--design">Free Design Included</div>
          <div class="pkg-name">Signature Bath</div>
          <div class="pkg-desc">Luxury hotel-style bathroom experience</div>
          <div class="pkg-price bath-price" data-base="1570000" data-rate="9600">LKR 1,570,000</div>
          <div class="pkg-price-note bath-note">base price up to 40 sq.ft</div>
          <ul class="pkg-includes">
            <li>Everything in Comfort Bath</li>
            <li>Premium water system</li>
            <li>High-end surface finishing</li>
            <li>Designer ceiling system</li>
            <li>Glass shower cubicle</li>
            <li>Vanity cupboard</li>
            <li>Luxury bathware <em>(wall-mounted WC, concealed mixers)</em></li>
            <li>15L geyser</li>
          </ul>
          <div class="pkg-design">
            <div class="pkg-design-label">Design Package</div>
            <div class="pkg-design-items">Civil plan · Plumbing layout · Wiring diagram · 3D visualization</div>
          </div>
          <button class="pkg-btn pkg-btn--primary atc-pkg" data-pkg-name="Signature Bath" data-base="1570000" data-rate="9600">Get Quotation</button>
          <a href="/contact" class="pkg-btn pkg-btn--ghost">Book Site Inspection</a>
        </div>

      </div>

      <!-- Add-ons -->
      <div class="addons-section reveal">
        <div class="addons-head">Optional Add-ons</div>
        <div class="addons-grid addons-grid--single">
          <div class="addon-card">
            <div class="addon-name">Renovation Preparation Package</div>
            <div class="addon-sublabel">Demolition + Wall Plastering</div>
            <div class="addon-price addon-calc-pkg" data-base="100000" data-rate="1500">LKR 100,000</div>
            <div class="addon-desc">For existing bathrooms requiring demolition and surface preparation</div>
            <button class="addon-atc atc-addon-pkg" data-addon-name="Renovation Preparation Package" data-base="100000" data-rate="1500">Get Quotation</button>
          </div>
        </div>
      </div>

      <div class="not-included reveal">
        <strong>Custom Upgrades Available</strong>
        <ul class="not-included-list">
          <li>Designer tiles</li>
          <li>Premium fittings</li>
          <li>Structural modifications</li>
        </ul>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
(function () {
  function formatLKR(n) {
    return 'LKR\u00a0' + Math.round(n).toLocaleString('en-US');
  }

  function calcPrice(base, rate, area) {
    if (!area || area <= 0) return base;
    return base + Math.max(0, area - 40) * rate;
  }

  var lengthInput = document.getElementById('bathLength');
  var widthInput  = document.getElementById('bathWidth');

  function getArea() {
    var l = parseFloat(lengthInput.value) || 0;
    var w = parseFloat(widthInput.value)  || 0;
    if (l <= 0 || w <= 0) return 0;
    return parseFloat((l * w).toFixed(2));
  }

  function onDimensionChange() {
    var area = getArea();
    var l    = parseFloat(lengthInput.value) || 0;
    var w    = parseFloat(widthInput.value)  || 0;

    /* Package prices */
    document.querySelectorAll('.bath-price').forEach(function (el) {
      el.textContent = formatLKR(calcPrice(parseInt(el.dataset.base, 10), parseInt(el.dataset.rate, 10), area));
    });

    /* Package price notes */
    document.querySelectorAll('.bath-note').forEach(function (el) {
      el.textContent = area > 0 ? 'Bathroom size: ' + area + ' sq.ft' : 'base price up to 40 sq.ft';
    });

    /* Renovation prep add-on — base + surcharge logic */
    document.querySelectorAll('.addon-calc-pkg').forEach(function (el) {
      var base = parseInt(el.dataset.base, 10);
      var rate = parseInt(el.dataset.rate, 10);
      el.textContent = formatLKR(calcPrice(base, rate, area));
    });

    /* Area hint */
    var hint = document.getElementById('areaHint');
    if (hint) {
      hint.textContent = (l > 0 && w > 0) ? 'Floor area: ' + area + ' sq.ft' : '';
    }
  }

  lengthInput.addEventListener('input', onDimensionChange);
  widthInput.addEventListener('input',  onDimensionChange);

  /* ── Get Quotation: packages ── */
  document.querySelectorAll('.atc-pkg').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var base  = parseInt(btn.dataset.base, 10);
      var rate  = parseInt(btn.dataset.rate, 10);
      var area  = getArea();
      var price = calcPrice(base, rate, area);
      var details = area > 0 ? area + ' sq.ft' : 'up to 40 sq.ft (base price)';
      window.LHCart.add({ name: btn.dataset.pkgName, details: details, price: price });
    });
  });

  /* ── Get Quotation: renovation prep add-on ── */
  document.querySelectorAll('.atc-addon-pkg').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var base  = parseInt(btn.dataset.base, 10);
      var rate  = parseInt(btn.dataset.rate, 10);
      var area  = getArea();
      var price = calcPrice(base, rate, area);
      var details = area > 0 ? area + ' sq.ft' : 'base (up to 40 sq.ft)';
      window.LHCart.add({ name: btn.dataset.addonName, details: details, price: price });
    });
  });
})();
</script>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.80);
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(240,236,224,.80); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(240,236,224,.93);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: background .2s;
  }
  .btn-primary:hover { background: #b5673c; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Pricing section ── */

  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.85);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  /* ── Area input ── */

  .area-input-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(61,79,66,.08);
    border: 1px solid rgba(61,79,66,.25);
    border-radius: 4px;
    padding: .85rem 1.2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .area-label {
    font-size: .72rem;
    color: rgba(240,236,224,.78);
    text-transform: uppercase;
    letter-spacing: .09em;
    font-weight: 500;
    min-width: 120px;
  }

  .area-fields {
    display: flex;
    align-items: center;
    gap: .6rem;
    flex-wrap: wrap;
  }

  .area-multiply {
    color: rgba(240,236,224,.68);
    font-size: 1rem;
  }

  .area-field {
    display: flex;
    align-items: center;
    gap: .45rem;
  }

  .area-input {
    width: 90px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(61,79,66,.35);
    border-radius: 3px;
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-size: 1.05rem;
    padding: .42rem .65rem;
    text-align: center;
    outline: none;
    min-height: 40px;
    -webkit-appearance: none;
  }

  .area-input:focus { border-color: var(--clay); }

  .area-unit {
    font-size: .75rem;
    color: rgba(240,236,224,.68);
  }

  .area-hint {
    font-size: .72rem;
    color: var(--clay);
    font-style: italic;
    margin-left: auto;
  }

  /* ── Package grid ── */

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .pkg-card {
    background: rgba(255,255,255,.03);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    position: relative;
  }

  .pkg-card--mid {
    background: rgba(61,79,66,.07);
    border-left: 1px solid rgba(61,79,66,.18);
    border-right: 1px solid rgba(61,79,66,.18);
  }

  .pkg-badge {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .18rem .6rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: .2rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
  }

  .pkg-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
    margin-top: .2rem;
    transition: all .15s;
  }

  .pkg-design-tagline {
    font-size: .82rem;
    color: rgba(240,236,224,.72);
    font-style: italic;
    margin-top: -.6rem;
    margin-bottom: 2rem;
  }

  .pkg-desc {
    font-size: .78rem;
    color: rgba(240,236,224,.65);
    font-style: italic;
    line-height: 1.4;
    margin-bottom: .2rem;
  }

  .pkg-price-note {
    font-size: .68rem;
    color: rgba(245,240,232,.65);
    font-weight: 300;
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding-bottom: .75rem;
    margin-bottom: .2rem;
  }

  .pkg-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    flex: 1;
  }

  .pkg-includes li {
    font-size: .75rem;
    color: rgba(240,236,224,.85);
    display: flex;
    align-items: center;
    gap: .5rem;
    line-height: 1.3;
  }

  .pkg-includes li::before {
    content: '◆';
    font-size: .28rem;
    color: var(--clay);
    flex-shrink: 0;
  }

  .pkg-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: .8rem;
    background: var(--clay);
    border: none;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .6rem 1rem;
    border-radius: 3px;
    cursor: pointer;
    width: 100%;
    min-height: 44px;
    transition: background .2s;
  }

  .pkg-btn:hover { background: var(--terracotta); }

  .pkg-btn--primary {
    background: var(--clay);
    color: #fff;
  }
  .pkg-btn--primary:hover { background: var(--terracotta); }

  .pkg-btn--ghost {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(240,236,224,.2);
    color: rgba(240,236,224,.75);
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .6rem 1rem;
    border-radius: 3px;
    text-decoration: none;
    min-height: 44px;
    transition: border-color .2s, color .2s;
    margin-top: 0;
    cursor: pointer;
  }
  .pkg-btn--ghost:hover { border-color: var(--clay); color: var(--clay); }

  .pkg-design {
    border-top: 1px solid rgba(255,255,255,.08);
    padding-top: .6rem;
    margin-top: .2rem;
  }
  .pkg-design-label {
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--clay);
    font-weight: 600;
    margin-bottom: .3rem;
  }
  .pkg-design-items {
    font-size: .7rem;
    color: rgba(240,236,224,.72);
    line-height: 1.6;
  }

  /* ── Add-ons ── */

  .addons-section {
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 4px;
    padding: 1.6rem;
    margin-bottom: 1.6rem;
  }

  .addons-head {
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    font-weight: 600;
    color: rgba(245,240,232,.72);
    margin-bottom: 1rem;
  }

  .addons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 3px;
    overflow: hidden;
  }

  .addons-grid--single {
    grid-template-columns: 1fr;
    max-width: 480px;
  }

  .addon-sublabel {
    font-size: .68rem;
    color: rgba(240,236,224,.55);
    font-style: italic;
    margin-top: -.15rem;
  }

  .addon-card {
    background: rgba(255,255,255,.03);
    padding: 1.2rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .addon-name {
    font-size: .72rem;
    color: rgba(240,236,224,.78);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .07em;
  }

  .addon-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--clay);
    transition: all .15s;
  }

  .addon-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    color: rgba(245,240,232,.65);
    margin-left: .1rem;
  }

  .addon-desc {
    font-size: .7rem;
    color: rgba(245,240,232,.68);
    line-height: 1.5;
    margin-bottom: .2rem;
  }

  .addon-atc {
    margin-top: .4rem;
    background: none;
    border: 1px solid rgba(61,79,66,.35);
    color: var(--clay);
    font-family: 'DM Sans', sans-serif;
    font-size: .67rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    padding: .4rem .7rem;
    border-radius: 3px;
    cursor: pointer;
    width: 100%;
    min-height: 38px;
    transition: background .2s, border-color .2s;
  }

  .addon-atc:hover {
    background: rgba(61,79,66,.1);
    border-color: var(--clay);
  }

  /* ── Not included notice ── */

  .not-included {
    font-size: .8rem;
    color: rgba(240,236,224,.78);
    padding: 1rem 1.2rem;
    background: rgba(61,79,66,.05);
    border-left: 3px solid rgba(61,79,66,.4);
    border-radius: 0 3px 3px 0;
    line-height: 1.65;
  }

  .not-included strong { color: rgba(240,236,224,.90); }

  .not-included-list {
    margin: .5rem 0 0 1rem;
    padding: 0;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .not-included-list li {
    font-size: .78rem;
    color: rgba(240,236,224,.72);
