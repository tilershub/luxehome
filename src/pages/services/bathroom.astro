---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Services — Tiling & Full Renovation — TILERSHUB Sri Lanka"
  description="Expert bathroom tiling and full bathroom renovation across Sri Lanka. Rs. 500/sq.ft tiling with all materials, or complete gut-to-finish renovation packages from Rs. 450,000."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#services">Services</a>
        <span>›</span>
        <span>Bathroom</span>
      </div>
      <h1 class="reveal">Bathroom Services</h1>
      <p class="hero-desc reveal">
        Whether you need professional tiling for walls and floors, or a complete
        bathroom transformation from demolition to final fittings — TILERSHUB
        handles it all under one team.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          Get a Quote
        </a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="hub-section">
    <div class="hub-inner">
      <div class="stag reveal">Choose Your Service</div>
      <h2 class="reveal">Everything Your<br />Bathroom Needs</h2>
      <p class="sdesc reveal">
        From a single trade to a complete gut-and-rebuild — every bathroom
        service under one team, with transparent pricing on every job.
      </p>

      <div class="hub-grid reveal">

        <!-- Bathroom Tiling -->
        <a href="/services/bathroom-tiling" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/5768318/pexels-photo-5768318.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Bathroom tiling" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Tiling</div>
            <h3>Bathroom Tiling</h3>
            <p>Walls &amp; floors — Tokyo Super HP adhesive, Swisstek grout, tile leveling system. You supply tiles; we handle everything else.</p>
            <div class="hc-price">From <strong>Rs. 500</strong> <span>/ sq.ft</span></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Waterproofing -->
        <a href="/services/bathroom-waterproofing" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/4953232/pexels-photo-4953232.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Bathroom waterproofing" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Waterproofing</div>
            <h3>Bathroom Waterproofing</h3>
            <p>Tokyo Super 2K membrane applied to all wet surfaces with fibre net reinforcement at every edge and joint.</p>
            <div class="hc-price">From <strong>Rs. 350</strong> <span>/ sq.ft</span></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Plumbing -->
        <a href="/services/bathroom-plumbing" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/5825561/pexels-photo-5825561.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Bathroom plumbing" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Plumbing</div>
            <h3>Bathroom Plumbing</h3>
            <p>Slon UPVC &amp; CPVC pipe systems — standard or fully concealed fittings. Pressure tested before handover.</p>
            <div class="hc-price"><strong>Rs. 100,000</strong> <span>Standard &nbsp;·&nbsp; </span><strong>Rs. 150,000</strong> <span>Concealed</span></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Ceiling -->
        <a href="/services/bathroom-ceiling" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/1643383/pexels-photo-1643383.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Bathroom ceiling" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Ceiling</div>
            <h3>Bathroom Ceiling</h3>
            <p>Moisture-resistant iPanel PVC ceiling with concealed steel frame and integrated lighting fixtures — fully installed.</p>
            <div class="hc-price">From <strong>Rs. 1,500</strong> <span>/ sq.ft with lighting</span></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Electrical -->
        <a href="/services/bathroom-electrical" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/1080721/pexels-photo-1080721.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Bathroom electrical works" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Electrical</div>
            <h3>Bathroom Electrical</h3>
            <p>Full wiring with ACL cables and IP-rated fixtures — lighting, geyser dedicated circuit, exhaust fan, and switchboard connection.</p>
            <div class="hc-price"><strong>Rs. 60,000</strong> <span>per bathroom</span></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Shower Cubicle -->
        <a href="/services/shower-cubicle" class="hub-card">
          <div class="hc-thumb">
            <img src="https://images.pexels.com/photos/5825561/pexels-photo-5825561.jpeg?auto=compress&cs=tinysrgb&w=600&h=320&fit=crop" alt="Glass shower cubicle" loading="lazy" width="600" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge">Shower</div>
            <h3>Shower Cubicle</h3>
            <p>Frameless &amp; semi-frameless tempered glass cubicles — L-shape, panel swing, panel sliding, and double sliding configurations.</p>
            <div class="hc-price">From <strong>Rs. 76,500</strong></div>
            <span class="hc-link">View Details →</span>
          </div>
        </a>

        <!-- Bathroom Renovation — full width -->
        <a href="/services/bathroom-renovation" class="hub-card hub-card--wide">
          <div class="hc-thumb hc-thumb--wide">
            <img src="https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1200&h=320&fit=crop" alt="Full bathroom renovation" loading="lazy" width="1200" height="320" />
          </div>
          <div class="hc-body">
            <div class="hc-badge hc-badge--reno">Full Renovation</div>
            <h3>Bathroom Renovation</h3>
            <p>Complete bathroom construction — demolition, masonry, plumbing, electrical, waterproofing, tiling, ceiling, and vanity cupboard. Every trade under one team, from start to final handover.</p>
            <ul class="hc-list">
              <li>✓ Demolition &amp; masonry &nbsp;·&nbsp; ✓ Plumbing &amp; electrical</li>
              <li>✓ Waterproofing &amp; full tiling &nbsp;·&nbsp; ✓ iPanel ceiling</li>
              <li>✓ Optional: Bathware, taps &amp; geyser &nbsp;·&nbsp; ✓ Optional: 3D design</li>
            </ul>
            <div class="hc-price">From <strong>Rs. 450,000</strong></div>
            <span class="hc-link">View Full Details →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <CTA />
  <Footer />
</Layout>

<style>
  /* ── Page Hero ── */

  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    margin-top: 0;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(30, 26, 23, .72) 0%,
      rgba(30, 26, 23, .45) 60%,
      rgba(30, 26, 23, .72) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, .55);
    margin-bottom: 1.2rem;
  }

  .breadcrumb a {
    color: rgba(245, 240, 232, .55);
    text-decoration: none;
    transition: color .2s;
  }

  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(245, 240, 232, .8);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: #25d366;
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }

  .btn-primary:hover { background: #1fb855; transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245, 240, 232, .35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }

  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* ── Hub Section ── */

  .hub-section {
    background: var(--cream);
    padding: 5.5rem 4rem;
  }

  .hub-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 3.5vw, 2.7rem);
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .sdesc {
    font-size: .97rem;
    color: var(--warm-gray);
    line-height: 1.72;
    max-width: 58ch;
    margin-bottom: 3rem;
  }

  /* ── Hub Cards Grid ── */

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .hub-card--wide {
    grid-column: span 3;
    flex-direction: row;
  }

  .hub-card--wide .hc-thumb--wide {
    width: 420px;
    height: auto;
    flex-shrink: 0;
  }

  .hub-card--wide .hc-body {
    padding: 2rem 2.2rem;
  }

  .hub-card {
    background: #fff;
    border: 1px solid var(--stone);
    border-radius: 3px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: box-shadow .3s, transform .3s;
  }

  .hub-card:hover {
    box-shadow: 0 12px 40px rgba(30, 26, 23, .12);
    transform: translateY(-4px);
  }

  .hc-thumb {
    height: 240px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .hc-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(.75) saturate(.8);
    transition: transform .45s ease, filter .4s ease;
  }

  .hub-card:hover .hc-thumb img {
    transform: scale(1.05);
    filter: brightness(.88) saturate(.95);
  }

  .hc-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .hc-badge {
    display: inline-block;
    font-size: .68rem;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    background: rgba(196, 120, 74, .12);
    color: var(--clay);
    border: 1px solid rgba(196, 120, 74, .25);
    padding: .25rem .65rem;
    border-radius: 2px;
    margin-bottom: 1rem;
    width: fit-content;
  }

  .hc-badge--reno {
    background: rgba(30, 26, 23, .07);
    color: var(--charcoal);
    border-color: rgba(30, 26, 23, .18);
  }

  .hc-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--charcoal);
    line-height: 1.2;
    margin-bottom: .85rem;
  }

  .hc-body p {
    font-size: .88rem;
    color: var(--warm-gray);
    line-height: 1.72;
    margin-bottom: 1.2rem;
  }

  .hc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .hc-list li {
    font-size: .8rem;
    color: var(--warm-gray);
    line-height: 1.5;
  }

  .hc-price {
    font-size: .85rem;
    color: var(--warm-gray);
    margin-top: auto;
    padding-top: 1.2rem;
    border-top: 1px solid var(--stone);
    margin-bottom: 1rem;
  }

  .hc-price strong {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--clay);
  }

  .hc-price span {
    font-size: .78rem;
    color: var(--warm-gray);
  }

  .hc-link {
    display: inline-block;
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .05em;
    color: var(--clay);
    border-bottom: 1px solid rgba(196, 120, 74, .35);
    padding-bottom: .1rem;
    width: fit-content;
    transition: border-color .2s, color .2s;
  }

  .hub-card:hover .hc-link {
    border-color: var(--clay);
    color: #e08c5a;
  }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .hub-section { padding: 4.5rem 2.5rem; }
    .hub-grid { grid-template-columns: repeat(2, 1fr); }
    .hub-card--wide { grid-column: span 2; flex-direction: column; }
    .hub-card--wide .hc-thumb--wide { width: 100%; height: 200px; }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .hub-section { padding: 4rem 1.5rem; }
    .hub-grid { grid-template-columns: 1fr; }
    .hub-card--wide { grid-column: span 1; }
    .hub-card--wide .hc-thumb--wide { width: 100%; }
  }
</style>
