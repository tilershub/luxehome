---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Flooring — Tile & Slab Installation — TILERSHUB Sri Lanka"
  description="Professional floor tiling across Sri Lanka. Three packages from Rs. 350/sq.ft — Standard, Medium, and Large Format / Slabs. Tile leveling system, Tokyo cement, Swisstek grout."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#services">Services</a>
        <span>›</span>
        <span>Flooring</span>
      </div>
      <h1 class="reveal">Flooring</h1>
      <p class="hero-desc reveal">
        Precision tile installation with a leveling system, Tokyo HP cement, and Swisstek grout —
        three packages to match any tile size and budget.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Get an Instant Price →</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Pricing overview -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">Transparent Pricing</div>
      <h2 class="reveal">Three Packages, One Standard of Work</h2>
      <p class="sdesc reveal">All packages include tile leveling system, Tokyo Super HP cement, Swisstek grout, and a clean finished edge. You supply the tiles — we handle everything else.</p>

      <div class="pkg-grid reveal">

        <div class="pkg-card">
          <div class="pkg-name">Standard</div>
          <div class="pkg-sub">Up to 4×2 tiles · Spacer joints</div>
          <div class="pkg-price-row"><span class="pkg-label">Floor</span><span class="pkg-price">Rs. 350 <em>/sq.ft</em></span></div>
          <div class="pkg-price-row"><span class="pkg-label">Skirting</span><span class="pkg-price">Rs. 250 <em>/lin.ft</em></span></div>
        </div>

        <div class="pkg-card pkg-card--mid">
          <div class="pkg-badge">Most Popular</div>
          <div class="pkg-name">Medium Tiles</div>
          <div class="pkg-sub">Router edge · Precision levelling · Large format</div>
          <div class="pkg-price-row"><span class="pkg-label">Floor</span><span class="pkg-price">Rs. 500 <em>/sq.ft</em></span></div>
          <div class="pkg-price-row"><span class="pkg-label">Skirting</span><span class="pkg-price">Rs. 350 <em>/lin.ft</em></span></div>
        </div>

        <div class="pkg-card">
          <div class="pkg-name">Large Tiles & Slabs</div>
          <div class="pkg-sub">Levelling clips · Expert handling · Seamless finish</div>
          <div class="pkg-price-row"><span class="pkg-label">Floor</span><span class="pkg-price">Rs. 700 <em>/sq.ft</em></span></div>
          <div class="pkg-price-row"><span class="pkg-label">Skirting</span><span class="pkg-price">Rs. 450 <em>/lin.ft</em></span></div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(245,240,232,.55);
    margin-bottom: 1.2rem;
  }
  .breadcrumb a { color: rgba(245,240,232,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(245,240,232,.8);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #b5673c; transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* Pricing section */
  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(245,240,232,.6);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2.8rem;
  }

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .pkg-card {
    background: rgba(255,255,255,.03);
    padding: 1.8rem 2rem;
    display: flex;
    flex-direction: column;
    gap: .7rem;
    position: relative;
  }

  .pkg-card--mid {
    background: rgba(196,120,74,.07);
    border-left: 1px solid rgba(196,120,74,.18);
    border-right: 1px solid rgba(196,120,74,.18);
  }

  .pkg-badge {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .2rem .6rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: .3rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
  }

  .pkg-sub {
    font-size: .75rem;
    color: rgba(245,240,232,.5);
    line-height: 1.5;
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding-bottom: .8rem;
    margin-bottom: .3rem;
  }

  .pkg-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .pkg-label {
    font-size: .72rem;
    color: rgba(245,240,232,.45);
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .pkg-price {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clay);
  }

  .pkg-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .7rem;
    font-weight: 300;
    color: rgba(245,240,232,.4);
    margin-left: .1rem;
  }

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .pricing-section { padding: 4.5rem 2.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
    .pkg-card--mid { border-left: none; border-right: none; border-top: 1px solid rgba(196,120,74,.18); border-bottom: 1px solid rgba(196,120,74,.18); }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .pricing-section { padding: 4rem 1.5rem; }
  }
</style>
