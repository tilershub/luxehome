---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import SiteVisitCTA from '../../components/SiteVisitCTA.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Floor Tiling Sri Lanka — From Rs. 350/sq.ft | LUXEHOME"
  description="Professional floor tiling across Sri Lanka from Rs. 350/sq.ft. Tile leveling system, Swisstek grout, Tokyo cement — all materials included. Serving Colombo, Kandy, Galle & all Sri Lanka."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/1144871/pexels-photo-1144871.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#shop">Services</a>
        <span>›</span>
        <span>Tiling</span>
      </div>
      <h1 class="reveal">Tiling</h1>
      <p class="hero-desc reveal">
        Everything included — tiles, leveling system, Tokyo HP cement, and Swisstek grout.
        Two options by tile brand, up to 4×2 size. Enter your measurements below to get an accurate price.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Book Site Inspection — Rs. 10,000</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">Transparent Pricing</div>
      <h2 class="reveal">Two Options, One Standard of Work</h2>
      <p class="sdesc reveal">All materials included in the rate — tiles, leveling system, Tokyo Super HP cement, and Swisstek grout. Choose your tile brand; both handle tiles up to 4×2 size.</p>

      <div class="pkg-grid reveal">

        <!-- Mega Tiles -->
        <div class="pkg-card" data-floor-rate="1000">
          <div class="pkg-name">Mega Tiles</div>
          <div class="pkg-sub">Up to 4×2 size</div>
          <div class="pkg-inputs">
            <div class="input-row">
              <label>Floor area</label>
              <div class="input-field">
                <input type="number" class="area-in floor-in" min="1" placeholder="sq.ft" inputmode="decimal" />
                <span>sq.ft</span>
              </div>
            </div>
          </div>
          <div class="pkg-result" hidden>
            <div class="result-total"><span>Total</span><span class="grand-total"></span></div>
          </div>
          <div class="pkg-rates">
            <div class="pkg-price-row"><span class="pkg-label">Floor</span><span class="pkg-price">Rs. 1,000 <em>/sq.ft</em></span></div>
          </div>
          <button class="pkg-btn atc-tile-btn">Add to Cart</button>
        </div>

        <!-- Rocell Tiles -->
        <div class="pkg-card pkg-card--mid" data-floor-rate="1200">
          <div class="pkg-badge">Premium</div>
          <div class="pkg-name">Rocell Tiles</div>
          <div class="pkg-sub">Up to 4×2 size</div>
          <div class="pkg-inputs">
            <div class="input-row">
              <label>Floor area</label>
              <div class="input-field">
                <input type="number" class="area-in floor-in" min="1" placeholder="sq.ft" inputmode="decimal" />
                <span>sq.ft</span>
              </div>
            </div>
          </div>
          <div class="pkg-result" hidden>
            <div class="result-total"><span>Total</span><span class="grand-total"></span></div>
          </div>
          <div class="pkg-rates">
            <div class="pkg-price-row"><span class="pkg-label">Floor</span><span class="pkg-price">Rs. 1,200 <em>/sq.ft</em></span></div>
          </div>
          <button class="pkg-btn atc-tile-btn">Add to Cart</button>
        </div>

      </div>

      <div class="not-included reveal">
        <strong>All materials included:</strong> Tiles, adhesive, leveling clips, and Swisstek grout are all covered in the quoted rate. No hidden extras.
      </div>
    </div>
  </section>

  <section id="recent-projects" class="recent-proj-section">
    <div class="recent-proj-inner">
      <div class="stag">Our Work</div>
      <h2>Recent Flooring Projects</h2>
      <div id="proj-grid" class="mini-proj-row"></div>
      <a href="/projects?category=flooring" class="view-all-link">View All Flooring Projects →</a>
    </div>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    if (SB_URL && SB_KEY) {
      const sb = createClient(SB_URL, SB_KEY);
      (async () => {
        const { data } = await sb.from('projects')
          .select('slug,title,cover_image,location')
          .eq('category', 'flooring')
          .in('status', ['published', 'featured'])
          .order('completion_year', { ascending: false })
          .limit(3);
        if (!data?.length) return;
        const section = document.getElementById('recent-projects');
        const grid = document.getElementById('proj-grid');
        if (!section || !grid) return;
        grid.innerHTML = data.map(p => `
          <a href="/projects/${p.slug}" class="mini-card">
            <div class="mini-img">${p.cover_image ? `<img src="${p.cover_image}" alt="${p.title}" loading="lazy">` : ''}</div>
            <div class="mini-body">
              <div class="mini-title">${p.title}</div>
              ${p.location ? `<div class="mini-loc">${p.location}</div>` : ''}
            </div>
          </a>
        `).join('');
        section.style.display = '';
      })();
    }
  </script>

  <SiteVisitCTA service="floor tiling" />
  <Footer />
</Layout>

<script is:inline>
(function () {
  function fmt(n) {
    return 'Rs.\u00a0' + Math.round(n).toLocaleString('en-IN');
  }

  document.querySelectorAll('.pkg-card[data-floor-rate]').forEach(function (card) {
    var floorRate = parseInt(card.dataset.floorRate, 10);
    var floorIn = card.querySelector('.floor-in');
    var result = card.querySelector('.pkg-result');
    var atcBtn = card.querySelector('.atc-tile-btn');
    var pkgName = card.querySelector('.pkg-name').textContent.trim();

    function calcTotal() {
      var floor = parseFloat(floorIn.value) || 0;
      return { floor: floor, total: floor * floorRate };
    }

    function update() {
      var v = calcTotal();
      if (v.floor <= 0) { result.hidden = true; return; }
      card.querySelector('.grand-total').textContent = fmt(v.total);
      result.hidden = false;
    }

    floorIn.addEventListener('input', update);

    atcBtn.addEventListener('click', function () {
      var v = calcTotal();
      if (v.total <= 0) {
        floorIn.focus();
        floorIn.style.borderColor = 'var(--clay)';
        setTimeout(function () { floorIn.style.borderColor = ''; }, 1500);
        return;
      }
      window.LHCart.add({ name: pkgName, details: v.floor + ' sq.ft floor', price: v.total });
    });
  });
})();
</script>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.80);
    margin-bottom: 1.2rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(240,236,224,.80); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(240,236,224,.93);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: background .2s;
  }
  .btn-primary:hover { background: #b5673c; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    min-height: 44px;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.85);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2.8rem;
  }

  /* ── Package grid ── */

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1.6rem;
    align-items: start;
  }

  .pkg-card {
    background: rgba(255,255,255,.03);
    padding: 1.6rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .8rem;
    position: relative;
  }

  .pkg-card--mid {
    background: rgba(184,148,90,.07);
    border-left: 1px solid rgba(184,148,90,.18);
    border-right: 1px solid rgba(184,148,90,.18);
  }

  .pkg-badge {
    display: inline-block;
    background: var(--clay);
    color: #fff;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .18rem .6rem;
    border-radius: 20px;
    width: fit-content;
    margin-bottom: -.2rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cream);
  }

  .pkg-sub {
    font-size: .7rem;
    color: rgba(240,236,224,.68);
    line-height: 1.5;
    border-bottom: 1px solid rgba(255,255,255,.07);
    padding-bottom: .75rem;
    margin-bottom: -.1rem;
  }

  /* ── Inputs ── */

  .pkg-inputs {
    display: flex;
    flex-direction: column;
    gap: .55rem;
  }

  .input-row {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .input-row label {
    font-size: .65rem;
    color: rgba(240,236,224,.68);
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 500;
  }

  .input-field {
    display: flex;
    align-items: center;
    gap: .35rem;
  }

  .area-in {
    flex: 1;
    min-width: 0;
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 3px;
    color: var(--cream);
    font-family: 'DM Sans', sans-serif;
    font-size: .95rem;
    padding: .4rem .55rem;
    outline: none;
    min-height: 38px;
    -webkit-appearance: none;
    transition: border-color .2s;
  }

  .area-in:focus {
    border-color: var(--clay);
    background: rgba(184,148,90,.06);
  }

  .input-field span {
    font-size: .68rem;
    color: rgba(245,240,232,.35);
    flex-shrink: 0;
  }

  /* ── Result breakdown ── */

  .pkg-result {
    background: rgba(184,148,90,.07);
    border: 1px solid rgba(184,148,90,.2);
    border-radius: 3px;
    padding: .8rem .9rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: .72rem;
    color: rgba(240,236,224,.78);
    gap: .4rem;
  }

  .result-row span:last-child {
    font-family: 'Playfair Display', serif;
    font-size: .85rem;
    font-weight: 700;
    color: rgba(245,240,232,.75);
    text-align: right;
  }

  .result-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: .72rem;
    color: rgba(240,236,224,.78);
    border-top: 1px solid rgba(184,148,90,.2);
    padding-top: .35rem;
    margin-top: .1rem;
    gap: .4rem;
  }

  .result-total span:last-child {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 800;
    color: var(--clay);
    text-align: right;
  }

  /* ── Rates (reference) ── */

  .pkg-rates {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    padding-top: .5rem;
    border-top: 1px solid rgba(255,255,255,.07);
  }

  .pkg-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: .4rem;
  }

  .pkg-label {
    font-size: .68rem;
    color: rgba(245,240,232,.35);
    text-transform: uppercase;
    letter-spacing: .08em;
    flex-shrink: 0;
  }

  .pkg-price {
    font-family: 'Playfair Display', serif;
    font-size: .82rem;
    font-weight: 700;
    color: rgba(184,148,90,.65);
    text-align: right;
  }

  .pkg-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    color: rgba(245,240,232,.28);
    margin-left: .1rem;
  }

  /* ── Book button ── */

  .pkg-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clay);
    border: none;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .55rem 1rem;
    border-radius: 3px;
    cursor: pointer;
    width: 100%;
    min-height: 44px;
    margin-top: auto;
    transition: background .2s;
  }

  .pkg-btn:hover { background: #b5673c; }

  /* ── Not included ── */

  .not-included {
    font-size: .8rem;
    color: rgba(240,236,224,.78);
    padding: 1rem 1.2rem;
    background: rgba(184,148,90,.05);
    border-left: 3px solid rgba(184,148,90,.4);
    border-radius: 0 3px 3px 0;
    line-height: 1.65;
  }

  .not-included strong { color: rgba(240,236,224,.90); }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .pricing-section { padding: 4.5rem 2.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .pricing-section { padding: 4rem 1.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
    .pkg-card--mid {
      border-left: none;
      border-right: none;
      border-top: 1px solid rgba(184,148,90,.18);
      border-bottom: 1px solid rgba(184,148,90,.18);
    }
  }

  @media (max-width: 480px) {
    .page-hero {
      padding: 0 1rem 2rem;
      min-height: auto;
    }
    .hero-inner {
      padding-top: calc(5rem + env(safe-area-inset-top, 0px));
    }
    .pricing-section { padding: 2.5rem 1rem; }

    h1 { font-size: clamp(2rem, 8vw, 2.4rem); margin-bottom: .8rem; }
    .hero-desc { font-size: .88rem; margin-bottom: 1.4rem; }

    .hero-cta { flex-direction: column; gap: .7rem; }
    .btn-primary, .btn-ghost { width: 100%; justify-content: center; }

    .pkg-card { padding: 1.2rem 1rem; }
    .area-in { min-height: 44px; font-size: 1rem; }
  }

  /* ── Recent Projects ── */
  .recent-proj-section {
    display: none;
    background: rgba(255,255,255,.02);
    border-top: 1px solid rgba(255,255,255,.07);
    padding: 4rem 4rem 5rem;
  }
  .recent-proj-inner { max-width: 1100px; margin: 0 auto; }
  .recent-proj-inner h2 { margin-bottom: 1.8rem; }
  .mini-proj-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }
  .mini-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .25s, border-color .25s;
    background: rgba(255,255,255,.03);
  }
  .mini-card:hover { transform: translateY(-4px); border-color: rgba(184,148,90,.35); }
  .mini-img { height: 180px; overflow: hidden; background: rgba(255,255,255,.05); }
  .mini-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .mini-card:hover .mini-img img { transform: scale(1.05); }
  .mini-body { padding: 1rem 1.1rem 1.2rem; }
  .mini-title { font-size: .88rem; font-weight: 600; color: var(--cream); line-height: 1.35; margin-bottom: .3rem; }
  .mini-loc { font-size: .72rem; color: rgba(240,236,224,.55); }
  .view-all-link {
    font-size: .8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .1em; color: var(--clay); text-decoration: none; transition: opacity .2s;
  }
  .view-all-link:hover { opacity: .75; }
  @media (max-width: 900px) { .mini-proj-row { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 580px) {
    .recent-proj-section { padding: 3rem 1rem 4rem; }
    .mini-proj-row { grid-template-columns: 1fr; }
  }
</style>
