---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import BathroomCalculator from '../../components/BathroomCalculator.astro';
---

<Layout
  title="Bathroom Renovation Services — TILERSHUB Sri Lanka"
  description="Full-scope bathroom renovation across Sri Lanka. Masonry, plumbing, waterproofing, electrical, tiling, ceiling and more. Packages from Rs. 450,000."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/16249146/pexels-photo-16249146.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/services/bathroom">Bathroom</a>
        <span>›</span>
        <span>Bathroom Renovation</span>
      </div>
      <h1 class="reveal">Bathroom Construction<br />&amp; Renovation</h1>
      <p class="hero-desc reveal">
        Full-scope renovation from demolition to final fittings — every trade under one team.
        All labour and materials included. You supply only tiles, bathware, and tapware.
      </p>
      <div class="price-tags reveal">
        <div class="price-tag">
          <span class="p-amt">Rs. 450,000</span>
          <span class="p-unit">from · Basic</span>
        </div>
        <div class="price-tag">
          <span class="p-amt">Rs. 550,000</span>
          <span class="p-unit">from · Standard</span>
        </div>
        <div class="price-tag">
          <span class="p-amt">Rs. 650,000</span>
          <span class="p-unit">from · Luxury</span>
        </div>
      </div>
      <div class="hero-badges reveal">
        <span class="hbadge">Mason Works</span>
        <span class="hbadge">Plumbing</span>
        <span class="hbadge">Electrical Wiring</span>
        <span class="hbadge">Waterproofing</span>
        <span class="hbadge">Tiling</span>
        <span class="hbadge">Ceiling</span>
        <span class="hbadge">Vanity Cupboard</span>
        <span class="hbadge">Shower Cubicle</span>
        <span class="hbadge">+ Demolition Add-on</span>
        <span class="hbadge">+ 3D Design Add-on</span>
      </div>
      <div class="hero-cta reveal">
        <a href="#renovation-calculator" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          Get a Bathroom Quote
        </a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Scope Grid -->
  <section class="scope-section">
    <div class="scope-inner">
      <div class="stag reveal">Full Scope Breakdown</div>
      <h2 class="reveal">Every Trade. One Team.</h2>
      <p class="sdesc reveal">
        All trades managed and executed under one contract — no coordinating subcontractors, no handover gaps, no surprises.
        All three packages include masonry, plumbing, electrical, waterproofing, and tiling.
        Demolition and 3D design are available as optional add-ons.
      </p>
      <div class="scope-grid reveal">
        <div class="scope-card featured">
          <div class="scope-icon">🔨</div>
          <div class="scope-name">Demolition <span style="font-size:.72rem;font-weight:400;color:var(--warm-gray);margin-left:.4rem;">Optional Add-on · Rs. 1,000 / sq.ft</span></div>
          <div class="scope-desc">Full strip-out of existing bathroom — floor, walls, fittings, and ceiling. Site cleared and ready for new construction. Available as an optional add-on if your bathroom requires full demolition before work begins.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">📐</div>
          <div class="scope-name">3D Bathroom Design <span style="font-size:.72rem;font-weight:400;color:var(--warm-gray);margin-left:.4rem;">Optional Add-on · Rs. 25,000</span></div>
          <div class="scope-desc">Visualise your new bathroom before work begins. We produce a 3D render of your layout, tile selection, fixture placement, and finishes — so you can approve the look before a single tile is laid.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🧱</div>
          <div class="scope-name">Masonry Works <span class="scope-pkg-tag">All Packages</span></div>
          <div class="scope-desc">Wall niche construction, floor concrete, floor screed preparation, vanity top construction, and wall plastering. No structural changes.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🚿</div>
          <div class="scope-name">Plumbing <span class="scope-pkg-tag">All Packages</span></div>
          <div class="scope-desc">Complete supply and drain rough-in — hot and cold supply lines, waste pipes, and all rough plumbing for shower, basin, and WC.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">⚡</div>
          <div class="scope-name">Electrical Wiring <span class="scope-pkg-tag">All Packages</span></div>
          <div class="scope-desc">Lighting rough-in, exhaust fan wiring, and shaving/mirror point installation — all to code and safely inside the waterproofed envelope.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">💧</div>
          <div class="scope-name">Waterproofing <span class="scope-pkg-tag">All Packages</span></div>
          <div class="scope-desc">Full membrane application across floor, walls to splash height, and shower recess. Critical in Sri Lanka's humid climate — never skipped.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🔲</div>
          <div class="scope-name">Tiling <span class="scope-pkg-tag">All Packages</span></div>
          <div class="scope-desc">Floor tiling, full wall tiling to ceiling, shower recess, and all wet areas — using tile leveling system throughout for a perfect finish.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🏠</div>
          <div class="scope-name">Ceiling <span class="scope-pkg-tag">Standard &amp; Luxury</span></div>
          <div class="scope-desc">Waterproof PVC or gypsum ceiling installed and finished — appropriate for bathroom humidity and fully compatible with exhaust fitting.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🪵</div>
          <div class="scope-name">Vanity Cupboard <span class="scope-pkg-tag">Luxury</span></div>
          <div class="scope-desc">Eco board vanity cupboard constructed and fitted with a durable, moisture-resistant quartz top — cleanly edged and built to last.</div>
        </div>
        <div class="scope-card">
          <div class="scope-icon">🚪</div>
          <div class="scope-name">Shower Cubicle <span class="scope-pkg-tag">Luxury</span></div>
          <div class="scope-desc">Shower cubicle fitted and commissioned along with all client-supplied fittings — basin, WC, mirror, towel rails, and accessories.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Details -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="pricing-card reveal">
        <div class="pc-label">Packages</div>
        <div class="pkg-compare">
          <div class="pkgc-row pkgc-header">
            <span></span>
            <span class="pkgc-pkg">Basic</span>
            <span class="pkgc-pkg pkgc-popular">Standard</span>
            <span class="pkgc-pkg">Luxury</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Base Price</span>
            <span>Rs. 450,000</span>
            <span class="pkgc-highlight">Rs. 550,000</span>
            <span>Rs. 650,000</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Base Area</span>
            <span>up to 40 sq.ft</span>
            <span class="pkgc-highlight">up to 40 sq.ft</span>
            <span>up to 40 sq.ft</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Extra / sq.ft</span>
            <span>Rs. 5,000</span>
            <span class="pkgc-highlight">Rs. 6,000</span>
            <span>Rs. 7,000</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Ceiling</span>
            <span class="pkgc-no">—</span>
            <span class="pkgc-highlight pkgc-yes">✓</span>
            <span class="pkgc-yes">✓</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Vanity Cupboard</span>
            <span class="pkgc-no">—</span>
            <span class="pkgc-highlight pkgc-no">—</span>
            <span class="pkgc-yes">✓</span>
          </div>
          <div class="pkgc-row">
            <span class="pkgc-attr">Shower Cubicle</span>
            <span class="pkgc-no">—</span>
            <span class="pkgc-highlight pkgc-no">—</span>
            <span class="pkgc-yes">✓</span>
          </div>
        </div>
        <div class="pc-note">
          All packages include: Masonry Works, Plumbing, Electrical Wiring, Waterproofing, and Tiling.
          Demolition (Rs. 1,000/sq.ft) and 3D Bathroom Design (Rs. 25,000) available as add-ons.
        </div>
        <a href="#renovation-calculator" class="pc-cta">Use the Calculator →</a>
        <a
          href="https://wa.me/94774503744?text=Hello%2C%20I%20am%20interested%20in%20a%20bathroom%20renovation%20quote."
          class="pc-cta pc-cta-wa"
        >WhatsApp for a Site Visit →</a>
      </div>
      <div class="supply-col reveal">
        <div class="stag">What You Supply</div>
        <h2>Three things only.</h2>
        <p class="sdesc">
          Everything else — all labour, all other materials, and all trades — is included in our rate.
        </p>
        <div class="supply-items">
          <div class="supply-item">
            <div class="supply-num">01</div>
            <div>
              <div class="supply-name">Tiles</div>
              <div class="supply-desc">Floor tiles, wall tiles, and any feature tiles of your choice. We advise on quantities needed once we have the measurements.</div>
            </div>
          </div>
          <div class="supply-item">
            <div class="supply-num">02</div>
            <div>
              <div class="supply-name">Bathware Fittings</div>
              <div class="supply-desc">WC suite, wash basin, shower tray or base, bath (if applicable), and shower cubicle/screen.</div>
            </div>
          </div>
          <div class="supply-item">
            <div class="supply-num">03</div>
            <div>
              <div class="supply-name">Tapware &amp; Accessories</div>
              <div class="supply-desc">Mixer taps, showerhead, towel rails, toilet roll holders, mirror, and any other surface-mounted accessories.</div>
            </div>
          </div>
        </div>
        <div class="supply-note">
          We can advise on specifications and quantities for all three — just ask when we do the site visit.
        </div>
      </div>
    </div>
  </section>

  <BathroomCalculator />

  <!-- Process -->
  <section class="process-section">
    <div class="section-inner">
      <div class="stag">Project Stages</div>
      <h2>How a Renovation Runs</h2>
      <p class="sdesc">
        A clear, sequenced approach — each trade completed and inspected before the next begins.
      </p>
      <div class="steps">
        <div class="step reveal">
          <div class="step-num">01</div>
          <div class="step-content">
            <div class="step-name">Designing & Planning</div>
            <div class="step-desc">Site visit, measurements, layout design, fixture placement planning, tile size guidance, and a detailed fixed quote — all before any work begins.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">02</div>
          <div class="step-content">
            <div class="step-name">Demolition</div>
            <div class="step-desc">Full strip-out of existing floor, walls, ceiling, and fittings. All waste removed from site. Clean slate for new construction.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">03</div>
          <div class="step-content">
            <div class="step-name">Mason Work</div>
            <div class="step-desc">Wall niches formed, floor concrete and screed laid, vanity top constructed, and wall plastering completed. No structural changes — inspected before next stage.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">04</div>
          <div class="step-content">
            <div class="step-name">Plumbing & Electrical Rough-in</div>
            <div class="step-desc">All supply, drain, and electrical rough-in completed and tested before walls are closed. No chasing walls open later.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">05</div>
          <div class="step-content">
            <div class="step-name">Waterproofing</div>
            <div class="step-desc">Full membrane applied across all wet areas — floor and walls. Allowed to fully cure before tiling begins. Critical step, never skipped.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">06</div>
          <div class="step-content">
            <div class="step-name">Tiling</div>
            <div class="step-desc">Floor, walls, shower recess tiled with tile leveling system. Waterproof Swisstek grout applied throughout. Full clean-up.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">07</div>
          <div class="step-content">
            <div class="step-name">Ceiling & Finishing</div>
            <div class="step-desc">Waterproof ceiling installed and finished. Electrical trims fitted. All surfaces inspected and any snags addressed.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">08</div>
          <div class="step-content">
            <div class="step-name">Fixtures & Handover</div>
            <div class="step-desc">All client-supplied fittings installed and commissioned. Final walkthrough with you — bathroom ready to use.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="section-inner faq-inner">
      <div class="stag">Common Questions</div>
      <h2>Bathroom Renovation FAQ</h2>
      <div class="faqs">
        <div class="faq reveal">
          <div class="faq-q">How is the price calculated?</div>
          <div class="faq-a">Each package has a base price that covers bathrooms up to 40 sq.ft. If your bathroom is larger, an additional rate per sq.ft above 40 is added — Rs. 5,000 (Basic), Rs. 6,000 (Standard), or Rs. 7,000 (Luxury). Use the calculator on this page to get an instant estimate for your floor area.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Why is waterproofing so important?</div>
          <div class="faq-a">Waterproofing is the single most critical stage of any bathroom renovation in Sri Lanka's humid climate. A missed or inadequate membrane leads to water ingress into the structure within months. We never skip or skimp on this step — full membrane application is standard on every project.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">How long does a full bathroom renovation take?</div>
          <div class="faq-a">A standard bathroom (30–50 sq.ft) typically takes 10–15 working days depending on scope. We confirm the timeline during the site visit and keep you updated throughout.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Can you advise on tile selection?</div>
          <div class="faq-a">Yes — we're happy to advise on tile sizes, formats, and finishes that suit your bathroom dimensions and your brief. We work alongside your tile supplier, or can recommend suppliers if needed.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Do you handle new bathroom builds as well as renovations?</div>
          <div class="faq-a">Yes — our full scope covers both new bathroom construction (where no bathroom existed before) and complete renovations of existing bathrooms. The process and pricing approach is the same.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Is the price fixed once agreed?</div>
          <div class="faq-a">Yes — once we've done the site visit and issued a quote, that price is fixed for the agreed scope. Any additions or changes to scope during the project are priced and agreed with you before work proceeds.</div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
  <Footer />
</Layout>

<style>
  /* ── Page Hero ── */

  .page-hero {
    background:
      linear-gradient(rgba(30,26,23,.82), rgba(30,26,23,.96)),
      var(--hero-bg, var(--charcoal));
    background-size: cover;
    background-position: center;
    padding: 7rem 4rem 5.5rem;
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .75rem;
    color: rgba(245,240,232,.6);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: rgba(245,240,232,.6);
    text-decoration: none;
    transition: color .2s;
  }

  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    letter-spacing: -.02em;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: .96rem;
    font-weight: 300;
    color: rgba(245,240,232,.7);
    line-height: 1.75;
    max-width: 58ch;
    margin-bottom: 1.8rem;
  }

  .price-tags {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.2rem;
  }

  .price-tag {
    display: flex;
    align-items: baseline;
    gap: .4rem;
    background: rgba(196,120,74,.1);
    border: 1px solid rgba(196,120,74,.25);
    padding: .55rem 1rem;
    border-radius: 3px;
  }

  .p-amt {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--clay);
  }

  .p-unit {
    font-size: .75rem;
    color: rgba(245,240,232,.6);
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: .45rem;
    margin-bottom: 2.2rem;
  }

  .hbadge {
    font-size: .75rem;
    font-weight: 500;
    letter-spacing: .05em;
    color: rgba(245,240,232,.7);
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.1);
    padding: .25rem .7rem;
    border-radius: 20px;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Scope Section ── */

  .scope-section {
    background: var(--sand);
    padding: 5.5rem 4rem;
  }

  .scope-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .scope-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--stone);
    border: 1px solid var(--stone);
    margin-top: .5rem;
  }

  .scope-card {
    background: rgba(255,255,255,.6);
    padding: 1.6rem 1.4rem;
    transition: background .25s, border-color .25s;
    border-top: 3px solid transparent;
  }

  .scope-card:hover {
    background: rgba(255,255,255,.85);
    border-top-color: var(--clay);
  }

  .scope-card.featured {
    grid-column: span 3;
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1.2rem;
    align-items: start;
    background: rgba(196,120,74,.07);
    border-top: 3px solid var(--clay);
  }

  .scope-card.featured .scope-icon {
    font-size: 1.6rem;
    margin-bottom: 0;
    grid-row: span 2;
    padding-top: .1rem;
  }

  .scope-card.featured .scope-name {
    font-size: .95rem;
    color: var(--charcoal);
  }

  .scope-card.featured .scope-desc {
    font-size: .78rem;
    line-height: 1.7;
  }

  .scope-icon {
    font-size: 1.4rem;
    margin-bottom: .7rem;
  }

  .scope-name {
    font-size: .86rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: .4rem;
  }

  .scope-desc {
    font-size: .75rem;
    color: var(--warm-gray);
    line-height: 1.65;
  }

  /* ── Pricing Section ── */

  .pricing-section {
    background: var(--off-white);
    padding: 5.5rem 4rem;
  }

  .pricing-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--charcoal);
    padding: 2.2rem;
    border-radius: 4px;
    position: sticky;
    top: 7rem;
  }

  .pc-label {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: rgba(245,240,232,.6);
    margin-bottom: .5rem;
  }

  .pc-price {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 900;
    color: var(--clay);
    line-height: 1;
  }

  .pc-unit {
    font-size: .78rem;
    color: rgba(245,240,232,.6);
    margin-top: .3rem;
    margin-bottom: 1.4rem;
  }

  .pc-note {
    font-size: .78rem;
    color: rgba(245,240,232,.7);
    line-height: 1.65;
    padding: .9rem;
    background: rgba(255,255,255,.04);
    border-radius: 3px;
    margin-bottom: 1.3rem;
  }

  .pc-cta {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--clay);
    color: var(--cream);
    text-decoration: none;
    padding: .9rem;
    border-radius: 2px;
    font-size: .86rem;
    font-weight: 500;
    transition: background .2s;
  }

  .pc-cta:hover { background: var(--terracotta); }

  .pc-cta-wa {
    margin-top: .6rem;
    background: rgba(255,255,255,.08);
