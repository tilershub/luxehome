  }

  .step-name {
    font-size: .88rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: .5rem;
  }

  .step-desc {
    font-size: .78rem;
    font-weight: 300;
    color: rgba(245,240,232,.6);
    line-height: 1.7;
  }

  /* ── FAQ Section ── */

  .faq-section {
