---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Staircase Tiling Services — LUXEhome Sri Lanka"
  description="Expert staircase tiling in Sri Lanka. Double nosing, router edge finish, side elevation and skirting included. All-inclusive at Rs. 2,400 per lin.ft."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/10991408/pexels-photo-10991408.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#shop">Services</a>
        <span>›</span>
        <span>Staircase Tiling</span>
      </div>
      <h1 class="reveal">Staircase Tiling</h1>
      <p class="hero-desc reveal">
        Every step finished with double nosing, router edge detail, side elevation tiling,
        and skirting — all at one all-inclusive rate. The result is a staircase that looks
        as premium as the rest of your space.
      </p>
      <div class="price-tags reveal">
        <div class="price-tag">
          <span class="p-amt">Rs. 2,400</span>
          <span class="p-unit">/ lin.ft — staircase tiling</span>
        </div>
        <div class="price-tag">
          <span class="p-amt">Rs. 12,500</span>
          <span class="p-unit">/ ft — hand railing</span>
        </div>
      </div>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Book Site Inspection — Rs. 10,000</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="details-section">
    <div class="section-inner">
      <div class="col-content">
        <div class="stag">What's Covered</div>
        <h2>Everything in the<br />Rs. 2,400/lin.ft Rate</h2>
        <p class="sdesc">
          The per-linear-foot price is all-in — every element of a properly finished staircase
          is included, with no hidden extras.
        </p>
        <ul class="include-list">
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Tread tiling</strong>
              <span>Full horizontal step surface tiled with precision adhesive bedding</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Riser tiling</strong>
              <span>Vertical face of each step fully tiled for a clean, seamless finish</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Double nosing</strong>
              <span>Two-layer nosing profile on every step edge — safe, durable, and sharp</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Router edge finish</strong>
              <span>Edges routed smooth for a beveled, high-end look — no exposed raw cuts</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Side elevation tiling</strong>
              <span>Side cheek / stringer wall tiled to match the staircase for a complete look</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Skirting</strong>
              <span>Skirting tiles applied along the wall side of each step where applicable</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Premium adhesive & tile leveling</strong>
              <span>Tokyo Super Tile Adhesive with tile leveling system on each tread surface</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Swisstek Grout</strong>
              <span>Stain-resistant, colour-consistent grout on all joints — flush-finished throughout</span>
            </div>
          </li>
        </ul>
        <div class="not-included">
          <strong>Not included:</strong> Tiles and tile accessories — you source your preferred tiles.
          Handrail or balustrade work is not part of this service.
        </div>
      </div>
      <div class="col-aside">

        <!-- Staircase Tiling Calculator -->
        <div class="calc-card">
          <div class="calc-title">Staircase Tiling</div>
          <div class="calc-rate">Rs. 2,400 / lin.ft · per step</div>
          <div class="calc-fields">
            <div class="calc-row">
              <label for="stepLen">Step length</label>
              <div class="calc-input-wrap">
                <input type="number" id="stepLen" min="1" placeholder="e.g. 4" inputmode="decimal" />
                <span>lin.ft</span>
              </div>
            </div>
            <div class="calc-row">
              <label for="numSteps">Number of steps</label>
              <div class="calc-input-wrap">
                <input type="number" id="numSteps" min="1" placeholder="e.g. 12" inputmode="numeric" />
                <span>steps</span>
              </div>
            </div>
            <div class="calc-row">
              <label for="numLandings">Landings <em>(= 2 steps each)</em></label>
              <div class="calc-input-wrap">
                <input type="number" id="numLandings" min="0" value="0" inputmode="numeric" />
                <span>landings</span>
              </div>
            </div>
          </div>
          <div class="calc-result" id="stairResult" hidden>
            <div class="cr-row"><span>Effective steps</span><span id="effSteps"></span></div>
            <div class="cr-row"><span>Step length</span><span id="dispStepLen"></span></div>
            <div class="cr-total"><span>Tiling Total</span><span id="stairTotal"></span></div>
          </div>
          <button class="calc-cta" id="stairAtcBtn">Add to Cart</button>
        </div>

        <!-- Railing Calculator -->
        <div class="calc-card calc-card--highlight">
          <div class="calc-title">Staircase Railing</div>
          <div class="calc-rate">Rs. 12,500 / ft</div>
          <div class="calc-fields">
            <div class="calc-row">
              <label for="railLen">Railing length</label>
              <div class="calc-input-wrap">
                <input type="number" id="railLen" min="1" placeholder="e.g. 20" inputmode="decimal" />
                <span>ft</span>
              </div>
            </div>
          </div>
          <div class="calc-result" id="railResult" hidden>
            <div class="cr-total"><span>Railing Total</span><span id="railTotal"></span></div>
          </div>
          <button class="calc-cta" id="railAtcBtn">Add to Cart</button>
        </div>

      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process-section">
    <div class="section-inner">
      <div class="stag">How It Works</div>
      <h2>Our Staircase Process</h2>
      <p class="sdesc">
        A methodical approach to every flight — from measuring to the final step handover.
      </p>
      <div class="steps">
        <div class="step reveal">
          <div class="step-num">01</div>
          <div class="step-content">
            <div class="step-name">Measurement & Assessment</div>
            <div class="step-desc">We measure every step, tread depth, riser height, and nosing projection. Side elevation and skirting extent confirmed on site.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">02</div>
          <div class="step-content">
            <div class="step-name">Tile Planning</div>
            <div class="step-desc">Tile layout mapped for each tread to minimise cuts and ensure symmetry. Pattern and direction agreed with you before any work begins.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">03</div>
          <div class="step-content">
            <div class="step-name">Substrate Preparation</div>
            <div class="step-desc">All stair surfaces checked for stability, high spots ground back, and substrate primed ready for adhesive bonding.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">04</div>
          <div class="step-content">
            <div class="step-name">Tread & Riser Installation</div>
            <div class="step-desc">Each step tiled from the bottom up — tread first, then riser, with tile leveling clips on all treads for zero lippage.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">05</div>
          <div class="step-content">
            <div class="step-name">Nosing & Router Finish</div>
            <div class="step-desc">Double nosing profile applied on every step edge. All exposed cuts router-finished to a smooth bevel — no tile trim needed.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">06</div>
          <div class="step-content">
            <div class="step-name">Grouting & Handover</div>
            <div class="step-desc">Swisstek grout applied to all joints, finished flush. Side elevation and skirting completed. Full clean-up and inspection before handover.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="section-inner faq-inner">
      <div class="stag">Common Questions</div>
      <h2>Staircase Tiling FAQ</h2>
      <div class="faqs">
        <div class="faq reveal">
          <div class="faq-q">How is the linear footage measured?</div>
          <div class="faq-a">We measure the total run length of your staircase in linear feet — this covers all treads, risers, nosing finish, and a proportional share of the side elevation and skirting. The Rs. 2,400/lin.ft rate covers everything along that run.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Do you supply the tiles?</div>
          <div class="faq-a">No — you source tiles from any supplier you prefer. We handle all installation, nosing, edge finishing, adhesive, and grout.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">What tile sizes work for staircases?</div>
          <div class="faq-a">Most standard staircase tiles (300×600mm, 400×800mm) are ideal. We can advise on sizing during the site visit to ensure the tile format works well for your step dimensions.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Is a handrail or balustrade included?</div>
          <div class="faq-a">No — our service covers only the tiling, nosing, and finishing work. Handrail and balustrade installation is a separate trade.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Can you tile over existing stair tiles?</div>
          <div class="faq-a">In some cases yes — it depends on the condition of the existing surface and the height constraints. We assess this during the site visit and advise accordingly.</div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script is:inline>
(function () {
  function fmt(n) {
    return 'Rs.\u00a0' + Math.round(n).toLocaleString('en-IN');
  }

  // Staircase tiling calc
  var stepLenIn = document.getElementById('stepLen');
  var numStepsIn = document.getElementById('numSteps');
  var numLandingsIn = document.getElementById('numLandings');
  var stairResult = document.getElementById('stairResult');

  function calcStair() {
    var stepLen = parseFloat(stepLenIn.value) || 0;
    var steps = parseInt(numStepsIn.value) || 0;
    var landings = parseInt(numLandingsIn.value) || 0;
    if (stepLen <= 0 || steps <= 0) { stairResult.hidden = true; return; }
    var effSteps = steps + landings * 2;
    var total = effSteps * stepLen * 2400;
    document.getElementById('effSteps').textContent = effSteps + ' steps (' + steps + ' + ' + (landings * 2) + ' from landings)';
    document.getElementById('dispStepLen').textContent = stepLen + ' lin.ft each';
    document.getElementById('stairTotal').textContent = fmt(total);
    stairResult.hidden = false;
  }

  [stepLenIn, numStepsIn, numLandingsIn].forEach(function (el) {
    el.addEventListener('input', calcStair);
  });

  // Railing calc
  var railLenIn = document.getElementById('railLen');
  var railResult = document.getElementById('railResult');

  railLenIn.addEventListener('input', function () {
    var len = parseFloat(this.value) || 0;
    if (len <= 0) { railResult.hidden = true; return; }
    document.getElementById('railTotal').textContent = fmt(len * 12500);
    railResult.hidden = false;
  });

  // Cart buttons
  document.getElementById('stairAtcBtn').addEventListener('click', function () {
    var stepLen = parseFloat(stepLenIn.value) || 0;
    var steps = parseInt(numStepsIn.value) || 0;
    if (stepLen <= 0 || steps <= 0) {
      stepLenIn.focus();
      return;
    }
    var landings = parseInt(numLandingsIn.value) || 0;
    var effSteps = steps + landings * 2;
    var total = effSteps * stepLen * 2400;
    var details = effSteps + ' steps × ' + stepLen + ' lin.ft';
    window.LHCart.add({ name: 'Staircase Tiling', details: details, price: total });
  });

  document.getElementById('railAtcBtn').addEventListener('click', function () {
    var len = parseFloat(railLenIn.value) || 0;
    if (len <= 0) { railLenIn.focus(); return; }
    window.LHCart.add({ name: 'Staircase Railing', details: len + ' ft', price: len * 12500 });
  });
})();
</script>

<style>
