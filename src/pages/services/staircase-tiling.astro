---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import SiteVisitCTA from '../../components/SiteVisitCTA.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Staircase Tiling Services — LUXEHOME Sri Lanka"
  description="Designer staircase tiling in Sri Lanka. All materials, surface preparation, tiling, tile router, glass hand railing, and handover — from Rs. 25,000 per step."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('/hero-staircase.png')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#shop">Services</a>
        <span>›</span>
        <span>Staircase Tiling</span>
      </div>
      <h1 class="reveal">Staircase Tiling</h1>
      <p class="hero-desc reveal">
        One all-inclusive rate covers everything — materials, surface preparation, tiling,
        tile router finish, glass hand railing, and full clean-up at handover. Your staircase
        completed to a standard that commands attention.
      </p>
      <div class="price-tags reveal">
        <div class="price-tag">
          <span class="p-amt">Rs. 25,000</span>
          <span class="p-unit">starting / step — all materials included</span>
        </div>
      </div>
      <p class="price-note reveal">Price may vary based on site conditions, step dimensions, and material brand selected.</p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Book Site Inspection — Rs. 10,000</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="details-section">
    <div class="section-inner">
      <div class="col-content">
        <div class="stag">What's Covered</div>
        <h2>Everything in the<br />Rs. 25,000 / Step Rate</h2>
        <p class="sdesc">
          Every item below is included in the per-step price — materials, labour, and finishing.
          No hidden extras.
        </p>
        <ul class="include-list">
          <li>
            <span class="check">✓</span>
            <div>
              <strong>All Materials</strong>
              <span>Tiles, adhesive, grout, nosing profiles, railing hardware — everything supplied and included in the per-step rate</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Surface Preparation</strong>
              <span>Existing surfaces cleaned, levelled, and primed; high spots ground back for a stable substrate ready for bonding</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Tiling &amp; Grouting</strong>
              <span>Tread and riser fully tiled with precision adhesive bedding; double nosing profile applied on every step edge; all joints grouted flush with stain-resistant Swisstek grout</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Tile Router</strong>
              <span>All exposed tile edges router-finished to a smooth, bevelled profile — no raw cuts visible</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Glass Hand Railing</strong>
              <span>Modern frameless or framed glass hand railing fitted with premium stainless steel fittings — safe, elegant, and built to last</span>
            </div>
          </li>
          <li>
            <span class="check">✓</span>
            <div>
              <strong>Cleaning &amp; Handover</strong>
              <span>Full site clean-up on completion; all surfaces wiped down and inspected before formal handover to you</span>
            </div>
          </li>
        </ul>
        <div class="price-note-box">
          <strong>Pricing note:</strong> The Rs. 25,000 per step is a starting rate. Final price may vary based on site conditions, step dimensions, and the material brand selected. A site visit confirms the exact figure before any work begins.
        </div>
      </div>
      <div class="col-aside">

        <!-- Pricing Summary -->
        <div class="price-card">
          <div class="price-card-label">Starting from</div>
          <div class="price-card-amount">Rs. 25,000</div>
          <div class="price-card-unit">per step · all-inclusive</div>
          <ul class="price-card-list">
            <li>✓ All Materials</li>
            <li>✓ Surface Preparation</li>
            <li>✓ Tiling &amp; Grouting</li>
            <li>✓ Tile Router Finish</li>
            <li>✓ Glass Hand Railing</li>
            <li>✓ Cleaning &amp; Handover</li>
          </ul>
          <p class="price-card-note">Final price confirmed after a site visit — may vary based on site conditions, step dimensions, and material brand.</p>
          <a href="/contact?service=Staircase+Tiling" class="calc-cta" style="display:flex;align-items:center;justify-content:center;text-decoration:none;margin-top:.5rem">Get a Free Quote</a>
          <a href="https://wa.me/94774503744?text=Hello%2C+I+would+like+a+quote+for+staircase+tiling." class="wa-cta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/></svg>
            WhatsApp for a Quick Quote
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process-section">
    <div class="section-inner">
      <div class="stag">How It Works</div>
      <h2>Our Staircase Process</h2>
      <p class="sdesc">
        A methodical approach to every flight — from measuring to the final step handover.
      </p>
      <div class="steps">
        <div class="step reveal">
          <div class="step-num">01</div>
          <div class="step-content">
            <div class="step-name">Measurement & Assessment</div>
            <div class="step-desc">We measure every step, tread depth, riser height, and nosing projection. Side elevation and skirting extent confirmed on site.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">02</div>
          <div class="step-content">
            <div class="step-name">Tile Planning</div>
            <div class="step-desc">Tile layout mapped for each tread to minimise cuts and ensure symmetry. Pattern and direction agreed with you before any work begins.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">03</div>
          <div class="step-content">
            <div class="step-name">Surface Preparation</div>
            <div class="step-desc">All stair surfaces cleaned, high spots ground back, and substrate primed for adhesive bonding — a stable base is essential for long-term adhesion on steps.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">04</div>
          <div class="step-content">
            <div class="step-name">Tiling, Grouting & Router Finish</div>
            <div class="step-desc">Each step tiled bottom-up with zero-lippage leveling. Double nosing applied on every edge; all cuts router-finished to a smooth bevel. Swisstek grout applied flush throughout.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">05</div>
          <div class="step-content">
            <div class="step-name">Glass Hand Railing</div>
            <div class="step-desc">Premium safety glass panels fitted with stainless steel brackets and fittings — aligned perfectly with the finished steps for a seamless, modern look.</div>
          </div>
        </div>
        <div class="step reveal">
          <div class="step-num">06</div>
          <div class="step-content">
            <div class="step-name">Cleaning & Handover</div>
            <div class="step-desc">Full site clean-down on completion. All tile surfaces wiped, glass polished, and the staircase inspected with you before formal handover.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="section-inner faq-inner">
      <div class="stag">Common Questions</div>
      <h2>Staircase Tiling FAQ</h2>
      <div class="faqs">
        <div class="faq reveal">
          <div class="faq-q">What does the Rs. 25,000 per step include?</div>
          <div class="faq-a">Everything — all materials (tiles, adhesive, grout, nosing profiles, railing hardware), surface preparation, tiling and grouting, tile router edge finish, glass hand railing installation, and a full site clean-up and handover. There are no add-ons or hidden charges.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Why might the final price differ from Rs. 25,000 per step?</div>
          <div class="faq-a">The starting rate assumes standard site conditions. Price can vary based on the size and complexity of your steps, your preferred material brand (tile grade, railing glass type), and any site-specific challenges identified during the visit. The confirmed rate is always agreed in writing before work begins.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Do I need to choose the tiles and materials myself?</div>
          <div class="faq-a">No — all materials are sourced and supplied by us as part of the package. During the site visit we discuss your style preferences, and we guide you to the right tile and finish options that suit your space and budget within the package.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Is the glass hand railing always included?</div>
          <div class="faq-a">Yes, glass hand railing is included in the standard per-step package. The style (frameless vs. framed) and fittings can be discussed during the consultation — both are covered within the rate.</div>
        </div>
        <div class="faq reveal">
          <div class="faq-q">Can you tile over existing stair tiles?</div>
          <div class="faq-a">In some cases yes — it depends on the condition of the existing surface and height constraints. We assess this during the site visit and advise accordingly before committing to a price.</div>
        </div>
      </div>
    </div>
  </section>

  <section id="recent-projects" class="recent-proj-section">
    <div class="recent-proj-inner">
      <div class="stag">Our Work</div>
      <h2>Recent Staircase Projects</h2>
      <div id="proj-grid" class="mini-proj-row"></div>
      <a href="/projects?category=staircase" class="view-all-link">View All Staircase Projects →</a>
    </div>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    if (SB_URL && SB_KEY) {
      const sb = createClient(SB_URL, SB_KEY);
      (async () => {
        const { data } = await sb.from('projects')
          .select('slug,title,cover_image,location')
          .eq('category', 'staircase')
          .in('status', ['published', 'featured'])
          .order('completion_year', { ascending: false })
          .limit(3);
        if (!data?.length) return;
        const section = document.getElementById('recent-projects');
        const grid = document.getElementById('proj-grid');
        if (!section || !grid) return;
        grid.innerHTML = data.map(p => `
          <a href="/projects/${p.slug}" class="mini-card">
            <div class="mini-img">${p.cover_image ? `<img src="${p.cover_image}" alt="${p.title}" loading="lazy">` : ''}</div>
            <div class="mini-body">
              <div class="mini-title">${p.title}</div>
              ${p.location ? `<div class="mini-loc">${p.location}</div>` : ''}
            </div>
          </a>
        `).join('');
        section.style.display = '';
      })();
    }
  </script>

  <SiteVisitCTA service="staircase tiling" />
  <Footer />
</Layout>



<style>
  /* ── Page Hero ── */

  .page-hero {
    background:
      linear-gradient(rgba(30,26,23,.82), rgba(30,26,23,.96)),
      var(--hero-bg, var(--charcoal));
    background-size: cover;
    background-position: center;
    padding: 7rem 4rem 5.5rem;
    position: relative;
    overflow: hidden;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px),
      repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,.01) 60px, rgba(255,255,255,.01) 61px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .75rem;
    color: rgba(240,236,224,.85);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: rgba(240,236,224,.85);
    text-decoration: none;
    transition: color .2s;
  }

  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    letter-spacing: -.02em;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: .96rem;
    font-weight: 300;
    color: rgba(240,236,224,.90);
    line-height: 1.75;
    max-width: 58ch;
    margin-bottom: 1.8rem;
  }

  .price-tags {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.2rem;
  }

  .price-tag {
    display: flex;
    align-items: baseline;
    gap: .4rem;
    background: rgba(184,148,90,.1);
    border: 1px solid rgba(184,148,90,.25);
    padding: .55rem 1rem;
    border-radius: 3px;
  }

  .p-amt {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--clay);
  }

  .p-unit {
    font-size: .75rem;
    color: rgba(240,236,224,.85);
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Details Section ── */

  .details-section {
    background: var(--off-white);
    padding: 5.5rem 4rem;
  }

  .section-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 5rem;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  .include-list {
    list-style: none;
    margin-bottom: 2rem;
  }

  .include-list li {
    display: flex;
    gap: 1rem;
    padding: .9rem 0;
    border-bottom: 1px solid var(--stone);
  }

  .include-list li:last-child { border-bottom: none; }

  .check {
    color: var(--clay);
    font-weight: 700;
    font-size: .9rem;
    flex-shrink: 0;
    margin-top: .1rem;
  }

  .include-list strong {
    display: block;
    font-size: .84rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: .2rem;
  }

  .include-list span {
    font-size: .78rem;
    color: var(--warm-gray);
    line-height: 1.6;
  }

  .not-included {
    font-size: .8rem;
    color: var(--warm-gray);
    padding: 1rem 1.2rem;
    background: rgba(184,148,90,.06);
    border-left: 3px solid var(--clay);
    border-radius: 0 3px 3px 0;
    line-height: 1.65;
  }

  .not-included strong { color: var(--charcoal); }

  .col-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }

  .aside-card {
    background: var(--cream);
    border: 1px solid var(--stone);
    border-radius: 4px;
    padding: 1.4rem;
  }

  .aside-label {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .13em;
    color: var(--warm-gray);
    margin-bottom: .4rem;
  }

  .aside-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--charcoal);
    margin-bottom: .5rem;
  }

  .aside-card--highlight {
    border-color: rgba(184,148,90,.35);
    background: rgba(184,148,90,.05);
  }

  .aside-card--highlight .aside-value {
    color: var(--clay);
  }

  .aside-card p {
    font-size: .76rem;
    color: var(--warm-gray);
    line-height: 1.65;
  }

  /* ── Process Section ── */

  .process-section {
    background: var(--charcoal);
    padding: 5.5rem 4rem;
  }

  .process-section .stag { color: var(--clay); }
  .process-section h2 { color: var(--cream); }
  .process-section .sdesc { color: rgba(240,236,224,.85); }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(255,255,255,.07);
    border: 1.5px solid rgba(255,255,255,.07);
  }

  .step {
    background: #211c18;
    padding: 2rem;
    transition: background .25s;
  }

  .step:hover { background: #28211a; }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 900;
    color: rgba(184,148,90,.25);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .step-name {
    font-size: .88rem;
    font-weight: 600;
    color: var(--cream);
    margin-bottom: .5rem;
  }

  .step-desc {
    font-size: .78rem;
    font-weight: 300;
    color: rgba(240,236,224,.85);
    line-height: 1.7;
  }

  /* ── FAQ Section ── */

  .faq-section {
    background: var(--sand);
    padding: 5.5rem 4rem;
  }

  .faq-inner {
    grid-template-columns: 1fr;
    max-width: 820px;
  }

  .faqs {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: .5rem;
  }

  .faq {
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(184,148,90,.18);
  }

  .faq:first-child { border-top: 1px solid rgba(184,148,90,.18); }

  .faq-q {
    font-size: .9rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: .55rem;
  }

  .faq-a {
    font-size: .82rem;
    font-weight: 300;
    color: var(--warm-gray);
    line-height: 1.75;
  }

  /* ── Pricing note (hero) ── */
  .price-note {
    font-size: .8rem;
    color: rgba(240,236,224,.65);
    margin-bottom: 2rem;
    margin-top: -.8rem;
    line-height: 1.6;
  }

  /* ── Pricing note box (inclusions) ── */
  .price-note-box {
    font-size: .8rem;
    color: var(--warm-gray);
    padding: 1rem 1.2rem;
    background: rgba(184,148,90,.06);
    border-left: 3px solid var(--clay);
    border-radius: 0 3px 3px 0;
    line-height: 1.65;
    margin-top: 1.5rem;
  }
  .price-note-box strong { color: var(--charcoal); }

  /* ── Price card (aside) ── */
  .price-card {
    background: var(--cream);
    border: 1px solid rgba(184,148,90,.35);
    border-radius: 4px;
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .price-card-label {
    font-size: .72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--warm-gray);
  }

  .price-card-amount {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--clay);
    line-height: 1;
  }

  .price-card-unit {
    font-size: .78rem;
    color: var(--warm-gray);
    margin-bottom: .5rem;
  }

  .price-card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .4rem;
    padding: .8rem 0;
    border-top: 1px solid var(--stone);
    border-bottom: 1px solid var(--stone);
    margin-bottom: .4rem;
  }

  .price-card-list li {
    font-size: .82rem;
    color: var(--charcoal);
    font-weight: 400;
  }

  .price-card-note {
    font-size: .74rem;
    color: var(--warm-gray);
    line-height: 1.6;
    margin-bottom: .5rem;
  }

  .calc-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clay);
    color: #fff;
    text-decoration: none;
    padding: .65rem 1rem;
    border: none;
    border-radius: 3px;
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    min-height: 44px;
    width: 100%;
    cursor: pointer;
    touch-action: manipulation;
    transition: background .2s;
  }

  .calc-cta:hover { background: #b5673c; }

  .wa-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .45rem;
    background: #25d366;
    color: #fff;
    text-decoration: none;
    padding: .65rem 1rem;
    border-radius: 3px;
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    min-height: 44px;
    transition: background .2s;
  }

  .wa-cta:hover { background: #1ebe5d; }

  /* ── Responsive ── */

  @media (max-width: 1100px) {
    .page-hero,
    .details-section,
    .process-section,
    .faq-section {
      padding-left: 2.5rem;
      padding-right: 2.5rem;
    }

    .section-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .col-aside { position: static; }

    .steps { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .page-hero,
    .details-section,
    .process-section,
    .faq-section {
      padding: 4rem 1.5rem;
    }

    .page-hero { padding-top: 6rem; }

    .steps { grid-template-columns: 1fr; }
  }

