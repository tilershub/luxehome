---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CTA from '../../components/CTA.astro';
import QuoteForm from '../../components/QuoteForm.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Bathroom Plumbing — Standard Rs. 100,000 · Concealed Rs. 150,000 — LUXEhome Sri Lanka"
  description="Professional bathroom plumbing with Slon UPVC & CPVC pipes. Standard bathroom plumbing Rs. 100,000 | Concealed fittings Rs. 150,000. Pressure tested and fully guaranteed."
>
  <Nav />

  <!-- Page Hero -->
  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/5825561/pexels-photo-5825561.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/services/bathroom">Bathroom</a>
        <span>›</span>
        <span>Bathroom Plumbing</span>
      </div>
      <h1 class="reveal">Bathroom Plumbing</h1>
      <p class="hero-desc reveal">
        Complete bathroom plumbing using Slon UPVC &amp; CPVC pipe systems —
        pressure-tested and built to last. Choose standard exposed pipework or
        fully concealed fittings for a clean, wall-flush finish.
      </p>
      <div class="hero-cta reveal">
        <a href="#get-a-quote" class="btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.143.566 4.148 1.553 5.887L0 24l6.296-1.529A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.001-1.368l-.36-.213-3.733.906.946-3.643-.234-.374A9.818 9.818 0 1112 21.818z"/>
          </svg>
          Get a Quote
        </a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section class="details-section">
    <div class="section-inner">
      <div class="col-content">
        <div class="stag">Plumbing Packages</div>
        <h2>Two Options for<br />Every Bathroom</h2>
        <p class="sdesc">
          Both packages use Slon UPVC &amp; CPVC pipe systems and include a
          full pressure test before handover. Choose the level of finish
          that suits your renovation.
        </p>

        <div class="pkg-grid">
          <!-- Standard -->
          <div class="pkg-card">
            <div class="pkg-header">
              <span class="pkg-badge">Standard</span>
              <div class="pkg-price">Rs. 100,000</div>
            </div>
            <ul class="pkg-list">
              <li>✓ Hot &amp; cold supply lines</li>
              <li>✓ WC inlet connection</li>
              <li>✓ Basin waste &amp; supply</li>
              <li>✓ Shower supply line</li>
              <li>✓ Geyser inlet &amp; outlet</li>
              <li>✓ Drain waste &amp; vent stack</li>
              <li>✓ Slon UPVC &amp; CPVC pipes</li>
              <li>✓ Full pressure test</li>
            </ul>
          </div>
          <!-- Concealed -->
          <div class="pkg-card pkg-card--featured">
            <div class="pkg-header">
              <span class="pkg-badge pkg-badge--featured">Concealed Fittings</span>
              <div class="pkg-price">Rs. 150,000</div>
            </div>
            <ul class="pkg-list">
              <li>✓ All Standard inclusions</li>
              <li>✓ All pipework fully concealed in walls</li>
              <li>✓ Concealed cistern boxing</li>
              <li>✓ Wall-mount tap rough-in</li>
              <li>✓ Concealed shower valve rough-in</li>
              <li>✓ Precision chasing &amp; backfilling</li>
              <li>✓ Slon UPVC &amp; CPVC pipes</li>
              <li>✓ Full pressure test</li>
            </ul>
          </div>
        </div>
      </div>

      <aside class="col-aside">
        <div class="aside-card">
          <div class="aside-title">Standard Bathroom</div>
          <div class="aside-price">Rs. 100,000</div>
          <div class="aside-note">Exposed pipework, full scope</div>
        </div>
        <div class="aside-card aside-card--featured">
          <div class="aside-title">Concealed Fittings</div>
          <div class="aside-price">Rs. 150,000</div>
          <div class="aside-note">All pipes hidden in walls</div>
        </div>
        <div class="aside-card">
          <div class="aside-title">Pipe System</div>
          <div class="aside-spec">Slon UPVC &amp; CPVC</div>
          <div class="aside-note">Heat &amp; pressure rated</div>
        </div>
        <div class="aside-card">
          <div class="aside-title">Testing</div>
          <div class="aside-spec">Pressure Test</div>
          <div class="aside-note">Every installation tested before handover</div>
        </div>
      </aside>
    </div>
  </section>

  <!-- Materials -->
  <section class="materials-section">
    <div class="mat-inner">
      <div class="stag">Pipe System</div>
      <h2>Slon UPVC &amp;<br />CPVC Pipeline</h2>
      <div class="mat-grid">
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Slon UPVC Pipes</div>
          <div class="mat-desc">Unplasticised PVC for cold water supply and drainage — corrosion-resistant, smooth bore, and long service life</div>
        </div>
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Slon CPVC Pipes</div>
          <div class="mat-desc">Chlorinated PVC rated for hot water supply lines up to 93°C — no scaling, no corrosion, no taste transfer</div>
        </div>
        <div class="mat-card">
          <div class="mat-icon">◈</div>
          <div class="mat-name">Pressure Test</div>
          <div class="mat-desc">Full system pressure test conducted before walls are closed and before any fixtures are connected — zero leaks guaranteed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-inner">
      <div class="stag">FAQ</div>
      <h2>Common Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What is the difference between Standard and Concealed plumbing?</summary>
          <p>Standard plumbing runs pipes along the wall surface — visible but neatly installed. Concealed plumbing chases all pipework into the walls so no pipes are visible. Concealed is the preferred choice for modern, minimal bathroom designs.</p>
        </details>
        <details class="faq-item">
          <summary>Why do you use Slon UPVC and CPVC pipes?</summary>
          <p>Slon is a trusted Sri Lankan pipe brand with consistent quality. UPVC handles cold water and waste — CPVC handles hot water from the geyser. Using the correct pipe type for each application ensures longevity and safety.</p>
        </details>
        <details class="faq-item">
          <summary>What is a pressure test?</summary>
          <p>After all pipework is installed, we pressurise the system and hold it for a set period to confirm there are no leaks at any joint or connection. This is done before the walls are tiled so any issues can be fixed without demolition.</p>
        </details>
        <details class="faq-item">
          <summary>Is plumbing included in the Bathroom Construction/Renovation package?</summary>
          <p>Yes — plumbing is a core trade in all LUXEhome bathroom renovation packages. This standalone plumbing service applies when you need plumbing only, without a full renovation.</p>
        </details>
      </div>
    </div>
  </section>

  <QuoteForm id="get-a-quote" />
  <CTA />
  <Footer />
</Layout>

<style>
  .page-hero {
    min-height: 52vh; display: flex; align-items: flex-end;
    padding: 0 4rem 4rem; position: relative;
    background-image: var(--hero-bg); background-size: cover; background-position: center;
  }
  .page-hero::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.78) 0%, rgba(30,26,23,.5) 60%, rgba(30,26,23,.78) 100%);
  }
  .hero-inner { position: relative; z-index: 1; max-width: 700px; padding-top: 7rem; }
  .breadcrumb {
    display: flex; gap: .4rem; align-items: center;
    font-size: .72rem; letter-spacing: .06em; text-transform: uppercase;
    color: rgba(245,240,232,.55); margin-bottom: 1.2rem;
  }
  .breadcrumb a { color: rgba(245,240,232,.55); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }
  h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 700; color: var(--cream); line-height: 1.1; margin-bottom: 1.1rem; }
  .hero-desc { font-size: 1rem; color: rgba(245,240,232,.8); line-height: 1.72; max-width: 55ch; margin-bottom: 1.8rem; }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { display: inline-flex; align-items: center; gap: .5rem; background: #25d366; color: #fff; padding: .75rem 1.6rem; border-radius: 2px; font-size: .82rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; transition: background .2s, transform .2s; }
  .btn-primary:hover { background: #1fb855; transform: translateY(-2px); }
  .btn-ghost { display: inline-flex; align-items: center; background: transparent; color: var(--cream); padding: .75rem 1.6rem; border-radius: 2px; border: 1px solid rgba(245,240,232,.35); font-size: .82rem; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; transition: border-color .2s, color .2s; }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  .details-section { background: var(--cream); padding: 5.5rem 4rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: start; }
  .stag { font-size: .72rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--clay); margin-bottom: .75rem; }
  h2 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 700; color: var(--charcoal); line-height: 1.2; margin-bottom: 1rem; }
  .sdesc { font-size: .95rem; color: var(--warm-gray); line-height: 1.72; max-width: 58ch; margin-bottom: 2rem; }

  .pkg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
  .pkg-card { background: #fff; border: 1px solid var(--stone); border-radius: 2px; overflow: hidden; }
  .pkg-card--featured { border-color: var(--clay); }
  .pkg-header { padding: 1.2rem 1.4rem; background: var(--off-white); border-bottom: 1px solid var(--stone); }
  .pkg-card--featured .pkg-header { background: rgba(196,120,74,.08); border-bottom-color: rgba(196,120,74,.2); }
  .pkg-badge { display: inline-block; font-size: .68rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--warm-gray); }
  .pkg-badge--featured { color: var(--clay); }
  .pkg-price { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--charcoal); margin-top: .3rem; }
  .pkg-card--featured .pkg-price { color: var(--clay); }
  .pkg-list { list-style: none; padding: 1rem 1.4rem 1.4rem; margin: 0; display: flex; flex-direction: column; gap: .45rem; }
  .pkg-list li { font-size: .8rem; color: var(--warm-gray); line-height: 1.5; }

  .col-aside { display: flex; flex-direction: column; gap: 1rem; }
  .aside-card { background: #fff; border: 1px solid var(--stone); padding: 1.4rem 1.6rem; border-radius: 2px; }
  .aside-card--featured { border-color: var(--clay); }
  .aside-title { font-size: .68rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--warm-gray); margin-bottom: .5rem; }
  .aside-price { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--clay); }
  .aside-spec { font-size: 1rem; font-weight: 600; color: var(--charcoal); }
  .aside-note { font-size: .75rem; color: var(--warm-gray); margin-top: .25rem; }

  .materials-section { background: var(--off-white); padding: 5rem 4rem; }
  .mat-inner { max-width: 1200px; margin: 0 auto; }
  .mat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2.5rem; }
  .mat-card { background: #fff; border: 1px solid var(--stone); padding: 2rem; border-radius: 2px; }
  .mat-icon { font-size: 1.4rem; color: var(--clay); margin-bottom: 1rem; }
  .mat-name { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--charcoal); margin-bottom: .6rem; }
  .mat-desc { font-size: .82rem; color: var(--warm-gray); line-height: 1.65; }

  .faq-section { background: var(--cream); padding: 5rem 4rem; }
  .faq-inner { max-width: 820px; margin: 0 auto; }
  .faq-list { margin-top: 2.5rem; display: flex; flex-direction: column; gap: .5rem; }
  .faq-item { border: 1px solid var(--stone); border-radius: 2px; overflow: hidden; }
  .faq-item summary { padding: 1.1rem 1.4rem; cursor: pointer; font-size: .9rem; font-weight: 600; color: var(--charcoal); list-style: none; display: flex; justify-content: space-between; align-items: center; transition: background .2s; }
  .faq-item summary:hover { background: var(--off-white); }
  .faq-item summary::after { content: '+'; font-size: 1.2rem; color: var(--clay); font-weight: 300; flex-shrink: 0; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: .2rem 1.4rem 1.2rem; font-size: .85rem; color: var(--warm-gray); line-height: 1.72; margin: 0; }

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .details-section, .materials-section, .faq-section { padding-left: 2.5rem; padding-right: 2.5rem; }
    .section-inner { grid-template-columns: 1fr; }
    .col-aside { flex-direction: row; flex-wrap: wrap; }
    .aside-card { flex: 1; min-width: 160px; }
  }
  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .details-section, .materials-section, .faq-section { padding: 4rem 1.5rem; }
    .pkg-grid { grid-template-columns: 1fr; }
    .mat-grid { grid-template-columns: 1fr; }
    .col-aside { flex-direction: column; }
  }
</style>
