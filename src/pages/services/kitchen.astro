---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Kitchen — Pantry Tiling & Cupboard — LUXEHOME Sri Lanka"
  description="Complete kitchen package — pantry tiling plus cupboard. Eco board, melamine finish, Mcoco accessories, quartz top, and backsplash. Rs. 45,000 / lin.ft."
>
  <Nav />

  <section class="page-hero" style="--hero-bg: url('https://images.pexels.com/photos/6283970/pexels-photo-6283970.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop')">
    <div class="hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/#services">Services</a>
        <span>›</span>
        <span>Kitchen</span>
      </div>
      <h1 class="reveal">Kitchen</h1>
      <p class="hero-desc reveal">
        Pantry tiling and full cupboard installation — one combined package.
        Eco board, melamine finish, Mcoco accessories, quartz countertop, and backsplash tiling.
      </p>
      <div class="hero-cta reveal">
        <a href="/contact" class="btn-primary">Get an Instant Price →</a>
        <a href="tel:+94774503744" class="btn-ghost">0774 503 744</a>
      </div>
    </div>
  </section>

  <!-- Package detail -->
  <section class="pricing-section">
    <div class="pricing-inner">
      <div class="stag reveal">Combined Package</div>
      <h2 class="reveal">Everything in One Price per Linear Foot</h2>
      <p class="sdesc reveal">One package, one team, one quote. Enter the length of your kitchen pantry below to get an instant price.</p>

      <div class="pkg-wide reveal">
        <div class="pkg-wide-left">
          <div class="pkg-name">Complete Kitchen Package</div>
          <div class="pkg-price-row"><span class="pkg-label">Tiling</span><span class="pkg-price">Rs. 5,000 <em>/lin.ft</em></span></div>
          <div class="pkg-price-row"><span class="pkg-label">Cupboard</span><span class="pkg-price">Rs. 40,000 <em>/lin.ft</em></span></div>
          <div class="pkg-price-row pkg-total-row"><span class="pkg-label">Combined</span><span class="pkg-price pkg-price--total">Rs. 45,000 <em>/lin.ft</em></span></div>
        </div>
        <div class="pkg-wide-right">
          <ul class="what-included">
            <li>
              <strong>Pantry Tiling</strong>
              <span>Countertop & backsplash · Waterproof joints</span>
            </li>
            <li>
              <strong>Cupboard</strong>
              <span>Eco board carcass · Melamine finish</span>
            </li>
            <li>
              <strong>Accessories</strong>
              <span>Mcoco hinges, channels & soft-close hardware</span>
            </li>
            <li>
              <strong>Countertop</strong>
              <span>Quartz top · Precision edge finish</span>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  .page-hero {
    min-height: 52vh;
    display: flex;
    align-items: flex-end;
    padding: 0 4rem 4rem;
    position: relative;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(30,26,23,.75) 0%, rgba(30,26,23,.45) 60%, rgba(30,26,23,.75) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding-top: 7rem;
  }

  .breadcrumb {
    display: flex;
    gap: .4rem;
    align-items: center;
    font-size: .72rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(240,236,224,.80);
    margin-bottom: 1.2rem;
  }
  .breadcrumb a { color: rgba(240,236,224,.80); text-decoration: none; transition: color .2s; }
  .breadcrumb a:hover { color: var(--clay); }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1.1rem;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(240,236,224,.93);
    line-height: 1.72;
    max-width: 55ch;
    margin-bottom: 1.8rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--clay);
    color: #fff;
    padding: .75rem 1.6rem;
    border-radius: 2px;
    font-size: .82rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }
  .btn-primary:hover { background: #b5673c; transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--cream);
    padding: .75rem 1.6rem;
    border-radius: 2px;
    border: 1px solid rgba(245,240,232,.35);
    font-size: .82rem;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color .2s, color .2s;
  }
  .btn-ghost:hover { border-color: var(--clay); color: var(--clay); }

  /* Pricing section */
  .pricing-section {
    background: var(--charcoal);
    padding: 5rem 4rem;
  }

  .pricing-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stag {
    font-size: .72rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: .75rem;
  }

  h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 700;
    color: var(--cream);
    line-height: 1.2;
    margin-bottom: .9rem;
  }

  .sdesc {
    font-size: .95rem;
    color: rgba(240,236,224,.85);
    line-height: 1.72;
    max-width: 60ch;
    margin-bottom: 2.8rem;
  }

  /* Wide package card */
  .pkg-wide {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 1px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .pkg-wide-left {
    background: rgba(184,148,90,.07);
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: .8rem;
  }

  .pkg-wide-right {
    background: rgba(255,255,255,.03);
    padding: 2.2rem;
  }

  .pkg-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    border-bottom: 1px solid rgba(255,255,255,.08);
    padding-bottom: .9rem;
    margin-bottom: .3rem;
  }

  .pkg-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .pkg-total-row {
    border-top: 1px solid rgba(184,148,90,.25);
    padding-top: .6rem;
    margin-top: .2rem;
  }

  .pkg-label {
    font-size: .72rem;
    color: rgba(240,236,224,.72);
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .pkg-price {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--clay);
  }

  .pkg-price--total { font-size: 1.2rem; }

  .pkg-price em {
    font-style: normal;
    font-family: 'DM Sans', sans-serif;
    font-size: .7rem;
    font-weight: 300;
    color: rgba(240,236,224,.68);
    margin-left: .1rem;
  }

  .what-included {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }

  .what-included li {
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .what-included strong {
    font-size: .85rem;
    font-weight: 700;
    color: var(--cream);
  }

  .what-included span {
    font-size: .75rem;
    color: rgba(240,236,224,.78);
    line-height: 1.4;
  }

  @media (max-width: 1100px) {
    .page-hero { padding: 0 2.5rem 3.5rem; }
    .pricing-section { padding: 4.5rem 2.5rem; }
    .pkg-wide { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .page-hero { padding: 0 1.5rem 3rem; min-height: 60vh; }
    .pricing-section { padding: 4rem 1.5rem; }
    .what-included { grid-template-columns: 1fr; }
  }
</style>
