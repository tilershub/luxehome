# Meta Pixel — exposed to the browser (must be PUBLIC_ prefix)
PUBLIC_META_PIXEL_ID=your_pixel_id_here

# Meta Conversions API — server-side only, never exposed to browser
META_PIXEL_ID=your_pixel_id_here
META_ACCESS_TOKEN=your_capi_access_token_here

# Supabase — public (anon key, safe to expose)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
